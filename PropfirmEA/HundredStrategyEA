         FileWriteString(handle, "    var range=maxV-minV;\n");
         FileWriteString(handle, "    if(range<1)range=1;\n");
         FileWriteString(handle, "    var topY=3,botY=29,chartH=botY-topY;\n");
         FileWriteString(handle, "    var zeroY=topY+((maxV-0)/range)*chartH;\n");
         FileWriteString(handle, "    if(maxV<=0)zeroY=botY;\n");
         FileWriteString(handle, "    if(minV>=0)zeroY=topY;\n");
         FileWriteString(handle, "    var pts=[];\n");
         FileWriteString(handle, "    var tooltips=[];\n");
         FileWriteString(handle, "    for(var i=0;i<dn;i++){\n");
         FileWriteString(handle, "      var x=(i/Math.max(1,dn-1))*130+5;\n");
         FileWriteString(handle, "      var cv=cumVals[i];\n");
         FileWriteString(handle, "      var y=topY+((maxV-cv)/range)*chartH;\n");
         FileWriteString(handle, "      pts.push(x.toFixed(1)+','+y.toFixed(1));\n");
         FileWriteString(handle, "      var tip=dates[i]||'';\n");
         FileWriteString(handle, "      if(data[i]!==null){tip=dates[i]+': cum '+data[i][0].toFixed(0)+' ('+data[i][1]+'P / '+data[i][2]+'B / '+data[i][3]+'end)';}\n");
         FileWriteString(handle, "      else{tip=dates[i]+': idle (cum '+cv.toFixed(0)+')';}\n");
         FileWriteString(handle, "      tooltips.push(tip);\n");
         FileWriteString(handle, "    }\n");
         FileWriteString(handle, "    var color='#64748b';\n");
         FileWriteString(handle, "    if(lastCum>0)color='#16a34a';\n");
         FileWriteString(handle, "    else if(lastCum<0)color='#dc2626';\n");
         FileWriteString(handle, "    var svg='<svg width=\"140\" height=\"32\" style=\"vertical-align:middle\">';\n");
         FileWriteString(handle, "    svg+='<line x1=\"5\" y1=\"'+zeroY.toFixed(1)+'\" x2=\"135\" y2=\"'+zeroY.toFixed(1)+'\" stroke=\"#e2e8f0\" stroke-width=\"1\" stroke-dasharray=\"2,2\"/>';\n");
         FileWriteString(handle, "    svg+='<polyline points=\"'+pts.join(' ')+'\" fill=\"none\" stroke=\"'+color+'\" stroke-width=\"1.5\"/>';\n");
         FileWriteString(handle, "    var lastPt=pts[pts.length-1].split(',');\n");
         FileWriteString(handle, "    svg+='<circle cx=\"'+lastPt[0]+'\" cy=\"'+lastPt[1]+'\" r=\"2\" fill=\"'+color+'\"/>';\n");
         FileWriteString(handle, "    var lastTip=tooltips[tooltips.length-1];\n");
         FileWriteString(handle, "    svg+='<title>'+lastTip+'</title>';\n");
         FileWriteString(handle, "    svg+='</svg>';\n");
         FileWriteString(handle, "    el.innerHTML=svg;\n");
         FileWriteString(handle, "  }\n");
         FileWriteString(handle, "}\n");
      FileWriteString(handle, "if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',function(){renderSparklines();});}else{renderSparklines();}\n");
      FileWriteString(handle, "</script>\n");

      PropWriteFooter(handle, "strat");
      PropWriteRunsFooter(handle, useRecency);
      FileWriteString(handle, "</div>\n</body>\n</html>\n");
      FileClose(handle);
      Print("Propfirm rolling HTML report exported to Common Files: ", reportFileName, " (", IntegerToString(totalRuns), " runs)");
   }

   string PropJsonEscape(const string s)
   {
      string result = "";
      for(int i = 0; i < StringLen(s); i++)
      {
         ushort ch = StringGetCharacter(s, i);
         if(ch == '"') result += "\\\"";
         else if(ch == '\\') result += "\\\\";
         else if(ch == '\n') result += "\\n";
         else if(ch == '\r') result += "\\r";
         else result += ShortToString(ch);
      }
      return result;
   }

