   int GlobalMinutesUntil(const int targetHour, const int targetMinute)
   {
      MqlDateTime dt;
      TimeToStruct(TimeCurrent(), dt);
      int nowMin = dt.hour * 60 + dt.min;
      int targetMin = targetHour * 60 + targetMinute;
      int diff = targetMin - nowMin;
      if(diff <= 0)
         diff += 1440;
      return diff;
   }

   int GlobalSecondsUntil(const int targetHour, const int targetMinute)
   {
      MqlDateTime dt;
      TimeToStruct(TimeCurrent(), dt);
      int nowSec = dt.hour * 3600 + dt.min * 60 + dt.sec;
      int targetSec = targetHour * 3600 + targetMinute * 60;
      int diff = targetSec - nowSec;
      if(diff <= 0)
         diff += 86400;
      return diff;
   }

