        "<th data-type=\"num\">Trades</th>\n<th data-type=\"num\">PF</th>\n<th data-type=\"num\">R:R</th>\n<th data-type=\"num\">Max Profit</th>\n" +
       "<th data-type=\"num\">Max DD</th>\n<th data-type=\"num\">Days->Target</th>\n<th data-type=\"num\">Days->Breach</th>\n" +
       "<th data-type=\"num\">Eq. Prot</th>\n" + (useRecency ? "<th data-type=\"num\">Weight</th>\n" : "") + "<th data-type=\"str\">Ended</th>\n</tr></thead>\n<tbody></tbody>\n</table>\n" +
       "<div class=\"pagination\" id=\"runs_pagination\"></div>\n" +
       "</div>\n</div>\n</div>\n");

    FileWriteString(handle, "<script>var runData=[");
    for(int i = 0; i < totalRuns; i++)
    {
       string status = propRuns[i].passed ? "pass" : (propRuns[i].breached ? "blow" : "act");
       int closedTrades = propRuns[i].wins + propRuns[i].losses;
       double winRate = (closedTrades > 0) ? (double)propRuns[i].wins / (double)closedTrades * 100.0 : 0.0;
       double netProfit = propRuns[i].balance - propRuns[i].startingBalance;
       string reason = propRuns[i].breachReason;
       if(reason == "") reason = propRuns[i].passed ? "Target hit" : "-";
       double profitFactor = (propRuns[i].grossLoss < 0.0) ? propRuns[i].grossProfit / MathAbs(propRuns[i].grossLoss) : 0.0;
       double runAvgWin = (propRuns[i].wins > 0) ? propRuns[i].grossProfit / (double)propRuns[i].wins : 0.0;
       double runAvgLoss = (propRuns[i].losses > 0) ? MathAbs(propRuns[i].grossLoss) / (double)propRuns[i].losses : 0.0;
       double realizedRR = (runAvgLoss > 0.0) ? runAvgWin / runAvgLoss : 0.0;
       string netStr = DoubleToString(netProfit, 2);
       if(netProfit > 0.0) netStr = "+" + netStr;
       string endedStr = propRuns[i].ended > 0 ? TimeToString(propRuns[i].ended, TIME_DATE | TIME_MINUTES) : "n/a";

       double weight = 0.0;
       if(useRecency)
       {
          double lambda = MathLog(2.0) / PropRecencyHalfLifeDays;
          double ageInDays = (double)(testEndTime - propRuns[i].startDay) / 86400.0;
          weight = MathExp(-lambda * ageInDays);
       }

       string json = "{";
       json += StringFormat("\"n\":%d,", i + 1);
       json += "\"strat\":\"" + PropJsonEscape(propRuns[i].strategyName) + "\",";
       json += "\"startDay\":\"" + TimeToString(propRuns[i].startDay, TIME_DATE | TIME_MINUTES) + "\",";
       json += "\"status\":\"" + status + "\",";
       json += "\"reason\":\"" + PropJsonEscape(reason) + "\",";
       json += StringFormat("\"startBal\":%.2f,", propRuns[i].startingBalance);
       json += StringFormat("\"endBal\":%.2f,", propRuns[i].balance);
       json += StringFormat("\"net\":%.2f,", netProfit);
       json += StringFormat("\"netStr\":\"%s\",", netStr);
       json += StringFormat("\"netPos\":%s,", netProfit > 0.0 ? "true" : "false");
       json += StringFormat("\"netZero\":%s,", MathAbs(netProfit) < 0.005 ? "true" : "false");
       json += StringFormat("\"winRate\":%.1f,", winRate);
       json += StringFormat("\"hasWinRate\":%s,", closedTrades > 0 ? "true" : "false");
       json += StringFormat("\"wins\":%d,", propRuns[i].wins);
       json += StringFormat("\"losses\":%d,", propRuns[i].losses);
       json += StringFormat("\"trades\":%d,", propRuns[i].trades);
       json += StringFormat("\"pf\":%.2f,", profitFactor);
       json += StringFormat("\"hasPF\":%s,", propRuns[i].grossLoss < 0.0 ? "true" : "false");
       json += StringFormat("\"rr\":%.2f,", realizedRR);
       json += StringFormat("\"hasRR\":%s,", runAvgLoss > 0.0 ? "true" : "false");
       json += StringFormat("\"maxProfit\":%.2f,", propRuns[i].maxProfit);
       json += StringFormat("\"maxDD\":%.2f,", propRuns[i].maxDrawdown);
       json += StringFormat("\"daysTgt\":%d,", propRuns[i].daysToTarget);
       json += StringFormat("\"daysBrk\":%d,", propRuns[i].daysToBreach);
       json += StringFormat("\"eqProt\":%d,", propRuns[i].equityProtectionTriggers);
       json += StringFormat("\"weight\":%.4f,", weight);
       json += "\"ended\":\"" + endedStr + "\"";
       json += "}";
       if(i > 0) json = "," + json;
       FileWriteString(handle, json);
    }
    FileWriteString(handle, "];</script>\n");

    PropWriteFooter(handle, "strat");
    PropWriteRunsFooter(handle, useRecency);
    FileWriteString(handle, "</div>\n</body>\n</html>\n");
    FileClose(handle);
    Print("Propfirm rolling HTML report exported to Common Files: ", reportFileName, " (", IntegerToString(totalRuns), " runs)");
}

string PropJsonEscape(const string s)
{
   string result = "";
   for(int i = 0; i < StringLen(s); i++)
   {
       ushort ch = StringGetCharacter(s, i);
      if(ch == '"') result += "\\\"";
      else if(ch == '\\') result += "\\\\";
      else if(ch == '\n') result += "\\n";
      else if(ch == '\r') result += "\\r";
      else result += ShortToString(ch);
   }
   return result;
}

