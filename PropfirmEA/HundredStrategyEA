      {
         SetLine(line++, "LIVE STATE", MutedColor());
         SetLine(line++, "Balance       " + DoubleToString(AccountInfoDouble(ACCOUNT_BALANCE), 2) + "    Equity        " + DoubleToString(AccountInfoDouble(ACCOUNT_EQUITY), 2));
         SetLine(line++, "Floating P/L  " + DoubleToString(EaFloatingProfit(), 2) + "    Open pos      " + IntegerToString(CountOpenPositions()));
         if(eaStopped)
            SetLine(line++, "EA STOPPED    " + stopReason, BadColor());
         else
            SetLine(line++, "Magic         " + IntegerToString((long)MagicNumber) + "    Status        ACTIVE", GoodColor());
         SetLine(line++, " ");

         if(EnableGlobalTimeControls)
         {
            SetLine(line++, "TIME CONTROLS (UTC)", MutedColor());
            bool inPause = GlobalSignalsPaused();
            bool inClose = GlobalIsCloseTime();
            datetime pauseDt = GlobalNextOccurrence(GlobalPauseSignalsHourUTC, GlobalPauseSignalsMinuteUTC);
            datetime closeDt = GlobalNextOccurrence(GlobalCloseAllHourUTC, GlobalCloseAllMinuteUTC);
            datetime resumeDt = GlobalNextOccurrence(GlobalResumeSignalsHourUTC, GlobalResumeSignalsMinuteUTC);
            string pauseDate = GlobalDateLabel(pauseDt);
            string closeDate = GlobalDateLabel(closeDt);
            string resumeDate = GlobalDateLabel(resumeDt);
            string pauseStatus = inPause ? "ACTIVE now" : "in " + GlobalFormatCountdownSec(GlobalSecondsUntil(GlobalPauseSignalsHourUTC, GlobalPauseSignalsMinuteUTC));
            string closeStatus = inClose ? "ACTIVE now" : "in " + GlobalFormatCountdownSec(GlobalSecondsUntil(GlobalCloseAllHourUTC, GlobalCloseAllMinuteUTC));
            string resumeStatus = (inPause || inClose) ? "in " + GlobalFormatCountdownSec(GlobalSecondsUntil(GlobalResumeSignalsHourUTC, GlobalResumeSignalsMinuteUTC)) : "-";
            SetLine(line++, "Pause signals " + StringFormat("%02d:%02d", GlobalPauseSignalsHourUTC, GlobalPauseSignalsMinuteUTC) + " " + pauseDate + "  " + pauseStatus, inPause ? WarnColor() : MutedColor());
            SetLine(line++, "Close all     " + StringFormat("%02d:%02d", GlobalCloseAllHourUTC, GlobalCloseAllMinuteUTC) + " " + closeDate + "  " + closeStatus, inClose ? BadColor() : MutedColor());
            SetLine(line++, "Resume signal " + StringFormat("%02d:%02d", GlobalResumeSignalsHourUTC, GlobalResumeSignalsMinuteUTC) + " " + resumeDate + "  " + resumeStatus, (inPause || inClose) ? GoodColor() : MutedColor());
            SetLine(line++, " ");
         }
      }

      // ── Receiver EA Status ─────────────────────────────────────────────────────
      string recLabel = "Receiver EA [" + ReceiverCopierKey + "]";
      if(EnableReceiverConnection)
      {
         string csvStatus = g_receiverTradingCSV ? "ENABLED" : "DISABLED";
         color csvColor = g_receiverTradingCSV ? GoodColor() : BadColor();
         SetLine(line++, recLabel + "  CSV: Trading " + csvStatus, csvColor);
         if(g_receiverHitTime != "")
         {
            string ts = g_receiverHitTime;
            int dot = StringFind(ts, ".");
            if(dot > 0)
               ts = StringSubstr(ts, 0, dot);
            SetLine(line++, recLabel + "  Last CSV: " + ts, GoodColor());
         }
         else
         {
            SetLine(line++, recLabel + "  Last CSV: ---", MutedColor());
         }
      }
      else
      {
         SetLine(line++, recLabel + "  OFF", MutedColor());
      }
      SetLine(line++, " ");

      SetLine(line++, "LAST 5 SIGNALS", MutedColor());
      if(signalHistoryCount == 0)
      {
         SetLine(line++, "No signals yet", MutedColor());
      }
      else
      {
         for(int i = 0; i < signalHistoryCount && i < 5; i++)
         {
            string ts = TimeToString(signalHistory[i].time, TIME_DATE | TIME_MINUTES);
            string status = "";
            color col = WarnColor();
            if(signalHistory[i].executed)
            {
               if(signalHistory[i].ticket > 0 && PositionSelectByTicket(signalHistory[i].ticket))
                  status = "RUNNING";
               else
                  status = "CLOSED";
               col = GoodColor();
            }
            else
            {
               status = "SKIP";
            }
            string txt = IntegerToString(i + 1) + ". " + ts + " " + status + " " + signalHistory[i].direction + " - " + signalHistory[i].reason;
            SetLine(line++, txt, col);
         }
      }

      for(; line < H100_LINE_COUNT; line++)
         SetLine(line, " ");

      ChartRedraw(0);
   }

