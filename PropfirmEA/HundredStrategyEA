   SetLine(line++, "RISK MANAGEMENT", MutedColor());
   SetLine(line++, "Lot mode      " + EnumToString(LotMode) + "    Risk %        " + DoubleToString(RiskPerTradePercent, 2));
   SetLine(line++, "Start bal     " + DoubleToString(CustomStartingBalance, 2) + "    Fixed lot     " + DoubleToString(FixedLot, 2));
   SetLine(line++, "Max lot       " + DoubleToString(MaxLot, 2) + "    SL / TP mode  " + EnumToString(StopLossMode) + " / " + EnumToString(TakeProfitMode));
   SetLine(line++, "ATR mult      SL " + DoubleToString(SlAtrMultiplier, 2) + " / TP " + DoubleToString(TpAtrMultiplier, 2) + "    ATR period " + IntegerToString(AtrPeriod));
   SetLine(line++, "Fixed pts     SL " + DoubleToString(FixedSlPoints, 0) + " / TP " + DoubleToString(FixedTpPoints, 0) + "    Money SL " + DoubleToString(SlMoney, 2) + " / TP " + DoubleToString(TpMoney, 2));
