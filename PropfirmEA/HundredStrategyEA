   void PropSortResults()
   {
      for(int i = 0; i < PROP_STRATEGY_COUNT - 1; i++)
      {
         for(int j = i + 1; j < PROP_STRATEGY_COUNT; j++)
         {
            if(PropScore(j) > PropScore(i))
            {
               PropStrategyResult temp = propResults[i];
               propResults[i] = propResults[j];
               propResults[j] = temp;
            }
         }
      }
   }

   double PropScore(const int index)
   {
      double score = propResults[index].balance + propResults[index].maxProfit - propResults[index].maxDrawdown;
      if(propResults[index].passed)
         score += 1000000.0;
      if(propResults[index].breached)
         score -= 100000.0;
      return score;
   }

   void RecordSignalAudit(const string direction, const string reason, const bool executed, const string details, const ulong ticket = 0)
   {
      SignalAuditEntry entry;
      entry.time = TimeCurrent();
      entry.direction = direction;
      entry.reason = reason;
      entry.executed = executed;
      entry.details = details;
      entry.ticket = ticket;

      if(signalHistoryCount < 5)
         signalHistoryCount++;

      for(int i = signalHistoryCount - 1; i > 0; i--)
         signalHistory[i] = signalHistory[i - 1];

      signalHistory[0] = entry;
   }

