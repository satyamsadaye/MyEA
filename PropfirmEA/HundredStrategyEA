      double f2 = BufferValue(handle, 0, 2);
      if(f2 <= 0.0 && f1 > 0.0) return 1;
      if(f2 >= 0.0 && f1 < 0.0) return -1;
      return 0;
   }

   int VolumeBreakoutSignal(const int lookback)
   {
      int hi = iHighest(_Symbol, _Period, MODE_HIGH, lookback, 2);
      int lo = iLowest(_Symbol, _Period, MODE_LOW, lookback, 2);
      if(hi < 0 || lo < 0) return 0;
      double close1 = iClose(_Symbol, _Period, 1);
      double vol1 = (double)iVolume(_Symbol, _Period, 1);
      double avgVol = 0.0;
      for(int i = 2; i <= lookback + 1; i++)
         avgVol += (double)iVolume(_Symbol, _Period, i);
      avgVol /= lookback;
      if(close1 > iHigh(_Symbol, _Period, hi) && vol1 > avgVol) return 1;
      if(close1 < iLow(_Symbol, _Period, lo) && vol1 > avgVol) return -1;
      return 0;
   }

   int AcSignal()
   {
      int handle = iAC(_Symbol, _Period);
      double a1 = BufferValue(handle, 0, 1);
      double a2 = BufferValue(handle, 0, 2);
      if(a2 <= 0.0 && a1 > 0.0) return 1;
      if(a2 >= 0.0 && a1 < 0.0) return -1;
      return 0;
   }

   int EngulfingSignal(const int lookback)
   {
      double open1 = iOpen(_Symbol, _Period, 1);
      double close1 = iClose(_Symbol, _Period, 1);
      double open2 = iOpen(_Symbol, _Period, 2);
      double close2 = iClose(_Symbol, _Period, 2);
      double rangeAvg = AverageRange(lookback);
      if(close2 < open2 && close1 > open2 && close1 > open1 && (close1 - open1) > rangeAvg * 0.3) return 1;
      if(close2 > open2 && close1 < open2 && close1 < open1 && (open1 - close1) > rangeAvg * 0.3) return -1;
      return 0;
   }

   int PinBarSignal(const int lookback)
   {
      double open1 = iOpen(_Symbol, _Period, 1);
      double close1 = iClose(_Symbol, _Period, 1);
      double high1 = iHigh(_Symbol, _Period, 1);
      double low1 = iLow(_Symbol, _Period, 1);
      double range = high1 - low1;
      double rangeAvg = AverageRange(lookback);
      if(range < rangeAvg * 0.5) return 0;
      double upperWick = high1 - MathMax(open1, close1);
      double lowerWick = MathMin(open1, close1) - low1;
      double body = MathAbs(close1 - open1);
      if(body < 0.0001) return 0;
      if(lowerWick > body * 2.0 && upperWick < body * 0.5 && close1 > open1) return 1;
      if(upperWick > body * 2.0 && lowerWick < body * 0.5 && close1 < open1) return -1;
      return 0;
   }

   int InsideBarSignal(const int lookback)
   {
      double high1 = iHigh(_Symbol, _Period, 1);
      double low1 = iLow(_Symbol, _Period, 1);
      double high2 = iHigh(_Symbol, _Period, 2);
      double low2 = iLow(_Symbol, _Period, 2);
      double close1 = iClose(_Symbol, _Period, 1);
      if(high1 < high2 && low1 > low2)
      {
         double rangeAvg = AverageRange(lookback);
         if(close1 > high2 && (close1 - low1) > rangeAvg * 0.3) return 1;
         if(close1 < low2 && (high1 - close1) > rangeAvg * 0.3) return -1;
      }
      return 0;
   }

   int ThreeBarReversalSignal(const int lookback)
   {
      double close1 = iClose(_Symbol, _Period, 1);
      double close3 = iClose(_Symbol, _Period, 3);
      double high3 = iHigh(_Symbol, _Period, 3);
      double low3 = iLow(_Symbol, _Period, 3);
      double rangeAvg = AverageRange(lookback);
      if(close3 < low3 && close1 > high3 && (close1 - close3) > rangeAvg * 0.3) return 1;
      if(close3 > high3 && close1 < low3 && (close3 - close1) > rangeAvg * 0.3) return -1;
