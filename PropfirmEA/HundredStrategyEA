int OnInit()
{
   trade.SetExpertMagicNumber(MagicNumber);
   trade.SetDeviationInPoints(SlippagePoints);

   atrHandle = iATR(_Symbol, _Period, AtrPeriod);
   if(atrHandle == INVALID_HANDLE)
   {
      LogEvent("INIT_ERROR", "Failed to create ATR handle");
      return INIT_FAILED;
   }

   int selectedStrategyId = (int)SelectedStrategy;
   if(selectedStrategyId < 1 || selectedStrategyId > 100)
   {
      LogEvent("INIT_ERROR", "SelectedStrategy must be between 1 and 100");
      return INIT_PARAMETERS_INCORRECT;
   }

   if(MaxOpenPositions < 1)
   {
      LogEvent("INIT_ERROR", "MaxOpenPositions must be at least 1");
      return INIT_PARAMETERS_INCORRECT;
   }

   EnsureLogHeader();
   if(EnablePropfirmBacktestMode)
      InitPropfirmBacktest();
   EventSetMillisecondTimer(1000);
   CreateDashboard();
   UpdateDashboard();
   LogEvent("INIT", "HundredStrategyEA started on " + _Symbol + " | mode=" + (StrategyMode == STRATEGY_SINGLE ? "SINGLE" : "ALL-100"));
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   if(EnablePropfirmBacktestMode)
      ExportPropfirmHtmlReport();
   if(atrHandle != INVALID_HANDLE)
      IndicatorRelease(atrHandle);
   EventKillTimer();
   DeleteDashboard();
   LogEvent("DEINIT", "EA stopped. reason=" + IntegerToString(reason));
}

void OnTimer()
{
   UpdateDashboard();
}

void OnTick()
{
   if(eaStopped)
      return;

   if(EnablePropfirmBacktestMode)
   {
      RunPropfirmBacktestTick();
      return;
   }

   ManageVirtualDollarExits();

   if(CheckProtectionStops())
      return;

   if(GlobalIsCloseTime())
   {
      if(CountOpenPositions() > 0)
      {
         CloseAllEaPositions();
         LogEvent("GLOBAL_CLOSE", "Force-close all at " + StringFormat("%02d:%02d", GlobalCloseAllHourUTC, GlobalCloseAllMinuteUTC) + " UTC window");
      }
      UpdateDashboard();
      return;
   }

   if(GlobalSignalsPaused())
   {
      UpdateDashboard();
      return;
   }

   if(OneTradePerBar)
   {
      datetime currentBar = iTime(_Symbol, _Period, 0);
      if(currentBar == lastBarTime)
         return;
      lastBarTime = currentBar;
   }

   int openPositions = CountOpenPositions();
   if(openPositions >= MaxOpenPositions)
   {
      LogEvent("SIGNAL_SKIPPED", "MaxOpenPositions reached: " + IntegerToString(openPositions));
      return;
   }

   StrategySignal signal;
   signal.buyVotes = 0;
   signal.sellVotes = 0;
   signal.details = "";
   EvaluateStrategies(signal);

    int direction = 0;
    if(signal.buyVotes >= MinVotesToTrade && signal.buyVotes > signal.sellVotes)
       direction = ORDER_TYPE_BUY;
    else if(signal.sellVotes >= MinVotesToTrade && signal.sellVotes > signal.buyVotes)
       direction = ORDER_TYPE_SELL;
    else
    {
       LogEvent("NO_TRADE", "buyVotes=" + IntegerToString(signal.buyVotes) + ", sellVotes=" + IntegerToString(signal.sellVotes));
       return;
    }

    if(ReverseSignals)
       direction = (direction == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;

    if((AllowedDirection == SIGNAL_BUY_ONLY && direction == ORDER_TYPE_SELL) ||
        (AllowedDirection == SIGNAL_SELL_ONLY && direction == ORDER_TYPE_BUY))
   {
      string skipReason = "Direction blocked by AllowedDirection";
      LogEvent("SIGNAL_SKIPPED", skipReason);
      RecordSignalAudit(DirectionText(direction), skipReason, false, signal.details);
      UpdateDashboard();
      return;
   }

   bool tradeOpened = OpenTrade(direction, signal);
   RecordSignalAudit(DirectionText(direction), tradeOpened ? "OPENED" : "FAILED", tradeOpened, signal.details);
   UpdateDashboard();
}

void EvaluateStrategies(StrategySignal &signal)
{
   if(StrategyMode == STRATEGY_SINGLE)
   {
      EvaluateStrategy((int)SelectedStrategy, signal);
      return;
   }

   for(int id = 1; id <= 100; id++)
      EvaluateStrategy(id, signal);
}

void EvaluateStrategy(const int id, StrategySignal &signal)
{
   int family = (id - 1) / 10;
   int variant = (id - 1) % 10;
   int fast = 5 + variant * 2;
   int slow = 20 + variant * 5;
   int lookback = 10 + variant * 3;
   double threshold = 0.2 + variant * 0.1;

   int result = 0;
   switch(family)
   {
      case 0: result = MaTrendSignal(fast, slow); break;
      case 1: result = RsiSignal(7 + variant * 2, 30.0 + variant, 70.0 - variant); break;
      case 2: result = BreakoutSignal(lookback); break;
      case 3: result = BollingerSignal(14 + variant, 1.5 + variant * 0.15); break;
      case 4: result = MacdSignal(8 + variant, 21 + variant * 2, 5 + variant); break;
      case 5: result = StochasticSignal(5 + variant, 3, 3, 20 + variant, 80 - variant); break;
      case 6: result = CciSignal(14 + variant * 2, 100 + variant * 10); break;
      case 7: result = MomentumSignal(10 + variant, threshold); break;
      case 8: result = AtrChannelSignal(14 + variant, 1.0 + variant * 0.12); break;
      case 9: result = PriceActionSignal(lookback); break;
   }

   if(result > 0)
   {
      signal.buyVotes++;
      signal.details += StrategyName(id) + "=BUY;";
   }
   else if(result < 0)
   {
      signal.sellVotes++;
      signal.details += StrategyName(id) + "=SELL;";
   }
}

