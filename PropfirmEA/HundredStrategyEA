   int EmaRsiConfirmSignal(const int fast, const int slow, const int rsiPeriod)
   {
      double f1 = IndicatorValue(iMA(_Symbol, _Period, fast, 0, MODE_EMA, PRICE_CLOSE), 1);
      double f2 = IndicatorValue(iMA(_Symbol, _Period, fast, 0, MODE_EMA, PRICE_CLOSE), 2);
      double s1 = IndicatorValue(iMA(_Symbol, _Period, slow, 0, MODE_EMA, PRICE_CLOSE), 1);
      double s2 = IndicatorValue(iMA(_Symbol, _Period, slow, 0, MODE_EMA, PRICE_CLOSE), 2);
      double rsi = IndicatorValue(iRSI(_Symbol, _Period, rsiPeriod, PRICE_CLOSE), 1);
      if(f2 <= s2 && f1 > s1 && rsi > 50.0) return 1;
