      case 97: return "097_PRICE_ACTION_VOLATILE_BAR";
      case 98: return "098_PRICE_ACTION_STRUCTURE_BAR";
      case 99: return "099_PRICE_ACTION_POSITION_BAR";
      case 100: return "100_PRICE_ACTION_MAJOR_BAR";
   }
   return "UNKNOWN_STRATEGY";
}

int MaTrendSignal(const int fast, const int slow)
{
   double f1 = IndicatorValue(iMA(_Symbol, _Period, fast, 0, MODE_EMA, PRICE_CLOSE), 1);
   double f2 = IndicatorValue(iMA(_Symbol, _Period, fast, 0, MODE_EMA, PRICE_CLOSE), 2);
   double s1 = IndicatorValue(iMA(_Symbol, _Period, slow, 0, MODE_EMA, PRICE_CLOSE), 1);
   double s2 = IndicatorValue(iMA(_Symbol, _Period, slow, 0, MODE_EMA, PRICE_CLOSE), 2);
   if(f2 <= s2 && f1 > s1) return 1;
   if(f2 >= s2 && f1 < s1) return -1;
   return 0;
}

int RsiSignal(const int period, const double low, const double high)
{
   double r1 = IndicatorValue(iRSI(_Symbol, _Period, period, PRICE_CLOSE), 1);
   double r2 = IndicatorValue(iRSI(_Symbol, _Period, period, PRICE_CLOSE), 2);
   if(r2 < low && r1 >= low) return 1;
   if(r2 > high && r1 <= high) return -1;
   return 0;
}

int BreakoutSignal(const int lookback)
{
   int hi = iHighest(_Symbol, _Period, MODE_HIGH, lookback, 2);
   int lo = iLowest(_Symbol, _Period, MODE_LOW, lookback, 2);
   if(hi < 0 || lo < 0) return 0;
   double close1 = iClose(_Symbol, _Period, 1);
   if(close1 > iHigh(_Symbol, _Period, hi)) return 1;
   if(close1 < iLow(_Symbol, _Period, lo)) return -1;
   return 0;
}

int BollingerSignal(const int period, const double deviation)
{
   int handle = iBands(_Symbol, _Period, period, 0, deviation, PRICE_CLOSE);
   double upper = BufferValue(handle, 1, 1);
   double lower = BufferValue(handle, 2, 1);
   double close1 = iClose(_Symbol, _Period, 1);
   double close2 = iClose(_Symbol, _Period, 2);
   if(close2 < lower && close1 > lower) return 1;
   if(close2 > upper && close1 < upper) return -1;
   return 0;
}

int MacdSignal(const int fast, const int slow, const int signalPeriod)
{
   int handle = iMACD(_Symbol, _Period, fast, slow, signalPeriod, PRICE_CLOSE);
   double main1 = BufferValue(handle, 0, 1);
   double sig1 = BufferValue(handle, 1, 1);
   double main2 = BufferValue(handle, 0, 2);
   double sig2 = BufferValue(handle, 1, 2);
   if(main2 <= sig2 && main1 > sig1) return 1;
   if(main2 >= sig2 && main1 < sig1) return -1;
   return 0;
}

int StochasticSignal(const int k, const int d, const int slowing, const double low, const double high)
{
   int handle = iStochastic(_Symbol, _Period, k, d, slowing, MODE_SMA, STO_LOWHIGH);
   double k1 = BufferValue(handle, 0, 1);
   double d1 = BufferValue(handle, 1, 1);
   double k2 = BufferValue(handle, 0, 2);
   double d2 = BufferValue(handle, 1, 2);
   if(k2 <= d2 && k1 > d1 && k1 < low) return 1;
   if(k2 >= d2 && k1 < d1 && k1 > high) return -1;
   return 0;
}

int CciSignal(const int period, const double level)
{
   double c1 = IndicatorValue(iCCI(_Symbol, _Period, period, PRICE_TYPICAL), 1);
   double c2 = IndicatorValue(iCCI(_Symbol, _Period, period, PRICE_TYPICAL), 2);
   if(c2 < -level && c1 >= -level) return 1;
   if(c2 > level && c1 <= level) return -1;
   return 0;
}

int MomentumSignal(const int period, const double threshold)
{
   double m1 = IndicatorValue(iMomentum(_Symbol, _Period, period, PRICE_CLOSE), 1);
   double m2 = IndicatorValue(iMomentum(_Symbol, _Period, period, PRICE_CLOSE), 2);
   if(m2 <= 100.0 + threshold && m1 > 100.0 + threshold) return 1;
   if(m2 >= 100.0 - threshold && m1 < 100.0 - threshold) return -1;
   return 0;
}

int AtrChannelSignal(const int period, const double multiplier)
{
   double atr = IndicatorValue(iATR(_Symbol, _Period, period), 1);
   double ma = IndicatorValue(iMA(_Symbol, _Period, period, 0, MODE_SMA, PRICE_CLOSE), 1);
   double close1 = iClose(_Symbol, _Period, 1);
   if(close1 > ma + atr * multiplier) return 1;
   if(close1 < ma - atr * multiplier) return -1;
   return 0;
}

int PriceActionSignal(const int lookback)
{
   double close1 = iClose(_Symbol, _Period, 1);
   double open1 = iOpen(_Symbol, _Period, 1);
   double high2 = iHigh(_Symbol, _Period, 2);
   double low2 = iLow(_Symbol, _Period, 2);
   double rangeAvg = AverageRange(lookback);
   if(close1 > open1 && close1 > high2 && (close1 - open1) > rangeAvg * 0.35) return 1;
   if(close1 < open1 && close1 < low2 && (open1 - close1) > rangeAvg * 0.35) return -1;
   return 0;
}

double IndicatorValue(const int handle, const int shift)
{
   return BufferValue(handle, 0, shift);
}

double BufferValue(const int handle, const int buffer, const int shift)
{
   if(handle == INVALID_HANDLE)
      return 0.0;
   double values[];
   ArraySetAsSeries(values, true);
   if(CopyBuffer(handle, buffer, shift, 1, values) != 1)
   {
      IndicatorRelease(handle);
      return 0.0;
   }
   IndicatorRelease(handle);
   return values[0];
}

double AverageRange(const int lookback)
{
   double sum = 0.0;
   int count = 0;
   for(int i = 1; i <= lookback; i++)
   {
      double high = iHigh(_Symbol, _Period, i);
      double low = iLow(_Symbol, _Period, i);
      if(high > 0 && low > 0)
      {
         sum += high - low;
         count++;
      }
   }
   return count > 0 ? sum / count : 0.0;
}

bool OpenTrade(const int orderType, const StrategySignal &signal)
{
   double entry = (orderType == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   bool useBrokerStops = PlaceBrokerStopLossTakeProfit && !(EnableVirtualDollarExit && DisableBrokerStopsWhenVirtualExitOn);
   double slDistance = 0.0;
   double tpDistance = 0.0;

     if(useBrokerStops)
     {
        if(EnableVirtualDollarExit)
        {
           slDistance = MoneyToPriceDistance(VirtualStopLossMoney, VirtualExitLot);
           tpDistance = MoneyToPriceDistance(VirtualTakeProfitMoney, VirtualExitLot);
           bool slNeeded = (VirtualStopLossMoney > 0.0);
           bool tpNeeded = (VirtualTakeProfitMoney > 0.0);
           if((slNeeded && slDistance <= 0.0) || (tpNeeded && tpDistance <= 0.0))
           {
              LogEvent("TRADE_SKIPPED", "Invalid SL/TP distance");
              return false;
           }
        }
        else
        {
           slDistance = StopDistance(StopLossMode, true);
           tpDistance = StopDistance(TakeProfitMode, false);
           if(slDistance <= 0.0 || tpDistance <= 0.0)
           {
              LogEvent("TRADE_SKIPPED", "Invalid SL/TP distance");
              return false;
           }
           if(ReverseSignals)
           {
              double tmp = slDistance;
              slDistance = tpDistance;
              tpDistance = tmp;
           }
        }
     }
    else if(!EnableVirtualDollarExit)
    {
       slDistance = StopDistance(StopLossMode, true);
       if(slDistance <= 0.0)
       {
          LogEvent("TRADE_SKIPPED", "Invalid risk distance for lot sizing while broker stops are disabled");
          return false;
       }
       if(ReverseSignals)
          slDistance = StopDistance(TakeProfitMode, false);
    }

    double lots = CalculateLot(slDistance);
    if(lots <= 0.0)
    {
       LogEvent("TRADE_SKIPPED", "Calculated lot is zero");
       return false;
    }

    double sl = 0.0;
    double tp = 0.0;
    if(useBrokerStops)
    {
       if(slDistance > 0.0)
          sl = (orderType == ORDER_TYPE_BUY) ? entry - slDistance : entry + slDistance;
       if(tpDistance > 0.0)
          tp = (orderType == ORDER_TYPE_BUY) ? entry + tpDistance : entry - tpDistance;
       sl = NormalizeDouble(sl, _Digits);
       tp = NormalizeDouble(tp, _Digits);
    }

    string comment = "H100 Sigs B" + IntegerToString(signal.buyVotes) + " S" + IntegerToString(signal.sellVotes);
    if(ReverseSignals)
       comment += " REV";
    bool ok = false;
    if(orderType == ORDER_TYPE_BUY)
       ok = trade.Buy(lots, _Symbol, 0.0, sl, tp, comment);
    else
       ok = trade.Sell(lots, _Symbol, 0.0, sl, tp, comment);

    string message = StringFormat("type=%s,lots=%.2f,entry=%.5f,sl=%.5f,tp=%.5f,brokerStops=%s,virtualExit=%s,virtualTP=%.2f,virtualSL=%.2f,buyVotes=%d,sellVotes=%d,reversed=%s,strategies=%s,retcode=%d",
                                  orderType == ORDER_TYPE_BUY ? "BUY" : "SELL", lots, entry, sl, tp,
                                  useBrokerStops ? "true" : "false", EnableVirtualDollarExit ? "true" : "false",
                                  VirtualTakeProfitMoney, VirtualStopLossMoney,
                                  signal.buyVotes, signal.sellVotes, ReverseSignals ? "true" : "false", signal.details, trade.ResultRetcode());
   LogEvent(ok ? "TRADE_OPENED" : "TRADE_FAILED", message);
   return ok;
}

double StopDistance(const ENUM_STOP_MODE mode, const bool isStopLoss)
{
   if(mode == STOP_ATR_MULTIPLIER)
   {
      double atr = CurrentAtr();
      return atr * (isStopLoss ? SlAtrMultiplier : TpAtrMultiplier);
   }

   if(mode == STOP_FIXED_POINTS)
      return (isStopLoss ? FixedSlPoints : FixedTpPoints) * _Point;

   double money = isStopLoss ? SlMoney : TpMoney;
   double lot = MathMax(FixedLot, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
   return MoneyToPriceDistance(money, lot);
}

double CurrentAtr()
{
   double values[];
   ArraySetAsSeries(values, true);
   if(CopyBuffer(atrHandle, 0, 1, 1, values) != 1)
      return 0.0;
   return values[0];
}

double CalculateLot(const double slDistance)
{
   if(EnableVirtualDollarExit)
      return NormalizeLot(VirtualExitLot);

   if(LotMode == LOT_FIXED)
      return NormalizeLot(FixedLot);

   double base = (LotMode == LOT_RISK_STARTING_BALANCE) ? CustomStartingBalance : AccountInfoDouble(ACCOUNT_BALANCE);
   double riskMoney = base * RiskPerTradePercent / 100.0;
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickValue <= 0.0 || tickSize <= 0.0 || slDistance <= 0.0)
      return 0.0;

   double lossPerLot = (slDistance / tickSize) * tickValue;
   if(lossPerLot <= 0.0)
      return 0.0;

   return NormalizeLot(riskMoney / lossPerLot);
}

double MoneyToPriceDistance(const double money, const double lots)
{
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(money <= 0.0 || lots <= 0.0 || tickValue <= 0.0 || tickSize <= 0.0)
      return 0.0;
   return (money / (tickValue * lots)) * tickSize;
}

double NormalizeLot(const double rawLot)
{
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxLot = MathMin(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX), MaxLot);
   double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
   if(step <= 0.0)
      step = 0.01;

   double lot = MathMax(minLot, MathMin(maxLot, rawLot));
   lot = MathFloor(lot / step) * step;
   return NormalizeDouble(lot, 2);
}

int CountOpenPositions()
