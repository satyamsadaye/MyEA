   int MacdBandsSignal(const int fast, const int slow, const int signalPeriod, const int bbPeriod)
   {
      int macdHandle = iMACD(_Symbol, _Period, fast, slow, signalPeriod, PRICE_CLOSE);
      double main1 = BufferValue(macdHandle, 0, 1);
      double main2 = BufferValue(macdHandle, 0, 2);
      int bbHandle = iBands(_Symbol, _Period, bbPeriod, 0, 2.0, PRICE_CLOSE);
      double upper = BufferValue(bbHandle, 1, 1);
      double lower = BufferValue(bbHandle, 2, 1);
