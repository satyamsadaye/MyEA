   void ExportPropfirmSingleReport()
   {
      int passedCount = 0, blownCount = 0, activeCount = 0;
      int activeProfit = 0, activeDD = 0;
      long totalTrades = 0;
      long totalSignals = 0;
      double totalWinRateSum = 0.0;
      int winRateCount = 0;
      double bestNetProfit = -DBL_MAX;
      double worstNetProfit = DBL_MAX;
      string bestName = "", worstName = "";
      datetime testStart = 0;

      int reportCount = PropEffectiveStrategyCount();

      for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
      {
         if(!PropIsCustomStrategy(i + 1))
            continue;

         if(propResults[i].passed) passedCount++;
         else if(propResults[i].breached) blownCount++;
         else
         {
            activeCount++;
            if(propResults[i].equity >= propResults[i].startingBalance)
               activeProfit++;
            else
               activeDD++;
         }

         totalTrades += propResults[i].trades;
         totalSignals += propResults[i].totalSignals;

         int closedTrades = propResults[i].wins + propResults[i].losses;
         if(closedTrades > 0)
         {
            totalWinRateSum += (double)propResults[i].wins / (double)closedTrades * 100.0;
            winRateCount++;
         }

         double net = propResults[i].balance - propResults[i].startingBalance;
         if(net > bestNetProfit) { bestNetProfit = net; bestName = propResults[i].name; }
         if(net < worstNetProfit) { worstNetProfit = net; worstName = propResults[i].name; }

         if(testStart == 0 || propResults[i].started < testStart)
            testStart = propResults[i].started;
      }

      double avgWinRate = (winRateCount > 0) ? totalWinRateSum / (double)winRateCount : 0.0;
      double passRate = (reportCount > 0) ? (double)passedCount / (double)reportCount * 100.0 : 0.0;
      datetime testEnd = TimeCurrent();

      PropSortResults();

      string reportFileName = PropTimestampedReportFileName();
      int handle = FileOpen(reportFileName, FILE_WRITE | FILE_TXT | FILE_COMMON);
      if(handle == INVALID_HANDLE)
      {
         Print("Failed to export propfirm HTML report. error=", GetLastError());
         return;
      }

      PropWriteHtmlHead(handle);
      string singleTitle = (PropStrategyMode == PROP_STRATEGY_CUSTOM) ? "Forward test" : "Propfirm 100 Strategy Backtest Report";
      PropWriteHeader(handle, singleTitle, testEnd);

      FileWriteString(handle, "<div class=\"section\">\n<h2>Run Report - Settings Used For This Run</h2>\n<div class=\"settings-grid\">\n");
      PropWriteCommonSettings(handle, testStart, testEnd);
      FileWriteString(handle, PropKv("Rolling Start Mode", PropBoolStr(false)));
      FileWriteString(handle, PropKv("Total Strategies Tested", IntegerToString(reportCount)));
      FileWriteString(handle, "</div>\n<div class=\"note\">Best performer: <b>" + bestName + "</b> (" + DoubleToString(bestNetProfit, 2) + ") &nbsp;|&nbsp; Worst performer: <b>" + worstName + "</b> (" + DoubleToString(worstNetProfit, 2) + ")</div>\n</div>\n");

      FileWriteString(handle,
         "<div class=\"section\">\n<h2>Summary Dashboard</h2>\n<div class=\"cards\">\n" +
         "<div class=\"card pass\"><div class=\"label\">Passed</div><div class=\"value\">" + IntegerToString(passedCount) + "</div><div class=\"sub\">of " + IntegerToString(reportCount) + " strategies</div></div>\n" +
         "<div class=\"card blow\"><div class=\"label\">Blown</div><div class=\"value\">" + IntegerToString(blownCount) + "</div><div class=\"sub\">rule breach</div></div>\n" +
         "<div class=\"card act\"><div class=\"label\">Active</div><div class=\"value\">" + IntegerToString(activeCount) + "</div><div class=\"sub\">still running</div></div>\n" +
         (activeCount > 0 ?
            "<div class=\"card profit\"><div class=\"label\">Active in Profit</div><div class=\"value\">" + DoubleToString((double)activeProfit / activeCount * 100.0, 1) + "%</div><div class=\"sub\">" + IntegerToString(activeProfit) + " of " + IntegerToString(activeCount) + "</div></div>\n" +
            "<div class=\"card loss\"><div class=\"label\">Active in Drawdown</div><div class=\"value\">" + DoubleToString((double)activeDD / activeCount * 100.0, 1) + "%</div><div class=\"sub\">" + IntegerToString(activeDD) + " of " + IntegerToString(activeCount) + "</div></div>\n" :
            "") +
         "<div class=\"card rate\"><div class=\"label\">Pass Rate</div><div class=\"value\">" + DoubleToString(passRate, 1) + "%</div><div class=\"sub\">target hit</div></div>\n" +
         "<div class=\"card avg\"><div class=\"label\">Avg Win Rate</div><div class=\"value\">" + DoubleToString(avgWinRate, 1) + "%</div><div class=\"sub\">across closed trades</div></div>\n" +
         "<div class=\"card tot\"><div class=\"label\">Total Trades</div><div class=\"value\">" + IntegerToString(totalTrades) + "</div><div class=\"sub\">virtual positions</div></div>\n" +
         "<div class=\"card sig\"><div class=\"label\">Total Signals</div><div class=\"value\">" + IntegerToString(totalSignals) + "</div><div class=\"sub\">strategy triggers</div></div>\n" +
         "</div>\n</div>\n");

      FileWriteString(handle,
         "<div class=\"section\">\n<h2>Strategy Results (ranked)</h2>\n" +
         PropToolbarHtml("results") +
         PropTopScrollHtml("results") +
         "<div class=\"table-scroll has-top\" id=\"ts_results\">\n<table id=\"results\">\n<thead><tr>\n" +
         "<th data-type=\"num\" class=\"sticky-col\">Rank</th>\n<th data-type=\"str\" class=\"sticky-col\">Strategy</th>\n<th data-type=\"str\">Status</th>\n" +
         "<th data-type=\"str\">Reason</th>\n<th data-type=\"num\">Start Bal</th>\n<th data-type=\"num\">End Bal</th>\n" +
         "<th data-type=\"num\">Net P/L</th>\n<th data-type=\"num\">Win Rate</th>\n<th data-type=\"num\">Wins</th>\n" +
         "<th data-type=\"num\">Losses</th>\n<th data-type=\"num\">Trades</th>\n<th data-type=\"num\">Total Signals</th>\n<th data-type=\"num\">Avg Sig/Day</th>\n<th data-type=\"num\">PF</th>\n" +
         "<th data-type=\"num\">Max Profit</th>\n<th data-type=\"num\">Max DD</th>\n<th data-type=\"num\">Days->Target</th>\n" +
         "<th data-type=\"num\">Days->Breach</th>\n<th data-type=\"num\">Eq. Prot</th>\n<th data-type=\"str\">Started</th>\n" +
         "<th data-type=\"str\">Ended</th>\n</tr></thead>\n<tbody>\n");

      int rankOut = 0;
      for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
      {
         if(!PropIsCustomStrategy(i + 1))
            continue;
         rankOut++;

         string status = propResults[i].passed ? "pass" : (propResults[i].breached ? "blow" : "act");
         string badge = propResults[i].passed ? "PASSED" : (propResults[i].breached ? "BLOWN" : "ACTIVE");
         int closedTrades = propResults[i].wins + propResults[i].losses;
         double winRate = (closedTrades > 0) ? (double)propResults[i].wins / (double)closedTrades * 100.0 : 0.0;
         double netProfit = propResults[i].balance - propResults[i].startingBalance;
         string netClass = (netProfit > 0.0) ? "pos" : ((netProfit < 0.0) ? "neg" : "zero");
         string netStr = DoubleToString(netProfit, 2);
         if(netProfit > 0.0) netStr = "+" + netStr;
         string reason = propResults[i].breachReason;
         if(reason == "") reason = propResults[i].passed ? "Target hit" : "-";

         string row = "";
         row += StringFormat("<tr class=\"%s\" data-status=\"%s\">", status, status);
         row += StringFormat("<td class=\"num sticky-col\">%d</td>", rankOut);
         row += StringFormat("<td class=\"sticky-col\">%s</td>", propResults[i].name);
         row += StringFormat("<td><span class=\"badge %s\">%s</span></td>", status, badge);
         row += StringFormat("<td class=\"reason\">%s</td>", reason);
         row += StringFormat("<td class=\"num\">%.2f</td>", propResults[i].startingBalance);
         row += StringFormat("<td class=\"num\">%.2f</td>", propResults[i].balance);
         row += StringFormat("<td class=\"num %s\">%s</td>", netClass, netStr);
         if(closedTrades > 0)
            row += StringFormat("<td data-sort=\"%.4f\"><div class=\"barwrap\"><div class=\"barfill b%d\"></div></div>%.1f%%</td>", winRate, (int)MathRound(winRate), winRate);
         else
            row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
         row += StringFormat("<td class=\"num pos\">%d</td>", propResults[i].wins);
         row += StringFormat("<td class=\"num neg\">%d</td>", propResults[i].losses);
         row += StringFormat("<td class=\"num\">%d</td>", propResults[i].trades);
         double singleTestDays = (testEnd > testStart) ? (double)(testEnd - testStart) / 86400.0 : 0.0;
         double avgSigDay = (singleTestDays > 0.0) ? (double)propResults[i].totalSignals / singleTestDays : 0.0;
         row += StringFormat("<td class=\"num\">%d</td>", propResults[i].totalSignals);
         row += StringFormat("<td class=\"num\">%.1f</td>", avgSigDay);
         if(propResults[i].grossLoss < 0.0)
            row += StringFormat("<td class=\"num\">%.2f</td>", propResults[i].grossProfit / MathAbs(propResults[i].grossLoss));
         else
            row += "<td class=\"num zero\">n/a</td>";
         row += StringFormat("<td class=\"num pos\">%.2f</td>", propResults[i].maxProfit);
         row += StringFormat("<td class=\"num neg\">%.2f</td>", propResults[i].maxDrawdown);
         row += StringFormat("<td class=\"num\">%d</td>", propResults[i].daysToTarget);
         row += StringFormat("<td class=\"num\">%d</td>", propResults[i].daysToBreach);
         row += StringFormat("<td class=\"num\">%d</td>", propResults[i].equityProtectionTriggers);
         row += StringFormat("<td>%s</td>", TimeToString(propResults[i].started, TIME_DATE | TIME_MINUTES));
         row += StringFormat("<td>%s</td>", propResults[i].ended > 0 ? TimeToString(propResults[i].ended, TIME_DATE | TIME_MINUTES) : "n/a");
         row += "</tr>\n";
         FileWriteString(handle, row);
      }

      FileWriteString(handle, "</tbody>\n</table>\n</div>\n</div>\n");
      PropWriteFooter(handle, "results");
      FileWriteString(handle, "</div>\n</body>\n</html>\n");
      FileClose(handle);
      Print("Propfirm HTML report exported to Common Files: ", reportFileName);
   }

   void ExportPropfirmRollingReport()
   {
      int totalRuns = ArraySize(propRuns);
      int aggStarts[500], aggPassed[500], aggBlown[500], aggActive[500];
      int aggWins[500], aggLosses[500], aggTrades[500], aggDaysToTarget[500];
      double aggNetSum[500], aggBestNet[500], aggWorstNet[500], aggWinRateSum[500];
      double aggGrossProfit[500], aggGrossLoss[500];
      double aggDuration[500];
      int aggWinRateCount[500];
      double aggRecencyWeightSum[500], aggRecencyPassedWeight[500];
      datetime testStart = 0;

      ArrayInitialize(aggStarts, 0);
      ArrayInitialize(aggPassed, 0);
      ArrayInitialize(aggBlown, 0);
      ArrayInitialize(aggActive, 0);
      ArrayInitialize(aggWins, 0);
      ArrayInitialize(aggLosses, 0);
      ArrayInitialize(aggTrades, 0);
      ArrayInitialize(aggDaysToTarget, 0);
      ArrayInitialize(aggWinRateSum, 0.0);
      ArrayInitialize(aggWinRateCount, 0);
      ArrayInitialize(aggNetSum, 0.0);
      ArrayInitialize(aggBestNet, -DBL_MAX);
      ArrayInitialize(aggWorstNet, DBL_MAX);
      ArrayInitialize(aggGrossProfit, 0.0);
      ArrayInitialize(aggGrossLoss, 0.0);
      ArrayInitialize(aggDuration, 0.0);
      ArrayInitialize(aggRecencyWeightSum, 0.0);
      ArrayInitialize(aggRecencyPassedWeight, 0.0);

      datetime testEndTime = TimeCurrent();
      if(g_testEndTime > 0) testEndTime = g_testEndTime;
      int activeProfit = 0, activeDD = 0;

      for(int i = 0; i < totalRuns; i++)
      {
         int sid = propRuns[i].strategyId - 1;
         if(sid < 0 || sid >= 500) continue;

         aggStarts[sid]++;
         if(propRuns[i].passed) aggPassed[sid]++;
         else if(propRuns[i].breached) aggBlown[sid]++;
         else
         {
            aggActive[sid]++;
            if(propRuns[i].equity >= propRuns[i].startingBalance)
               activeProfit++;
            else
               activeDD++;
         }

         aggWins[sid] += propRuns[i].wins;
         aggLosses[sid] += propRuns[i].losses;
         aggTrades[sid] += propRuns[i].trades;
         aggGrossProfit[sid] += propRuns[i].grossProfit;
         aggGrossLoss[sid] += propRuns[i].grossLoss;

         datetime runEnd = (propRuns[i].ended > 0) ? propRuns[i].ended : testEndTime;
         double runDays = (double)(runEnd - propRuns[i].startDay) / 86400.0 + 1.0;
         if(runDays < 1.0) runDays = 1.0;
         aggDuration[sid] += runDays;

         int closedTrades = propRuns[i].wins + propRuns[i].losses;
         if(closedTrades > 0)
         {
            aggWinRateSum[sid] += (double)propRuns[i].wins / (double)closedTrades * 100.0;
            aggWinRateCount[sid]++;
         }

         double net = propRuns[i].balance - propRuns[i].startingBalance;
         aggNetSum[sid] += net;
         if(net > aggBestNet[sid]) aggBestNet[sid] = net;
         if(net < aggWorstNet[sid]) aggWorstNet[sid] = net;

         if(propRuns[i].passed && propRuns[i].daysToTarget > 0)
            aggDaysToTarget[sid] += propRuns[i].daysToTarget;

         if(testStart == 0 || propRuns[i].startDay < testStart)
            testStart = propRuns[i].startDay;

         if(PropRecencyHalfLifeDays > 0.0)
         {
            double lambda = MathLog(2.0) / PropRecencyHalfLifeDays;
            double ageInDays = (double)(testEndTime - propRuns[i].startDay) / 86400.0;
            double weight = MathExp(-lambda * ageInDays);
            aggRecencyWeightSum[sid] += weight;
            if(propRuns[i].passed)
               aggRecencyPassedWeight[sid] += weight;
         }
      }

      int sortOrder[500];
      for(int i = 0; i < 500; i++) sortOrder[i] = i;
      bool useRecency = (PropRecencyHalfLifeDays > 0.0);
      double testSpanDays = (testStart > 0) ? (double)(testEndTime - testStart) / 86400.0 : 0.0;
      bool recencyIneffective = useRecency && testSpanDays > 0.0 && PropRecencyHalfLifeDays > testSpanDays * 3.0;

      datetime trendDayList[];
      ArrayResize(trendDayList, 0);
      for(int i = 0; i < totalRuns; i++)
      {
         long raw = (long)propRuns[i].startDay;
         datetime bucket = (datetime)(raw - (raw % 86400));
         bool found = false;
         for(int d = 0; d < ArraySize(trendDayList); d++)
         {
            if(trendDayList[d] == bucket) { found = true; break; }
         }
         if(!found)
         {
            int sz = ArraySize(trendDayList);
            ArrayResize(trendDayList, sz + 1);
            trendDayList[sz] = bucket;
         }
      }
      int trendDayCount = ArraySize(trendDayList);
      for(int d = 0; d < trendDayCount - 1; d++)
      {
         for(int e = d + 1; e < trendDayCount; e++)
         {
            if(trendDayList[e] < trendDayList[d])
            {
               datetime tmp = trendDayList[d];
               trendDayList[d] = trendDayList[e];
               trendDayList[e] = tmp;
            }
         }
      }
      if(trendDayCount > 90) trendDayCount = 90;

         int trendPass[500][90];
         int trendBreach[500][90];
         int trendHasData[500][90];
         double trendCumulative[500][90];
         double trendLatestCumulative[500];
         for(int s = 0; s < 500; s++)
         {
            for(int d = 0; d < 90; d++)
            {
               trendPass[s][d] = 0;
               trendBreach[s][d] = 0;
               trendHasData[s][d] = 0;
               trendCumulative[s][d] = 0.0;
            }
            trendLatestCumulative[s] = 0.0;
         }
         for(int i = 0; i < totalRuns; i++)
         {
            int sid = propRuns[i].strategyId - 1;
            if(sid < 0 || sid >= 500) continue;
            long raw = (long)propRuns[i].startDay;
            datetime bucket = (datetime)(raw - (raw % 86400));
            int dayIdx = -1;
            for(int d = 0; d < trendDayCount; d++)
            {
               if(trendDayList[d] == bucket) { dayIdx = d; break; }
            }
            if(dayIdx < 0 || dayIdx >= trendDayCount) continue;
            if(!propRuns[i].passed && !propRuns[i].breached) continue;
            trendHasData[sid][dayIdx] = 1;
            if(propRuns[i].passed)
               trendPass[sid][dayIdx]++;
            else
               trendBreach[sid][dayIdx]++;
         }
         for(int s = 0; s < 500; s++)
         {
            double cumulative = 0.0;
            for(int d = 0; d < trendDayCount; d++)
            {
               int net = trendPass[s][d] - trendBreach[s][d];
               cumulative += net;
               trendCumulative[s][d] = cumulative;
            if(trendHasData[s][d])
                  trendLatestCumulative[s] = cumulative;
            }
         }

         int rankHistory[500][90];
         for(int s = 0; s < 500; s++)
            for(int d = 0; d < 90; d++)
               rankHistory[s][d] = 0;

         for(int d = 0; d < trendDayCount; d++)
         {
            int candList[500];
            int candCount = 0;
            for(int s = 0; s < 500; s++)
            {
               if(trendHasData[s][d])
                  candList[candCount++] = s;
            }
            if(candCount == 0) continue;
            for(int i = 0; i < candCount - 1; i++)
            {
               for(int j = i + 1; j < candCount; j++)
               {
                  int a = candList[i], b = candList[j];
                  int totA = trendPass[a][d] + trendBreach[a][d];
                  int totB = trendPass[b][d] + trendBreach[b][d];
                  double rateA = (totA > 0) ? (double)trendPass[a][d] / totA : 0.0;
                  double rateB = (totB > 0) ? (double)trendPass[b][d] / totB : 0.0;
                  int netA = trendPass[a][d] - trendBreach[a][d];
                  int netB = trendPass[b][d] - trendBreach[b][d];
                  bool swap = false;
                  if(rateB > rateA + 0.0001) swap = true;
                  else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
                  if(swap) { candList[i] = b; candList[j] = a; }
               }
            }
            for(int i = 0; i < candCount; i++)
               rankHistory[candList[i]][d] = i + 1;
         }

         int numRankedStrats = 0;
         for(int s = 0; s < 500; s++)
         {
            for(int d = 0; d < trendDayCount; d++)
            {
               if(rankHistory[s][d] > 0) { numRankedStrats++; break; }
            }
         }

         double persistenceScore[500];
         double persistTop10[500];
         double persistAvgRank[500];
         double persistStability[500];
         double persistMomentum[500];
         bool persistHasData[500];
         for(int s = 0; s < 500; s++)
         {
            persistHasData[s] = false;
            persistenceScore[s] = 0.0;
            persistTop10[s] = 0.0;
            persistAvgRank[s] = 0.0;
            persistStability[s] = 0.0;
            persistMomentum[s] = 0.0;
         }
         for(int s = 0; s < 500; s++)
         {
            int daysWithData = 0, daysTop10 = 0, comparablePairs = 0;
            double sumAbsChange = 0.0;
            double sumRanks = 0.0;
            int prevRank = 0;
            bool hasPrev = false;
            int recentRanks[90];
            int recentCount = 0;
            int recentDayIdx[90];
            for(int d = 0; d < trendDayCount; d++)
            {
               int rk = rankHistory[s][d];
               if(rk == 0) continue;
               persistHasData[s] = true;
               daysWithData++;
               daysTop10 += (rk <= 10) ? 1 : 0;
               sumRanks += rk;
               recentDayIdx[recentCount] = d;
               recentRanks[recentCount] = rk;
               recentCount++;
               if(hasPrev)
               {
                  comparablePairs++;
                  sumAbsChange += MathAbs(rk - prevRank);
               }
               prevRank = rk;
               hasPrev = true;
            }
            if(!persistHasData[s]) continue;
            double pctTop10 = (double)daysTop10 / daysWithData * 100.0;
            double avgRank = sumRanks / daysWithData;
            double meanAbsChange = (comparablePairs > 0) ? sumAbsChange / comparablePairs : 0.0;
            double rankVolatility = (numRankedStrats > 1) ? meanAbsChange / (double)(numRankedStrats - 1) * 100.0 : 0.0;
            if(rankVolatility > 100.0) rankVolatility = 100.0;
            double stabilityScore = 100.0 - rankVolatility;
            double avgRankScore = (numRankedStrats > 1) ? (double)(numRankedStrats - avgRank) / (double)(numRankedStrats - 1) * 100.0 : 100.0;
            if(avgRankScore < 0.0) avgRankScore = 0.0;
            if(avgRankScore > 100.0) avgRankScore = 100.0;
            double momentumScore = 50.0;
            if(recentCount >= 2)
            {
               int half = recentCount / 2;
               if(half < 1) half = 1;
               double recentSum = 0.0, prevSum = 0.0;
               int recentN = 0, prevN = 0;
               int splitPoint = recentCount - half;
               if(splitPoint < 1) splitPoint = 1;
               if(splitPoint >= recentCount) splitPoint = recentCount - 1;
               for(int r = 0; r < splitPoint; r++) { prevSum += recentRanks[r]; prevN++; }
               for(int r = splitPoint; r < recentCount; r++) { recentSum += recentRanks[r]; recentN++; }
               if(prevN > 0 && recentN > 0)
               {
                  double prevAvg = prevSum / prevN;
                  double recentAvg = recentSum / recentN;
                  if(prevAvg > 0.0)
                  {
                     double improvement = (prevAvg - recentAvg) / prevAvg;
                     momentumScore = 50.0 + improvement * 50.0;
                  }
               }
            }
            if(momentumScore < 0.0) momentumScore = 0.0;
            if(momentumScore > 100.0) momentumScore = 100.0;
            persistenceScore[s] = 0.40 * pctTop10 + 0.25 * avgRankScore + 0.20 * stabilityScore + 0.15 * momentumScore;
            persistTop10[s] = pctTop10;
            persistAvgRank[s] = avgRank;
            persistStability[s] = stabilityScore;
            persistMomentum[s] = momentumScore;
         }

         string bestPersistStratName = "";
         double bestPersistScore = -999.0;
         for(int s = 0; s < 500; s++)
         {
            if(persistHasData[s] && persistenceScore[s] > bestPersistScore)
            {
               bestPersistScore = persistenceScore[s];
               bestPersistStratName = StrategyName(s + 1);
            }
         }

         for(int i = 0; i < 499; i++)
      {
         for(int j = i + 1; j < 500; j++)
         {
            int a = sortOrder[i], b = sortOrder[j];
            double rateA = (aggStarts[a] > 0) ? (double)aggPassed[a] / (double)aggStarts[a] : 0.0;
            double rateB = (aggStarts[b] > 0) ? (double)aggPassed[b] / (double)aggStarts[b] : 0.0;
            double netA = (aggStarts[a] > 0) ? aggNetSum[a] / (double)aggStarts[a] : 0.0;
            double netB = (aggStarts[b] > 0) ? aggNetSum[b] / (double)aggStarts[b] : 0.0;
            double recA = (aggRecencyWeightSum[a] > 0.0) ? aggRecencyPassedWeight[a] / aggRecencyWeightSum[a] : 0.0;
            double recB = (aggRecencyWeightSum[b] > 0.0) ? aggRecencyPassedWeight[b] / aggRecencyWeightSum[b] : 0.0;
            bool swap = false;
            if(useRecency)
            {
               if(recB > recA + 0.0001) swap = true;
               else if(MathAbs(recB - recA) <= 0.0001)
               {
                  if(rateB > rateA + 0.0001) swap = true;
                  else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
               }
            }
            else
            {
               if(rateB > rateA + 0.0001) swap = true;
               else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
            }
            if(swap) { sortOrder[i] = b; sortOrder[j] = a; }
         }
      }

      int totalPassed = 0, totalBlown = 0, totalActive = 0;
      long grandTotalTrades = 0;
      long grandTotalSignals = 0;
      string bestStratName = "";
      double bestStratRate = -1.0;
      string bestRecentStratName = "";
      double bestRecentStratScore = -1.0;
      double bestRecentAllTimeRate = 0.0;
      for(int i = 0; i < 500; i++)
      {
         totalPassed += aggPassed[i];
         totalBlown += aggBlown[i];
         totalActive += aggActive[i];
         grandTotalTrades += aggTrades[i];
         grandTotalSignals += propSignalCounts[i];
         double rate = (aggStarts[i] > 0) ? (double)aggPassed[i] / (double)aggStarts[i] * 100.0 : 0.0;
         if(rate > bestStratRate) { bestStratRate = rate; bestStratName = StrategyName(i + 1); }
         if(useRecency)
         {
            double recScore = (aggRecencyWeightSum[i] > 0.0) ? aggRecencyPassedWeight[i] / aggRecencyWeightSum[i] * 100.0 : 0.0;
            if(recScore > bestRecentStratScore) { bestRecentStratScore = recScore; bestRecentStratName = StrategyName(i + 1); bestRecentAllTimeRate = rate; }
         }
      }
      double overallPassRate = (totalRuns > 0) ? (double)totalPassed / (double)totalRuns * 100.0 : 0.0;
      double completedPassRate = (totalPassed + totalBlown > 0) ? (double)totalPassed / (double)(totalPassed + totalBlown) * 100.0 : 0.0;
      datetime testEnd = TimeCurrent();
      if(g_testEndTime > 0) testEnd = g_testEndTime;

      string reportFileName = PropTimestampedReportFileName();
      int handle = FileOpen(reportFileName, FILE_WRITE | FILE_TXT | FILE_COMMON);
      if(handle == INVALID_HANDLE)
      {
         Print("Failed to export propfirm HTML report. error=", GetLastError());
         return;
      }

      PropWriteHtmlHead(handle);
      string rollingTitle = (PropStrategyMode == PROP_STRATEGY_CUSTOM) ? "Forward test" : "Propfirm Rolling Backtest Report";
      PropWriteHeader(handle, rollingTitle, testEnd);

      FileWriteString(handle, "<div class=\"section\">\n<h2>Run Report - Settings Used For This Run</h2>\n<div class=\"settings-grid\">\n");
      PropWriteCommonSettings(handle, testStart, testEnd);
