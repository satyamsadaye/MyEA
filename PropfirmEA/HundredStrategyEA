   SetLine(line++, "Direction     " + EnumToString(AllowedDirection) + "    OneTradePerBar " + PropBoolStr(OneTradePerBar));
   SetLine(line++, "Reverse       " + PropBoolStr(ReverseSignals), ReverseSignals ? WarnColor() : MutedColor());
