   string PropCsvEscape(const string s)
   {
      string result = "";
      for(int i = 0; i < StringLen(s); i++)
      {
         ushort ch = StringGetCharacter(s, i);
         if(ch == '|')
            result += "\\p";
         else if(ch == '\\')
            result += "\\\\";
         else if(ch == '\n')
            result += "\\n";
         else if(ch == '\r')
            result += "\\r";
         else
            result += ShortToString(ch);
      }
      return result;
   }

   string PropCsvUnescape(const string s)
   {
      string result = "";
      int len = StringLen(s);
      for(int i = 0; i < len; i++)
      {
         ushort ch = StringGetCharacter(s, i);
         if(ch == '\\' && i + 1 < len)
         {
            ushort next = StringGetCharacter(s, i + 1);
            if(next == 'p') { result += "|"; i++; }
            else if(next == '\\') { result += "\\"; i++; }
            else if(next == 'n') { result += "\n"; i++; }
            else if(next == 'r') { result += "\r"; i++; }
            else result += ShortToString(ch);
         }
         else
            result += ShortToString(ch);
      }
      return result;
   }

