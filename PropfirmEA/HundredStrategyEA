   void ManageVirtualDollarExits()
   {
      if(!EnableVirtualDollarExit)
         return;

      for(int i = PositionsTotal() - 1; i >= 0; i--)
      {
         ulong ticket = PositionGetTicket(i);
         if(ticket == 0 || !PositionSelectByTicket(ticket))
            continue;
         if(PositionGetString(POSITION_SYMBOL) != _Symbol || PositionGetInteger(POSITION_MAGIC) != (long)MagicNumber)
            continue;

         double positionProfit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
         bool takeProfitHit = VirtualTakeProfitMoney > 0.0 && positionProfit >= VirtualTakeProfitMoney;
         bool stopLossHit = VirtualStopLossMoney > 0.0 && positionProfit <= -VirtualStopLossMoney;
         if(!takeProfitHit && !stopLossHit)
            continue;

         string reason = takeProfitHit ? "virtual dollar take profit hit" : "virtual dollar stop loss hit";
         bool ok = trade.PositionClose(ticket);
         LogEvent(ok ? "VIRTUAL_EXIT_CLOSED" : "VIRTUAL_EXIT_CLOSE_FAILED",
                  StringFormat("ticket=%I64u,profit=%.2f,reason=%s,retcode=%d", ticket, positionProfit, reason, trade.ResultRetcode()));
      }
   }

   bool CheckProtectionStops()
   {
      if(!EnableProtectionStops)
         return false;

      double balance = AccountInfoDouble(ACCOUNT_BALANCE);
      double equity = AccountInfoDouble(ACCOUNT_EQUITY);
      double floating = EaFloatingProfit();
      double pnlFromReference = (balance - CustomStartingBalance) + floating;
      double drawdown = MathMax(0.0, CustomStartingBalance - equity);

      if(StopProfitMoney > 0.0 && pnlFromReference >= StopProfitMoney)
         return StopEa("Profit money target hit");
      if(StopLossMoney > 0.0 && pnlFromReference <= -StopLossMoney)
         return StopEa("Loss money limit hit");
      if(StopDrawdownMoney > 0.0 && drawdown >= StopDrawdownMoney)
         return StopEa("Drawdown money limit hit");
      if(StopProfitPercentOfStart > 0.0 && pnlFromReference >= CustomStartingBalance * StopProfitPercentOfStart / 100.0)
         return StopEa("Profit percent target hit");
      if(StopLossPercentOfStart > 0.0 && pnlFromReference <= -CustomStartingBalance * StopLossPercentOfStart / 100.0)
         return StopEa("Loss percent limit hit");
      if(StopDrawdownPercentOfStart > 0.0 && drawdown >= CustomStartingBalance * StopDrawdownPercentOfStart / 100.0)
         return StopEa("Drawdown percent limit hit");

      return false;
   }

