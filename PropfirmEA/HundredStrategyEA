      double mom2 = IndicatorValue(iMomentum(_Symbol, _Period, momPeriod, PRICE_CLOSE), 2);
      double close1 = iClose(_Symbol, _Period, 1);
      if(close1 > ma && mom2 <= 100.0 && mom1 > 100.0) return 1;
      if(close1 < ma && mom2 >= 100.0 && mom1 < 100.0) return -1;
