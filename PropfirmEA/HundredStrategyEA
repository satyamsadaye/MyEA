   int StochAdxSignal(const int k, const int d, const int slowing, const int adxPeriod)
   {
      int stochHandle = iStochastic(_Symbol, _Period, k, d, slowing, MODE_SMA, STO_LOWHIGH);
      double k1 = BufferValue(stochHandle, 0, 1);
      double d1 = BufferValue(stochHandle, 1, 1);
      double k2 = BufferValue(stochHandle, 0, 2);
      double d2 = BufferValue(stochHandle, 1, 2);
      int adxHandle = iADX(_Symbol, _Period, adxPeriod);
      double adx = BufferValue(adxHandle, 0, 1);
      if(adx > 20.0 && k2 <= d2 && k1 > d1 && k1 < 30.0) return 1;
      if(adx > 20.0 && k2 >= d2 && k1 < d1 && k1 > 70.0) return -1;
      return 0;
   }

   int AtrBreakoutSignal(const int period, const double multiplier)
   {
      double atr = IndicatorValue(iATR(_Symbol, _Period, period), 1);
      double close1 = iClose(_Symbol, _Period, 1);
      double close2 = iClose(_Symbol, _Period, 2);
      double open1 = iOpen(_Symbol, _Period, 1);
      if(close2 < open1 && close1 > open1 + multiplier * atr) return 1;
      if(close2 > open1 && close1 < open1 - multiplier * atr) return -1;
      return 0;
   }

   int TrendMomentumSignal(const int maPeriod, const int momPeriod)
   {
