   }

   FileWriteString(handle, "</tbody>\n</table>\n</div>\n</div>\n");
   PropWriteFooter(handle, "results");
   FileWriteString(handle, "</div>\n</body>\n</html>\n");
   FileClose(handle);
   Print("Propfirm HTML report exported to Common Files: ", reportFileName);
}

void ExportPropfirmRollingReport()
{
   int totalRuns = ArraySize(propRuns);
    int aggStarts[100], aggPassed[100], aggBlown[100], aggActive[100];
    int aggWins[100], aggLosses[100], aggTrades[100], aggDaysToTarget[100];
    double aggNetSum[100], aggBestNet[100], aggWorstNet[100], aggWinRateSum[100];
    double aggGrossProfit[100], aggGrossLoss[100];
    double aggDuration[100];
    int aggWinRateCount[100];
    double aggRecencyWeightSum[100], aggRecencyPassedWeight[100];
    datetime testStart = 0;

   ArrayInitialize(aggStarts, 0);
   ArrayInitialize(aggPassed, 0);
   ArrayInitialize(aggBlown, 0);
   ArrayInitialize(aggActive, 0);
   ArrayInitialize(aggWins, 0);
   ArrayInitialize(aggLosses, 0);
   ArrayInitialize(aggTrades, 0);
   ArrayInitialize(aggDaysToTarget, 0);
   ArrayInitialize(aggWinRateSum, 0.0);
   ArrayInitialize(aggWinRateCount, 0);
   ArrayInitialize(aggNetSum, 0.0);
   ArrayInitialize(aggBestNet, -DBL_MAX);
   ArrayInitialize(aggWorstNet, DBL_MAX);
    ArrayInitialize(aggGrossProfit, 0.0);
    ArrayInitialize(aggGrossLoss, 0.0);
    ArrayInitialize(aggDuration, 0.0);
    ArrayInitialize(aggRecencyWeightSum, 0.0);
    ArrayInitialize(aggRecencyPassedWeight, 0.0);

   datetime testEndTime = TimeCurrent();

   for(int i = 0; i < totalRuns; i++)
   {
      int sid = propRuns[i].strategyId - 1;
      if(sid < 0 || sid >= 100) continue;

      aggStarts[sid]++;
      if(propRuns[i].passed) aggPassed[sid]++;
      else if(propRuns[i].breached) aggBlown[sid]++;
      else aggActive[sid]++;

      aggWins[sid] += propRuns[i].wins;
      aggLosses[sid] += propRuns[i].losses;
      aggTrades[sid] += propRuns[i].trades;
      aggGrossProfit[sid] += propRuns[i].grossProfit;
      aggGrossLoss[sid] += propRuns[i].grossLoss;

      datetime runEnd = (propRuns[i].ended > 0) ? propRuns[i].ended : testEndTime;
      double runDays = (double)(runEnd - propRuns[i].startDay) / 86400.0 + 1.0;
      if(runDays < 1.0) runDays = 1.0;
      aggDuration[sid] += runDays;

      int closedTrades = propRuns[i].wins + propRuns[i].losses;
      if(closedTrades > 0)
      {
         aggWinRateSum[sid] += (double)propRuns[i].wins / (double)closedTrades * 100.0;
         aggWinRateCount[sid]++;
      }

      double net = propRuns[i].balance - propRuns[i].startingBalance;
      aggNetSum[sid] += net;
      if(net > aggBestNet[sid]) aggBestNet[sid] = net;
      if(net < aggWorstNet[sid]) aggWorstNet[sid] = net;

      if(propRuns[i].passed && propRuns[i].daysToTarget > 0)
         aggDaysToTarget[sid] += propRuns[i].daysToTarget;

       if(testStart == 0 || propRuns[i].startDay < testStart)
          testStart = propRuns[i].startDay;

       if(PropRecencyHalfLifeDays > 0.0)
       {
          double lambda = MathLog(2.0) / PropRecencyHalfLifeDays;
          double ageInDays = (double)(testEndTime - propRuns[i].startDay) / 86400.0;
          double weight = MathExp(-lambda * ageInDays);
          aggRecencyWeightSum[sid] += weight;
          if(propRuns[i].passed)
             aggRecencyPassedWeight[sid] += weight;
       }
    }

    int sortOrder[100];
    for(int i = 0; i < 100; i++) sortOrder[i] = i;
    bool useRecency = (PropRecencyHalfLifeDays > 0.0);
    double testSpanDays = (testStart > 0) ? (double)(testEndTime - testStart) / 86400.0 : 0.0;
    bool recencyIneffective = useRecency && testSpanDays > 0.0 && PropRecencyHalfLifeDays > testSpanDays * 3.0;

    int recentDays = (int)MathCeil(0.30 * testSpanDays);
    if(recentDays < 1) recentDays = 1;
    if(recentDays > 14) recentDays = 14;
    datetime windowStart = testEndTime - (datetime)(recentDays * 86400);

    datetime dayList[];
    ArrayResize(dayList, 0);
    for(int i = 0; i < totalRuns; i++)
    {
       if(propRuns[i].startDay < windowStart)
          continue;
       long raw = (long)propRuns[i].startDay;
       datetime bucket = (datetime)(raw - (raw % 86400));
       bool found = false;
       for(int d = 0; d < ArraySize(dayList); d++)
       {
          if(dayList[d] == bucket) { found = true; break; }
       }
       if(!found)
       {
          int sz = ArraySize(dayList);
          ArrayResize(dayList, sz + 1);
          dayList[sz] = bucket;
       }
    }
    int dayCount = ArraySize(dayList);
    for(int d = 0; d < dayCount - 1; d++)
    {
       for(int e = d + 1; e < dayCount; e++)
       {
          if(dayList[e] < dayList[d])
          {
             datetime tmp = dayList[d];
             dayList[d] = dayList[e];
             dayList[e] = tmp;
          }
       }
    }

    int histPass[100][14];
    int histBlow[100][14];
    int histNet[100];
    ArrayInitialize(histNet, 0);
    for(int s = 0; s < 100; s++)
    {
       for(int d = 0; d < 14; d++)
       {
          histPass[s][d] = 0;
          histBlow[s][d] = 0;
       }
    }
    int histMaxPass = 1, histMaxBlow = 1;
    for(int i = 0; i < totalRuns; i++)
    {
       if(propRuns[i].startDay < windowStart)
          continue;
       int sid = propRuns[i].strategyId - 1;
       if(sid < 0 || sid >= 100) continue;
       long raw = (long)propRuns[i].startDay;
       datetime bucket = (datetime)(raw - (raw % 86400));
       int dayIdx = -1;
       for(int d = 0; d < dayCount; d++)
       {
          if(dayList[d] == bucket) { dayIdx = d; break; }
       }
       if(dayIdx < 0 || dayIdx >= 14) continue;
       if(propRuns[i].passed)
       {
          histPass[sid][dayIdx]++;
          histNet[sid]++;
          if(histPass[sid][dayIdx] > histMaxPass) histMaxPass = histPass[sid][dayIdx];
       }
       else if(propRuns[i].breached)
       {
          histBlow[sid][dayIdx]++;
          histNet[sid]--;
          if(histBlow[sid][dayIdx] > histMaxBlow) histMaxBlow = histBlow[sid][dayIdx];
       }
    }

    for(int i = 0; i < 99; i++)
    {
       for(int j = i + 1; j < 100; j++)
       {
          int a = sortOrder[i], b = sortOrder[j];
          double rateA = (aggStarts[a] > 0) ? (double)aggPassed[a] / (double)aggStarts[a] : 0.0;
          double rateB = (aggStarts[b] > 0) ? (double)aggPassed[b] / (double)aggStarts[b] : 0.0;
          double netA = (aggStarts[a] > 0) ? aggNetSum[a] / (double)aggStarts[a] : 0.0;
          double netB = (aggStarts[b] > 0) ? aggNetSum[b] / (double)aggStarts[b] : 0.0;
          double recA = (aggRecencyWeightSum[a] > 0.0) ? aggRecencyPassedWeight[a] / aggRecencyWeightSum[a] : 0.0;
          double recB = (aggRecencyWeightSum[b] > 0.0) ? aggRecencyPassedWeight[b] / aggRecencyWeightSum[b] : 0.0;
          bool swap = false;
          if(useRecency)
          {
             if(recB > recA + 0.0001) swap = true;
             else if(MathAbs(recB - recA) <= 0.0001)
             {
                if(rateB > rateA + 0.0001) swap = true;
                else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
             }
          }
          else
          {
             if(rateB > rateA + 0.0001) swap = true;
             else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
          }
          if(swap) { sortOrder[i] = b; sortOrder[j] = a; }
       }
    }

    int totalPassed = 0, totalBlown = 0, totalActive = 0;
    long grandTotalTrades = 0;
    long grandTotalSignals = 0;
    string bestStratName = "";
    double bestStratRate = -1.0;
    string bestRecentStratName = "";
    double bestRecentStratScore = -1.0;
    double bestRecentAllTimeRate = 0.0;
    for(int i = 0; i < 100; i++)
    {
       totalPassed += aggPassed[i];
       totalBlown += aggBlown[i];
       totalActive += aggActive[i];
       grandTotalTrades += aggTrades[i];
       grandTotalSignals += propSignalCounts[i];
       double rate = (aggStarts[i] > 0) ? (double)aggPassed[i] / (double)aggStarts[i] * 100.0 : 0.0;
       if(rate > bestStratRate) { bestStratRate = rate; bestStratName = StrategyName(i + 1); }
       if(useRecency)
       {
          double recScore = (aggRecencyWeightSum[i] > 0.0) ? aggRecencyPassedWeight[i] / aggRecencyWeightSum[i] * 100.0 : 0.0;
          if(recScore > bestRecentStratScore) { bestRecentStratScore = recScore; bestRecentStratName = StrategyName(i + 1); bestRecentAllTimeRate = rate; }
       }
    }
   double overallPassRate = (totalRuns > 0) ? (double)totalPassed / (double)totalRuns * 100.0 : 0.0;
   datetime testEnd = TimeCurrent();

   string reportFileName = PropTimestampedReportFileName();
   int handle = FileOpen(reportFileName, FILE_WRITE | FILE_TXT | FILE_COMMON);
   if(handle == INVALID_HANDLE)
   {
      Print("Failed to export propfirm HTML report. error=", GetLastError());
      return;
   }

   PropWriteHtmlHead(handle);
   PropWriteHeader(handle, "Propfirm Rolling Backtest Report", testEnd);

   FileWriteString(handle, "<div class=\"section\">\n<h2>Run Report - Settings Used For This Run</h2>\n<div class=\"settings-grid\">\n");
   PropWriteCommonSettings(handle, testStart, testEnd);
   FileWriteString(handle, PropKv("Rolling Start Mode", PropBoolStr(true)));
   FileWriteString(handle, PropKv("Max Spawn Batches", IntegerToString(PropMaxStartDays) + " (0=unlimited)"));
   FileWriteString(handle, PropKv("Total Strategies", IntegerToString(PROP_STRATEGY_COUNT)));
   FileWriteString(handle, PropKv("Total Runs Simulated", IntegerToString(totalRuns)));
    FileWriteString(handle, "</div>\n<div class=\"note\">Each strategy is re-started fresh " + PropSpawnIntervalLabel() + " during the active window (pause/close hours skipped). A strategy can have multiple runs active simultaneously. Best strategy: <b>" + bestStratName + "</b> (" + DoubleToString(bestStratRate, 1) + "% pass rate)" + (recencyIneffective ? "<br><b style=\"color:#dc2626\">&#9888; Recency warning:</b> Half-life (" + DoubleToString(PropRecencyHalfLifeDays, 1) + "d) is much longer than test span (" + DoubleToString(testSpanDays, 1) + "d). All runs get near-equal weight, so recency score &asymp; raw pass rate. For meaningful recency differentiation, use a half-life &le; " + DoubleToString(testSpanDays, 1) + "d or run a longer backtest." : "") + "</div>\n</div>\n");

    FileWriteString(handle,
       "<div class=\"section\">\n<h2>Summary Dashboard</h2>\n<div class=\"cards\">\n" +
       "<div class=\"card pass\"><div class=\"label\">Passed Runs</div><div class=\"value\">" + IntegerToString(totalPassed) + "</div><div class=\"sub\">target hit</div></div>\n" +
       "<div class=\"card blow\"><div class=\"label\">Blown Runs</div><div class=\"value\">" + IntegerToString(totalBlown) + "</div><div class=\"sub\">rule breach</div></div>\n" +
       "<div class=\"card act\"><div class=\"label\">Active Runs</div><div class=\"value\">" + IntegerToString(totalActive) + "</div><div class=\"sub\">still running at end</div></div>\n" +
       "<div class=\"card rate\"><div class=\"label\">Overall Pass Rate</div><div class=\"value\">" + DoubleToString(overallPassRate, 1) + "%</div><div class=\"sub\">passed / total runs</div></div>\n" +
       "<div class=\"card avg\"><div class=\"label\">Total Trades</div><div class=\"value\">" + IntegerToString(grandTotalTrades) + "</div><div class=\"sub\">virtual positions</div></div>\n" +
       "<div class=\"card sig\"><div class=\"label\">Total Signals</div><div class=\"value\">" + IntegerToString(grandTotalSignals) + "</div><div class=\"sub\">strategy triggers</div></div>\n" +
       "<div class=\"card tot\"><div class=\"label\">Total Runs</div><div class=\"value\">" + IntegerToString(totalRuns) + "</div><div class=\"sub\">strategy x start-days</div></div>\n" +
       (useRecency ?
          "<div class=\"card rec\"><div class=\"label\">Top Strategy (Recent)</div><div class=\"value\" style=\"font-size:13px;line-height:1.3\">" + bestRecentStratName + "</div><div class=\"sub\">Recency: " + DoubleToString(bestRecentStratScore, 1) + "% &nbsp;|&nbsp; All-time: " + DoubleToString(bestRecentAllTimeRate, 1) + "%</div></div>\n" :
          "") +
       "</div>\n</div>\n");

    FileWriteString(handle,
       "<div class=\"section\">\n<h2>Strategy Ranking (" + (useRecency ? "by recency score" : "by pass rate across start-days") + ")</h2>\n" +
       PropToolbarHtml("strat") +
       "<div class=\"table-scroll\">\n<table id=\"strat\">\n<thead><tr>\n" +
       "<th data-type=\"num\">Rank</th>\n<th data-type=\"str\">Strategy</th>\n<th data-type=\"num\">Starts</th>\n" +
       "<th data-type=\"num\">Passed</th>\n<th data-type=\"num\">Blown</th>\n<th data-type=\"num\">Active</th>\n" +
        (useRecency ? "<th data-type=\"num\">Recency Score</th>\n" : "") +
        "<th data-type=\"num\">All-Time Pass Rate</th>\n<th data-type=\"num\">Avg Win Rate</th>\n" +
        "<th data-type=\"num\">Recent Trend<br><span style=\"font-weight:400;font-size:10px\">latest " + IntegerToString(recentDays) + "d (30%) &middot; green&#8593;pass red&#8595;blow</span></th>\n" +
        "<th data-type=\"num\">PF</th>\n<th data-type=\"num\">Avg R:R</th>\n" +
        "<th data-type=\"num\">Avg Net P/L</th>\n<th data-type=\"num\">Best Net</th>\n<th data-type=\"num\">Worst Net</th>\n" +
         "<th data-type=\"num\">Total Trades</th>\n<th data-type=\"num\">Avg Trades/Day</th>\n<th data-type=\"num\">Total Signals</th>\n<th data-type=\"num\">Avg Sig/Day</th>\n<th data-type=\"num\">Wins</th>\n<th data-type=\"num\">Losses</th>\n" +
        "<th data-type=\"num\">Avg Days->Target</th>\n</tr></thead>\n<tbody>\n");

   for(int rank = 0; rank < 100; rank++)
   {
      int sid = sortOrder[rank];
      double passRate = (aggStarts[sid] > 0) ? (double)aggPassed[sid] / (double)aggStarts[sid] * 100.0 : 0.0;
      double recencyScore = (aggRecencyWeightSum[sid] > 0.0) ? aggRecencyPassedWeight[sid] / aggRecencyWeightSum[sid] * 100.0 : 0.0;
      double avgWinRate = (aggWinRateCount[sid] > 0) ? aggWinRateSum[sid] / (double)aggWinRateCount[sid] : 0.0;
      double avgNet = (aggStarts[sid] > 0) ? aggNetSum[sid] / (double)aggStarts[sid] : 0.0;
      double avgDays = (aggPassed[sid] > 0) ? (double)aggDaysToTarget[sid] / (double)aggPassed[sid] : 0.0;
      double profitFactor = (aggGrossLoss[sid] < 0.0) ? aggGrossProfit[sid] / MathAbs(aggGrossLoss[sid]) : 0.0;
      double avgWin = (aggWins[sid] > 0) ? aggGrossProfit[sid] / (double)aggWins[sid] : 0.0;
      double avgLoss = (aggLosses[sid] > 0) ? MathAbs(aggGrossLoss[sid]) / (double)aggLosses[sid] : 0.0;
      double realizedRR = (avgLoss > 0.0) ? avgWin / avgLoss : 0.0;
      string netClass = (avgNet > 0.0) ? "pos" : ((avgNet < 0.0) ? "neg" : "zero");
      string bestClass = (aggBestNet[sid] > 0.0) ? "pos" : "zero";
      string worstClass = (aggWorstNet[sid] < 0.0) ? "neg" : "zero";
       string pfClass = (profitFactor >= 1.0) ? "pos" : "neg";
       string histCell = "<td class=\"hist\" data-sort=\"" + IntegerToString(histNet[sid]) + "\">";
       if(dayCount == 0)
          histCell += "<span class=\"zero\">n/a</span>";
       else
       {
          histCell += "<div class=\"hist\">";
          for(int hd = 0; hd < dayCount; hd++)
          {
             int hp = histPass[sid][hd];
             int hb = histBlow[sid][hd];
             int upH = (int)MathRound((double)hp / (double)histMaxPass * 20.0);
             int dnH = (int)MathRound((double)hb / (double)histMaxBlow * 20.0);
             MqlDateTime hdt;
             TimeToStruct(dayList[hd], hdt);
             string dayLabel = StringFormat("%02d-%02d", hdt.mon, hdt.day);
             histCell += StringFormat("<div class=\"dcell\" title=\"%s: %d pass / %d blow\"><div class=\"bar-up\" style=\"height:%dpx\"></div><div class=\"bar-down\" style=\"height:%dpx\"></div></div>", dayLabel, hp, hb, upH, dnH);
          }
          histCell += "</div>";
       }
       histCell += "</td>";

      string row = "";
      row += StringFormat("<tr><td class=\"num\">%d</td>", rank + 1);
      row += StringFormat("<td>%s</td>", StrategyName(sid + 1));
      row += StringFormat("<td class=\"num\">%d</td>", aggStarts[sid]);
      row += StringFormat("<td class=\"num pos\">%d</td>", aggPassed[sid]);
      row += StringFormat("<td class=\"num neg\">%d</td>", aggBlown[sid]);
      row += StringFormat("<td class=\"num\">%d</td>", aggActive[sid]);
       if(useRecency)
       {
          if(aggRecencyWeightSum[sid] > 0.0)
             row += StringFormat("<td data-sort=\"%.4f\"><div class=\"barwrap\"><div class=\"barfill b%d\"></div></div>%.1f%%</td>", recencyScore, (int)MathRound(recencyScore), recencyScore);
          else
             row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
       }
       if(aggStarts[sid] > 0)
          row += StringFormat("<td data-sort=\"%.4f\"><div class=\"barwrap\"><div class=\"barfill b%d\"></div></div>%.1f%%</td>", passRate, (int)MathRound(passRate), passRate);
       else
          row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
       if(aggWinRateCount[sid] > 0)
          row += StringFormat("<td data-sort=\"%.4f\"><div class=\"barwrap\"><div class=\"barfill b%d\"></div></div>%.1f%%</td>", avgWinRate, (int)MathRound(avgWinRate), avgWinRate);
       else
          row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
       row += histCell;
      if(aggGrossLoss[sid] < 0.0)
         row += StringFormat("<td class=\"num %s\">%.2f</td>", pfClass, profitFactor);
      else
         row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
      if(realizedRR > 0.0)
         row += StringFormat("<td class=\"num\">%.2f</td>", realizedRR);
      else
         row += "<td class=\"num zero\">n/a</td>";
      row += StringFormat("<td class=\"num %s\">%.2f</td>", netClass, avgNet);
      row += StringFormat("<td class=\"num %s\">%.2f</td>", bestClass, aggBestNet[sid]);
      row += StringFormat("<td class=\"num %s\">%.2f</td>", worstClass, aggWorstNet[sid]);
      row += StringFormat("<td class=\"num\">%d</td>", aggTrades[sid]);
       double avgTradesPerDay = (aggDuration[sid] > 0.0) ? (double)aggTrades[sid] / aggDuration[sid] : 0.0;
       row += StringFormat("<td class=\"num\">%.1f</td>", avgTradesPerDay);
       double avgSigDay = (testSpanDays > 0.0) ? (double)propSignalCounts[sid] / testSpanDays : 0.0;
       row += StringFormat("<td class=\"num\">%d</td>", propSignalCounts[sid]);
       row += StringFormat("<td class=\"num\">%.1f</td>", avgSigDay);
       row += StringFormat("<td class=\"num pos\">%d</td>", aggWins[sid]);
      row += StringFormat("<td class=\"num neg\">%d</td>", aggLosses[sid]);
      row += StringFormat("<td class=\"num\">%.1f</td>", avgDays);
      row += "</tr>\n";
      FileWriteString(handle, row);
   }
   FileWriteString(handle, "</tbody>\n</table>\n</div>\n</div>\n");

    FileWriteString(handle,
       "<div class=\"section\">\n<h2>Per-Run Detail (all strategy x start-day runs)</h2>\n" +
       "<div class=\"collapse-header\" id=\"runs_collapse_h\" onclick=\"var b=document.getElementById('runs_body');var h=document.getElementById('runs_collapse_h');if(b.style.display==='none'){b.style.display='block';h.classList.add('open');}else{b.style.display='none';h.classList.remove('open');}\">" +
       "<span class=\"collapse-arrow\">&#9654;</span> Click to expand per-run detail (" + IntegerToString(totalRuns) + " runs)</div>\n" +
       "<div id=\"runs_body\" style=\"display:none\">\n" +
       PropToolbarHtml("runs") +
       "<div class=\"table-scroll\">\n<table id=\"runs\">\n<thead><tr>\n" +
       "<th data-type=\"num\">#</th>\n<th data-type=\"str\">Strategy</th>\n<th data-type=\"str\">Start Day</th>\n" +
