   // ── Receiver EA Status Reader ───────────────────────────────────────────────
   bool ReadReceiverStatusForReceiverEA()
   {
      if(!EnableReceiverConnection)
      {
         g_receiverTradingAllowed = true;
         g_receiverBlockReason = "";
         return true;
      }

      uint now = GetTickCount();
      if(now - g_lastReceiverTickCheck < (uint)ReceiverPollIntervalMs)
         return g_receiverTradingAllowed;

      g_lastReceiverTickCheck = now;

      string key = ReceiverCopierKey;
      StringTrimLeft(key);
      StringTrimRight(key);
      if(StringLen(key) == 0)
         key = "default";

      string status_file = "propfirm_receiver_status_" + key + ".csv";

      int handle = FileOpen(status_file, FILE_READ|FILE_CSV|FILE_COMMON|FILE_SHARE_READ|FILE_SHARE_WRITE, ';');
      if(handle == INVALID_HANDLE)
      {
         g_receiverBlockReason = "Status file not found: " + status_file;
         return g_receiverTradingAllowed;
      }

      string version = FileReadString(handle);
      if(version != "PROP_RECEIVER_STATUS_V6")
      {
         FileClose(handle);
         g_receiverBlockReason = "File version mismatch: " + version;
         return g_receiverTradingAllowed;
      }

      // Skip 25 fields after version (fields 1-25)
      for(int skip = 0; skip < 25; skip++)
         FileReadString(handle);

      bool trading_allowed = (StringToInteger(FileReadString(handle)) != 0);
      bool protection_breached = (StringToInteger(FileReadString(handle)) != 0);

      g_receiverHitTime = FileReadString(handle);       // hit_time (28)
      FileReadString(handle);                            // hit_receiver (29)
      FileReadString(handle);                            // hit_source  (30)
      g_receiverBlockReason = FileReadString(handle);

      FileClose(handle);

      g_receiverTradingCSV = trading_allowed;
      g_receiverTradingAllowed = trading_allowed && !protection_breached;

      return g_receiverTradingAllowed;
   }

