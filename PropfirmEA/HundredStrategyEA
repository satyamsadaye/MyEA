void RunPropfirmRollingTick()
{
   datetime now = TimeCurrent();

   while(now >= propCurrentDayReset + 86400)
   {
      propCurrentDayReset += 86400;
      PropRollingResetDaily();
   }

   if(PropIsCloseTime(now))
      PropRollingCloseAll();

   datetime currentBar = iTime(_Symbol, _Period, 0);
   bool newBar = (currentBar != propSignalCacheBar);
   if(newBar)
      propSignalCacheBar = currentBar;

   PropRollingUpdatePositions();

    if(newBar && !PropSignalsPaused(now))
    {
       for(int id = 1; id <= PROP_STRATEGY_COUNT; id++)
       {
          StrategySignal signal;
          signal.buyVotes = 0;
          signal.sellVotes = 0;
          signal.details = "";
          EvaluateStrategy(id, signal);
          if(signal.buyVotes > 0)
             propSignalCache[id - 1] = ORDER_TYPE_BUY;
          else if(signal.sellVotes > 0)
             propSignalCache[id - 1] = ORDER_TYPE_SELL;
          else
             propSignalCache[id - 1] = 0;
          if(propSignalCache[id - 1] != 0)
             propSignalCounts[id - 1]++;
       }
    }

   PropRollingCheckRules();

   if(PropRollingShouldSpawn(now))
      PropRollingSpawnRuns(now);

   if(PropSignalsPaused(now))
      return;

   if(OneTradePerBar && !newBar)
      return;

   for(int i = 0; i < ArraySize(propRuns); i++)
   {
      if(propRuns[i].breached || propRuns[i].passed || propRuns[i].pos.open)
         continue;
      if(propRuns[i].protectionTriggeredToday)
         continue;

      int dir = propSignalCache[propRuns[i].strategyId - 1];
      if(dir == 0)
         continue;
      if(ReverseSignals)
         dir = (dir == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
      if((AllowedDirection == SIGNAL_BUY_ONLY && dir == ORDER_TYPE_SELL) ||
         (AllowedDirection == SIGNAL_SELL_ONLY && dir == ORDER_TYPE_BUY))
         continue;

      PropRollingOpenPosition(i, dir, now);
   }
}

bool PropRollingShouldSpawn(const datetime now)
{
   if(PropSignalsPaused(now))
      return false;

   MqlDateTime dt;
   TimeToStruct(now, dt);
   dt.hour = PropResumeSignalsHourUTC;
   dt.min = PropResumeSignalsMinuteUTC;
   dt.sec = 0;
   datetime resumeToday = StructToTime(dt);

   if(now < resumeToday)
      return false;

   if(propLastResumeSpawn >= resumeToday)
   {
      int intervalHours = (int)PropSpawnInterval;
      if(intervalHours <= 0)
         return false;
      long intervalSeconds = (long)intervalHours * 3600;
      if((long)(now - propLastResumeSpawn) < intervalSeconds)
         return false;
   }

   if(PropMaxStartDays > 0)
   {
      int totalBatches = ArraySize(propRuns) / PROP_STRATEGY_COUNT;
      if(totalBatches >= PropMaxStartDays)
         return false;
   }

   return true;
}

void PropRollingSpawnRuns(const datetime now)
{
   int oldSize = ArraySize(propRuns);
   ArrayResize(propRuns, oldSize + PROP_STRATEGY_COUNT);
   datetime dayReset = PropCurrentResetTime(now);

   for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
   {
      int idx = oldSize + i;
      propRuns[idx].strategyId = i + 1;
      propRuns[idx].strategyName = StrategyName(i + 1);
      propRuns[idx].startDay = now;
      propRuns[idx].ended = 0;
      propRuns[idx].breached = false;
      propRuns[idx].passed = false;
      propRuns[idx].protectionTriggeredToday = false;
      propRuns[idx].breachReason = "";
      propRuns[idx].dayReset = dayReset;
      propRuns[idx].lastTradeBar = 0;
      propRuns[idx].balance = PropStartingBalance;
      propRuns[idx].equity = PropStartingBalance;
      propRuns[idx].dayStartReference = PropStartingBalance;
      propRuns[idx].startingBalance = PropStartingBalance;
      propRuns[idx].maxDrawdown = 0.0;
      propRuns[idx].maxProfit = 0.0;
      propRuns[idx].grossProfit = 0.0;
      propRuns[idx].grossLoss = 0.0;
      propRuns[idx].daysToTarget = 0;
      propRuns[idx].daysToBreach = 0;
      propRuns[idx].equityProtectionTriggers = 0;
      propRuns[idx].trades = 0;
      propRuns[idx].wins = 0;
      propRuns[idx].losses = 0;
      propRuns[idx].breakevenTrades = 0;
      propRuns[idx].pos.open = false;
   }

   propLastResumeSpawn = now;
   LogEvent("PROP_SPAWN", "Spawned " + IntegerToString(PROP_STRATEGY_COUNT) + " runs at " + TimeToString(now, TIME_DATE | TIME_MINUTES) + ". Total runs: " + IntegerToString(ArraySize(propRuns)));
}

void PropRollingOpenPosition(const int index, const int type, const datetime now)
{
   propRuns[index].pos.open = true;
   propRuns[index].pos.type = type;
   propRuns[index].pos.entry = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   propRuns[index].pos.lot = VirtualExitLot;
   propRuns[index].pos.openTime = now;
   propRuns[index].trades++;
}

double PropRollingPositionProfit(const int index)
{
   if(!propRuns[index].pos.open)
      return 0.0;
   int type = propRuns[index].pos.type;
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_BID) : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double diff = (type == ORDER_TYPE_BUY) ? price - propRuns[index].pos.entry : propRuns[index].pos.entry - price;
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickValue <= 0.0 || tickSize <= 0.0)
      return 0.0;
   return diff / tickSize * tickValue * propRuns[index].pos.lot;
}

void PropRollingCloseVirtualPosition(const int index)
{
   if(!propRuns[index].pos.open)
      return;
   double profit = PropRollingPositionProfit(index);
   propRuns[index].balance += profit;
   propRuns[index].equity = propRuns[index].balance;
   if(profit > 0.0)
   {
      propRuns[index].wins++;
      propRuns[index].grossProfit += profit;
   }
   else if(profit < 0.0)
   {
      propRuns[index].losses++;
      propRuns[index].grossLoss += profit;
   }
   else
      propRuns[index].breakevenTrades++;
   propRuns[index].pos.open = false;
}

void PropRollingCloseAll()
{
   for(int i = 0; i < ArraySize(propRuns); i++)
      PropRollingCloseVirtualPosition(i);
}

void PropRollingUpdatePositions()
{
   for(int i = 0; i < ArraySize(propRuns); i++)
   {
      if(propRuns[i].breached || propRuns[i].passed)
         continue;

      if(propRuns[i].pos.open)
      {
         double profit = PropRollingPositionProfit(i);
         if(VirtualTakeProfitMoney > 0.0 && profit >= VirtualTakeProfitMoney)
            PropRollingCloseVirtualPosition(i);
         else if(VirtualStopLossMoney > 0.0 && profit <= -VirtualStopLossMoney)
            PropRollingCloseVirtualPosition(i);
      }

      propRuns[i].equity = propRuns[i].balance + (propRuns[i].pos.open ? PropRollingPositionProfit(i) : 0.0);
      propRuns[i].maxDrawdown = MathMax(propRuns[i].maxDrawdown, propRuns[i].startingBalance - propRuns[i].equity);
      propRuns[i].maxProfit = MathMax(propRuns[i].maxProfit, propRuns[i].equity - propRuns[i].startingBalance);
   }
}

void PropRollingCheckRules()
{
   datetime now = TimeCurrent();
   for(int i = 0; i < ArraySize(propRuns); i++)
   {
      if(propRuns[i].breached || propRuns[i].passed)
         continue;

      double totalDrawdown = propRuns[i].startingBalance - propRuns[i].equity;
      double dailyDrawdown = propRuns[i].dayStartReference - propRuns[i].equity;
      double targetMoney = propRuns[i].startingBalance * PropProfitTargetPercent / 100.0;
      double maxDrawdownMoney = propRuns[i].startingBalance * PropMaxTotalDrawdownPercent / 100.0;
      double protectedDailyPercent = MathMax(0.0, PropDailyDrawdownPercent - PropDailyProtectionBufferPercent);
      double dailyProtectionMoney = propRuns[i].dayStartReference * protectedDailyPercent / 100.0;
      double dailyBreachMoney = propRuns[i].dayStartReference * PropDailyDrawdownPercent / 100.0;

      if(dailyProtectionMoney > 0.0 && dailyDrawdown >= dailyProtectionMoney && propRuns[i].pos.open && !propRuns[i].protectionTriggeredToday)
      {
         propRuns[i].equityProtectionTriggers++;
         propRuns[i].protectionTriggeredToday = true;
         PropRollingCloseVirtualPosition(i);
      }

      if(propRuns[i].equity - propRuns[i].startingBalance >= targetMoney)
      {
         propRuns[i].passed = true;
         propRuns[i].ended = now;
         propRuns[i].daysToTarget = (int)((now - propRuns[i].startDay) / 86400) + 1;
         propRuns[i].breachReason = "Target hit";
         PropRollingCloseVirtualPosition(i);
      }
      else if(totalDrawdown >= maxDrawdownMoney || dailyDrawdown >= dailyBreachMoney)
      {
         propRuns[i].breached = true;
         propRuns[i].ended = now;
         propRuns[i].daysToBreach = (int)((now - propRuns[i].startDay) / 86400) + 1;
         if(totalDrawdown >= maxDrawdownMoney && dailyDrawdown >= dailyBreachMoney)
            propRuns[i].breachReason = "Total + Daily DD";
         else if(totalDrawdown >= maxDrawdownMoney)
            propRuns[i].breachReason = "Total DD";
         else
            propRuns[i].breachReason = "Daily DD";
         PropRollingCloseVirtualPosition(i);
      }
   }
}

void PropRollingResetDaily()
{
   for(int i = 0; i < ArraySize(propRuns); i++)
   {
      if(propRuns[i].breached || propRuns[i].passed)
         continue;
      propRuns[i].dayStartReference = propRuns[i].balance;
      propRuns[i].protectionTriggeredToday = false;
   }
}

