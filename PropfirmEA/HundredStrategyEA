   {
      SetLine(line++, "VIRTUAL DOLLAR EXIT", GoodColor());
      SetLine(line++, "Status        ON    Exit lot      " + DoubleToString(VirtualExitLot, 2));
      SetLine(line++, "Take profit   " + DoubleToString(VirtualTakeProfitMoney, 2) + "    Stop loss     " + DoubleToString(VirtualStopLossMoney, 2));
      SetLine(line++, "Broker stops  " + (DisableBrokerStopsWhenVirtualExitOn ? "DISABLED (virtual only)" : "ENABLED"));
      SetLine(line++, " ");
   }

   SetLine(line++, "EA STOP PROTECTION", MutedColor());
   SetLine(line++, "Enabled       " + PropBoolStr(EnableProtectionStops) + "    Close on hit  " + PropBoolStr(ClosePositionsWhenProtectionHit));
   SetLine(line++, "Profit $      " + DoubleToString(StopProfitMoney, 2) + "    Loss $        " + DoubleToString(StopLossMoney, 2));
   SetLine(line++, "Drawdown $    " + DoubleToString(StopDrawdownMoney, 2) + "    Profit %      " + DoubleToString(StopProfitPercentOfStart, 2));
   SetLine(line++, "Loss %        " + DoubleToString(StopLossPercentOfStart, 2) + "    Drawdown %    " + DoubleToString(StopDrawdownPercentOfStart, 2));
   SetLine(line++, " ");

     if(EnablePropfirmBacktestMode)
     {
        SetLine(line++, "BACKTEST MODE", WarnColor());
        SetLine(line++, "Virtual simulation running - no real trades placed");
        SetLine(line++, "Recency HL    " + DoubleToString(PropRecencyHalfLifeDays, 1) + "d" + (PropRecencyHalfLifeDays > 0.0 ? " (active)" : " (disabled)"), PropRecencyHalfLifeDays > 0.0 ? GoodColor() : MutedColor());
        int liveTotalSignals = 0;
        if(PropRollingStartMode)
        {
           for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
              liveTotalSignals += propSignalCounts[s];
        }
        else
        {
           for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
              liveTotalSignals += propResults[s].totalSignals;
        }
        SetLine(line++, "Total Signals " + IntegerToString(liveTotalSignals), GoodColor());
        SetLine(line++, " ");
     }
   else
   {
      SetLine(line++, "LIVE STATE", MutedColor());
      SetLine(line++, "Balance       " + DoubleToString(AccountInfoDouble(ACCOUNT_BALANCE), 2) + "    Equity        " + DoubleToString(AccountInfoDouble(ACCOUNT_EQUITY), 2));
