   int StochRsiSignal(const int rsiPeriod, const int period)
   {
      double r1 = IndicatorValue(iRSI(_Symbol, _Period, rsiPeriod, PRICE_CLOSE), 1);
      double r2 = IndicatorValue(iRSI(_Symbol, _Period, rsiPeriod, PRICE_CLOSE), 2);
      double r3 = IndicatorValue(iRSI(_Symbol, _Period, rsiPeriod, PRICE_CLOSE), 3);
      double highest = r1;
      if(r2 > highest) highest = r2;
      if(r3 > highest) highest = r3;
      double lowest = r1;
      if(r2 < lowest) lowest = r2;
      if(r3 < lowest) lowest = r3;
      double range = highest - lowest;
      if(range > 0.0)
      {
         double stochRsi = (r1 - lowest) / range;
         double stochRsi2 = (r2 - lowest) / range;
         double threshold = 0.2 + (period - 14) * 0.02;
         if(stochRsi2 < threshold && stochRsi >= threshold) return 1;
         if(stochRsi2 > 1.0 - threshold && stochRsi <= 1.0 - threshold) return -1;
      }
      return 0;
   }

