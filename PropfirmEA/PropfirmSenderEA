   SetLine(line++, "Master balance " + Money(AccountInfoDouble(ACCOUNT_BALANCE)) + "        Equity        " + Money(AccountInfoDouble(ACCOUNT_EQUITY)));
   SetLine(line++, "Floating P/L   " + SignedMoney(AccountInfoDouble(ACCOUNT_PROFIT)) + "        Last write    " + FormatAge(last_snapshot_time));
   SetLine(line++, " ");
   SetLine(line++, "RECEIVER", MutedColor());
   if(receiver_status.loaded)
   {
      SetLine(line++, "Account        " + (string)receiver_status.login + "        Status age    " + receiver_age);
      SetLine(line++, "Balance        " + Money(receiver_status.balance) + "        Equity        " + Money(receiver_status.equity));
      SetLine(line++, "Floating P/L   " + SignedMoney(receiver_status.floating) + "        Gate          " + (receiver_status.trading_allowed ? "ALLOWED" : "BLOCKED"), receiver_status.trading_allowed ? GoodColor() : BadColor());
      SetLine(line++, "Free margin    " + Money(receiver_status.free_margin) + "        Used margin   " + Money(receiver_status.balance - receiver_status.free_margin));
      SetLine(line++, "Daily floor    " + Money(receiver_status.daily_floor) + "        Left          " + Money(receiver_status.daily_left), StatusColor(receiver_status.daily_left, receiver_status.daily_limit_money));
      SetLine(line++, "Total floor    " + Money(receiver_status.total_floor) + "        Left          " + Money(receiver_status.total_left), StatusColor(receiver_status.total_left, receiver_status.total_limit_money));
      SetLine(line++, "Equity stop    " + Money(receiver_status.equity_stop_level) + "        Buffer        " + Money(receiver_status.equity_buffer_money));
      SetLine(line++, receiver_status.daily_protection_latched ? "DAILY DD PROTECTION HIT - PAUSED UNTIL RESET" : "Daily DD protection  SAFE - NOT HIT", receiver_status.daily_protection_latched ? BadColor() : GoodColor());
      SetLine(line++, "Reset UTC      " + ResetUtcText(receiver_status.next_daily_reset_utc) + "        Reset IST     " + ResetIstText(receiver_status.next_daily_reset_utc), receiver_status.daily_protection_latched ? WarnColor() : TextColor());
      SetLine(line++, "DAILY RESET REMAINING  " + ResetCountdownText(receiver_status.next_daily_reset_utc), receiver_status.daily_protection_latched ? WarnColor() : GoodColor());
      SetLine(line++, "Protection hit " + ProtectionHitIstText(receiver_status.protection_hit_time_utc), receiver_status.protection_hit_time_utc > 0 ? BadColor() : MutedColor());
      SetLine(line++, "Hit trade      " + ProtectionHitTicketsText(), receiver_status.protection_hit_time_utc > 0 ? WarnColor() : MutedColor());
      SetLine(line++, "Open copied    " + (string)receiver_status.copied_positions + " position(s)        Pending       " + (string)receiver_status.copied_pending_orders);
      SetLine(line++, "Receiver msg   " + receiver_status.reason, receiver_status.trading_allowed ? TextColor() : BadColor());
      SetLine(line++, " ");
      SetLine(line++, "PROFIT TARGET", MutedColor());
      if(receiver_status.profit_target_enabled && receiver_status.profit_target_money > 0.0)
      {
         SetLine(line++, "Profit target  " + Money(receiver_status.profit_target_money) + "        Target equity " + Money(receiver_status.profit_target_equity));
         SetLine(line++, "Progress       " + SignedMoney(receiver_status.profit_target_progress) + "        Remaining     " + Money(receiver_status.profit_target_left), receiver_status.profit_target_reached ? GoodColor() : TextColor());
         SetLine(line++, "Target state   " + (receiver_status.profit_target_reached ? "REACHED / PAUSED" : "ACTIVE"), receiver_status.profit_target_reached ? BadColor() : GoodColor());
      }
      else
      {
         SetLine(line++, "Profit target lock is OFF");
         SetLine(line++, "Target         --        Remaining     --");
         SetLine(line++, "Target state   OFF");
      }
   }
   else
   {
      SetLine(line++, "Receiver status file missing: " + ReceiverStatusFileName(), BadColor());
      SetLine(line++, "Sender will not publish trades while RequireReceiverStatus=true", BadColor());
      for(int i = 0; i < 11; i++)
         SetLine(line++, " ");
   }

   SetLine(line++, " ");
   SetLine(line++, "SIGNALS", MutedColor());
   SetLine(line++, "Sent now       " + (string)last_sent_positions + "        Blocked now   " + (string)last_blocked_positions, last_blocked_positions > 0 ? WarnColor() : GoodColor());
   SetLine(line++, "Close events   " + (string)ArraySize(close_events) + "        Exposure gate " + (BlockWhenReceiverHasOpenExposure ? "ON" : "OFF"));
   SetLine(line++, "Strict close   " + (CloseMasterPositionWhenSenderBlocksSignal ? "ON" : "OFF") + "        Protect close " + (CloseMasterPositionsOnReceiverProtectionBreach ? "ON" : "OFF"));
   SetLine(line++, "Active source  " + (string)ArraySize(allowed_active_source_tickets) + " remembered        Fresh blocks  " + (BlockWhenReceiverHasOpenExposure ? "ON" : "OFF"));
   SetLine(line++, "Optional SL risk gate  Daily " + (BlockTradeWhenRiskExceedsDailyLeft ? "ON" : "OFF") + " / Total " + (BlockTradeWhenRiskExceedsTotalLeft ? "ON" : "OFF"));
   SetLine(line++, "Last action    " + last_action);
   SetLine(line++, "Last block     " + (last_block_reason == "" ? "--" : last_block_reason), last_block_reason == "" ? MutedColor() : BadColor());

   for(; line < SENDER_LINE_COUNT; line++)
      SetLine(line, " ");

   ChartRedraw(0);
}

string ResetUtcText(datetime reset_utc)
{
   if(reset_utc <= 0)
      return "--";
   MqlDateTime parts;
   TimeToStruct(reset_utc, parts);
   return StringFormat("%02d:%02d", parts.hour, parts.min);
}

string ResetIstText(datetime reset_utc)
{
   if(reset_utc <= 0)
      return "--";
   MqlDateTime parts;
   TimeToStruct(reset_utc + 5 * 3600 + 30 * 60, parts);
   int hour12 = parts.hour % 12;
   if(hour12 == 0)
      hour12 = 12;
   return StringFormat("%02d:%02d %s", hour12, parts.min, parts.hour < 12 ? "AM" : "PM");
}

string ResetCountdownText(datetime reset_utc)
{
   if(reset_utc <= 0)
      return "--";
   long seconds_left = (long)(reset_utc - TimeGMT());
   if(seconds_left < 0)
      seconds_left = 0;
   int hours = (int)(seconds_left / 3600);
   int minutes = (int)((seconds_left % 3600) / 60);
   int seconds = (int)(seconds_left % 60);
   return StringFormat("%02d:%02d:%02d  (%02dh %02dm %02ds)", hours, minutes, seconds, hours, minutes, seconds);
}

string ProtectionHitIstText(datetime hit_utc)
{
   if(hit_utc <= 0)
      return "--";

   MqlDateTime parts;
   TimeToStruct(hit_utc + 5 * 3600 + 30 * 60, parts);
   int hour12 = parts.hour % 12;
   if(hour12 == 0)
      hour12 = 12;
   return StringFormat("%04d.%02d.%02d %02d:%02d:%02d %s IST",
                       parts.year, parts.mon, parts.day, hour12, parts.min, parts.sec,
                       parts.hour < 12 ? "AM" : "PM");
}

string ProtectionHitTicketsText()
{
   if(receiver_status.protection_hit_time_utc <= 0)
      return "--";
   if(receiver_status.protection_hit_receiver_ticket == 0)
      return "no copied trade was open";

   return "Receiver #" + (string)receiver_status.protection_hit_receiver_ticket +
          "        Source #" + (string)receiver_status.protection_hit_source_ticket;
}

