string ResetUtcText(datetime reset_utc)
{
   if(reset_utc <= 0)
      return "--";
   MqlDateTime parts;
   TimeToStruct(reset_utc, parts);
   return StringFormat("%02d:%02d", parts.hour, parts.min);
}

string ResetIstText(datetime reset_utc)
{
   if(reset_utc <= 0)
      return "--";
   MqlDateTime parts;
   TimeToStruct(reset_utc + 5 * 3600 + 30 * 60, parts);
   int hour12 = parts.hour % 12;
   if(hour12 == 0)
      hour12 = 12;
   return StringFormat("%02d:%02d %s", hour12, parts.min, parts.hour < 12 ? "AM" : "PM");
}

string ResetCountdownText(datetime reset_utc)
{
   if(reset_utc <= 0)
      return "--";
   long seconds_left = (long)(reset_utc - TimeGMT());
   if(seconds_left < 0)
      seconds_left = 0;
   int hours = (int)(seconds_left / 3600);
   int minutes = (int)((seconds_left % 3600) / 60);
   int seconds = (int)(seconds_left % 60);
   return StringFormat("%02d:%02d:%02d  (%02dh %02dm %02ds)", hours, minutes, seconds, hours, minutes, seconds);
}

string ProtectionHitIstText(datetime hit_utc)
{
   if(hit_utc <= 0)
      return "--";

   MqlDateTime parts;
   TimeToStruct(hit_utc + 5 * 3600 + 30 * 60, parts);
   int hour12 = parts.hour % 12;
   if(hour12 == 0)
      hour12 = 12;
   return StringFormat("%04d.%02d.%02d %02d:%02d:%02d %s IST",
                       parts.year, parts.mon, parts.day, hour12, parts.min, parts.sec,
                       parts.hour < 12 ? "AM" : "PM");
}

string ProtectionHitTicketsText()
{
   if(receiver_status.protection_hit_time_utc <= 0)
      return "--";
   if(receiver_status.protection_hit_receiver_ticket == 0)
      return "no copied trade was open";

   return "Receiver #" + (string)receiver_status.protection_hit_receiver_ticket +
          "        Source #" + (string)receiver_status.protection_hit_source_ticket;
}

