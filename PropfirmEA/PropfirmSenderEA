void CreateDashboard()
{
   if(!ShowDashboard)
      return;

   int width = MathMax(650, PanelWidth);
   int line_step = 16;
   int height = 88 + SENDER_LINE_COUNT * line_step;
   EnsureBox(SENDER_PREFIX + "BG", PanelX, PanelY, width, height, PanelColor(), BorderColor());
   EnsureBox(SENDER_PREFIX + "HEADER", PanelX, PanelY, width, 42, HeaderColor(), HeaderColor());
   EnsureBox(SENDER_PREFIX + "ACCENT", PanelX, PanelY, 4, height, GoodColor(), GoodColor());
   EnsureLabel(SENDER_PREFIX + "TITLE", PanelX + 18, PanelY + 12, FontSize + 4, TextColor(), "Arial Bold");
   EnsureButton(SENDER_RESET_BUTTON, PanelX + width - 118, PanelY + 9, 96, 24, "RESET");
   for(int i = 0; i < SENDER_LINE_COUNT; i++)
      EnsureLabel(SENDER_PREFIX + "LINE_" + (string)i, PanelX + 18, PanelY + 56 + i * line_step, FontSize, TextColor());

   g_objects_created = true;
}

void SetLine(int index, string text, color text_color = clrNONE)
{
   if(index < 0 || index >= SENDER_LINE_COUNT)
      return;

   string name = SENDER_PREFIX + "LINE_" + (string)index;
   ObjectSetString(0, name, OBJPROP_TEXT, text);
   ObjectSetInteger(0, name, OBJPROP_COLOR, (text_color == clrNONE ? TextColor() : text_color));
}

color StatusColor(double left, double limit)
{
   if(left < 0.0)
      return BadColor();
   if(limit > 0.0 && left <= MathMax(1.0, limit * 0.2))
      return WarnColor();
   return GoodColor();
}

color StatusTextColor(string status)
{
   if(status == "ARMED")
      return GoodColor();
   if(status == "BLOCKED")
      return BadColor();
   return WarnColor();
}

string SignedMoney(double value)
{
   string sign = (value > 0.0 ? "+" : "");
   return sign + Money(value);
