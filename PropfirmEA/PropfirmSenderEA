void CalculateCumulativeFeeRecovered()
{
   /*
   Calculate TOTAL cumulative fee recovered based on sender's ALL-TIME P&L
   
   Fee Recovered = Sender's Total P&L from ALL closed trades (cumulative)
   - If positive: showing how much profit sender made overall (fee recovery progress)
   - If negative: showing cumulative loss
   
   This gets ALL trades from history, not just today
   */
    
    fee_stats.fee_recovered_till_now = 0;
    
    datetime to_time = TimeCurrent();
    if(!HistorySelect(0, to_time))
       return;
    
    int total_deals = HistoryDealsTotal();
    
    for(int i = 0; i < total_deals; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;
      
      long magic = HistoryDealGetInteger(ticket, DEAL_MAGIC);
      if(!MagicMatches(magic, MagicNumberFeeTracking))
         continue;
      
      // Skip entry deals, only count exits
      long entry_type = HistoryDealGetInteger(ticket, DEAL_ENTRY);
      if(entry_type == DEAL_ENTRY_IN)
         continue;
      
      double profit = HistoryDealGetDouble(ticket, DEAL_PROFIT) +
                      HistoryDealGetDouble(ticket, DEAL_SWAP) +
                      HistoryDealGetDouble(ticket, DEAL_COMMISSION);
      fee_stats.fee_recovered_till_now += profit;
   }
}

void CalculateCapitalNeededToSurvive()
{
   /*
   CORRECT LOGIC FOR CAPITAL NEEDED TO SURVIVE TARGET HIT:
   
   SCENARIO:
   - Propfirm needs X trades to reach profit target (profit_target_left / avg_win_per_trade)
   - For each of those X trades, if propfirm wins, sender LOSES (inverse relationship)
   - Sender's average loss per losing trade: avg_sender_loss
   - When propfirm wins X trades, sender loses: X × avg_sender_loss
   
   CALCULATION:
   1. trades_propfirm_needs = profit_target_left / avg_receiver_win_per_trade
   2. expected_sender_loss = trades_propfirm_needs × avg_sender_loss
   3. extra_capital = MAX(0, expected_sender_loss - current_balance)
   4. total_capital_needed = expected_sender_loss (base capital to survive)
   5. fee_at_risk = extra_capital_needed (amount over current balance that could be lost)
   
   EXAMPLE:
   - Sender current balance: $1000
   - Propfirm profit target left: $500
   - Propfirm average win: $100/trade
   - Sender average loss per trade: $300
   
   Trades propfirm needs: $500 / $100 = 5 trades
   Expected sender loss: 5 × $300 = $1500
   Extra capital needed: $1500 - $1000 = $500
   Total capital to survive: $1500
   */
   
   double current_balance = AccountInfoDouble(ACCOUNT_BALANCE);
   fee_stats.expected_sender_loss_at_target = 0;
   fee_stats.extra_capital_needed_to_survive = 0;
   fee_stats.capital_needed_to_survive = current_balance;
   fee_stats.fee_at_risk_if_target_hit = 0;
   fee_stats.propfirm_trades_to_target = 0;
   
   // If no target enabled or target already reached, no additional capital needed
   if(!receiver_status.profit_target_enabled || receiver_status.profit_target_left <= 0.01)
   {
      fee_stats.capital_needed_to_survive = current_balance;
      fee_stats.fee_at_risk_if_target_hit = 0;
      return;
   }
   
   // How many trades does propfirm need to win to reach target?
   if(receiver_status.avg_receiver_win_per_trade > 0.01)
      fee_stats.propfirm_trades_to_target = receiver_status.profit_target_left / receiver_status.avg_receiver_win_per_trade;
   else
      return;
   
   // If propfirm wins those trades, how much does sender LOSE (inverse)?
   // Use sender's actual average loss if available, otherwise use receiver's average loss
   if(fee_stats.avg_sender_loss > 0.01)
      fee_stats.expected_sender_loss_at_target = fee_stats.propfirm_trades_to_target * fee_stats.avg_sender_loss;
   else if(receiver_status.avg_receiver_loss_per_trade > 0.01)
      fee_stats.expected_sender_loss_at_target = fee_stats.propfirm_trades_to_target * receiver_status.avg_receiver_loss_per_trade;
   else
      fee_stats.expected_sender_loss_at_target = 0;
   
   // How much extra capital is needed beyond current balance?
   fee_stats.extra_capital_needed_to_survive = MathMax(0.0, fee_stats.expected_sender_loss_at_target - current_balance);
   
   // Total capital needed to survive if target is hit
   fee_stats.capital_needed_to_survive = fee_stats.expected_sender_loss_at_target;
   
   // Fee at risk if target hit = how much we would need beyond current balance
   fee_stats.fee_at_risk_if_target_hit = fee_stats.extra_capital_needed_to_survive;
}

