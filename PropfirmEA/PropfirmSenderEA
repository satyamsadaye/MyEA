   receiver_status.total_floor = StringToDouble(FileReadString(handle));
   receiver_status.total_limit_money = StringToDouble(FileReadString(handle));
   receiver_status.total_left = StringToDouble(FileReadString(handle));
   receiver_status.equity_stop_level = StringToDouble(FileReadString(handle));
   receiver_status.equity_buffer_money = StringToDouble(FileReadString(handle));
   receiver_status.copied_positions = (int)StringToInteger(FileReadString(handle));
   receiver_status.copied_pending_orders = (int)StringToInteger(FileReadString(handle));
   receiver_status.daily_protection_latched = (StringToInteger(FileReadString(handle)) != 0);
   receiver_status.next_daily_reset_utc = (datetime)StringToInteger(FileReadString(handle));
   receiver_status.profit_target_enabled = (StringToInteger(FileReadString(handle)) != 0);
   receiver_status.profit_target_money = StringToDouble(FileReadString(handle));
   receiver_status.profit_target_equity = StringToDouble(FileReadString(handle));
   receiver_status.profit_target_progress = StringToDouble(FileReadString(handle));
   receiver_status.profit_target_left = StringToDouble(FileReadString(handle));
   receiver_status.profit_target_reached = (StringToInteger(FileReadString(handle)) != 0);
   receiver_status.trading_allowed = (StringToInteger(FileReadString(handle)) != 0);
   receiver_status.protection_breached = (StringToInteger(FileReadString(handle)) != 0);
   receiver_status.protection_hit_time_utc = (datetime)StringToInteger(FileReadString(handle));
   receiver_status.protection_hit_receiver_ticket = (ulong)StringToInteger(FileReadString(handle));
   receiver_status.protection_hit_source_ticket = (ulong)StringToInteger(FileReadString(handle));
   receiver_status.reason = FileReadString(handle);
   receiver_status.avg_receiver_win_per_trade = StringToDouble(FileReadString(handle));
   receiver_status.avg_receiver_loss_per_trade = StringToDouble(FileReadString(handle));
   receiver_status.receiver_win_count = (int)StringToInteger(FileReadString(handle));
   receiver_status.receiver_loss_count = (int)StringToInteger(FileReadString(handle));

      receiver_status.loaded = true;
      FileClose(handle);
      return true;

      if(attempt < 2)
         Sleep(20);
   }

   return false;
}

double EstimatePositionRiskMoney(const string symbol,
                                 const long type,
                                 const double volume,
                                 const double entry,
                                 const double sl)
{
   if(entry <= 0.0 || sl <= 0.0 || volume <= 0.0)
      return 0.0;

   if(type == POSITION_TYPE_BUY && sl >= entry)
      return 0.0;
   if(type == POSITION_TYPE_SELL && sl <= entry)
      return 0.0;

   ENUM_ORDER_TYPE order_type = (type == POSITION_TYPE_BUY ? ORDER_TYPE_BUY : ORDER_TYPE_SELL);
   double profit = 0.0;
   if(!OrderCalcProfit(order_type, symbol, volume, entry, sl, profit))
      return 0.0;

   return MathAbs(profit);
}

void EnforceReceiverProtectionClose()
{
   if(!CloseMasterPositionsOnReceiverProtectionBreach && AutoCloseMasterPositionsAfterSeconds <= 0)
      return;

   int total = PositionsTotal();
   if(total <= 0)
   {
      g_receiver_zero_float_since = 0;
      return;
   }

   string reason = "";
   bool fresh = ReceiverStatusFresh(reason);
   bool receiver_has_no_used_margin = MathAbs(receiver_status.balance - receiver_status.free_margin) <= 0.01;
   if(fresh && receiver_has_no_used_margin)
   {
      if(g_receiver_zero_float_since == 0)
         g_receiver_zero_float_since = TimeCurrent();

      int elapsed = (int)(TimeCurrent() - g_receiver_zero_float_since);
      if(elapsed >= MathMax(1, AutoCloseMasterPositionsAfterSeconds))
      {
         last_action = "Receiver has no used margin; auto-closing master positions";
         if(PrintDetailedLogs)
         {
PrintFormat("PropfirmSender AUTO CLOSE NO MARGIN USED | Receiver=%I64d | elapsed=%d sec | MasterPositions=%d | close_after=%d | balance=%.2f | free_margin=%.2f",
                         receiver_status.login,
                         elapsed,
                         total,
                         AutoCloseMasterPositionsAfterSeconds,
                         receiver_status.balance,
                         receiver_status.free_margin);
         }

         for(int i = PositionsTotal() - 1; i >= 0; i--)
         {
            ulong ticket = PositionGetTicket(i);
            if(ticket != 0)
            {
               RememberBlockedNotice(ticket,
                                     PositionGetString(POSITION_SYMBOL),
                                     PositionGetInteger(POSITION_TYPE),
                                     PositionGetDouble(POSITION_VOLUME),
                                     "receiver has had no used margin for " + (string)elapsed + " sec (no margin in use ⇒ no open trades)");
               CloseMasterPositionWithRetries(ticket, "receiver has had no used margin for " + (string)elapsed + " sec (no margin in use ⇒ no open trades)");
            }
         }
         return;
      }
   }
   else
   {
      g_receiver_zero_float_since = 0;
   }

   if(!CloseMasterPositionsOnReceiverProtectionBreach)
      return;

   if(receiver_status.trading_allowed && !receiver_status.protection_breached)
      return;

   last_action = "Receiver protection is blocked; closing master positions";
   if(PrintDetailedLogs)
   {
      PrintFormat("PropfirmSender PROTECTION CLOSE | Receiver=%I64d | Equity=%.2f | StopLevel=%.2f | Reason=%s | MasterPositions=%d",
                  receiver_status.login, receiver_status.equity, receiver_status.equity_stop_level,
                  receiver_status.reason, total);
   }

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket != 0)
      {
         RememberBlockedNotice(ticket,
                               PositionGetString(POSITION_SYMBOL),
                               PositionGetInteger(POSITION_TYPE),
                               PositionGetDouble(POSITION_VOLUME),
                               receiver_status.reason);
         CloseMasterPositionWithRetries(ticket, receiver_status.reason);
      }
   }
}

bool RememberBlockedNotice(const ulong ticket,
                           const string symbol,
                           const long type,
                           const double volume,
                           const string reason)
{
   if(ticket == 0)
      return false;

   int total = ArraySize(blocked_notices);
   for(int i = 0; i < total; i++)
   {
      if(blocked_notices[i].ticket == ticket)
         return false;
   }

   ArrayResize(blocked_notices, total + 1);
   blocked_notices[total].ticket = ticket;
   blocked_notices[total].symbol = symbol;
   blocked_notices[total].type = type;
   blocked_notices[total].volume = volume;
   blocked_notices[total].blocked_time = TimeCurrent();
   blocked_notices[total].reason = reason;
   return true;
}

void PruneBlockedNotices()
{
   int retention = MathMax(10, ClosedTradeRetentionSeconds);
   datetime cutoff = TimeCurrent() - retention;
   int write_index = 0;
   int total = ArraySize(blocked_notices);
   for(int i = 0; i < total; i++)
   {
      if(blocked_notices[i].blocked_time < cutoff)
         continue;

      if(write_index != i)
         blocked_notices[write_index] = blocked_notices[i];
      write_index++;
   }
   ArrayResize(blocked_notices, write_index);
}

bool CloseMasterPositionWithRetries(const ulong ticket, const string close_reason)
{
   trade.SetDeviationInPoints(MathMax(0, CloseSlippagePoints));

   int retries = MathMax(1, CloseRetries);
   for(int attempt = 1; attempt <= retries; attempt++)
   {
      ResetLastError();
      if(!PositionSelectByTicket(ticket))
         return true;

      string symbol = PositionGetString(POSITION_SYMBOL);
      double volume = PositionGetDouble(POSITION_VOLUME);
      if(trade.PositionClose(ticket, MathMax(0, CloseSlippagePoints)))
      {
         last_action = "Closed master trade #" + (string)ticket + " " + symbol + " " + DoubleToString(volume, 2) +
                       " because sender gate blocked it: " + close_reason;
         last_block_reason = close_reason;
         if(PrintDetailedLogs)
            Print("PropfirmSender: ", last_action);
         return true;
      }

      string error = "Master close failed attempt " + (string)attempt + "/" + (string)retries +
                     " ticket #" + (string)ticket +
                     " | retcode " + (string)trade.ResultRetcode() + " " + trade.ResultRetcodeDescription() +
                     " | terminal error " + (string)GetLastError();
      last_block_reason = error;
      if(PrintDetailedLogs)
         Print("PropfirmSender: ", error);
      Sleep(MathMax(0, CloseRetryDelayMilliseconds));
   }

   return false;
}

void ResetSenderState()
{
   ArrayResize(close_events, 0);
   ArrayResize(remembered_positions, 0);
   ArrayResize(blocked_notices, 0);
