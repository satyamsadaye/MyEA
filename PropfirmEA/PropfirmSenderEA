      SetLineFeeRecovery(line++, "Computation             " + DoubleToString(fee_stats.propfirm_trades_to_target,2) + " * " + Money(fee_stats.avg_sender_loss) + " = " + Money(scenario1_fee_loss));
      SetLineFeeRecovery(line++, "Final master balance    " + Money(scenario1_final_balance) + "  (" + SignedMoney(scenario1_final_balance - current_balance) + ", " + DoubleToString(scenario1_pct, 2) + "%)", scenario1_final_balance < current_balance ? BadColor() : GoodColor());
   SetLineFeeRecovery(line++, " ");
   
   SetLineFeeRecovery(line++, "SCENARIO 2: PROPFIRM HITS DRAWDOWN", GoodColor());
   SetLineFeeRecovery(line++, "Propfirm DD left         " + Money(receiver_status.total_left));
   SetLineFeeRecovery(line++, "Avg prop LOSS/trade     " + Money(fee_stats.avg_receiver_loss));
   SetLineFeeRecovery(line++, "Trades to DD            " + (string)(int)fee_stats.propfirm_trades_to_drawdown);
