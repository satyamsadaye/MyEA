   SetLineFeeRecovery(line++, "Expected loss (sender)  " + Money(scenario1_fee_loss), BadColor());
      SetLineFeeRecovery(line++, "Fee recovery possible  " + Money(-scenario1_fee_loss) + " (LOSS)", BadColor());
      // Detailed math for Scenario 1
      SetLineFeeRecovery(line++, "Propfirm target left     " + Money(receiver_status.profit_target_left));
      SetLineFeeRecovery(line++, "Avg prop WIN/trade      " + Money(fee_stats.avg_receiver_win));
