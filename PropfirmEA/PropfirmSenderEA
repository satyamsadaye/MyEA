struct FeeRecoveryStats
{
   double fee_to_recover;           // Original fee amount
   double avg_sender_loss;          // Average LOSS per trade on sender (from sender trades)
   double avg_sender_win;           // Average WIN per trade on sender (from sender trades)
   double avg_receiver_loss;        // Average LOSS per trade on receiver (from receiver)
   double avg_receiver_win;         // Average WIN per trade on receiver (from receiver)
   double propfirm_trades_to_target; // How many trades propfirm needs to win equity target
   double propfirm_trades_to_drawdown; // How many trades propfirm can lose before DD breach
   double expected_sender_loss_at_target; // Expected loss if propfirm reaches target
   int trades_to_recover_fee;       // Estimated trades needed
   double fee_available_to_recover; // Fee amount that can be recovered before drawdown breach
   double fee_recovered_till_now;   // Cumulative fee recovered based on sender P&L
   double fee_at_risk_if_target_hit; // Fee amount at risk if prop firm hits profit target
   double extra_capital_needed_to_survive; // Additional capital needed beyond current balance
   double capital_needed_to_survive; // Total capital needed to survive target hit
   int receiver_wins;               // Recent receiver wins count (from receiver)
   int receiver_losses;             // Recent receiver losses count (from receiver)
   int sender_wins;                 // Recent sender wins count
   int sender_losses;               // Recent sender losses count
   int sender_total_trades;         // Total sender trades entered in history
   int sender_closed_trades;        // Number of closed sender trades
   int sender_open_trades;          // Number of open sender trades
   datetime last_updated;           // Last calculation time
};

SenderPositionState remembered_positions[];
SenderCloseEvent close_events[];
SenderBlockedNotice blocked_notices[];
ulong allowed_active_source_tickets[];
ReceiverRiskStatus receiver_status;
FeeRecoveryStats fee_stats;
CTrade trade;
string last_action = "Waiting for receiver status";
string last_block_reason = "";
int last_sent_positions = 0;
int last_blocked_positions = 0;
int g_receiver_stale_count = 0;
datetime g_receiver_zero_float_since = 0;
datetime last_snapshot_time = 0;
bool g_objects_created = false;

int OnInit()
{
   int timer_ms = MathMax(100, PublishMilliseconds);
   EventSetMillisecondTimer(timer_ms);
   WriteSnapshot();
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   EventKillTimer();
   WriteSnapshot();
   DeleteDashboard();
   DeleteFeeRecoveryDashboard();
   Comment("");
}

void OnTick()
{
   WriteSnapshot();
}

void OnTimer()
{
   WriteSnapshot();
   UpdateDashboard();
   UpdateFeeRecoveryDashboard();
}

void OnChartEvent(const int id, const long &lparam, const double &dparam, const string &sparam)
{
   if(id == CHARTEVENT_OBJECT_CLICK && sparam == SENDER_RESET_BUTTON)
   {
      ObjectSetInteger(0, SENDER_RESET_BUTTON, OBJPROP_STATE, false);
      ResetSenderState();
      WriteResetRequest();
      WriteSnapshot();
   }

   if(id == CHARTEVENT_CHART_CHANGE)
   {
      g_objects_created = false;
      CreateDashboard();
      CreateFeeRecoveryDashboard();
      UpdateDashboard();
      UpdateFeeRecoveryDashboard();
   }
}

void WriteSnapshot()
{
   RefreshCloseEvents();
   PruneAllowedActiveSourceTickets();
   PruneBlockedNotices();
   ReadReceiverStatus();
   
   // Calculate fee recovery stats if enabled
   if(EnableFeeRecovery)
      CalculateFeeRecoveryStats();

   EnforceReceiverProtectionClose();

   string snapshot_file = CopierFileName();

   int handle = FileOpen(snapshot_file,
                         FILE_WRITE | FILE_CSV | FILE_COMMON | FILE_SHARE_READ | FILE_SHARE_WRITE,
                         ';');
   if(handle == INVALID_HANDLE)
   {
      last_block_reason = "Cannot write sender file " + snapshot_file + " / error " + (string)GetLastError();
      if(PrintDetailedLogs)
         Print("PropfirmSender: ", last_block_reason);
      UpdateDashboard();
      return;
   }

   FileWrite(handle, "MT5_MINIMAL_TRADE_COPIER_V2", (long)AccountInfoInteger(ACCOUNT_LOGIN), (long)TimeCurrent());

   last_sent_positions = 0;
   last_blocked_positions = 0;
   last_block_reason = "";

   int total = PositionsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      long type = PositionGetInteger(POSITION_TYPE);
      double volume = PositionGetDouble(POSITION_VOLUME);
      double price_open = PositionGetDouble(POSITION_PRICE_OPEN);
      double sl = PositionGetDouble(POSITION_SL);
      double tp = PositionGetDouble(POSITION_TP);
      string reason = "";

      if(!SenderRiskGateAllows(ticket, symbol, type, volume, price_open, sl, reason))
      {
         last_blocked_positions++;
         last_block_reason = reason;
         bool new_notice = RememberBlockedNotice(ticket, symbol, type, volume, reason);
         if(PrintDetailedLogs && new_notice)
            PrintFormat("PropfirmSender BLOCKED source #%I64u %s %.2f: %s", ticket, symbol, volume, reason);
         if(CloseMasterPositionWhenSenderBlocksSignal)
            CloseMasterPositionWithRetries(ticket, reason);
         continue;
      }

      FileWrite(handle,
                (string)ticket,
                symbol,
                (string)type,
                DoubleToString(volume, 8),
                DoubleToString(price_open, (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS)),
                DoubleToString(sl, (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS)),
                DoubleToString(tp, (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS)));
      RememberAllowedActiveSourceTicket(ticket);
      last_sent_positions++;
   }

   int blocked_notice_total = ArraySize(blocked_notices);
   for(int i = 0; i < blocked_notice_total; i++)
   {
      FileWrite(handle,
                "BLOCKED",
                (string)blocked_notices[i].ticket,
                blocked_notices[i].symbol,
                (string)blocked_notices[i].type,
                DoubleToString(blocked_notices[i].volume, 8),
                (string)((long)blocked_notices[i].blocked_time),
                blocked_notices[i].reason);
   }

   int closed_total = ArraySize(close_events);
   for(int i = 0; i < closed_total; i++)
   {
      int digits = (int)SymbolInfoInteger(close_events[i].symbol, SYMBOL_DIGITS);
      if(digits <= 0)
         digits = 5;

      FileWrite(handle,
                "CLOSE",
                (string)close_events[i].ticket,
                close_events[i].symbol,
                (string)close_events[i].type,
                DoubleToString(close_events[i].close_price, digits),
                (string)((long)close_events[i].close_time));
   }

   FileWrite(handle, "COMPLETED");
   FileClose(handle);

   last_snapshot_time = TimeCurrent();
   last_action = "Published " + (string)last_sent_positions + " source trade(s), blocked " + (string)last_blocked_positions;
   UpdateDashboard();
   UpdateFeeRecoveryDashboard();
}

bool SenderRiskGateAllows(const ulong ticket,
                          const string symbol,
                          const long type,
                          const double volume,
                          const double entry,
                          const double sl,
                          string &reason)
{
   bool fresh = ReceiverStatusFresh(reason);
   if(!fresh)
   {
      g_receiver_stale_count++;
      int threshold = MathMax(1, ReceiverStatusConsecutive);
      if(PrintDetailedLogs)
         PrintFormat("PropfirmSender: receiver status not fresh (count %d/%d): %s", g_receiver_stale_count, threshold, reason);
      if(g_receiver_stale_count < threshold)
      {
         // treat as temporarily acceptable until we see `threshold` consecutive failures
      }
      else
      {
         return false;
      }
   }
   else
   {
      // reset counter on a fresh status
      g_receiver_stale_count = 0;
   }

   if(BlockWhenReceiverDisallowsTrading && receiver_status.loaded && (!receiver_status.trading_allowed || receiver_status.protection_breached))
   {
      reason = "receiver trading disabled/protection breached: " + receiver_status.reason;
      return false;
   }

   if(BlockWhenReceiverHasOpenExposure &&
      receiver_status.loaded &&
      (receiver_status.copied_positions > 0 || receiver_status.copied_pending_orders > 0) &&
      !AllowedActiveSourceTicketExists(ticket))
   {
      reason = "trade limit reached — receiver has " +
               (string)receiver_status.copied_positions + " position(s) running & " +
               (string)receiver_status.copied_pending_orders + " pending order(s)";
      return false;
   }

   double risk_money = EstimatePositionRiskMoney(symbol, type, volume, entry, sl);
   if(risk_money <= 0.0)
   {
      if(BlockTradesWithoutStopLoss)
      {
         reason = "missing or invalid SL; risk cannot be measured";
         return false;
      }

      return true;
   }

   double required_room = risk_money + MathMax(0.0, ExtraRiskBufferMoney);
   if(receiver_status.loaded && BlockTradeWhenRiskExceedsDailyLeft && required_room > receiver_status.daily_left)
   {
      reason = "risk " + Money(required_room) + " exceeds receiver daily DD left " + Money(receiver_status.daily_left);
      return false;
   }

   if(receiver_status.loaded && BlockTradeWhenRiskExceedsTotalLeft && required_room > receiver_status.total_left)
   {
      reason = "risk " + Money(required_room) + " exceeds receiver total DD left " + Money(receiver_status.total_left);
      return false;
   }

   return true;
}

bool AllowedActiveSourceTicketExists(const ulong ticket)
{
   int total = ArraySize(allowed_active_source_tickets);
   for(int i = 0; i < total; i++)
   {
      if(allowed_active_source_tickets[i] == ticket)
         return true;
   }

   return false;
}

void RememberAllowedActiveSourceTicket(const ulong ticket)
{
   if(ticket == 0 || AllowedActiveSourceTicketExists(ticket))
      return;

   int total = ArraySize(allowed_active_source_tickets);
   ArrayResize(allowed_active_source_tickets, total + 1);
   allowed_active_source_tickets[total] = ticket;
}

void PruneAllowedActiveSourceTickets()
{
   for(int i = ArraySize(allowed_active_source_tickets) - 1; i >= 0; i--)
   {
      if(PositionSelectByTicket(allowed_active_source_tickets[i]))
         continue;

      int last = ArraySize(allowed_active_source_tickets) - 1;
      for(int j = i; j < last; j++)
         allowed_active_source_tickets[j] = allowed_active_source_tickets[j + 1];

      ArrayResize(allowed_active_source_tickets, last);
   }
}

bool ReceiverStatusFresh(string &reason)
{
   if(!RequireReceiverStatus)
      return true;

   if(!receiver_status.loaded)
   {
      reason = "receiver status file unavailable: " + ReceiverStatusFileName();
      return false;
   }

   int age = (int)(TimeCurrent() - receiver_status.server_time);
   if(age < 0)
      age = 0;

   if(age > MathMax(1, ReceiverStatusMaxAgeSeconds))
   {
      reason = "receiver status stale: " + (string)age + " sec";
      return false;
   }

   return true;
}

bool ReceiverStatusFreshAndAvailable()
{
   if(!receiver_status.loaded)
      return false;

   int age = (int)(TimeCurrent() - receiver_status.server_time);
   if(age < 0)
      age = 0;

   if(age > MathMax(1, ReceiverStatusMaxAgeSeconds))
      return false;

   if(!receiver_status.trading_allowed || receiver_status.protection_breached)
      return false;

   return true;
}

