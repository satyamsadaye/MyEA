string CurrentIstText()
{
   MqlDateTime parts;
   TimeToStruct(TimeGMT() + 5 * 3600 + 30 * 60, parts);
   int hour12 = parts.hour % 12;
   if(hour12 == 0)
      hour12 = 12;
   return StringFormat("%04d.%02d.%02d %02d:%02d:%02d %s IST",
                       parts.year, parts.mon, parts.day, hour12, parts.min, parts.sec,
                       parts.hour < 12 ? "AM" : "PM");
}

string EscapeMarkdownV2(const string text)
{
   string out = "";
   int len = StringLen(text);
   for(int i = 0; i < len; i++)
   {
      uint ch = StringGetCharacter(text, i);
      // Characters that must be escaped for Telegram MarkdownV2
      if(ch == '_' || ch == '*' || ch == '[' || ch == ']' || ch == '(' || ch == ')' ||
         ch == '~' || ch == '`' || ch == '>' || ch == '#' || ch == '+' || ch == '-' ||
         ch == '=' || ch == '|' || ch == '{' || ch == '}' || ch == '.' || ch == '!')
      {
         out += "\\" + CharToString((uchar)ch);
      }
      else
         out += CharToString((uchar)ch);
   }
   return out;
}

string TelegramProtectionSnapshot()
{
   // Choose emoji: green if trading allowed, red if protection breached
   string status_emoji = (g_prop_trading_allowed ? "🟢" : "🔴");
