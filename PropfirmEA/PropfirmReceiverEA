void CheckRemoteResetRequest()
{
   int handle = FileOpen(ResetRequestFileName(),
                         FILE_READ | FILE_CSV | FILE_COMMON | FILE_SHARE_READ | FILE_SHARE_WRITE,
                         ';');
   if(handle == INVALID_HANDLE)
      return;

   string version = FileReadString(handle);
   if(version != "PROP_RESET_REQUEST_V1")
   {
      FileClose(handle);
      return;
   }

   long sender_login = (long)StringToInteger(FileReadString(handle));
   datetime request_time = (datetime)StringToInteger(FileReadString(handle));
   string reason = FileReadString(handle);
   FileClose(handle);

   double last_handled = (GlobalVariableCheck(LastRemoteResetKey()) ? GlobalVariableGet(LastRemoteResetKey()) : 0.0);
   if((double)request_time <= last_handled)
   {
      FileDelete(ResetRequestFileName(), FILE_COMMON);
      return;
   }

   GlobalVariableSet(LastRemoteResetKey(), (double)request_time);
   ResetProtectionState("remote sender " + (string)sender_login + " " + reason);
   FileDelete(ResetRequestFileName(), FILE_COMMON);
}

double DrawdownLimitMoney(ENUM_DRAWDOWN_LIMIT_MODE mode, double value, double baseline)
{
   if(mode == DD_LIMIT_PERCENT_OF_BASE)
      return MathMax(0.0, baseline * value / 100.0);
   if(mode == DD_LIMIT_PERCENT_OF_START)
      return MathMax(0.0, StartingBalance * value / 100.0);

   return MathMax(0.0, value);
}

double AccountBalancePeak()
{
   if(MaxDrawdownFloorMode == MAX_DD_FIXED_STARTING_BALANCE)
      return StartingBalance;

   datetime now = TimeCurrent();
   if(!HistorySelect(0, now))
      return MathMax(StartingBalance, AccountInfoDouble(ACCOUNT_BALANCE));

   double curve = StartingBalance;
   double peak = StartingBalance;
   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;

      curve += DealBalanceChange(ticket);
      if(curve > peak)
         peak = curve;
   }

   return MathMax(peak, AccountInfoDouble(ACCOUNT_BALANCE));
}

void UpdatePropFirmProtectionState()
{
   LoadOrResetDailyState();

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double balance_peak = AccountBalancePeak();

   if(g_equity_peak <= 0.0)
      g_equity_peak = (GlobalVariableCheck(EquityPeakKey()) ? GlobalVariableGet(EquityPeakKey()) : StartingBalance);

   if(equity > g_equity_peak)
   {
      g_equity_peak = equity;
      GlobalVariableSet(EquityPeakKey(), g_equity_peak);
   }

   double total_baseline = StartingBalance;
   if(MaxDrawdownFloorMode == MAX_DD_TRAILING_BALANCE_PEAK)
      total_baseline = MathMax(StartingBalance, balance_peak);
   else if(MaxDrawdownFloorMode == MAX_DD_TRAILING_EQUITY_PEAK)
      total_baseline = MathMax(MathMax(StartingBalance, balance_peak), g_equity_peak);

   g_total_limit_money = DrawdownLimitMoney(MaxDrawdownLimitMode, MaxTotalDrawdownValue, total_baseline);
   g_daily_limit_money = DrawdownLimitMoney(DailyDrawdownLimitMode, MaxDailyDrawdownValue, g_daily_start_equity);
   g_total_floor = total_baseline - g_total_limit_money;
   g_daily_floor = g_daily_start_equity - g_daily_limit_money;
   g_total_dd_left = equity - g_total_floor;
   g_daily_dd_left = equity - g_daily_floor;

   double stop_floor = MathMax(g_daily_floor, g_total_floor);
   g_equity_buffer_money = MathMax(0.0, EquityProtectionBufferMoney) +
                           MathMax(0.0, stop_floor * EquityProtectionBufferPercentOfStopFloor / 100.0) +
                           MathMax(0.0, g_daily_limit_money * EquityProtectionBufferPercentOfDailyLimit / 100.0);
   g_equity_stop_level = stop_floor + g_equity_buffer_money;

   g_prop_protection_breached = false;
   g_prop_trading_allowed = true;
   g_prop_block_reason = "OK";
   g_profit_target_reached = false;
   double target_basis = (ProfitTargetUsesEquity ? equity : AccountInfoDouble(ACCOUNT_BALANCE));
   g_profit_target_equity = StartingBalance + MathMax(0.0, ProfitTargetMoney);
   g_profit_target_progress = target_basis - StartingBalance;
   if(EnableProfitTargetLock && ProfitTargetMoney > 0.0)
   {
      g_profit_target_left = MathMax(0.0, g_profit_target_equity - target_basis);
      if(target_basis >= g_profit_target_equity)
         g_profit_target_reached = true;
   }
   else
   {
      g_profit_target_left = 0.0;
   }

   if(EnableProfitTargetLock && ProfitTargetMoney > 0.0)
   {
      if(PauseUntilNextDailyResetAfterProfitTarget && g_target_pause_latched)
      {
         g_prop_protection_breached = true;
         g_prop_trading_allowed = false;
         g_prop_block_reason = "profit target paused until next UTC reset";
         return;
      }

       if(PauseUntilNextDailyResetAfterProfitTarget && g_manual_reset_target_pause)
       {
          g_target_pause_latched = false;
          g_prop_protection_breached = false;
          g_prop_trading_allowed = true;
          g_prop_block_reason = "manual reset after profit target";
          g_manual_reset_target_pause = false;
          // Continue to protection checks so equity stop and daily/total drawdown
          // can still block trading even after a manual profit-target reset.
       }

      if(g_profit_target_reached)
      {
         if(PauseUntilNextDailyResetAfterProfitTarget)
            LatchTargetPause();
         g_prop_protection_breached = true;
         g_prop_trading_allowed = false;
         g_prop_block_reason = "profit target reached at " + MoneyText(g_profit_target_equity);
         if(PrintProtectionLogs)
         {
            PrintFormat("PropfirmReceiver TARGET HIT | %s=%.2f | StartingBalance=%.2f | ProfitTarget=%.2f | TargetEquity=%.2f | ClosingCopied=%s",
                        ProfitTargetUsesEquity ? "Equity" : "Balance",
                        target_basis,
                        StartingBalance,
                        ProfitTargetMoney,
                        g_profit_target_equity,
                        CloseCopiedPositionsOnProfitTarget ? "YES" : "NO");
         }
         return;
      }
   }

   if(!EnablePropFirmProtection)
      return;

   if(PauseUntilNextDailyResetAfterDailyBreach && g_daily_pause_latched)
   {
      g_prop_protection_breached = true;
      g_prop_trading_allowed = false;
      g_prop_block_reason = ProtectionReasonWithHit("daily protection paused until next UTC reset");
      return;
   }

   if(g_total_limit_money > 0.0 && equity <= g_total_floor)
   {
      RecordProtectionHit();
      g_prop_protection_breached = true;
      g_prop_trading_allowed = false;
      g_prop_block_reason = ProtectionReasonWithHit("total drawdown floor reached");
      return;
   }

   if(g_daily_limit_money > 0.0 && equity <= g_daily_floor)
   {
      RecordProtectionHit();
      if(PauseUntilNextDailyResetAfterDailyBreach)
         LatchDailyPause();
      g_prop_protection_breached = true;
      g_prop_trading_allowed = false;
      g_prop_block_reason = ProtectionReasonWithHit("daily drawdown floor reached");
      return;
   }

   if(equity <= g_equity_stop_level)
   {
      RecordProtectionHit();
      g_prop_protection_breached = true;
      g_prop_trading_allowed = false;
      g_prop_block_reason = ProtectionReasonWithHit("equity protection stop reached at " + MoneyText(g_equity_stop_level));
      if(PrintProtectionLogs)
      {
         PrintFormat("PropfirmReceiver PROTECTION HIT | HitIST=%s | ReceiverTicket=%I64u | SourceTicket=%I64u | Equity=%.2f | StopLevel=%.2f | HardFloor=%.2f | Buffer=%.2f | ClosingCopied=%s",
                     ProtectionHitIstText(), g_protection_hit_receiver_ticket, g_protection_hit_source_ticket,
                     equity, g_equity_stop_level, MathMax(g_daily_floor, g_total_floor), g_equity_buffer_money,
                     CloseCopiedPositionsOnProtectionBreach ? "YES" : "NO");
      }
      return;
   }
}

bool PropFirmRiskGateAllows(const SourcePosition &src,
                            const string symbol,
                            const long target_type,
                            const double volume,
                            const double entry,
                            const double sl,
                            string &reason)
{
   UpdatePropFirmProtectionState();

   if(!EnablePropFirmProtection)
      return true;

   if(!g_prop_trading_allowed)
   {
      reason = g_prop_block_reason;
      return false;
   }

   if(!EnablePreTradeRiskRoomCheck)
      return true;

   double risk_money = CopiedTradeRiskMoney(symbol, target_type, volume, entry, sl);
   if(risk_money <= 0.0)
   {
      if(BlockCopiedTradesWithoutStopLoss)
      {
         reason = "missing or invalid copied SL; risk cannot be measured";
         return false;
      }

      return true;
   }

   double required_room = risk_money + MathMax(0.0, ExtraRiskBufferMoney) + g_equity_buffer_money;
   if(g_daily_limit_money > 0.0 && required_room > g_daily_dd_left)
   {
      reason = "copied risk " + MoneyText(required_room) + " exceeds daily DD left " + MoneyText(g_daily_dd_left);
      return false;
   }

   if(g_total_limit_money > 0.0 && required_room > g_total_dd_left)
   {
      reason = "copied risk " + MoneyText(required_room) + " exceeds total DD left " + MoneyText(g_total_dd_left);
      return false;
   }

   if(PrintProtectionLogs)
   {
      PrintFormat("PropfirmReceiver ALLOW source #%I64u %s %.2f | Risk=%.2f | DailyLeft=%.2f | TotalLeft=%.2f | Buffer=%.2f",
                  src.ticket, symbol, volume, risk_money, g_daily_dd_left, g_total_dd_left,
                  g_equity_buffer_money + MathMax(0.0, ExtraRiskBufferMoney));
   }

   return true;
}

double CopiedTradeRiskMoney(const string symbol,
                            const long type,
                            const double volume,
                            const double entry,
                            const double sl)
{
   if(entry <= 0.0 || sl <= 0.0 || volume <= 0.0)
      return 0.0;

   if(type == POSITION_TYPE_BUY && sl >= entry)
      return 0.0;
   if(type == POSITION_TYPE_SELL && sl <= entry)
      return 0.0;

   ENUM_ORDER_TYPE order_type = (type == POSITION_TYPE_BUY ? ORDER_TYPE_BUY : ORDER_TYPE_SELL);
   double profit = 0.0;
   if(!OrderCalcProfit(order_type, symbol, volume, entry, sl, profit))
      return 0.0;

   return MathAbs(profit);
}

bool PositionIdExists(const ulong &items[], const ulong position_id)
{
   int total = ArraySize(items);
   for(int i = 0; i < total; i++)
   {
      if(items[i] == position_id)
         return true;
   }
   return false;
}

int FindTradeIdIndex(const ulong &trade_ids[], const ulong trade_id)
{
   int total = ArraySize(trade_ids);
   for(int i = 0; i < total; i++)
   {
      if(trade_ids[i] == trade_id)
         return i;
   }
   return -1;
}

void EnforceProtectionBreachActions()
{
   if(!g_prop_protection_breached)
      return;

   bool target_breach = (g_profit_target_reached || g_target_pause_latched);
   bool should_delete_pending = DeleteCopiedPendingOrdersOnProtectionBreach || target_breach;
   if(should_delete_pending)
   {
      for(int i = OrdersTotal() - 1; i >= 0; i--)
      {
         ulong ticket = OrderGetTicket(i);
         if(ticket != 0 && IsOurCopiedOrder())
         {
            last_action = "Deleting copied pending order due to prop protection: " + g_prop_block_reason;
            DeletePendingOrder(ticket);
         }
      }
   }

   bool should_close_copied = (target_breach && CloseCopiedPositionsOnProfitTarget) ||
                              (!target_breach && CloseCopiedPositionsOnProtectionBreach);

   if(should_close_copied)
   {
      for(int i = PositionsTotal() - 1; i >= 0; i--)
      {
         ulong ticket = PositionGetTicket(i);
         if(ticket != 0 && IsOurCopiedPosition())
         {
            last_action = "Closing copied position: " + g_prop_block_reason;
            ClosePosition(ticket);
         }
      }
   }
}

struct ReceiverTradeStats
{
   double avg_win_per_trade;
   double avg_loss_per_trade;
   int win_count;
   int loss_count;
   double total_win;
   double total_loss;
};

ReceiverTradeStats CalculateReceiverTradeStats()
{
   ReceiverTradeStats stats;
   stats.avg_win_per_trade = 0;
   stats.avg_loss_per_trade = 0;
   stats.win_count = 0;
   stats.loss_count = 0;
   stats.total_win = 0;
   stats.total_loss = 0;

   datetime to_time = TimeCurrent();
   if(!HistorySelect(0, to_time))
      return stats;
   
   int total_deals = HistoryDealsTotal();
   ulong entry_trade_ids[];
   ulong close_trade_ids[];
   ulong trade_ids[];
   double trade_profits[];

   // First pass: collect all receiver entry trade ids by magic
   for(int i = 0; i < total_deals; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0)
         continue;

      long magic = HistoryDealGetInteger(deal_ticket, DEAL_MAGIC);
      if(magic != (long)MagicNumber)
         continue;

      long entry = HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_IN && entry != DEAL_ENTRY_INOUT)
         continue;

      ulong trade_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_POSITION_ID);
      if(trade_id == 0)
         trade_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_ORDER);
      if(trade_id == 0)
         continue;

      if(!PositionIdExists(entry_trade_ids, trade_id))
      {
         int idx = ArraySize(entry_trade_ids);
         ArrayResize(entry_trade_ids, idx + 1);
         entry_trade_ids[idx] = trade_id;
      }
   }

   // Second pass: aggregate profits by receiver trade id, including exits even if magic differs
   for(int i = 0; i < total_deals; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0)
         continue;

      long entry = HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
      if(entry == DEAL_ENTRY_IN)
         continue;

      ulong trade_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_POSITION_ID);
      if(trade_id == 0)
         trade_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_ORDER);
      if(trade_id == 0)
         continue;

      if(!PositionIdExists(entry_trade_ids, trade_id))
         continue;

      if(!PositionIdExists(close_trade_ids, trade_id))
      {
         int idx = ArraySize(close_trade_ids);
         ArrayResize(close_trade_ids, idx + 1);
         close_trade_ids[idx] = trade_id;
      }

      double profit = HistoryDealGetDouble(deal_ticket, DEAL_PROFIT) +
                      HistoryDealGetDouble(deal_ticket, DEAL_COMMISSION) +
                      HistoryDealGetDouble(deal_ticket, DEAL_SWAP);

      int trade_index = FindTradeIdIndex(trade_ids, trade_id);
      if(trade_index < 0)
      {
         trade_index = ArraySize(trade_ids);
         ArrayResize(trade_ids, trade_index + 1);
         ArrayResize(trade_profits, trade_index + 1);
         trade_ids[trade_index] = trade_id;
         trade_profits[trade_index] = 0.0;
      }
      trade_profits[trade_index] += profit;
   }

   for(int i = 0; i < ArraySize(trade_ids); i++)
   {
      double trade_profit = trade_profits[i];
      if(trade_profit > 0.01)
      {
         stats.total_win += trade_profit;
         stats.win_count++;
      }
      else if(trade_profit < -0.01)
      {
         stats.total_loss += MathAbs(trade_profit);
         stats.loss_count++;
      }
   }

   if(stats.win_count > 0)
      stats.avg_win_per_trade = stats.total_win / stats.win_count;

   if(stats.loss_count > 0)
      stats.avg_loss_per_trade = stats.total_loss / stats.loss_count;

   return stats;
}

