datetime NextDailyResetUtc()
{
   return DashboardUtcDayStart(TimeGMT()) + 86400;
}

string ResetTimeIstText()
{
   datetime reset_ist = NextDailyResetUtc() + 5 * 3600 + 30 * 60;
   MqlDateTime parts;
   TimeToStruct(reset_ist, parts);
   int hour12 = parts.hour % 12;
   if(hour12 == 0)
      hour12 = 12;
   return StringFormat("%02d:%02d %s", hour12, parts.min, parts.hour < 12 ? "AM" : "PM");
}

string ResetCountdownText()
{
   long seconds_left = (long)(NextDailyResetUtc() - TimeGMT());
   if(seconds_left < 0)
      seconds_left = 0;
   int hours = (int)(seconds_left / 3600);
   int minutes = (int)((seconds_left % 3600) / 60);
   int seconds = (int)(seconds_left % 60);
   return StringFormat("%02d:%02d:%02d  (%02dh %02dm %02ds)", hours, minutes, seconds, hours, minutes, seconds);
}

