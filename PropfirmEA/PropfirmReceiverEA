   if(LotMode == COPIER_LOT_FIXED_MONEY_RISK)
   {
      return "Lot sizing: fixed money risk " +
             DoubleToString(MathMax(0.0, FixedRiskMoneyPerTrade), 2) +
             " per trade from sender entry to copied SL\n";
