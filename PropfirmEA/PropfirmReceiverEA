      double risk_amount = balance * (RiskPerTradePercent / 100.0);
      return "Lot sizing: current balance risk " + DoubleToString(RiskPerTradePercent, 2) +
             "% of " + DoubleToString(balance, 2) +
             " = " + DoubleToString(risk_amount, 2) + "\n";
