double DealBalanceChange(ulong ticket)
{
   return HistoryDealGetDouble(ticket, DEAL_PROFIT) +
          HistoryDealGetDouble(ticket, DEAL_COMMISSION) +
          HistoryDealGetDouble(ticket, DEAL_SWAP);
}

bool BalanceAtTime(datetime balance_time, double &balance)
{
   datetime now = TimeCurrent();
   if(!HistorySelect(0, now))
      return false;

   double later_changes = 0.0;
   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;

      datetime deal_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      if(deal_time < balance_time || deal_time > now)
         continue;

      later_changes += DealBalanceChange(ticket);
   }

   balance = AccountInfoDouble(ACCOUNT_BALANCE) - later_changes;
   return true;
}

void SaveDailyState()
{
   if(g_current_utc_day <= 0)
      return;

   GlobalVariableSet(DailyEquityKey(g_current_utc_day), g_daily_start_equity);
   GlobalVariableSet(DailyMinEquityKey(g_current_utc_day), g_daily_min_equity);
}

void LoadOrResetDailyState()
{
   datetime utc_day = DashboardUtcDayStart(TimeGMT());
   bool new_day = (utc_day != g_current_utc_day);
   g_current_utc_day = utc_day;

   string equity_key = DailyEquityKey(utc_day);
   string min_key = DailyMinEquityKey(utc_day);
   double current_equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double current_balance = AccountInfoDouble(ACCOUNT_BALANCE);

   if(!new_day && GlobalVariableCheck(equity_key))
      g_daily_start_equity = GlobalVariableGet(equity_key);
   else
   {
      double reconstructed_balance = 0.0;
      datetime reset_in_server_time = ServerTimeForUtc(utc_day);
      if(BalanceAtTime(reset_in_server_time, reconstructed_balance))
      {
         // If a trade was open across the reset, reconstructed_balance may be
         // lower than the current equity (floating P/L). Use the higher of the
         // reconstructed closed balance and the current equity to avoid
         // immediately latching daily protection when positions are still open.
         g_daily_start_equity = MathMax(reconstructed_balance, current_equity);
      }
      else if(current_balance > 0.0)
         g_daily_start_equity = current_balance;
      else
         g_daily_start_equity = current_equity;

      if(g_daily_start_equity <= 0.0)
         g_daily_start_equity = StartingBalance;

      GlobalVariableSet(equity_key, g_daily_start_equity);
   }

   if(!new_day && GlobalVariableCheck(min_key))
      g_daily_min_equity = GlobalVariableGet(min_key);
   else if(GlobalVariableCheck(min_key))
      g_daily_min_equity = GlobalVariableGet(min_key);
   else
   {
      g_daily_min_equity = current_equity;
      GlobalVariableSet(min_key, g_daily_min_equity);
   }

   if(current_equity < g_daily_min_equity)
   {
      g_daily_min_equity = current_equity;
      SaveDailyState();
   }

   if(g_daily_start_equity <= 0.0)
      g_daily_start_equity = StartingBalance;
   if(g_daily_min_equity <= 0.0)
      g_daily_min_equity = current_equity;

   string pause_key = DailyPauseKey(utc_day);
   if(new_day)
   {
      g_daily_pause_latched = false;
      g_target_pause_latched = false;
      g_manual_reset_target_pause = false;
      g_protection_hit_time_utc = 0;
      g_protection_hit_receiver_ticket = 0;
      g_protection_hit_source_ticket = 0;
      g_alert_target_active = false;
      g_alert_daily_floor_active = false;
      g_alert_total_floor_active = false;
      g_alert_equity_stop_active = false;
      g_alert_custom_active = false;
   }

   g_daily_pause_latched = (GlobalVariableCheck(pause_key) && GlobalVariableGet(pause_key) > 0.5);
   if(g_daily_pause_latched && g_protection_hit_time_utc <= 0)
   {
      if(GlobalVariableCheck(ProtectionHitTimeKey(utc_day)))
         g_protection_hit_time_utc = (datetime)GlobalVariableGet(ProtectionHitTimeKey(utc_day));
      if(GlobalVariableCheck(ProtectionHitReceiverTicketKey(utc_day)))
         g_protection_hit_receiver_ticket = (ulong)GlobalVariableGet(ProtectionHitReceiverTicketKey(utc_day));
      if(GlobalVariableCheck(ProtectionHitSourceTicketKey(utc_day)))
         g_protection_hit_source_ticket = (ulong)GlobalVariableGet(ProtectionHitSourceTicketKey(utc_day));
   }
   string target_pause_key = TargetPauseKey(utc_day);
   g_target_pause_latched = (GlobalVariableCheck(target_pause_key) && GlobalVariableGet(target_pause_key) > 0.5);
}

void LatchDailyPause()
{
   if(g_current_utc_day <= 0)
      return;

   g_daily_pause_latched = true;
   GlobalVariableSet(DailyPauseKey(g_current_utc_day), 1.0);
}

void RecordProtectionHit()
{
   if(g_protection_hit_time_utc > 0)
      return;

   g_protection_hit_time_utc = TimeGMT();
   g_protection_hit_receiver_ticket = 0;
   g_protection_hit_source_ticket = 0;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0 || !IsOurCopiedPosition())
         continue;

      g_protection_hit_receiver_ticket = ticket;
      g_protection_hit_source_ticket = SourceTicketFromSelectedPosition();
      break;
   }

   if(g_current_utc_day > 0)
   {
      GlobalVariableSet(ProtectionHitTimeKey(g_current_utc_day), (double)g_protection_hit_time_utc);
      GlobalVariableSet(ProtectionHitReceiverTicketKey(g_current_utc_day), (double)g_protection_hit_receiver_ticket);
      GlobalVariableSet(ProtectionHitSourceTicketKey(g_current_utc_day), (double)g_protection_hit_source_ticket);
   }
}

