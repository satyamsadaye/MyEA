   string msg = status_emoji + " *" + status_text + "*\n";
   msg += "*Account:* " + EscapeMarkdownV2((string)AccountInfoInteger(ACCOUNT_LOGIN)) + " \\| *Time:* " + EscapeMarkdownV2(CurrentIstText()) + "\n";
   msg += "*Balance:* " + EscapeMarkdownV2(MoneyText(AccountInfoDouble(ACCOUNT_BALANCE))) + " \\| *Equity:* " + EscapeMarkdownV2(MoneyText(AccountInfoDouble(ACCOUNT_EQUITY))) + "\n";
   msg += "*Daily floor:* " + EscapeMarkdownV2(MoneyText(g_daily_floor)) + " \\(" + "left " + EscapeMarkdownV2(MoneyText(g_daily_dd_left)) + "\\)\n";
   msg += "*Max DD floor:* " + EscapeMarkdownV2(MoneyText(g_total_floor)) + " \\(" + "left " + EscapeMarkdownV2(MoneyText(g_total_dd_left)) + "\\)\n";
   msg += "*Early equity stop:* " + EscapeMarkdownV2(MoneyText(g_equity_stop_level)) + "\n";
   msg += "*Status:* " + EscapeMarkdownV2(g_prop_block_reason);

   // Message already includes MarkdownV2 formatting markers for static labels.
   return msg;
