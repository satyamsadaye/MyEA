int DailyResetSecondsFromMidnight()
{
   int hour = MathMax(0, MathMin(23, DailyResetUtcHour));
   int minute = MathMax(0, MathMin(59, DailyResetUtcMinute));
   return (hour * 60 + minute) * 60;
}

datetime DashboardUtcDayStart(datetime utc_time)
{
   datetime utc_midnight = UtcDayStart(utc_time);
   datetime utc_reset_today = utc_midnight + DailyResetSecondsFromMidnight();
   if(utc_time < utc_reset_today)
      return utc_reset_today - 86400;
   return utc_reset_today;
}

datetime ServerTimeForUtc(datetime utc_time)
{
   datetime server_now = TimeTradeServer();
   if(server_now <= 0)
      server_now = TimeCurrent();

   return utc_time + (server_now - TimeGMT());
}

