void QueueTelegramAlert(const string title, const string details, const string title_emoji_override = "")
{
   if(!EnableTelegramAlerts)
      return;

   // Add emoji to title depending on protection state, allow explicit override
   string title_emoji = (title_emoji_override != "") ? title_emoji_override : (g_prop_trading_allowed ? "🟢" : "🔴");
   string header = title_emoji + " *" + EscapeMarkdownV2(title) + "*";

   string message = header + "\n\n" + TelegramProtectionSnapshot();
   if(details != "")
      message += "\n" + EscapeMarkdownV2(details);

   int size = ArraySize(g_telegram_alert_queue);
   ArrayResize(g_telegram_alert_queue, size + 1);
   g_telegram_alert_queue[size] = message;
   g_telegram_last_status = "Queued: " + title;
   if(PrintTelegramLogs)
      Print("PropfirmReceiver Telegram alert queued: ", title);
}

void EvaluateTelegramAlerts()
{
   if(!EnableTelegramAlerts)
      return;

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   bool target_now = (g_profit_target_reached || g_target_pause_latched);
   bool daily_floor_now = (EnablePropFirmProtection && g_daily_limit_money > 0.0 &&
                          g_prop_protection_breached &&
                          (StringFind(g_prop_block_reason, "daily drawdown floor reached") >= 0 ||
                           StringFind(g_prop_block_reason, "daily protection paused until next UTC reset") >= 0));
   bool total_floor_now = (EnablePropFirmProtection && g_total_limit_money > 0.0 &&
                           g_prop_protection_breached &&
                           StringFind(g_prop_block_reason, "total drawdown floor reached") >= 0);
   bool equity_stop_now = (EnablePropFirmProtection && g_equity_stop_level > 0.0 &&
                           g_prop_protection_breached &&
                           StringFind(g_prop_block_reason, "equity protection stop reached") >= 0);
   bool custom_now = false;
   if(CustomEquityAlertLevel > 0.0)
   {
      custom_now = (CustomEquityAlertDirection == CUSTOM_EQUITY_AT_OR_BELOW)
                   ? equity <= CustomEquityAlertLevel
                   : equity >= CustomEquityAlertLevel;
   }

   if(AlertProfitTargetReached && target_now && !g_alert_target_active)
      QueueTelegramAlert("PROFIT TARGET REACHED",
                         "Target: " + MoneyText(g_profit_target_equity) +
                         " | progress " + MoneyText(g_profit_target_progress),
                         "🟢");

   if(AlertDailyDrawdownFloorReached && daily_floor_now && !g_alert_daily_floor_active)
      QueueTelegramAlert("DAILY DRAWDOWN HARD FLOOR REACHED", "Protection hit: " + ProtectionHitTicketsText());

   if(AlertMaxDrawdownFloorReached && total_floor_now && !g_alert_total_floor_active)
      QueueTelegramAlert("MAX TOTAL DRAWDOWN HARD FLOOR REACHED", "Protection hit: " + ProtectionHitTicketsText());

   if(AlertEquityProtectionStopReached && equity_stop_now && !g_alert_equity_stop_active)
      QueueTelegramAlert("EARLY EQUITY PROTECTION STOP REACHED",
                         "Protection hit: " + ProtectionHitTicketsText() +
                         "\nHit time: " + ProtectionHitIstText());

   if(AlertCustomEquityLevelReached && custom_now && !g_alert_custom_active)
      QueueTelegramAlert("CUSTOM EQUITY LEVEL REACHED",
                         "Custom condition: equity " +
                         (CustomEquityAlertDirection == CUSTOM_EQUITY_AT_OR_BELOW ? "at or below " : "at or above ") +
                         MoneyText(CustomEquityAlertLevel));

   g_alert_target_active = target_now;
   g_alert_daily_floor_active = daily_floor_now;
   g_alert_total_floor_active = total_floor_now;
   g_alert_equity_stop_active = equity_stop_now;
   g_alert_custom_active = custom_now;

   EvaluateTelegramStreakAlerts();
}

bool IsPositionIdentifierOpen(const ulong position_id)
{
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      if(PositionGetTicket(i) == 0)
         continue;
      if((ulong)PositionGetInteger(POSITION_IDENTIFIER) == position_id)
         return true;
   }
   return false;
}

int FindClosedCopiedResult(const ClosedCopiedResult &results[], const ulong position_id)
{
   for(int i = 0; i < ArraySize(results); i++)
   {
      if(results[i].position_id == position_id)
         return i;
   }
   return -1;
}

void SortClosedCopiedResults(ClosedCopiedResult &results[])
{
   int total = ArraySize(results);
   for(int i = 0; i < total - 1; i++)
   {
      for(int j = i + 1; j < total; j++)
      {
         if(results[j].close_time < results[i].close_time)
         {
            ClosedCopiedResult swap = results[i];
            results[i] = results[j];
            results[j] = swap;
         }
      }
   }
}

bool CalculateCurrentCopiedStreak(int &streak_type, int &streak_length, ClosedCopiedResult &last_trade)
{
   streak_type = 0;
   streak_length = 0;
   last_trade.position_id = 0;
   last_trade.close_time = 0;
   last_trade.net_result = 0.0;

   datetime now = TimeCurrent();
   if(!HistorySelect(0, now))
      return false;

   int deals_total = HistoryDealsTotal();
   if(deals_total == g_last_streak_history_deals)
   {
      streak_type = g_cached_streak_type;
      streak_length = g_cached_streak_length;
      last_trade = g_cached_last_closed_trade;
      return true;
   }

   ClosedCopiedResult results[];
   for(int i = 0; i < deals_total; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0)
         continue;

      long entry = HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_OUT && entry != DEAL_ENTRY_OUT_BY && entry != DEAL_ENTRY_INOUT)
         continue;
      if(HistoryDealGetInteger(deal_ticket, DEAL_MAGIC) != (long)MagicNumber)
         continue;

      ulong position_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_POSITION_ID);
      if(position_id == 0 || IsPositionIdentifierOpen(position_id))
         continue;

      int index = FindClosedCopiedResult(results, position_id);
      datetime close_time = (datetime)HistoryDealGetInteger(deal_ticket, DEAL_TIME);
      if(index < 0)
      {
         int size = ArraySize(results);
         ArrayResize(results, size + 1);
         index = size;
         results[index].position_id = position_id;
         results[index].close_time = close_time;
         results[index].net_result = 0.0;
      }
      else if(close_time > results[index].close_time)
      {
         results[index].close_time = close_time;
      }
   }

   for(int i = 0; i < deals_total; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0)
         continue;
      ulong position_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_POSITION_ID);
      int index = FindClosedCopiedResult(results, position_id);
      if(index < 0)
         continue;
      results[index].net_result += HistoryDealGetDouble(deal_ticket, DEAL_PROFIT) +
                                   HistoryDealGetDouble(deal_ticket, DEAL_COMMISSION) +
                                   HistoryDealGetDouble(deal_ticket, DEAL_SWAP);
   }

   SortClosedCopiedResults(results);
   int result_total = ArraySize(results);
   if(result_total > 0)
   {
      last_trade = results[result_total - 1];
      if(last_trade.net_result > 0.01)
         streak_type = 1;
      else if(last_trade.net_result < -0.01)
         streak_type = -1;

      if(streak_type != 0)
      {
         for(int i = result_total - 1; i >= 0; i--)
         {
            int result_type = (results[i].net_result > 0.01 ? 1 : (results[i].net_result < -0.01 ? -1 : 0));
            if(result_type != streak_type)
               break;
            streak_length++;
         }
      }
   }

   g_last_streak_history_deals = deals_total;
   g_cached_streak_type = streak_type;
   g_cached_streak_length = streak_length;
   g_cached_last_closed_trade = last_trade;
   return true;
}

void EvaluateTelegramStreakAlerts()
{
   int streak_type = 0;
   int streak_length = 0;
   ClosedCopiedResult last_trade;
   if(!CalculateCurrentCopiedStreak(streak_type, streak_length, last_trade))
      return;

   string loss_key = TelegramAlertStateKey("loss_streak_active");
   string win_key = TelegramAlertStateKey("win_streak_active");
   bool loss_now = (AlertConsecutiveLosingTrades && ConsecutiveLossesToAlert > 0 &&
                    streak_type < 0 && streak_length >= ConsecutiveLossesToAlert);
   bool win_now = (AlertConsecutiveWinningTrades && ConsecutiveWinsToAlert > 0 &&
                   streak_type > 0 && streak_length >= ConsecutiveWinsToAlert);
   bool loss_was_active = (GlobalVariableCheck(loss_key) && GlobalVariableGet(loss_key) > 0.5);
   bool win_was_active = (GlobalVariableCheck(win_key) && GlobalVariableGet(win_key) > 0.5);

   if(loss_now && !loss_was_active)
   {
      QueueTelegramAlert("CONSECUTIVE LOSS ALERT",
                         "Current streak: " + (string)streak_length + " losing copied trades" +
                         "\nLast receiver position ID: " + (string)last_trade.position_id +
                         " | result " + MoneyText(last_trade.net_result));
      GlobalVariableSet(loss_key, 1.0);
   }
   else if(!loss_now && GlobalVariableCheck(loss_key))
      GlobalVariableDel(loss_key);

   if(win_now && !win_was_active)
   {
      QueueTelegramAlert("CONSECUTIVE WIN ALERT",
                         "Current streak: " + (string)streak_length + " winning copied trades" +
                         "\nLast receiver position ID: " + (string)last_trade.position_id +
                         " | result " + MoneyText(last_trade.net_result));
      GlobalVariableSet(win_key, 1.0);
   }
   else if(!win_now && GlobalVariableCheck(win_key))
      GlobalVariableDel(win_key);
}

string CleanTelegramInput(string value)
{
   StringTrimLeft(value);
   StringTrimRight(value);
   return value;
}

string TelegramUrlEncode(string value)
{
   uchar bytes[];
   StringToCharArray(value, bytes, 0, WHOLE_ARRAY, CP_UTF8);
   string encoded = "";
   for(int i = 0; i < ArraySize(bytes); i++)
   {
      uchar ch = bytes[i];
      if(ch == 0)
         break;
      bool safe = (ch >= 'A' && ch <= 'Z') ||
                  (ch >= 'a' && ch <= 'z') ||
                  (ch >= '0' && ch <= '9') ||
                  ch == '-' || ch == '_' || ch == '.' || ch == '~';
      if(safe)
         encoded += CharToString(ch);
      else if(ch == ' ')
         encoded += "+";
      else
         encoded += "%" + StringFormat("%02X", ch);
   }
   return encoded;
}

bool SendTelegramAlertMessage(const string message)
{
   string token = CleanTelegramInput(TelegramBotToken);
   string chat_id = CleanTelegramInput(TelegramChatId);
   if(token == "" || chat_id == "")
   {
      g_telegram_last_status = "Not configured";
      if(PrintTelegramLogs)
         Print("PropfirmReceiver Telegram: bot token or chat ID is empty");
      return false;
   }

   string url = "https://api.telegram.org/bot" + token + "/sendMessage";
   string body = "chat_id=" + TelegramUrlEncode(chat_id) + "&parse_mode=MarkdownV2&text=" + TelegramUrlEncode(message);
   char data[];
   char result[];
   string headers = "Content-Type: application/x-www-form-urlencoded\r\n";
   string result_headers = "";
   StringToCharArray(body, data, 0, WHOLE_ARRAY, CP_UTF8);
   int data_size = ArraySize(data);
   if(data_size > 0 && data[data_size - 1] == 0)
      ArrayResize(data, data_size - 1);

   ResetLastError();
   int http_code = WebRequest("POST", url, headers,
                              MathMax(1000, MathMin(10000, TelegramTimeoutMilliseconds)),
                              data, result, result_headers);
   if(http_code != 200)
   {
      g_telegram_last_status = "Send failed; retry pending";
      if(PrintTelegramLogs)
         PrintFormat("PropfirmReceiver Telegram send failed | HTTP=%d | Error=%d | Response=%s",
                     http_code, GetLastError(), CharArrayToString(result, 0, WHOLE_ARRAY, CP_UTF8));
      return false;
   }

   if(PrintTelegramLogs)
      Print("PropfirmReceiver Telegram alert sent successfully");
   g_telegram_last_status = "Last alert sent " + CurrentIstText();
   return true;
}

void ProcessTelegramAlertQueue()
{
   int total = ArraySize(g_telegram_alert_queue);
   if(!EnableTelegramAlerts || total <= 0)
      return;

   if(PrintTelegramLogs)
      PrintFormat("PropfirmReceiver Telegram queue processing | queue length=%d | last attempt=%d", total, g_last_telegram_attempt);

   datetime now = TimeCurrent();
   if(g_last_telegram_attempt > 0 && now - g_last_telegram_attempt < MathMax(5, TelegramRetrySeconds))
      return;
   g_last_telegram_attempt = now;

   string combined = "";
   for(int i = 0; i < total; i++)
   {
      if(i > 0)
