    }

    bool DetectBullDivergence(const double &price[], const double &ind[], const int lookback)
    {
       int ph1 = 0, ph2 = 0;
       double maxP = -1.0, maxI = -1.0;
       for(int i = 1; i <= lookback; i++)
       {
          bool isHigh = true;
          for(int j = -1; j <= 1; j++)
          {
             if(i + j < 1 || i + j > lookback) continue;
             if(price[i + j - 1] > price[i - 1]) { isHigh = false; break; }
          }
          if(isHigh)
          {
             if(ph1 == 0) { ph1 = i; maxP = price[i - 1]; maxI = ind[i - 1]; }
             else { ph2 = ph1; ph1 = i; }
          }
       }
       if(ph1 > 0 && ph2 > 0 && ph1 != ph2)
       {
          double p1 = price[ph2 - 1], p2 = price[ph1 - 1];
          double i1 = ind[ph2 - 1], i2 = ind[ph1 - 1];
          if(p1 <= p2 && i1 > i2) return true;
          if(p1 >= p2 && i1 < i2) return true;
       }
       return false;
    }

    bool DetectBearDivergence(const double &price[], const double &ind[], const int lookback)
    {
       int pl1 = 0, pl2 = 0;
       double minP = 999999.0, minI = 999999.0;
       for(int i = 1; i <= lookback; i++)
       {
          bool isLow = true;
          for(int j = -1; j <= 1; j++)
          {
             if(i + j < 1 || i + j > lookback) continue;
             if(price[i + j - 1] < price[i - 1]) { isLow = false; break; }
          }
          if(isLow)
          {
             if(pl1 == 0) { pl1 = i; minP = price[i - 1]; minI = ind[i - 1]; }
             else { pl2 = pl1; pl1 = i; }
          }
       }
       if(pl1 > 0 && pl2 > 0 && pl1 != pl2)
       {
          double p1 = price[pl2 - 1], p2 = price[pl1 - 1];
          double i1 = ind[pl2 - 1], i2 = ind[pl1 - 1];
