   void ExportPropfirmRollingReport()
   {
      int totalRuns = ArraySize(propRuns);
      int aggStarts[PROP_STRATEGY_COUNT], aggPassed[PROP_STRATEGY_COUNT], aggBlown[PROP_STRATEGY_COUNT], aggActive[PROP_STRATEGY_COUNT];
      int aggWins[PROP_STRATEGY_COUNT], aggLosses[PROP_STRATEGY_COUNT], aggTrades[PROP_STRATEGY_COUNT], aggDaysToTarget[PROP_STRATEGY_COUNT];
      int aggActiveProfit[PROP_STRATEGY_COUNT], aggActiveDD[PROP_STRATEGY_COUNT];
      double aggActiveProfitDepth[PROP_STRATEGY_COUNT], aggActiveDDDepth[PROP_STRATEGY_COUNT];
      double aggNetSum[PROP_STRATEGY_COUNT], aggBestNet[PROP_STRATEGY_COUNT], aggWorstNet[PROP_STRATEGY_COUNT], aggWinRateSum[PROP_STRATEGY_COUNT];
      double aggGrossProfit[PROP_STRATEGY_COUNT], aggGrossLoss[PROP_STRATEGY_COUNT];
      double aggDuration[PROP_STRATEGY_COUNT];
      int aggWinRateCount[PROP_STRATEGY_COUNT];
      int aggTradesToTarget[PROP_STRATEGY_COUNT], aggTradesToBreach[PROP_STRATEGY_COUNT];
      int aggTradesToTargetCount[PROP_STRATEGY_COUNT], aggTradesToBreachCount[PROP_STRATEGY_COUNT];
      int aggMaxWinStreak[PROP_STRATEGY_COUNT], aggMaxLossStreak[PROP_STRATEGY_COUNT];
      int aggWinStreakSum[PROP_STRATEGY_COUNT], aggLossStreakSum[PROP_STRATEGY_COUNT];
      int aggWinStreakCount[PROP_STRATEGY_COUNT], aggLossStreakCount[PROP_STRATEGY_COUNT];
      double aggRecencyWeightSum[PROP_STRATEGY_COUNT], aggRecencyPassedWeight[PROP_STRATEGY_COUNT];
      datetime aggLastCloseTime[PROP_STRATEGY_COUNT];
      datetime testStart = 0;

      ArrayInitialize(aggStarts, 0);
      ArrayInitialize(aggPassed, 0);
      ArrayInitialize(aggBlown, 0);
      ArrayInitialize(aggActive, 0);
      ArrayInitialize(aggWins, 0);
      ArrayInitialize(aggLosses, 0);
      ArrayInitialize(aggTrades, 0);
      ArrayInitialize(aggDaysToTarget, 0);
      ArrayInitialize(aggActiveProfit, 0);
      ArrayInitialize(aggActiveDD, 0);
      ArrayInitialize(aggActiveProfitDepth, 0.0);
      ArrayInitialize(aggActiveDDDepth, 0.0);
      ArrayInitialize(aggWinRateSum, 0.0);
      ArrayInitialize(aggWinRateCount, 0);
      ArrayInitialize(aggNetSum, 0.0);
      ArrayInitialize(aggBestNet, -DBL_MAX);
      ArrayInitialize(aggWorstNet, DBL_MAX);
      ArrayInitialize(aggGrossProfit, 0.0);
      ArrayInitialize(aggGrossLoss, 0.0);
      ArrayInitialize(aggDuration, 0.0);
      ArrayInitialize(aggRecencyWeightSum, 0.0);
      ArrayInitialize(aggRecencyPassedWeight, 0.0);
      ArrayInitialize(aggLastCloseTime, 0);
      ArrayInitialize(aggTradesToTarget, 0);
      ArrayInitialize(aggTradesToBreach, 0);
      ArrayInitialize(aggTradesToTargetCount, 0);
      ArrayInitialize(aggTradesToBreachCount, 0);
      ArrayInitialize(aggMaxWinStreak, 0);
      ArrayInitialize(aggMaxLossStreak, 0);
      ArrayInitialize(aggWinStreakSum, 0);
      ArrayInitialize(aggLossStreakSum, 0);
      ArrayInitialize(aggWinStreakCount, 0);
      ArrayInitialize(aggLossStreakCount, 0);

      datetime testEndTime = TimeCurrent();
      if(g_testEndTime > 0) testEndTime = g_testEndTime;
      int activeProfit = 0, activeDD = 0;
      double activeProfitDepthSum = 0.0, activeDDDepthSum = 0.0;

      for(int i = 0; i < totalRuns; i++)
      {
         int sid = propRuns[i].strategyId - 1;
         if(sid < 0 || sid >= PROP_STRATEGY_COUNT) continue;

         aggStarts[sid]++;
         if(propRuns[i].passed) aggPassed[sid]++;
         else if(propRuns[i].breached) aggBlown[sid]++;
         else
         {
            aggActive[sid]++;
            double equityPct = (propRuns[i].equity - propRuns[i].startingBalance) / propRuns[i].startingBalance * 100.0;
            if(propRuns[i].equity >= propRuns[i].startingBalance)
            {
               activeProfit++;
               aggActiveProfit[sid]++;
               activeProfitDepthSum += equityPct;
               aggActiveProfitDepth[sid] += equityPct;
            }
            else
            {
               activeDD++;
               aggActiveDD[sid]++;
               activeDDDepthSum += equityPct;
               aggActiveDDDepth[sid] += equityPct;
            }
         }

         aggWins[sid] += propRuns[i].wins;
         aggLosses[sid] += propRuns[i].losses;
         aggTrades[sid] += propRuns[i].trades;
         aggGrossProfit[sid] += propRuns[i].grossProfit;
         aggGrossLoss[sid] += propRuns[i].grossLoss;

         datetime runEnd = (propRuns[i].ended > 0) ? propRuns[i].ended : testEndTime;
         double runDays = (double)(runEnd - propRuns[i].startDay) / 86400.0 + 1.0;
         if(runDays < 1.0) runDays = 1.0;
         aggDuration[sid] += runDays;

         int closedTrades = propRuns[i].wins + propRuns[i].losses;
         if(closedTrades > 0)
         {
            aggWinRateSum[sid] += (double)propRuns[i].wins / (double)closedTrades * 100.0;
            aggWinRateCount[sid]++;
         }

          double net = propRuns[i].balance - propRuns[i].startingBalance;
          aggNetSum[sid] += net;
          if(net > aggBestNet[sid]) aggBestNet[sid] = net;
          if(net < aggWorstNet[sid]) aggWorstNet[sid] = net;
          if(propRuns[i].lastClosedTradeTime > aggLastCloseTime[sid])
             aggLastCloseTime[sid] = propRuns[i].lastClosedTradeTime;

           if(propRuns[i].passed && propRuns[i].daysToTarget > 0)
             aggDaysToTarget[sid] += propRuns[i].daysToTarget;

          if(propRuns[i].passed && propRuns[i].tradesToTarget > 0)
          {
             aggTradesToTarget[sid] += propRuns[i].tradesToTarget;
             aggTradesToTargetCount[sid]++;
          }
          if(propRuns[i].breached && propRuns[i].tradesToBreach > 0)
          {
             aggTradesToBreach[sid] += propRuns[i].tradesToBreach;
             aggTradesToBreachCount[sid]++;
          }
          if(propRuns[i].maxWinStreak > aggMaxWinStreak[sid])
             aggMaxWinStreak[sid] = propRuns[i].maxWinStreak;
          if(propRuns[i].maxLossStreak > aggMaxLossStreak[sid])
             aggMaxLossStreak[sid] = propRuns[i].maxLossStreak;
          if(propRuns[i].maxWinStreak > 0)
          {
             aggWinStreakSum[sid] += propRuns[i].maxWinStreak;
             aggWinStreakCount[sid]++;
          }
          if(propRuns[i].maxLossStreak > 0)
          {
             aggLossStreakSum[sid] += propRuns[i].maxLossStreak;
             aggLossStreakCount[sid]++;
          }

         if(testStart == 0 || propRuns[i].startDay < testStart)
            testStart = propRuns[i].startDay;

         if(PropRecencyHalfLifeDays > 0.0)
         {
            double lambda = MathLog(2.0) / PropRecencyHalfLifeDays;
            double ageInDays = (double)(testEndTime - propRuns[i].startDay) / 86400.0;
            double weight = MathExp(-lambda * ageInDays);
            aggRecencyWeightSum[sid] += weight;
            if(propRuns[i].passed)
               aggRecencyPassedWeight[sid] += weight;
         }
      }

      int sortOrder[PROP_STRATEGY_COUNT];
      for(int i = 0; i < PROP_STRATEGY_COUNT; i++) sortOrder[i] = i;
      bool useRecency = (PropRecencyHalfLifeDays > 0.0);
      double testSpanDays = (testStart > 0) ? (double)(testEndTime - testStart) / 86400.0 : 0.0;
      bool recencyIneffective = useRecency && testSpanDays > 0.0 && PropRecencyHalfLifeDays > testSpanDays * 3.0;

      datetime trendDayList[];
      ArrayResize(trendDayList, 0);
      for(int i = 0; i < totalRuns; i++)
      {
         long raw = (long)propRuns[i].startDay;
         datetime bucket = (datetime)(raw - (raw % 86400));
         bool found = false;
         for(int d = 0; d < ArraySize(trendDayList); d++)
         {
            if(trendDayList[d] == bucket) { found = true; break; }
         }
         if(!found)
         {
            int sz = ArraySize(trendDayList);
            ArrayResize(trendDayList, sz + 1);
            trendDayList[sz] = bucket;
         }
      }
      int trendDayCount = ArraySize(trendDayList);
      for(int d = 0; d < trendDayCount - 1; d++)
      {
         for(int e = d + 1; e < trendDayCount; e++)
         {
            if(trendDayList[e] < trendDayList[d])
            {
               datetime tmp = trendDayList[d];
               trendDayList[d] = trendDayList[e];
               trendDayList[e] = tmp;
            }
         }
      }
      if(trendDayCount > 90) trendDayCount = 90;

         int trendPass[][90];
         int trendBreach[][90];
         int trendHasData[][90];
         double trendCumulative[][90];
         double trendLatestCumulative[PROP_STRATEGY_COUNT];
         ArrayResize(trendPass, PROP_STRATEGY_COUNT);
         ArrayResize(trendBreach, PROP_STRATEGY_COUNT);
         ArrayResize(trendHasData, PROP_STRATEGY_COUNT);
         ArrayResize(trendCumulative, PROP_STRATEGY_COUNT);
         ArrayInitialize(trendPass, 0);
         ArrayInitialize(trendBreach, 0);
         ArrayInitialize(trendHasData, 0);
         ArrayInitialize(trendCumulative, 0.0);
         ArrayInitialize(trendLatestCumulative, 0.0);
         for(int i = 0; i < totalRuns; i++)
         {
            int sid = propRuns[i].strategyId - 1;
            if(sid < 0 || sid >= PROP_STRATEGY_COUNT) continue;
            long raw = (long)propRuns[i].startDay;
            datetime bucket = (datetime)(raw - (raw % 86400));
            int dayIdx = -1;
            for(int d = 0; d < trendDayCount; d++)
            {
               if(trendDayList[d] == bucket) { dayIdx = d; break; }
            }
            if(dayIdx < 0 || dayIdx >= trendDayCount) continue;
            if(!propRuns[i].passed && !propRuns[i].breached) continue;
            trendHasData[sid][dayIdx] = 1;
            if(propRuns[i].passed)
               trendPass[sid][dayIdx]++;
            else
               trendBreach[sid][dayIdx]++;
         }
         for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
         {
            double cumulative = 0.0;
            for(int d = 0; d < trendDayCount; d++)
            {
               int net = trendPass[s][d] - trendBreach[s][d];
               cumulative += net;
               trendCumulative[s][d] = cumulative;
            if(trendHasData[s][d])
                  trendLatestCumulative[s] = cumulative;
            }
         }

         int rankHistory[][90];
         ArrayResize(rankHistory, PROP_STRATEGY_COUNT);
         for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
            for(int d = 0; d < 90; d++)
               rankHistory[s][d] = 0;

         for(int d = 0; d < trendDayCount; d++)
         {
            int candList[PROP_STRATEGY_COUNT];
            int candCount = 0;
            for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
            {
               if(trendHasData[s][d])
                  candList[candCount++] = s;
            }
            if(candCount == 0) continue;
            for(int i = 0; i < candCount - 1; i++)
            {
               for(int j = i + 1; j < candCount; j++)
               {
                  int a = candList[i], b = candList[j];
                  int totA = trendPass[a][d] + trendBreach[a][d];
                  int totB = trendPass[b][d] + trendBreach[b][d];
                  double rateA = (totA > 0) ? (double)trendPass[a][d] / totA : 0.0;
                  double rateB = (totB > 0) ? (double)trendPass[b][d] / totB : 0.0;
                  int netA = trendPass[a][d] - trendBreach[a][d];
                  int netB = trendPass[b][d] - trendBreach[b][d];
                  bool swap = false;
                  if(rateB > rateA + 0.0001) swap = true;
                  else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
                  if(swap) { candList[i] = b; candList[j] = a; }
               }
            }
            for(int i = 0; i < candCount; i++)
               rankHistory[candList[i]][d] = i + 1;
         }

         int numRankedStrats = 0;
         for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
         {
            for(int d = 0; d < trendDayCount; d++)
            {
               if(rankHistory[s][d] > 0) { numRankedStrats++; break; }
            }
         }

         double persistenceScore[PROP_STRATEGY_COUNT];
         double persistTop10[PROP_STRATEGY_COUNT];
         double persistAvgRank[PROP_STRATEGY_COUNT];
         double persistStability[PROP_STRATEGY_COUNT];
         double persistMomentum[PROP_STRATEGY_COUNT];
         bool persistHasData[PROP_STRATEGY_COUNT];
         for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
         {
            persistHasData[s] = false;
            persistenceScore[s] = 0.0;
            persistTop10[s] = 0.0;
            persistAvgRank[s] = 0.0;
            persistStability[s] = 0.0;
            persistMomentum[s] = 0.0;
         }
         for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
         {
            int daysWithData = 0, daysTop10 = 0, comparablePairs = 0;
            double sumAbsChange = 0.0;
            double sumRanks = 0.0;
            int prevRank = 0;
            bool hasPrev = false;
            int recentRanks[90];
            int recentCount = 0;
            int recentDayIdx[90];
            for(int d = 0; d < trendDayCount; d++)
            {
               int rk = rankHistory[s][d];
               if(rk == 0) continue;
               persistHasData[s] = true;
               daysWithData++;
               daysTop10 += (rk <= 10) ? 1 : 0;
               sumRanks += rk;
               recentDayIdx[recentCount] = d;
               recentRanks[recentCount] = rk;
               recentCount++;
               if(hasPrev)
               {
                  comparablePairs++;
                  sumAbsChange += MathAbs(rk - prevRank);
               }
               prevRank = rk;
               hasPrev = true;
            }
            if(!persistHasData[s]) continue;
            double pctTop10 = (double)daysTop10 / daysWithData * 100.0;
            double avgRank = sumRanks / daysWithData;
            double meanAbsChange = (comparablePairs > 0) ? sumAbsChange / comparablePairs : 0.0;
            double rankVolatility = (numRankedStrats > 1) ? meanAbsChange / (double)(numRankedStrats - 1) * 100.0 : 0.0;
            if(rankVolatility > 100.0) rankVolatility = 100.0;
            double stabilityScore = 100.0 - rankVolatility;
            double avgRankScore = (numRankedStrats > 1) ? (double)(numRankedStrats - avgRank) / (double)(numRankedStrats - 1) * 100.0 : 100.0;
            if(avgRankScore < 0.0) avgRankScore = 0.0;
            if(avgRankScore > 100.0) avgRankScore = 100.0;
            double momentumScore = 50.0;
            if(recentCount >= 2)
            {
               int half = recentCount / 2;
               if(half < 1) half = 1;
               double recentSum = 0.0, prevSum = 0.0;
               int recentN = 0, prevN = 0;
               int splitPoint = recentCount - half;
               if(splitPoint < 1) splitPoint = 1;
               if(splitPoint >= recentCount) splitPoint = recentCount - 1;
               for(int r = 0; r < splitPoint; r++) { prevSum += recentRanks[r]; prevN++; }
               for(int r = splitPoint; r < recentCount; r++) { recentSum += recentRanks[r]; recentN++; }
               if(prevN > 0 && recentN > 0)
               {
                  double prevAvg = prevSum / prevN;
                  double recentAvg = recentSum / recentN;
                  if(prevAvg > 0.0)
                  {
                     double improvement = (prevAvg - recentAvg) / prevAvg;
                     momentumScore = 50.0 + improvement * 50.0;
                  }
               }
            }
            if(momentumScore < 0.0) momentumScore = 0.0;
            if(momentumScore > 100.0) momentumScore = 100.0;
            persistenceScore[s] = 0.40 * pctTop10 + 0.25 * avgRankScore + 0.20 * stabilityScore + 0.15 * momentumScore;
            persistTop10[s] = pctTop10;
            persistAvgRank[s] = avgRank;
            persistStability[s] = stabilityScore;
            persistMomentum[s] = momentumScore;
         }

         string bestPersistStratName = "";
         double bestPersistScore = -999.0;
         for(int s = 0; s < PROP_STRATEGY_COUNT; s++)
         {
            if(persistHasData[s] && persistenceScore[s] > bestPersistScore)
            {
               bestPersistScore = persistenceScore[s];
               bestPersistStratName = StrategyName(s + 1);
            }
         }

         for(int i = 0; i < 499; i++)
      {
         for(int j = i + 1; j < PROP_STRATEGY_COUNT; j++)
         {
            int a = sortOrder[i], b = sortOrder[j];
            double rateA = (aggStarts[a] > 0) ? (double)aggPassed[a] / (double)aggStarts[a] : 0.0;
            double rateB = (aggStarts[b] > 0) ? (double)aggPassed[b] / (double)aggStarts[b] : 0.0;
            double netA = (aggStarts[a] > 0) ? aggNetSum[a] / (double)aggStarts[a] : 0.0;
            double netB = (aggStarts[b] > 0) ? aggNetSum[b] / (double)aggStarts[b] : 0.0;
            double recA = (aggRecencyWeightSum[a] > 0.0) ? aggRecencyPassedWeight[a] / aggRecencyWeightSum[a] : 0.0;
            double recB = (aggRecencyWeightSum[b] > 0.0) ? aggRecencyPassedWeight[b] / aggRecencyWeightSum[b] : 0.0;
            bool swap = false;
            if(useRecency)
            {
               if(recB > recA + 0.0001) swap = true;
               else if(MathAbs(recB - recA) <= 0.0001)
               {
                  if(rateB > rateA + 0.0001) swap = true;
                  else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
               }
            }
            else
            {
               if(rateB > rateA + 0.0001) swap = true;
               else if(MathAbs(rateB - rateA) <= 0.0001 && netB > netA) swap = true;
            }
            if(swap) { sortOrder[i] = b; sortOrder[j] = a; }
         }
      }

      int totalPassed = 0, totalBlown = 0, totalActive = 0;
      long grandTotalTrades = 0;
      long grandTotalSignals = 0;
      string bestStratName = "";
      double bestStratRate = -1.0;
