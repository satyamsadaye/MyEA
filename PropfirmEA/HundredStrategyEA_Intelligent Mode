    int SoldiersCrowsSignal(const double bodyMin, const double wickMax)
    {
       int bullCount = 0, bearCount = 0;
       for(int i = 1; i <= 3; i++)
       {
          double o = _Open(i), c = _Close(i);
          double h = _High(i), l = _Low(i);
          double body = MathAbs(c - o), range = h - l;
          if(range <= 0.0) return 0;
          double upWick = h - MathMax(o, c);
          double dnWick = MathMin(o, c) - l;
          if(c > o && body / range >= bodyMin && upWick / range <= wickMax && dnWick / range <= wickMax) bullCount++;
          else if(c < o && body / range >= bodyMin && upWick / range <= wickMax && dnWick / range <= wickMax) bearCount++;
          else { bullCount = 0; bearCount = 0; break; }
       }
       if(bullCount == 3)
       {
          double c1 = _Close(1), c2 = _Close(2), c3 = _Close(3);
          if(c1 > c2 && c2 > c3) return 1;
       }
       if(bearCount == 3)
       {
          double c1 = _Close(1), c2 = _Close(2), c3 = _Close(3);
          if(c1 < c2 && c2 < c3) return -1;
       }
       return 0;
    }

