          "<div class=\"footer\">Generated by <code>HundredStrategyEA</code> propfirm backtest mode. This is a virtual simulation - no real trades were placed.</div>\n" +
           "<script>\n" +
            "function copyTableAsText(tid){\n" +
            "  var tbl=document.getElementById(tid);\n" +
            "  if(!tbl)return;\n" +
            "  var lines=[];\n" +
            "  var ths=tbl.querySelectorAll('thead th');\n" +
