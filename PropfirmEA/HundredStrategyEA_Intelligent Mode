   bool IntellIsCustomStrategy(const int id)
   {
      if(IntellStrategyMode != PROP_STRATEGY_CUSTOM) return true;
      string custom = IntellCustomStrategies;
      StringReplace(custom, " ", "");
      if(custom == "") return false;
      string parts[];
      int cnt = StringSplit(custom, (ushort)',', parts);
      for(int i = 0; i < cnt; i++)
         if(ParseStrategyToken(parts[i], id) > 0) return true;
      return false;
   }

   string IntellSpawnIntervalLabel()
   {
      int val = (int)IntellSpawnInterval;
      if(val == 0) return "daily at resume";
      if(val > 0) return "every " + IntegerToString(val) + "h";
      return "every " + IntegerToString(MathAbs(val)) + "m";
   }

   long IntellSpawnIntervalSeconds()
   {
      int val = (int)IntellSpawnInterval;
      if(val == 0) return 86400;
      if(val > 0) return (long)val * 3600;
      return (long)MathAbs(val) * 60;
   }

   datetime IntellCurrentResetTime(const datetime now)
   {
      MqlDateTime dt;
      TimeToStruct(now, dt);
      dt.hour = IntellDailyResetHourUTC;
      dt.min = IntellDailyResetMinuteUTC;
      dt.sec = 0;
      return StructToTime(dt);
   }

   bool IntellIsCloseTime(const datetime now)
   {
      if(!IntellEnableForceClose) return false;
      MqlDateTime dt;
      TimeToStruct(now, dt);
      int totalMin = dt.hour * 60 + dt.min;
      int closeMin = IntellCloseAllHourUTC * 60 + IntellCloseAllMinuteUTC;
      int pauseMin = IntellPauseSignalsHourUTC * 60 + IntellPauseSignalsMinuteUTC;
      if(closeMin >= pauseMin)
         return totalMin >= pauseMin && totalMin < closeMin;
      return totalMin >= pauseMin || totalMin < closeMin;
   }

   bool IntellSignalsPaused(const datetime now)
   {
      if(!IntellEnablePauseSignals) return false;
      MqlDateTime dt;
      TimeToStruct(now, dt);
      int totalMin = dt.hour * 60 + dt.min;
      int closeMin = IntellCloseAllHourUTC * 60 + IntellCloseAllMinuteUTC;
      int pauseMin = IntellPauseSignalsHourUTC * 60 + IntellPauseSignalsMinuteUTC;
      int resumeMin = IntellResumeSignalsHourUTC * 60 + IntellResumeSignalsMinuteUTC;
      if(pauseMin <= closeMin)
         return totalMin >= pauseMin && totalMin < closeMin;
      return totalMin >= pauseMin || totalMin < closeMin;
   }

