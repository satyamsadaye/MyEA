   void PropCheckRules()
   {
      datetime now = TimeCurrent();
      for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
      {
         if(propResults[i].breached || propResults[i].passed)
            continue;

         double totalDrawdown = PropStartingBalance - propResults[i].equity;
         double dailyDrawdown = propResults[i].dayStartReference - propResults[i].equity;
         double targetMoney = PropStartingBalance * PropProfitTargetPercent / 100.0;
         double maxDrawdownMoney = PropStartingBalance * PropMaxTotalDrawdownPercent / 100.0;
         double protectedDailyPercent = MathMax(0.0, PropDailyDrawdownPercent - PropDailyProtectionBufferPercent);
         double dailyProtectionMoney = propResults[i].dayStartReference * protectedDailyPercent / 100.0;
         double dailyBreachMoney = propResults[i].dayStartReference * PropDailyDrawdownPercent / 100.0;

          if(PropEnableDailyDrawdown && dailyProtectionMoney > 0.0 && dailyDrawdown >= dailyProtectionMoney && propResults[i].pos.open && !propResults[i].protectionTriggeredToday)
          {
             propResults[i].equityProtectionTriggers++;
             propResults[i].protectionTriggeredToday = true;
             PropCloseVirtualPosition(i);
          }

           if(propResults[i].equity - PropStartingBalance >= targetMoney)
           {
              propResults[i].passed = true;
              propResults[i].ended = now;
              propResults[i].daysToTarget = (int)((now - propResults[i].started) / 86400) + 1;
              propResults[i].tradesToTarget = propResults[i].trades;
              propResults[i].breachReason = "Target hit";
              PropCloseVirtualPosition(i);
           }
           else if(totalDrawdown >= maxDrawdownMoney || (PropEnableDailyDrawdown && dailyDrawdown >= dailyBreachMoney))
           {
              propResults[i].breached = true;
              propResults[i].ended = now;
              propResults[i].daysToBreach = (int)((now - propResults[i].started) / 86400) + 1;
              propResults[i].tradesToBreach = propResults[i].trades;
             if(PropEnableDailyDrawdown && totalDrawdown >= maxDrawdownMoney && dailyDrawdown >= dailyBreachMoney)
                propResults[i].breachReason = "Total + Daily DD";
             else if(totalDrawdown >= maxDrawdownMoney)
                propResults[i].breachReason = "Total DD";
             else
                propResults[i].breachReason = "Daily DD";
             PropCloseVirtualPosition(i);
          }
      }
   }

   bool PropSignalsPaused(const datetime t)
   {
      int minuteOfDay = PropMinuteOfDay(t);
      int pauseMinute = PropPauseSignalsHourUTC * 60 + PropPauseSignalsMinuteUTC;
      int resumeMinute = PropResumeSignalsHourUTC * 60 + PropResumeSignalsMinuteUTC;
      if(pauseMinute > resumeMinute)
         return (minuteOfDay >= pauseMinute || minuteOfDay < resumeMinute);
      return (minuteOfDay >= pauseMinute && minuteOfDay < resumeMinute);
   }

   bool PropIsCloseTime(const datetime t)
   {
      int minuteOfDay = PropMinuteOfDay(t);
      int closeMinute = PropCloseAllHourUTC * 60 + PropCloseAllMinuteUTC;
      int resumeMinute = PropResumeSignalsHourUTC * 60 + PropResumeSignalsMinuteUTC;
      if(closeMinute > resumeMinute)
         return (minuteOfDay >= closeMinute || minuteOfDay < resumeMinute);
      return (minuteOfDay >= closeMinute && minuteOfDay < resumeMinute);
