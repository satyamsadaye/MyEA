         return iHighest(_Symbol, g_intellTimeframe, MODE_HIGH, lookback, g_intellScanShift + 2);
      if(_hlCacheBar == _cacheBarTime && lookback < 100) return _highestCache[lookback];
      return iHighest(_Symbol, g_intellTimeframe, MODE_HIGH, lookback, 2);
   }
   int _iLowest(const int lookback)
   {
      if(g_intellScanShift > 0)
         return iLowest(_Symbol, g_intellTimeframe, MODE_LOW, lookback, g_intellScanShift + 2);
      if(_hlCacheBar == _cacheBarTime && lookback < 100) return _lowestCache[lookback];
      return iLowest(_Symbol, g_intellTimeframe, MODE_LOW, lookback, 2);
   }

   void _CacheHL()
   {
      if(_hlCacheBar == _cacheBarTime) return;
      if(g_intellScanShift > 0) return;
      _hlCacheBar = _cacheBarTime;
      for(int lb = 2; lb < 100; lb++)
      {
         _highestCache[lb] = iHighest(_Symbol, g_intellTimeframe, MODE_HIGH, lb, 2);
         _lowestCache[lb] = iLowest(_Symbol, g_intellTimeframe, MODE_LOW, lb, 2);
      }
   }
