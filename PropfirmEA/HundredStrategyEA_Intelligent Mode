       morning = morning && (MathAbs(o2 - c3) > range3 * gapMin);
       bool evening = (c3 > o3) && pct3 > bodyMin && (c2 > o2) && pct2 < bodyMin && (c1 < o1) && pct1 > bodyMin;
       evening = evening && (MathAbs(o2 - c3) > range3 * gapMin);
