   void RunPropfirmBacktestTick()
   {
      if(PropRollingStartMode)
      {
         RunPropfirmRollingTick();
         return;
      }

      _CacheRefresh();
      _CacheHL();

      datetime now = TimeCurrent();
      while(now >= propCurrentDayReset + 86400)
      {
         propCurrentDayReset += 86400;
         PropResetDailyReferences();
      }

      if(PropEnableForceClose && PropIsCloseTime(now))
         PropCloseAllVirtualPositions();

      PropUpdateOpenPositions();
      PropCheckRules();

      if(OneTradePerBar)
      {
         datetime currentBar = iTime(_Symbol, g_intellTimeframe, 0);
         if(currentBar == lastBarTime)
            return;
         lastBarTime = currentBar;
      }

      if(PropEnablePauseSignals && PropSignalsPaused(now))
         return;

      for(int id = 1; id <= PROP_STRATEGY_COUNT; id++)
      {
         if(!PropIsCustomStrategy(id))
            continue;

         int index = id - 1;

         // OPTIMIZATION: skip signal eval for already-finished strategies
         if(propResults[index].breached || propResults[index].passed || propResults[index].pos.open)
            continue;
         if(propResults[index].protectionTriggeredToday)
            continue;

         StrategySignal signal;
         signal.buyVotes = 0;
         signal.sellVotes = 0;
         signal.details = "";
         EvaluateStrategy(id, signal);

         int direction = 0;
         if(signal.buyVotes > 0)
            direction = ORDER_TYPE_BUY;
         else if(signal.sellVotes > 0)
            direction = ORDER_TYPE_SELL;

         if(direction != 0)
            propResults[index].totalSignals++;

         if(direction == 0)
            continue;
         if(ReverseSignals)
            direction = (direction == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
         if((AllowedDirection == SIGNAL_BUY_ONLY && direction == ORDER_TYPE_SELL) ||
            (AllowedDirection == SIGNAL_SELL_ONLY && direction == ORDER_TYPE_BUY))
            continue;

         PropOpenVirtualPosition(index, direction, now);
      }
   }

   void PropOpenVirtualPosition(const int index, const int type, const datetime now)
   {
      propResults[index].pos.open = true;
      propResults[index].pos.type = type;
      propResults[index].pos.entry = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
      propResults[index].pos.lot = VirtualExitLot;
      propResults[index].pos.openTime = now;
      propResults[index].trades++;
   }

   void PropUpdateOpenPositions()
   {
      for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
      {
         if(propResults[i].breached || propResults[i].passed)
            continue;

         if(propResults[i].pos.open)
         {
            double profit = PropPositionProfit(i);
            if(VirtualTakeProfitMoney > 0.0 && profit >= VirtualTakeProfitMoney)
               PropCloseVirtualPosition(i);
            else if(VirtualStopLossMoney > 0.0 && profit <= -VirtualStopLossMoney)
               PropCloseVirtualPosition(i);
         }

         propResults[i].equity = propResults[i].balance + (propResults[i].pos.open ? PropPositionProfit(i) : 0.0);
         propResults[i].maxDrawdown = MathMax(propResults[i].maxDrawdown, PropStartingBalance - propResults[i].equity);
         propResults[i].maxProfit = MathMax(propResults[i].maxProfit, propResults[i].equity - PropStartingBalance);
      }
   }

   double PropPositionProfit(const int index)
   {
      if(!propResults[index].pos.open)
         return 0.0;

      int type = propResults[index].pos.type;
      double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_BID) : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double diff = (type == ORDER_TYPE_BUY) ? price - propResults[index].pos.entry : propResults[index].pos.entry - price;
      double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      if(tickValue <= 0.0 || tickSize <= 0.0)
         return 0.0;
      return diff / tickSize * tickValue * propResults[index].pos.lot;
   }

   void PropCloseVirtualPosition(const int index)
   {
      if(!propResults[index].pos.open)
         return;
      double profit = PropPositionProfit(index);
      propResults[index].balance += profit;
      propResults[index].equity = propResults[index].balance;
      if(profit > 0.0)
      {
         propResults[index].wins++;
         propResults[index].grossProfit += profit;
         propResults[index].currentWinStreak++;
         propResults[index].currentLossStreak = 0;
         if(propResults[index].currentWinStreak > propResults[index].maxWinStreak)
            propResults[index].maxWinStreak = propResults[index].currentWinStreak;
      }
      else if(profit < 0.0)
      {
         propResults[index].losses++;
         propResults[index].grossLoss += profit;
         propResults[index].currentLossStreak++;
         propResults[index].currentWinStreak = 0;
         if(propResults[index].currentLossStreak > propResults[index].maxLossStreak)
            propResults[index].maxLossStreak = propResults[index].currentLossStreak;
      }
      else
         propResults[index].breakevenTrades++;
      propResults[index].pos.open = false;
   }

