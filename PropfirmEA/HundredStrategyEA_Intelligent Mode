         t5Blown += aggBlown[sid];
         t5Active += aggActive[sid];
         t5ActiveProfit += aggActiveProfit[sid];
         t5ActiveDD += aggActiveDD[sid];
         t5ActiveProfitDepthSum += aggActiveProfitDepth[sid];
