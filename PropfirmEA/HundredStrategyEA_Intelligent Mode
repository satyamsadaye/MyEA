   ulong OpenTrade(const int orderType, const StrategySignal &signal)
   {
      double entry = (orderType == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
      bool useBrokerStops = PlaceBrokerStopLossTakeProfit && !(EnableVirtualDollarExit && DisableBrokerStopsWhenVirtualExitOn);
      double slDistance = 0.0;
      double tpDistance = 0.0;

      if(useBrokerStops)
      {
         if(EnableVirtualDollarExit)
         {
            slDistance = MoneyToPriceDistance(VirtualStopLossMoney, VirtualExitLot);
            tpDistance = MoneyToPriceDistance(VirtualTakeProfitMoney, VirtualExitLot);
            bool slNeeded = (VirtualStopLossMoney > 0.0);
            bool tpNeeded = (VirtualTakeProfitMoney > 0.0);
            if((slNeeded && slDistance <= 0.0) || (tpNeeded && tpDistance <= 0.0))
            {
               LogEvent("TRADE_SKIPPED", "Invalid SL/TP distance");
               return 0;
            }
         }
         else
         {
            slDistance = StopDistance(StopLossMode, true);
            tpDistance = StopDistance(TakeProfitMode, false);
            if(slDistance <= 0.0 || tpDistance <= 0.0)
            {
               LogEvent("TRADE_SKIPPED", "Invalid SL/TP distance");
               return 0;
            }
            if(ReverseSignals)
            {
               double tmp = slDistance;
               slDistance = tpDistance;
               tpDistance = tmp;
            }
         }
      }
      else if(!EnableVirtualDollarExit)
      {
         slDistance = StopDistance(StopLossMode, true);
         if(slDistance <= 0.0)
         {
            LogEvent("TRADE_SKIPPED", "Invalid risk distance for lot sizing while broker stops are disabled");
            return 0;
         }
         if(ReverseSignals)
            slDistance = StopDistance(TakeProfitMode, false);
      }

      double lots = CalculateLot(slDistance);
      if(lots <= 0.0)
      {
         LogEvent("TRADE_SKIPPED", "Calculated lot is zero");
         return 0;
      }

      if(EnableMarginCheck)
      {
         double marginReq = CalcMarginRequired(lots);
         double freeMargin = AccountInfoDouble(ACCOUNT_MARGIN_FREE);
         if(freeMargin > 0.0 && marginReq > 0.0)
         {
            double marginPct = (marginReq / freeMargin) * 100.0;
            if(marginPct > MaxMarginPercentPerTrade)
            {
               LogEvent("TRADE_SKIPPED", StringFormat("Margin rule: required=%.2f, free=%.2f, %.1f%%%% exceeds max %.1f%%%%", marginReq, freeMargin, marginPct, MaxMarginPercentPerTrade));
               return 0;
            }
         }
      }

      double sl = 0.0;
      double tp = 0.0;
      if(useBrokerStops)
      {
         if(slDistance > 0.0)
            sl = (orderType == ORDER_TYPE_BUY) ? entry - slDistance : entry + slDistance;
         if(tpDistance > 0.0)
            tp = (orderType == ORDER_TYPE_BUY) ? entry + tpDistance : entry - tpDistance;
         sl = NormalizeDouble(sl, _Digits);
         tp = NormalizeDouble(tp, _Digits);
      }

      string comment = "H100 Sigs B" + IntegerToString(signal.buyVotes) + " S" + IntegerToString(signal.sellVotes);
      if(ReverseSignals)
         comment += " REV";
      bool ok = false;
      if(orderType == ORDER_TYPE_BUY)
         ok = trade.Buy(lots, _Symbol, 0.0, sl, tp, comment);
      else
         ok = trade.Sell(lots, _Symbol, 0.0, sl, tp, comment);

      string message = StringFormat("type=%s,lots=%.2f,entry=%.5f,sl=%.5f,tp=%.5f,brokerStops=%s,virtualExit=%s,virtualTP=%.2f,virtualSL=%.2f,buyVotes=%d,sellVotes=%d,reversed=%s,strategies=%s,retcode=%d",
                                    orderType == ORDER_TYPE_BUY ? "BUY" : "SELL", lots, entry, sl, tp,
                                    useBrokerStops ? "true" : "false", EnableVirtualDollarExit ? "true" : "false",
                                    VirtualTakeProfitMoney, VirtualStopLossMoney,
                                    signal.buyVotes, signal.sellVotes, ReverseSignals ? "true" : "false", signal.details, trade.ResultRetcode());
      LogEvent(ok ? "TRADE_OPENED" : "TRADE_FAILED", message);
      if(ok)
         return trade.ResultOrder();
      return 0;
   }

   double StopDistance(const ENUM_STOP_MODE mode, const bool isStopLoss)
   {
      if(mode == STOP_ATR_MULTIPLIER)
      {
         double atr = CurrentAtr();
         return atr * (isStopLoss ? SlAtrMultiplier : TpAtrMultiplier);
      }

      if(mode == STOP_FIXED_POINTS)
         return (isStopLoss ? FixedSlPoints : FixedTpPoints) * _Point;

      double money = isStopLoss ? SlMoney : TpMoney;
      double lot = MathMax(FixedLot, SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN));
      return MoneyToPriceDistance(money, lot);
   }

   double CurrentAtr()
   {
      double values[];
      ArraySetAsSeries(values, true);
      if(CopyBuffer(atrHandle, 0, 1, 1, values) != 1)
         return 0.0;
      return values[0];
   }

   double CalculateLot(const double slDistance)
   {
      if(EnableVirtualDollarExit)
         return NormalizeLot(VirtualExitLot);

      if(LotMode == LOT_FIXED)
         return NormalizeLot(FixedLot);

      double base = (LotMode == LOT_RISK_STARTING_BALANCE) ? CustomStartingBalance : AccountInfoDouble(ACCOUNT_BALANCE);
      double riskMoney = base * RiskPerTradePercent / 100.0;
      double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      if(tickValue <= 0.0 || tickSize <= 0.0 || slDistance <= 0.0)
         return 0.0;

      double lossPerLot = (slDistance / tickSize) * tickValue;
      if(lossPerLot <= 0.0)
         return 0.0;

      return NormalizeLot(riskMoney / lossPerLot);
   }

   double MoneyToPriceDistance(const double money, const double lots)
   {
      double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double tickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      if(money <= 0.0 || lots <= 0.0 || tickValue <= 0.0 || tickSize <= 0.0)
         return 0.0;
      return (money / (tickValue * lots)) * tickSize;
   }

   double NormalizeLot(const double rawLot)
   {
      double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
      double maxLot = MathMin(SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX), MaxLot);
      double step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
      if(step <= 0.0)
         step = 0.01;

      double lot = MathMax(minLot, MathMin(maxLot, rawLot));
      lot = MathFloor(lot / step) * step;
      return NormalizeDouble(lot, 2);
   }

   double GetNextTradeLot()
   {
      if(EnableVirtualDollarExit)
         return NormalizeLot(VirtualExitLot);
      if(LotMode == LOT_FIXED)
         return NormalizeLot(FixedLot);
      double slDist = StopDistance(StopLossMode, true);
      if(slDist <= 0.0)
         return 0.0;
      return CalculateLot(slDist);
   }

   double CalcMarginRequired(const double lots)
   {
      double price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double margin = 0.0;
      if(OrderCalcMargin(ORDER_TYPE_BUY, _Symbol, lots, price, margin))
         return margin;
      return 0.0;
   }

