       if(dt <= 0) return "-";
       int sec = (int)(ref - dt);
       if(sec < 0) sec = 0;
       if(sec < 60) return "<1m";
       if(sec < 3600) return IntegerToString(sec / 60) + "m";
       if(sec < 86400) return IntegerToString(sec / 3600) + "h";
       return IntegerToString(sec / 86400) + "d";
    }

   long PropSpawnIntervalSeconds()
   {
      int val = (int)PropSpawnInterval;
      if(val == 0) return 0;
      if(val > 0) return (long)val * 3600;
      return (long)MathAbs(val) * 60;
   }

   string PropSpawnIntervalLabel()
   {
      int val = (int)PropSpawnInterval;
      if(val == 0) return "daily at resume time";
      if(val > 0) return "every " + IntegerToString(val) + "h";
      return "every " + IntegerToString(MathAbs(val)) + "m";
   }

   string PropTimestampedReportFileName()
   {
      MqlDateTime dt;
      TimeToStruct(TimeLocal(), dt);
      string stamp = StringFormat("%04d%02d%02d_%02d%02d%02d_%03d",
                                 dt.year, dt.mon, dt.day, dt.hour, dt.min, dt.sec,
                                 GetTickCount() % 1000);
      string base = PropHtmlReportFileName;
      int dot = StringFind(base, ".", 0);
      if(dot <= 0)
         return base + "_" + stamp;
      return StringSubstr(base, 0, dot) + "_" + stamp + StringSubstr(base, dot);
   }

