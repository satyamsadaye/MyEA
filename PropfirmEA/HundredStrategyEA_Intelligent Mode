    int VwapSignal(const double dev)
    {
       double sumPV = 0.0, sumV = 0.0;
       for(int i = 1; i <= 20; i++)
       {
          double tp = (_High(i) + _Low(i) + _Close(i)) / 3.0;
          double vol = (double)_Volume(i);
          sumPV += tp * vol;
          sumV += vol;
       }
       if(sumV <= 0.0) return 0;
       double vwap = sumPV / sumV;
       double sqSum = 0.0;
       for(int i = 1; i <= 20; i++)
       {
          double tp = (_High(i) + _Low(i) + _Close(i)) / 3.0;
          sqSum += (tp - vwap) * (tp - vwap);
       }
       double std = MathSqrt(sqSum / 20.0);
       double upper = vwap + std * dev;
       double lower = vwap - std * dev;
       double close1 = _Close(1);
       double close2 = _Close(2);
       if(close2 < lower && close1 > lower) return 1;
       if(close2 > upper && close1 < upper) return -1;
       return 0;
    }

     int PivotSignal(const int lookback)
     {
        int hiBar = _iHighest(lookback);
        int loBar = _iLowest(lookback);
        if(hiBar < 0 || loBar < 0) return 0;
        double pivotH = _High(hiBar);
        double pivotL = _Low(loBar);
        double pp = (pivotH + pivotL + _Close(hiBar)) / 3.0;
        double r1 = 2.0 * pp - pivotL;
        double s1 = 2.0 * pp - pivotH;
        double close1 = _Close(1);
        double close2 = _Close(2);
        if(close2 <= r1 && close1 > r1) return 1;
        if(close2 >= s1 && close1 < s1) return -1;
        if(close1 > r1) return 1;
        if(close1 < s1) return -1;
        return 0;
     }

    int RegChannelSignal(const int period, const double dev)
    {
       double sumX = 0.0, sumY = 0.0, sumXY = 0.0, sumX2 = 0.0;
       int n = period;
       for(int i = 1; i <= n; i++)
       {
          double y = _Close(i);
          sumX += i;
          sumY += y;
          sumXY += i * y;
          sumX2 += i * i;
       }
       double slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
       double intercept = (sumY - slope * sumX) / n;
       double reg1 = slope * 1 + intercept;
       double close1 = _Close(1);
       double errSum = 0.0;
       for(int i = 1; i <= n; i++)
       {
          double yhat = slope * i + intercept;
          errSum += (_Close(i) - yhat) * (_Close(i) - yhat);
       }
       double stderr = MathSqrt(errSum / n);
       double upper = reg1 + stderr * dev;
       double lower = reg1 - stderr * dev;
       if(close1 > upper) return -1;
       if(close1 < lower) return 1;
       if(slope > 0.0 && close1 > reg1) return 1;
       if(slope < 0.0 && close1 < reg1) return -1;
       return 0;
    }

