   int OnInit()
   {
      trade.SetExpertMagicNumber(MagicNumber);
      trade.SetDeviationInPoints(SlippagePoints);

       atrHandle = iATR(_Symbol, g_intellTimeframe, AtrPeriod);
       if(atrHandle == INVALID_HANDLE)
       {
          LogEvent("INIT_ERROR", "Failed to create ATR handle");
          return INIT_FAILED;
       }

       g_intellTimeframe = IntellTimeframe;

      int selectedStrategyId = (int)SelectedStrategy;
      if(selectedStrategyId < 1 || selectedStrategyId > PROP_STRATEGY_COUNT)
      {
         LogEvent("INIT_ERROR", "SelectedStrategy must be between 1 and " + IntegerToString(PROP_STRATEGY_COUNT));
         return INIT_PARAMETERS_INCORRECT;
      }

      if(MaxOpenPositions < 1)
      {
         LogEvent("INIT_ERROR", "MaxOpenPositions must be at least 1");
         return INIT_PARAMETERS_INCORRECT;
      }

      if(ParallelMode > 0)
      {
         if(ParallelMode == 1)
         {
            if(ParallelNodeNumber < 1 || ParallelNodeNumber > ParallelTotalNodes)
            {
               LogEvent("INIT_ERROR", "ParallelNodeNumber must be between 1 and ParallelTotalNodes");
               return INIT_PARAMETERS_INCORRECT;
            }
            if(!EnablePropfirmBacktestMode)
            {
               LogEvent("INIT_ERROR", "Parallel node mode requires EnablePropfirmBacktestMode=true");
               return INIT_PARAMETERS_INCORRECT;
            }
             g_parallelEnabled = true;
             if(ParallelTotalNodes < 2)
             {
                Print("=== WARNING: ParallelTotalNodes=1 means multi-node is disabled. Set >1 for actual parallel split.");
             }
             g_testStartTime = TimeCurrent();
             int total = PROP_STRATEGY_COUNT;
            int perNode = total / ParallelTotalNodes;
            int rem = total % ParallelTotalNodes;
            g_parallelFromId = (ParallelNodeNumber - 1) * perNode + MathMin(ParallelNodeNumber - 1, rem) + 1;
            g_parallelToId = g_parallelFromId + perNode - 1;
            if(ParallelNodeNumber <= rem)
               g_parallelToId++;
            if(g_parallelToId > total) g_parallelToId = total;
            Print("=== PARALLEL NODE ", IntegerToString(ParallelNodeNumber), " of ", IntegerToString(ParallelTotalNodes),
                  " === Terminal ID: ", IntegerToString(ParallelNodeNumber),
                  " | Batch: strategies ", IntegerToString(g_parallelFromId), " - ", IntegerToString(g_parallelToId),
                  " (", IntegerToString(g_parallelToId - g_parallelFromId + 1), " strategies)");
            Print("Run the other node(s) with different ParallelNodeNumber, then merge with ParallelMode=2.");
            LogEvent("PARALLEL_INIT", "Node " + IntegerToString(ParallelNodeNumber) + "/" + IntegerToString(ParallelTotalNodes)
               + " | Terminal ID " + IntegerToString(ParallelNodeNumber)
               + " running strategies " + IntegerToString(g_parallelFromId) + "-" + IntegerToString(g_parallelToId));
         }
         else if(ParallelMode == 2)
         {
            if(ParallelSessionKey == "")
            {
               LogEvent("INIT_ERROR", "ParallelSessionKey is required for merge mode");
               return INIT_PARAMETERS_INCORRECT;
            }
            if(!EnablePropfirmBacktestMode)
            {
               LogEvent("INIT_ERROR", "Parallel merge requires EnablePropfirmBacktestMode=true");
               return INIT_PARAMETERS_INCORRECT;
            }
            g_mergeMode = true;
            MergePartialResults();
            return INIT_FAILED;
         }
      }

      EnsureLogHeader();
      if(EnablePropfirmBacktestMode)
         InitPropfirmBacktest();
      EventSetMillisecondTimer(1000);
      CreateDashboard();
      UpdateDashboard();
        LogEvent("INIT", "HundredStrategyEA started on " + _Symbol + " | mode=" + (StrategyMode == STRATEGY_SINGLE ? "SINGLE" : "ALL-" + IntegerToString(PROP_STRATEGY_COUNT)));
        if(EnableIntelligentTrader) IntellInit();
        return INIT_SUCCEEDED;
    }

    void OnDeinit(const int reason)
    {
       if(EnablePropfirmBacktestMode)
       {
          if(ParallelMode == 1)
             ExportPartialResults();
          else if(ParallelMode != 2)
             ExportPropfirmHtmlReport();
       }
       if(atrHandle != INVALID_HANDLE)
          IndicatorRelease(atrHandle);
       EventKillTimer();
       DeleteDashboard();
       if(EnableIntelligentTrader) IntellDeleteDashboard();
       LogEvent("DEINIT", "EA stopped. reason=" + IntegerToString(reason));
    }

     void OnTimer()
     {
        UpdateDashboard();
        IntellUpdateDashboard();
        if(EnableIntelligentTrader) IntellTick();
     }

    void OnTick()
    {
       if(eaStopped)
          return;

       if(EnablePropfirmBacktestMode)
       {
          RunPropfirmBacktestTick();
          return;
       }

       if(EnableIntelligentTrader)
       {
          IntellTick();
          return;
       }

       ManageVirtualDollarExits();

      if(CheckProtectionStops())
         return;

      if(GlobalIsCloseTime())
      {
         if(CountOpenPositions() > 0)
         {
            CloseAllEaPositions();
            LogEvent("GLOBAL_CLOSE", "Force-close all at " + StringFormat("%02d:%02d", GlobalCloseAllHourUTC, GlobalCloseAllMinuteUTC) + " UTC window");
         }
         UpdateDashboard();
         return;
      }

      if(GlobalSignalsPaused())
      {
         RecordSignalAudit("NONE", "Global signals paused", false, "");
         UpdateDashboard();
         return;
      }

      // ── Receiver EA Gate ──────────────────────────────────────────────────────
      if(!ReadReceiverStatusForReceiverEA())
      {
         string reason = "ReceiverEA blocked: " + g_receiverBlockReason;
         LogEvent("SIGNAL_SKIPPED", reason);
         RecordSignalAudit("NONE", reason, false, "");
         UpdateDashboard();
         return;
      }

      if(OneTradePerBar)
      {
         datetime currentBar = iTime(_Symbol, g_intellTimeframe, 0);
         if(currentBar == lastBarTime)
            return;
         lastBarTime = currentBar;
      }

      int openPositions = CountOpenPositions();
      if(openPositions >= MaxOpenPositions)
      {
         string reason = "MaxOpenPositions reached: " + IntegerToString(openPositions);
         LogEvent("SIGNAL_SKIPPED", reason);
         RecordSignalAudit("NONE", reason, false, "");
         UpdateDashboard();
         return;
      }

      StrategySignal signal;
      signal.buyVotes = 0;
      signal.sellVotes = 0;
      signal.details = "";
      EvaluateStrategies(signal);

      int direction = 0;
      if(signal.buyVotes >= MinVotesToTrade && signal.buyVotes > signal.sellVotes)
         direction = ORDER_TYPE_BUY;
      else if(signal.sellVotes >= MinVotesToTrade && signal.sellVotes > signal.buyVotes)
         direction = ORDER_TYPE_SELL;
      else
      {
         LogEvent("NO_TRADE", "buyVotes=" + IntegerToString(signal.buyVotes) + ", sellVotes=" + IntegerToString(signal.sellVotes));
         return;
      }

      if(ReverseSignals)
         direction = (direction == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;

      if((AllowedDirection == SIGNAL_BUY_ONLY && direction == ORDER_TYPE_SELL) ||
         (AllowedDirection == SIGNAL_SELL_ONLY && direction == ORDER_TYPE_BUY))
      {
         string skipReason = "Direction blocked by AllowedDirection";
         LogEvent("SIGNAL_SKIPPED", skipReason);
         RecordSignalAudit(DirectionText(direction), skipReason, false, signal.details);
         UpdateDashboard();
         return;
      }

      ulong ticket = OpenTrade(direction, signal);
      bool tradeOpened = (ticket > 0);
      RecordSignalAudit(DirectionText(direction), tradeOpened ? "OPENED" : "FAILED", tradeOpened, signal.details, ticket);
      UpdateDashboard();
   }

   int ParseStrategyToken(const string token, const int id)
   {
      string t = token;
      StringTrimLeft(t);
      StringTrimRight(t);
      if(t == "")
         return 0;
      int dashPos = StringFind(t, "-");
      if(dashPos > 0)
      {
         int fromId = (int)StringToInteger(StringSubstr(t, 0, dashPos));
         int toId = (int)StringToInteger(StringSubstr(t, dashPos + 1));
         if(fromId < 1) fromId = 1;
         if(toId > PROP_STRATEGY_COUNT) toId = PROP_STRATEGY_COUNT;
         if(fromId <= toId && id >= fromId && id <= toId)
            return 1;
      }
      else
      {
         int val = (int)StringToInteger(t);
         if(val == id)
            return 1;
      }
      return 0;
   }

   int CountStrategiesInToken(const string token)
   {
      string t = token;
      StringTrimLeft(t);
      StringTrimRight(t);
      if(t == "")
         return 0;
      int dashPos = StringFind(t, "-");
      if(dashPos > 0)
      {
         int fromId = (int)StringToInteger(StringSubstr(t, 0, dashPos));
         int toId = (int)StringToInteger(StringSubstr(t, dashPos + 1));
         if(fromId < 1) fromId = 1;
         if(toId > PROP_STRATEGY_COUNT) toId = PROP_STRATEGY_COUNT;
         if(fromId <= toId)
            return toId - fromId + 1;
         return 0;
      }
      else
      {
         int val = (int)StringToInteger(t);
         if(val >= 1 && val <= PROP_STRATEGY_COUNT)
            return 1;
         return 0;
      }
   }

   int PropEffectiveStrategyCount()
   {
      if(g_mergeMode)
         return PROP_STRATEGY_COUNT;
      if(g_parallelEnabled)
         return (g_parallelToId - g_parallelFromId + 1);
      if(PropStrategyMode != PROP_STRATEGY_CUSTOM || PropCustomStrategies == "")
         return PROP_STRATEGY_COUNT;
      string custom = PropCustomStrategies;
      StringReplace(custom, " ", "");
      string parts[];
      int count = StringSplit(custom, (ushort)',', parts);
      int validCount = 0;
      for(int i = 0; i < count; i++)
         validCount += CountStrategiesInToken(parts[i]);
      return validCount > 0 ? validCount : 0;
   }

   bool PropIsCustomStrategy(const int id)
   {
      if(g_mergeMode)
         return true;
      if(g_parallelEnabled)
         return (id >= g_parallelFromId && id <= g_parallelToId);
      if(PropStrategyMode != PROP_STRATEGY_CUSTOM)
         return true;
      string custom = PropCustomStrategies;
      StringReplace(custom, " ", "");
      if(custom == "")
         return false;
      string parts[];
      int count = StringSplit(custom, (ushort)',', parts);
      for(int i = 0; i < count; i++)
      {
         if(ParseStrategyToken(parts[i], id) > 0)
            return true;
      }
      return false;
   }

   void EvaluateStrategies(StrategySignal &signal)
   {
      _CacheRefresh();
      _CacheHL();
      if(StrategyMode == STRATEGY_SINGLE)
      {
         EvaluateStrategy((int)SelectedStrategy, signal);
         return;
      }

      for(int id = 1; id <= PROP_STRATEGY_COUNT; id++)
         EvaluateStrategy(id, signal);
   }

