   double IntellPositionProfit(const int idx)
   {
      if(!intellRuns[idx].pos.open) return 0.0;
      int type = intellRuns[idx].pos.type;
      double entry = intellRuns[idx].pos.entry;
      double barClose = _Close(0);
      double diff = (type == ORDER_TYPE_BUY) ? barClose - entry : entry - barClose;
      double tv = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double ts = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      if(tv <= 0.0 || ts <= 0.0) return 0.0;
      return diff / ts * tv * intellRuns[idx].pos.lot;
   }

   bool IntellCheckSlTpHit(const int idx, const double barHigh, const double barLow, double &outProfit)
   {
      if(!intellRuns[idx].pos.open) return false;
      int type = intellRuns[idx].pos.type;
      double entry = intellRuns[idx].pos.entry;
      double tv = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      double ts = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
      if(tv <= 0.0 || ts <= 0.0) return false;

      double slMoney = IntellEnableDailyDrawdown ? 0.0 : VirtualStopLossMoney;
      double tpMoney = VirtualTakeProfitMoney;
      bool slHit = false, tpHit = false;

      if(type == ORDER_TYPE_BUY)
      {
         double highPnl = (barHigh - entry) / ts * tv * intellRuns[idx].pos.lot;
         double lowPnl = (barLow - entry) / ts * tv * intellRuns[idx].pos.lot;
         if(tpMoney > 0.0 && highPnl >= tpMoney) tpHit = true;
         if(slMoney > 0.0 && lowPnl <= -slMoney) slHit = true;
         if(IntellEnableDailyDrawdown)
         {
            double ddProtect = intellRuns[idx].dayStartReference * MathMax(0.0, IntellDailyDrawdownPercent - IntellDailyProtectionBufferPercent) / 100.0;
            if(ddProtect > 0.0 && intellRuns[idx].balance + lowPnl <= intellRuns[idx].dayStartReference - ddProtect)
               slHit = true;
         }
      }
      else
      {
         double highPnl = (entry - barHigh) / ts * tv * intellRuns[idx].pos.lot;
         double lowPnl = (entry - barLow) / ts * tv * intellRuns[idx].pos.lot;
         if(tpMoney > 0.0 && lowPnl >= tpMoney) tpHit = true;
         if(slMoney > 0.0 && highPnl <= -slMoney) slHit = true;
         if(IntellEnableDailyDrawdown)
         {
            double ddProtect = intellRuns[idx].dayStartReference * MathMax(0.0, IntellDailyDrawdownPercent - IntellDailyProtectionBufferPercent) / 100.0;
            if(ddProtect > 0.0 && intellRuns[idx].balance + highPnl <= intellRuns[idx].dayStartReference - ddProtect)
               slHit = true;
         }
      }

      if(tpHit || slHit)
      {
         double barClose = _Close(0);
         double diff = (type == ORDER_TYPE_BUY) ? barClose - entry : entry - barClose;
         outProfit = diff / ts * tv * intellRuns[idx].pos.lot;
         return true;
      }
      return false;
   }

   void IntellOpenVirtualPosition(const int idx, const int direction, const datetime now)
   {
      intellRuns[idx].pos.open = true;
      intellRuns[idx].pos.type = direction;
      intellRuns[idx].pos.entry = (direction == ORDER_TYPE_BUY) ? _Close(0) : _Close(0);
      intellRuns[idx].pos.lot = VirtualExitLot;
      intellRuns[idx].pos.openTime = now;
      intellRuns[idx].trades++;
      intellRuns[idx].lastTriggeredSignal = TimeToString(now, TIME_DATE | TIME_SECONDS) + " " + (direction == ORDER_TYPE_BUY ? "BUY" : "SELL");
   }

   void IntellCloseVirtualPosition(const int idx, const double profit, const datetime now)
   {
      intellRuns[idx].pos.open = false;
      intellRuns[idx].balance += profit;
      intellRuns[idx].equity = intellRuns[idx].balance;
      if(profit > 0.0)
      {
         intellRuns[idx].wins++;
         intellRuns[idx].grossProfit += profit;
         intellRuns[idx].currentWinStreak++;
         intellRuns[idx].currentLossStreak = 0;
         if(intellRuns[idx].currentWinStreak > intellRuns[idx].maxWinStreak)
            intellRuns[idx].maxWinStreak = intellRuns[idx].currentWinStreak;
      }
      else if(profit < 0.0)
      {
         intellRuns[idx].losses++;
         intellRuns[idx].grossLoss += profit;
         intellRuns[idx].currentLossStreak++;
         intellRuns[idx].currentWinStreak = 0;
         if(intellRuns[idx].currentLossStreak > intellRuns[idx].maxLossStreak)
            intellRuns[idx].maxLossStreak = intellRuns[idx].currentLossStreak;
      }
      else intellRuns[idx].breakevenTrades++;
      intellRuns[idx].lastClosedTradeTime = now;
      for(int p = 3; p >= 0; p--)
         intellRuns[idx].closedTradePnL[p + 1] = intellRuns[idx].closedTradePnL[p];
      intellRuns[idx].closedTradePnL[0] = profit;
   }

   void IntellRemoveActive(const int idx)
   {
      int p = intellPosInActive[idx];
      if(p < 0) return;
      int last = ArraySize(intellActiveIdx) - 1;
      if(p != last)
      {
         int moved = intellActiveIdx[last];
         intellActiveIdx[p] = moved;
         intellPosInActive[moved] = p;
      }
      intellPosInActive[idx] = -1;
      ArrayResize(intellActiveIdx, last);
   }

   void IntellInit()
   {
      if(!EnableIntelligentTrader) return;
      int total = iBars(_Symbol, g_intellTimeframe);
      if(total < 100) { Print("Not enough history for Intelligent scan"); return; }

      datetime now = TimeCurrent();
      datetime scanEnd = now;
      if(!IntellScanToLatest && IntellScanEndYear > 0)
      {
         MqlDateTime de; ZeroMemory(de);
         de.year = IntellScanEndYear; de.mon = MathMax(1, IntellScanEndMonth);
         de.day = MathMax(1, IntellScanEndDay); de.hour = 23; de.min = 59; de.sec = 59;
         scanEnd = StructToTime(de);
      }
      datetime scanStart = iTime(_Symbol, g_intellTimeframe, total - 1);
      if(IntellScanStartYear > 0)
      {
         MqlDateTime ds; ZeroMemory(ds);
         ds.year = IntellScanStartYear; ds.mon = MathMax(1, IntellScanStartMonth);
         ds.day = MathMax(1, IntellScanStartDay);
         scanStart = StructToTime(ds);
      }
      if(scanStart >= scanEnd) scanStart = scanEnd - 86400 * 30;
      if(scanStart < iTime(_Symbol, g_intellTimeframe, total - 1)) scanStart = iTime(_Symbol, g_intellTimeframe, total - 1);

      g_intellScanStartBar = iBarShift(_Symbol, g_intellTimeframe, scanStart);
      g_intellScanEndBar = iBarShift(_Symbol, g_intellTimeframe, scanEnd);
      if(g_intellScanStartBar < 0) g_intellScanStartBar = total - 1;
      if(g_intellScanEndBar < 0) g_intellScanEndBar = 0;
      if(g_intellScanStartBar < g_intellScanEndBar) g_intellScanStartBar = g_intellScanEndBar;

      g_intellScanCurrentBar = g_intellScanStartBar;
      g_intellTotalBars = g_intellScanStartBar - g_intellScanEndBar + 1;
       g_intellProcessedBars = 0;
       g_intellScanShift = 0;
        g_intellSelectedStratId = 0;
      g_intellTradeTicket = 0;

      ArrayResize(intellRuns, 0);
      ArrayResize(intellActiveIdx, 0);
      ArrayResize(intellPosInActive, 0);
      ArrayInitialize(intellSignalCache, 0);
      ArrayInitialize(intellSignalCounts, 0);
      intellSignalCacheBar = 0;
      intellLastResumeSpawn = 0;
      intellCurrentDayReset = 0;
      g_intellLastRescanTime = now;
      g_intellState = INTELL_IDLE;
      IntellUpdateDashboard();

      IntellPreSpawn();
      if(ArraySize(intellRuns) == 0)
      {
         LogEvent("INTELL_ERR", "No strategies to scan (check IntellStrategyMode / IntellCustomStrategies)");
         return;
      }
       Print("INTELL_INIT Pre-spawned " + IntegerToString(ArraySize(intellRuns)) + " runs | " + IntegerToString(g_intellTotalBars) + " bars | Range: " + TimeToString(iTime(_Symbol, g_intellTimeframe, g_intellScanStartBar), TIME_DATE|TIME_MINUTES) + " -> " + TimeToString(iTime(_Symbol, g_intellTimeframe, g_intellScanEndBar), TIME_DATE|TIME_MINUTES));

      g_intellScanCurrentBar = g_intellScanStartBar;
      g_intellProcessedBars = 0;
      g_intellScanShift = 0;
      g_intellState = INTELL_SCANNING;
      Print("INTELL state set to SCANNING");
   }

   void IntellPreSpawn()
   {
      long intervalSec = IntellSpawnIntervalSeconds();
      if(intervalSec <= 0) intervalSec = 86400;
      datetime startTime = iTime(_Symbol, g_intellTimeframe, g_intellScanStartBar);
      datetime endTime = iTime(_Symbol, g_intellTimeframe, g_intellScanEndBar);

      for(int b = 0;; b++)
      {
          datetime bt = (datetime)((long)startTime + b * intervalSec);
         if(bt > endTime) break;

          int maxStrats = IntellMaxStrategies <= 0 ? PROP_STRATEGY_COUNT : MathMin(IntellMaxStrategies, PROP_STRATEGY_COUNT);
          for(int id = 1; id <= maxStrats; id++)
          {
             if(!IntellIsCustomStrategy(id)) continue;
            int idx = ArraySize(intellRuns);
            ArrayResize(intellRuns, idx + 1);
            ArrayResize(intellPosInActive, idx + 1);
            intellRuns[idx].strategyId = id;
            intellRuns[idx].strategyName = StrategyName(id);
            intellRuns[idx].startDay = bt;
            intellRuns[idx].ended = 0;
            intellRuns[idx].breached = false;
            intellRuns[idx].passed = false;
            intellRuns[idx].protectionTriggeredToday = false;
            intellRuns[idx].breachReason = "";
            intellRuns[idx].dayReset = IntellCurrentResetTime(bt);
            intellRuns[idx].lastTradeBar = 0;
            intellRuns[idx].balance = IntellStartingBalance;
            intellRuns[idx].equity = IntellStartingBalance;
            intellRuns[idx].dayStartReference = IntellStartingBalance;
            intellRuns[idx].startingBalance = IntellStartingBalance;
            intellRuns[idx].maxDrawdown = 0.0;
            intellRuns[idx].maxProfit = 0.0;
            intellRuns[idx].grossProfit = 0.0;
            intellRuns[idx].grossLoss = 0.0;
            intellRuns[idx].daysToTarget = 0;
            intellRuns[idx].daysToBreach = 0;
            intellRuns[idx].tradesToTarget = 0;
            intellRuns[idx].tradesToBreach = 0;
            intellRuns[idx].currentWinStreak = 0;
            intellRuns[idx].currentLossStreak = 0;
            intellRuns[idx].maxWinStreak = 0;
            intellRuns[idx].maxLossStreak = 0;
            intellRuns[idx].equityProtectionTriggers = 0;
            intellRuns[idx].trades = 0;
            intellRuns[idx].wins = 0;
            intellRuns[idx].losses = 0;
            intellRuns[idx].breakevenTrades = 0;
            intellRuns[idx].pos.open = false;
            intellRuns[idx].lastClosedTradeTime = 0;
            for(int p = 0; p < 5; p++) intellRuns[idx].closedTradePnL[p] = 0.0;
            intellRuns[idx].lastTriggeredSignal = "";
            intellRuns[idx].lastSkippedSignal = "";
            intellPosInActive[idx] = ArraySize(intellActiveIdx);
            ArrayResize(intellActiveIdx, intellPosInActive[idx] + 1);
            intellActiveIdx[intellPosInActive[idx]] = idx;
         }
      }
      LogEvent("INTELL_SPAWN", "Pre-spawned " + IntegerToString(ArraySize(intellRuns)) + " runs");
   }

    void IntellProcessNextBar()
    {
       int barIdx = g_intellScanCurrentBar;
        if(barIdx < g_intellScanEndBar || barIdx < 0 || barIdx >= iBars(_Symbol, g_intellTimeframe))
        {
           g_intellState = INTELL_SCAN_DONE;
           return;
        }

      g_intellScanShift = barIdx;
      _IntellCacheRefresh(barIdx);
      _CacheHL();
      datetime barTime = iTime(_Symbol, g_intellTimeframe, barIdx);

      if(intellCurrentDayReset == 0)
         intellCurrentDayReset = IntellCurrentResetTime(barTime);
      while(barTime >= intellCurrentDayReset + 86400)
      {
         intellCurrentDayReset += 86400;
         IntellResetDaily();
      }

      // Cache signals for all strategies on this bar
      for(int id = 1; id <= PROP_STRATEGY_COUNT; id++)
      {
         if(!IntellIsCustomStrategy(id)) continue;
         StrategySignal s;
         s.buyVotes = 0; s.sellVotes = 0; s.details = "";
         EvaluateStrategy(id, s);
         if(s.buyVotes > 0) intellSignalCache[id - 1] = ORDER_TYPE_BUY;
         else if(s.sellVotes > 0) intellSignalCache[id - 1] = ORDER_TYPE_SELL;
         else intellSignalCache[id - 1] = 0;
         if(intellSignalCache[id - 1] != 0) intellSignalCounts[id - 1]++;
      }

      double barHigh = _High(0);
      double barLow = _Low(0);

      // Update all active runs
      int k = 0;
      int cnt = ArraySize(intellActiveIdx);
      while(k < cnt)
      {
         int i = intellActiveIdx[k];

         // Skip runs that haven't started yet
         if(barTime < intellRuns[i].startDay)
         {
            k++; continue;
         }

         if(intellRuns[i].breached || intellRuns[i].passed)
         {
            IntellRemoveActive(i);
            cnt = ArraySize(intellActiveIdx);
            continue;
         }

         // Check daily protection trigger
         if(IntellEnableDailyDrawdown && intellRuns[i].pos.open &&
            !intellRuns[i].protectionTriggeredToday)
         {
            double ddProtect = intellRuns[i].dayStartReference * MathMax(0.0, IntellDailyDrawdownPercent - IntellDailyProtectionBufferPercent) / 100.0;
            double equity = intellRuns[i].balance + IntellPositionProfit(i);
            if(ddProtect > 0.0 && equity <= intellRuns[i].dayStartReference - ddProtect)
            {
               intellRuns[i].equityProtectionTriggers++;
               intellRuns[i].protectionTriggeredToday = true;
               double profit = IntellPositionProfit(i);
               IntellCloseVirtualPosition(i, profit, barTime);
            }
         }

         // Manage open position
         if(intellRuns[i].pos.open)
         {
            double hitProfit = 0.0;
            if(IntellCheckSlTpHit(i, barHigh, barLow, hitProfit))
            {
               IntellCloseVirtualPosition(i, hitProfit, barTime);
            }
            else
            {
               intellRuns[i].equity = intellRuns[i].balance + IntellPositionProfit(i);
            }
         }
         else
         {
            intellRuns[i].equity = intellRuns[i].balance;
         }

         intellRuns[i].maxDrawdown = MathMax(intellRuns[i].maxDrawdown, intellRuns[i].startingBalance - intellRuns[i].equity);
         intellRuns[i].maxProfit = MathMax(intellRuns[i].maxProfit, intellRuns[i].equity - intellRuns[i].startingBalance);

         // Check pass/breach
         double target = intellRuns[i].startingBalance * IntellProfitTargetPercent / 100.0;
         double maxDD = intellRuns[i].startingBalance * IntellMaxTotalDrawdownPercent / 100.0;
         double totalDD = intellRuns[i].startingBalance - intellRuns[i].equity;
         double dailyDD = intellRuns[i].dayStartReference - intellRuns[i].equity;
         double dailyBreach = intellRuns[i].dayStartReference * IntellDailyDrawdownPercent / 100.0;
         bool finished = false;

         if(intellRuns[i].equity - intellRuns[i].startingBalance >= target)
         {
            intellRuns[i].passed = true;
            intellRuns[i].ended = barTime;
            intellRuns[i].daysToTarget = (int)((barTime - intellRuns[i].startDay) / 86400) + 1;
            intellRuns[i].tradesToTarget = intellRuns[i].trades;
            intellRuns[i].breachReason = "Target hit";
            if(intellRuns[i].pos.open) IntellCloseVirtualPosition(i, IntellPositionProfit(i), barTime);
            finished = true;
         }
         else if(totalDD >= maxDD || (IntellEnableDailyDrawdown && dailyDD >= dailyBreach))
         {
            intellRuns[i].breached = true;
            intellRuns[i].ended = barTime;
            intellRuns[i].daysToBreach = (int)((barTime - intellRuns[i].startDay) / 86400) + 1;
            intellRuns[i].tradesToBreach = intellRuns[i].trades;
            if(IntellEnableDailyDrawdown && totalDD >= maxDD && dailyDD >= dailyBreach)
               intellRuns[i].breachReason = "Total + Daily DD";
            else if(totalDD >= maxDD) intellRuns[i].breachReason = "Total DD";
            else intellRuns[i].breachReason = "Daily DD";
            if(intellRuns[i].pos.open) IntellCloseVirtualPosition(i, IntellPositionProfit(i), barTime);
            finished = true;
         }

         if(finished)
         {
            IntellRemoveActive(i);
            cnt = ArraySize(intellActiveIdx);
            continue;
         }

         // Open new position if signal
         if(!intellRuns[i].pos.open && !intellRuns[i].protectionTriggeredToday)
         {
            int dir = intellSignalCache[intellRuns[i].strategyId - 1];
            if(dir != 0)
            {
               if(ReverseSignals) dir = (dir == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
               if((AllowedDirection != SIGNAL_BOTH) &&
                  ((AllowedDirection == SIGNAL_BUY_ONLY && dir == ORDER_TYPE_SELL) ||
                   (AllowedDirection == SIGNAL_SELL_ONLY && dir == ORDER_TYPE_BUY)))
               { k++; continue; }
               IntellOpenVirtualPosition(i, dir, barTime);
            }
         }
         k++;
      }

       g_intellScanCurrentBar--;
       g_intellProcessedBars++;
       if(g_intellProcessedBars % 50 == 0 || g_intellProcessedBars <= 3)
          Print("SCAN " + IntegerToString(g_intellProcessedBars) + "/" + IntegerToString(g_intellTotalBars) + " bars | " + IntegerToString(ArraySize(intellActiveIdx)) + " active runs");
       g_intellScanShift = 0;

       if(g_intellScanCurrentBar < g_intellScanEndBar || g_intellProcessedBars >= g_intellTotalBars)
        {
           g_intellState = INTELL_SCAN_DONE;
           string modeStr = IntellSelectWorst ? "WORST" : "BEST";
           Print("SCAN DONE | " + IntegerToString(g_intellProcessedBars) + " bars | " + IntegerToString(ArraySize(intellRuns)) + " runs | Select " + modeStr + " @" + IntegerToString(IntellMinPassRateOrBlown) + "% | MaxAge=" + IntegerToString(IntellMaxMinutesSinceLastTrade) + "m | Spawn=" + IntellSpawnIntervalLabel());
          LogEvent("INTELL_SCAN_DONE", "Processed " + IntegerToString(g_intellProcessedBars) + " bars, " +
             IntegerToString(ArraySize(intellRuns)) + " runs");
      }
   }
    void IntellBuildTopCandidates()
    {
       int passes[PROP_STRATEGY_COUNT];
       int trades[PROP_STRATEGY_COUNT];
       int wins[PROP_STRATEGY_COUNT];
       int losses[PROP_STRATEGY_COUNT];
       int totalComps[PROP_STRATEGY_COUNT];
       int activeCount[PROP_STRATEGY_COUNT];
       double netPL[PROP_STRATEGY_COUNT];
       double grossProfit[PROP_STRATEGY_COUNT];
       double grossLoss[PROP_STRATEGY_COUNT];
       datetime lastClose[PROP_STRATEGY_COUNT];
       ArrayInitialize(passes, 0); ArrayInitialize(trades, 0);
       ArrayInitialize(wins, 0); ArrayInitialize(losses, 0);
       ArrayInitialize(totalComps, 0); ArrayInitialize(activeCount, 0);
       ArrayInitialize(netPL, 0.0); ArrayInitialize(lastClose, 0);
       ArrayInitialize(grossProfit, 0.0); ArrayInitialize(grossLoss, 0.0);

       int runCount = ArraySize(intellRuns);
       for(int i = 0; i < runCount; i++)
       {
          int sid = intellRuns[i].strategyId - 1;
          if(sid < 0 || sid >= PROP_STRATEGY_COUNT) continue;
          trades[sid] += intellRuns[i].trades;
          wins[sid] += intellRuns[i].wins;
          losses[sid] += intellRuns[i].losses;
          netPL[sid] += intellRuns[i].balance - intellRuns[i].startingBalance;
          grossProfit[sid] += intellRuns[i].grossProfit;
          grossLoss[sid] += intellRuns[i].grossLoss;
          if(intellRuns[i].lastClosedTradeTime > lastClose[sid])
             lastClose[sid] = intellRuns[i].lastClosedTradeTime;
          if(intellRuns[i].passed || intellRuns[i].breached)
          {
             totalComps[sid]++;
             if(intellRuns[i].passed) passes[sid]++;
          }
          else activeCount[sid]++;
       }

       g_intellTopCount = 0;
       datetime now = TimeCurrent();
       double targetRate = (double)IntellMinPassRateOrBlown;

        for(int sid = 0; sid < PROP_STRATEGY_COUNT; sid++)
        {
           int tc = totalComps[sid];
           int act = activeCount[sid];
           int totalRuns = tc + act;
           if(totalRuns == 0) continue;
           double passRate = tc > 0 ? (double)passes[sid] / tc * 100.0 : 0.0;
           double blownRate = tc > 0 ? (double)(tc - passes[sid]) / tc * 100.0 : 0.0;

           int t = trades[sid];
           int w = wins[sid];
           int l = losses[sid];
           int cd = w + l;
           double wr = cd > 0 ? (double)w / cd * 100.0 : 0.0;
           double pf = l > 0 ? (double)w / l : (w > 0 ? 999.0 : 0.0);

           double candidateScore = IntellSelectWorst ? blownRate : passRate;

           string reject = "";
           if(tc == 0)
           {
              reject = IntegerToString(totalRuns) + " active, 0 completed";
           }
           else
           {
              int minsSince = lastClose[sid] > 0 ? (int)((now - lastClose[sid]) / 60) : 999999;
              if(minsSince > IntellMaxMinutesSinceLastTrade) reject += "last trade " + IntegerToString(minsSince) + "m ago > " + IntegerToString(IntellMaxMinutesSinceLastTrade) + "m | ";
              if(IntellSelectWorst)
              {
                 if(passes[sid] > 0) reject += IntegerToString(passes[sid]) + " passed | ";
                 if(blownRate < targetRate) reject += "blown " + DoubleToString(blownRate, 1) + "% < " + DoubleToString(targetRate, 1) + "% | ";
              }
              else
              {
                 if(tc - passes[sid] > 0) reject += IntegerToString(tc - passes[sid]) + " blown | ";
                 if(passRate < targetRate) reject += "pass " + DoubleToString(passRate, 1) + "% < " + DoubleToString(targetRate, 1) + "% | ";
              }
           }
            if(act > 0) reject += IntegerToString(act) + " active | ";
           if(reject != "") reject = "✗ " + reject;
           if(reject == "") reject = "✓ QUALIFIED";

           int ins = g_intellTopCount;
           for(int ti = 0; ti < g_intellTopCount; ti++)
           {
              bool better = IntellSelectWorst ?
                 (candidateScore > g_intellTopScore[ti] || (tc > 0 && g_intellTopTotalComps[ti] == 0)) :
                 (candidateScore < g_intellTopScore[ti] || (tc > 0 && g_intellTopTotalComps[ti] == 0));
              if(better) { ins = ti; break; }
           }
          if(ins < 10)
          {
             for(int ti = 9; ti > ins; ti--)
             {
                g_intellTopIds[ti] = g_intellTopIds[ti-1];
                g_intellTopScore[ti] = g_intellTopScore[ti-1];
                g_intellTopPassRate[ti] = g_intellTopPassRate[ti-1];
                g_intellTopBlownRate[ti] = g_intellTopBlownRate[ti-1];
                g_intellTopTotalComps[ti] = g_intellTopTotalComps[ti-1];
                g_intellTopActive[ti] = g_intellTopActive[ti-1];
                g_intellTopWR[ti] = g_intellTopWR[ti-1];
                g_intellTopPF[ti] = g_intellTopPF[ti-1];
                g_intellTopRR[ti] = g_intellTopRR[ti-1];
                g_intellTopRejection[ti] = g_intellTopRejection[ti-1];
             }
             g_intellTopIds[ins] = sid + 1;
             g_intellTopScore[ins] = candidateScore;
             g_intellTopPassRate[ins] = passRate;
             g_intellTopBlownRate[ins] = blownRate;
             g_intellTopTotalComps[ins] = tc;
             g_intellTopActive[ins] = act;
             g_intellTopWR[ins] = wr;
             g_intellTopPF[ins] = pf;
              {
                 double avgWin = wins[sid] > 0 ? grossProfit[sid] / wins[sid] : 0.0;
                 double avgLoss = losses[sid] > 0 ? MathAbs(grossLoss[sid]) / losses[sid] : 0.0;
                 g_intellTopRR[ins] = avgLoss > 0.0 ? avgWin / avgLoss : (avgWin > 0.0 ? 999.0 : 0.0);
              }
             g_intellTopRejection[ins] = reject;
             if(g_intellTopCount < 10) g_intellTopCount++;
          }
       }
    }

    void IntellSelectStrategy()
    {
       g_intellSelectedStratId = 0;
      g_intellTopCount = 0;
      int totalStrats = 0;
      int passes[PROP_STRATEGY_COUNT];
      int trades[PROP_STRATEGY_COUNT];
      int wins[PROP_STRATEGY_COUNT];
      int losses[PROP_STRATEGY_COUNT];
      datetime lastClose[PROP_STRATEGY_COUNT];
      double recencyWeight[PROP_STRATEGY_COUNT];
      double recencyPassWeight[PROP_STRATEGY_COUNT];
       double netPL[PROP_STRATEGY_COUNT];
       double grossProfit[PROP_STRATEGY_COUNT];
       double grossLoss[PROP_STRATEGY_COUNT];
       int closed[PROP_STRATEGY_COUNT];
       int breached[PROP_STRATEGY_COUNT];
       int actives[PROP_STRATEGY_COUNT];
       ArrayInitialize(passes, 0); ArrayInitialize(trades, 0);
       ArrayInitialize(wins, 0); ArrayInitialize(losses, 0);
       ArrayInitialize(lastClose, 0);
       ArrayInitialize(recencyWeight, 0.0);
       ArrayInitialize(recencyPassWeight, 0.0);
       ArrayInitialize(netPL, 0.0);
       ArrayInitialize(grossProfit, 0.0); ArrayInitialize(grossLoss, 0.0);
       ArrayInitialize(closed, 0);
       ArrayInitialize(breached, 0);
       ArrayInitialize(actives, 0);

       datetime now = TimeCurrent();
       double lambda = IntellRecencyHalfLifeDays > 0.0 ? MathLog(2.0) / IntellRecencyHalfLifeDays : 0.0;

       for(int i = 0; i < ArraySize(intellRuns); i++)
       {
          int sid = intellRuns[i].strategyId - 1;
          if(sid < 0 || sid >= PROP_STRATEGY_COUNT) continue;
          totalStrats = MathMax(totalStrats, sid + 1);
          if(intellRuns[i].passed) passes[sid]++;
          if(intellRuns[i].breached) breached[sid]++;
          if(intellRuns[i].passed || intellRuns[i].breached) closed[sid]++;
          if(!intellRuns[i].passed && !intellRuns[i].breached) actives[sid]++;
          trades[sid] += intellRuns[i].trades;
          wins[sid] += intellRuns[i].wins;
          losses[sid] += intellRuns[i].losses;
          netPL[sid] += intellRuns[i].balance - intellRuns[i].startingBalance;
          grossProfit[sid] += intellRuns[i].grossProfit;
          grossLoss[sid] += intellRuns[i].grossLoss;
         if(intellRuns[i].lastClosedTradeTime > lastClose[sid])
            lastClose[sid] = intellRuns[i].lastClosedTradeTime;
         if(lambda > 0.0)
         {
            double age = (double)(now - intellRuns[i].startDay) / 86400.0;
            double w = MathExp(-lambda * age);
            recencyWeight[sid] += w;
            if(intellRuns[i].passed) recencyPassWeight[sid] += w;
         }
      }

      int bestId = 0;
      double bestScore = IntellSelectWorst ? -1e99 : 1e99;
      int eligibleCount = 0;
       double targetRate = (double)IntellMinPassRateOrBlown;

       for(int sid = 0; sid < totalStrats; sid++)
       {
           int totalComps = closed[sid];
          int activeCount = actives[sid];
          int totalRuns = totalComps + activeCount;
          if(totalRuns == 0) continue;

          double passRate = totalComps > 0 ? (double)passes[sid] / totalComps * 100.0 : 0.0;
          double blownRate = totalComps > 0 ? (double)breached[sid] / totalComps * 100.0 : 0.0;

          int minsSince = lastClose[sid] > 0 ? (int)((now - lastClose[sid]) / 60) : 999999;

          int t = trades[sid];
          int w = wins[sid];
          int l = losses[sid];
          int cd = w + l;
          double wr = cd > 0 ? (double)w / cd * 100.0 : 0.0;
          double pf = l > 0 ? (double)w / l : (w > 0 ? 999.0 : 0.0);
           double avgWin = wins[sid] > 0 ? grossProfit[sid] / wins[sid] : 0.0;
           double avgLoss = losses[sid] > 0 ? MathAbs(grossLoss[sid]) / losses[sid] : 0.0;
           double rr = avgLoss > 0.0 ? avgWin / avgLoss : (avgWin > 0.0 ? 999.0 : 0.0);

           double candidateScore = IntellSelectWorst ? blownRate : passRate;

          // Build rejection reason & eligibility
          bool isEligible = true;
          string reject = "";
          if(totalComps == 0)
          {
             isEligible = false;
             reject = IntegerToString(totalRuns) + " active, 0 completed";
          }
          else
          {
               if(minsSince > IntellMaxMinutesSinceLastTrade)
               {
                  isEligible = false;
                  reject += "last " + IntegerToString(minsSince) + "m ago > " + IntegerToString(IntellMaxMinutesSinceLastTrade) + "m | ";
               }
               int hoursSinceLastTrade = (int)((now - g_intellLastTradeCloseTime) / 3600);
               if(sid + 1 == g_intellLastTradedStratId && g_intellLastTradeCloseTime > 0 && hoursSinceLastTrade < IntellMinHoursBetweenSameStrat)
               {
                  isEligible = false;
                  reject += "cooldown " + IntegerToString(hoursSinceLastTrade) + "h < " + IntegerToString(IntellMinHoursBetweenSameStrat) + "h | ";
               }
              if(IntellSelectWorst)
              {
                 if(blownRate < targetRate) { isEligible = false; reject += "blown " + DoubleToString(blownRate, 1) + "% < " + DoubleToString(targetRate, 1) + "% | "; }
                 if(passes[sid] > 0) reject += IntegerToString(passes[sid]) + " passed | ";
              }
              else
              {
                 if(passRate < targetRate) { isEligible = false; reject += "pass " + DoubleToString(passRate, 1) + "% < " + DoubleToString(targetRate, 1) + "% | "; }
                 if(breached[sid] > 0) reject += IntegerToString(breached[sid]) + " blown | ";
              }
           }
           if(activeCount > 0) reject += IntegerToString(activeCount) + " active | ";
           if(reject != "") reject = "✗ " + reject;
           if(isEligible) reject = "✓ QUALIFIED";

           // Select best eligible
           if(isEligible)
           {
              eligibleCount++;
              if(IntellSelectWorst)
              {
                 double score = candidateScore * 10000.0 - netPL[sid];
                 if(score > bestScore) { bestScore = score; bestId = sid + 1; }
              }
              else
              {
                 double score = candidateScore * 10000.0 + netPL[sid];
                 if(score < bestScore) { bestScore = score; bestId = sid + 1; }
              }
           }

          // Always track top candidates for display (up to 10)
          int ins = g_intellTopCount;
          for(int ti = 0; ti < g_intellTopCount; ti++)
          {
             bool better = IntellSelectWorst ?
                (candidateScore > g_intellTopScore[ti] || (totalComps > 0 && g_intellTopTotalComps[ti] == 0)) :
                (candidateScore < g_intellTopScore[ti] || (totalComps > 0 && g_intellTopTotalComps[ti] == 0));
             if(better) { ins = ti; break; }
          }
         if(ins < 10)
         {
            for(int ti = 9; ti > ins; ti--)
            {
               g_intellTopIds[ti] = g_intellTopIds[ti-1];
               g_intellTopScore[ti] = g_intellTopScore[ti-1];
               g_intellTopPassRate[ti] = g_intellTopPassRate[ti-1];
               g_intellTopBlownRate[ti] = g_intellTopBlownRate[ti-1];
               g_intellTopTotalComps[ti] = g_intellTopTotalComps[ti-1];
               g_intellTopActive[ti] = g_intellTopActive[ti-1];
               g_intellTopWR[ti] = g_intellTopWR[ti-1];
               g_intellTopPF[ti] = g_intellTopPF[ti-1];
               g_intellTopRR[ti] = g_intellTopRR[ti-1];
               g_intellTopRejection[ti] = g_intellTopRejection[ti-1];
            }
            g_intellTopIds[ins] = sid + 1;
            g_intellTopScore[ins] = candidateScore;
            g_intellTopPassRate[ins] = passRate;
            g_intellTopBlownRate[ins] = blownRate;
            g_intellTopTotalComps[ins] = totalComps;
            g_intellTopActive[ins] = activeCount;
            g_intellTopWR[ins] = wr;
            g_intellTopPF[ins] = pf;
            g_intellTopRR[ins] = rr;
            g_intellTopRejection[ins] = reject;
            if(g_intellTopCount < 10) g_intellTopCount++;
         }
      }

      if(bestId > 0)
      {
         g_intellSelectedStratId = bestId;
         g_intellState = INTELL_READY;
         string mode = IntellSelectWorst ? "WORST" : "BEST";
         Print("SELECTED #" + IntegerToString(bestId) + " " + StrategyName(bestId) + " | " + IntegerToString(eligibleCount) + " eligible out of " + IntegerToString(g_intellTopCount) + " candidates");
         LogEvent("INTELL_SELECT", "Selected " + mode + " strategy #" + IntegerToString(bestId) +
            " " + StrategyName(bestId) + " (" + IntegerToString(eligibleCount) + " eligible)");
      }
      else
      {
         g_intellRetryTime = TimeCurrent() + MathMax(60, IntellRetryMinutes * 60);
         g_intellState = INTELL_RETRY_WAIT;
         LogEvent("INTELL_RETRY", "No eligible strategy found (" + IntegerToString(eligibleCount) +
            " eligible), retry in " + IntegerToString(IntellRetryMinutes) + "m");
      }
   }

   void IntellTradeTick()
   {
      if(g_intellSelectedStratId <= 0) { g_intellState = INTELL_SCANNING; return; }

      _CacheRefresh();
      _CacheHL();

      if(CountOpenPositions() > 0)
      {
         g_intellState = INTELL_TRADING;
         return;
      }

      StrategySignal sig;
      sig.buyVotes = 0; sig.sellVotes = 0; sig.details = "";
      EvaluateStrategy(g_intellSelectedStratId, sig);

      int dir = 0;
      if(sig.buyVotes > 0) dir = ORDER_TYPE_BUY;
      else if(sig.sellVotes > 0) dir = ORDER_TYPE_SELL;
      else return;

      if(ReverseSignals) dir = (dir == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
      if((AllowedDirection == SIGNAL_BUY_ONLY && dir == ORDER_TYPE_SELL) ||
         (AllowedDirection == SIGNAL_SELL_ONLY && dir == ORDER_TYPE_BUY)) return;

      ulong ticket = OpenTrade(dir, sig);
      if(ticket > 0)
       {
          g_intellTradeTicket = ticket;
          g_intellState = INTELL_TRADING;
          g_intellLastTradedStratId = g_intellSelectedStratId;
          LogEvent("INTELL_TRADE", "Opened " + (dir == ORDER_TYPE_BUY ? "BUY" : "SELL") +
            " using #" + IntegerToString(g_intellSelectedStratId) + " " +
            StrategyName(g_intellSelectedStratId) + " ticket=" + IntegerToString((long)ticket));
      }
   }

   void IntellTick()
   {
      if(!EnableIntelligentTrader || eaStopped) return;

      switch(g_intellState)
      {
         case INTELL_IDLE:
            if(g_intellAutoStartTick > 0 && GetTickCount() >= g_intellAutoStartTick)
            {
               g_intellAutoStartTick = 0;
               g_intellScanCurrentBar = g_intellScanStartBar;
               g_intellProcessedBars = 0;
               g_intellScanShift = 0;
               g_intellState = INTELL_SCANNING;
               LogEvent("INTELL_START", "Auto-start scanning " + IntegerToString(g_intellTotalBars) + " bars (" + IntegerToString(ArraySize(intellRuns)) + " runs)");
            }
            break;

         case INTELL_SCANNING:
            IntellProcessNextBar();
            break;

          case INTELL_SCAN_DONE:
             IntellSelectStrategy();
             for(int ti = 0; ti < MathMin(g_intellTopCount, 5); ti++)
             {
                int sid = g_intellTopIds[ti];
                 Print("  #" + IntegerToString(ti + 1) + " #" + IntegerToString(sid) + " " + StrategyName(sid) +
                    " R" + IntegerToString(g_intellTopTotalComps[ti] + g_intellTopActive[ti]) +
                    " P" + DoubleToString(g_intellTopPassRate[ti], 1) +
                    "% B" + DoubleToString(g_intellTopBlownRate[ti], 1) +
                    " WR" + DoubleToString(g_intellTopWR[ti], 1) +
                    "% PF" + DoubleToString(g_intellTopPF[ti], 1) +
                    " " + g_intellTopRejection[ti]);
             }
             break;

         case INTELL_READY:
            IntellTradeTick();
            break;

         case INTELL_TRADING:
         {
            // Check if trade is still open
            if(g_intellTradeTicket > 0 && PositionSelectByTicket(g_intellTradeTicket))
            {
               // Trade is still alive - manage it
               ManageVirtualDollarExits();
               if(CheckProtectionStops()) return;
               if(GlobalIsCloseTime()) { CloseAllEaPositions(); }
            }
             else
              {
                 // Trade closed — full fresh re-scan from scratch
                 g_intellTradeTicket = 0;
                 g_intellLastTradeCloseTime = TimeCurrent();
                 g_intellSelectedStratId = 0;
                 LogEvent("INTELL_TRADE_CLOSE", "Trade closed, full rescan from scratch");
                 IntellInit();
                 return;
              }
            break;
         }

           case INTELL_RETRY_WAIT:
              if(TimeCurrent() >= g_intellRetryTime)
              {
                 g_intellSelectedStratId = 0;
                 LogEvent("INTELL_RETRY_END", "Retry timer expired, full rescan");
                 IntellInit();
                 return;
              }
              break;
      }
   }
