      double t5CompletedPassRate = (t5Passed + t5Blown > 0) ? (double)t5Passed / (double)(t5Passed + t5Blown) * 100.0 : 0.0;
      string top5html = "<div class=\"section\">\n<h2>Top 5 Strategies Summary</h2>\n<div class=\"cards\">\n" +
