   void PropWriteCommonSettings(const int handle, const datetime testStart, const datetime testEnd)
   {
      FileWriteString(handle, PropKv("Symbol", _Symbol));
      FileWriteString(handle, PropKv("Period", EnumToString(g_intellTimeframe)));
      FileWriteString(handle, PropKv("Magic Number", IntegerToString((long)MagicNumber)));
      FileWriteString(handle, PropKv("Strategy Mode", EnumToString(StrategyMode)));
      FileWriteString(handle, PropKv("Allowed Direction", EnumToString(AllowedDirection)));
      FileWriteString(handle, PropKv("One Trade Per Bar", PropBoolStr(OneTradePerBar)));
      FileWriteString(handle, PropKv("Reverse Signals", PropBoolStr(ReverseSignals)));
      FileWriteString(handle, PropKv("Starting Balance", DoubleToString(PropStartingBalance, 2)));
      FileWriteString(handle, PropKv("Profit Target", DoubleToString(PropProfitTargetPercent, 2) + "%"));
      FileWriteString(handle, PropKv("Max Total Drawdown", DoubleToString(PropMaxTotalDrawdownPercent, 2) + "%"));
      FileWriteString(handle, PropKv("Daily Drawdown Enabled", PropBoolStr(PropEnableDailyDrawdown)));
      FileWriteString(handle, PropKv("Daily Drawdown", DoubleToString(PropDailyDrawdownPercent, 2) + "%"));
      FileWriteString(handle, PropKv("Daily Protection Buffer", DoubleToString(PropDailyProtectionBufferPercent, 2) + "%"));
      FileWriteString(handle, PropKv("Daily Reset (UTC)", StringFormat("%02d:%02d", PropDailyResetHourUTC, PropDailyResetMinuteUTC)));
      FileWriteString(handle, PropKv("Pause Signals (UTC)", StringFormat("%02d:%02d", PropPauseSignalsHourUTC, PropPauseSignalsMinuteUTC)));
      FileWriteString(handle, PropKv("Close All (UTC)", StringFormat("%02d:%02d", PropCloseAllHourUTC, PropCloseAllMinuteUTC)));
      FileWriteString(handle, PropKv("Resume Signals (UTC)", StringFormat("%02d:%02d", PropResumeSignalsHourUTC, PropResumeSignalsMinuteUTC)));
      FileWriteString(handle, PropKv("Force Close Enabled", PropBoolStr(PropEnableForceClose)));
      FileWriteString(handle, PropKv("Pause Signals Enabled", PropBoolStr(PropEnablePauseSignals)));
      FileWriteString(handle, PropKv("Spawn Interval", PropSpawnIntervalLabel()));
      FileWriteString(handle, PropKv("Recency Half-Life (days)", DoubleToString(PropRecencyHalfLifeDays, 1) + (PropRecencyHalfLifeDays > 0.0 ? "" : " (disabled)")));
      FileWriteString(handle, PropKv("Prop Strategy Mode", (PropStrategyMode == PROP_STRATEGY_CUSTOM) ? ("CUSTOM: " + PropCustomStrategies) : "ALL"));
      FileWriteString(handle, PropKv("Virtual Dollar Exit", PropBoolStr(EnableVirtualDollarExit)));
      FileWriteString(handle, PropKv("Virtual Exit Lot", DoubleToString(VirtualExitLot, 2)));
      FileWriteString(handle, PropKv("Virtual Take Profit", DoubleToString(VirtualTakeProfitMoney, 2)));
      FileWriteString(handle, PropKv("Virtual Stop Loss", DoubleToString(VirtualStopLossMoney, 2)));
      FileWriteString(handle, PropKv("Test Started", TimeToString(testStart, TIME_DATE | TIME_MINUTES)));
      FileWriteString(handle, PropKv("Report Generated", TimeToString(testEnd, TIME_DATE | TIME_SECONDS)));
      double totalDays = (testEnd > testStart) ? (double)(testEnd - testStart) / 86400.0 : 0.0;
      FileWriteString(handle, PropKv("Total Backtested Days", DoubleToString(totalDays, 0) + " Days"));
   }

   void PropWriteMethodology(const int handle)
   {
      FileWriteString(handle,
         "<div class=\"section\">\n<h2>Methodology &mdash; How Scores Are Calculated</h2>\n<div class=\"method\">\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Pass Rate (All-Time)</h3>\n" +
         "<p>Passed runs &divide; total starts for the strategy, shown as a percentage. A run <b>passes</b> when equity reaches the profit target (" + DoubleToString(PropProfitTargetPercent, 1) + "% of starting balance) before any rule breach. A run <b>blows</b> when total drawdown exceeds " + DoubleToString(PropMaxTotalDrawdownPercent, 1) + "% or daily drawdown exceeds " + DoubleToString(PropDailyDrawdownPercent, 1) + "%.</p>\n" +
         "<p><b>Caution:</b> Pass rate rewards strategies that hit the profit target <i>quickly</i>. A fast strategy resolves runs as &ldquo;passed&rdquo; before it ever has time to blow, inflating its pass rate. Slower-but-safer strategies accumulate &ldquo;active&rdquo; (unresolved) runs that drag their pass rate down without indicating any real risk. Use <b>True Blow Risk</b> and <b>Safety Score</b> below to judge actual danger.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>True Blow Risk</h3>\n" +
         "<p>Blown runs &divide; (passed + blown runs), shown as a percentage. This <b>excludes active (unresolved) runs entirely</b>, so it answers: <i>of the runs that actually finished one way or the other, what fraction blew?</i></p>\n" +
         "<p>Unlike pass rate, this is not distorted by speed. A strategy with 0% blow risk has <b>never</b> blown a single account among all resolved runs &mdash; the safest possible record. Lower is better. A strategy with 80% pass rate and 5% blow risk is far safer than one with 83% pass rate and 13% blow risk, even though the report sorts them in the opposite order by pass rate alone.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Safety Score</h3>\n" +
         "<p>100 &minus; True Blow Risk. Higher is safer. A score of 100 means the strategy has never blown an account (0% blow risk). A score of 85 means 15% of resolved runs blew. This is the single most reliable column for ranking by <b>risk of failure</b> rather than speed of success.</p>\n" +
         "<p><b>How to read it:</b> Sort by this column (click the header) to find the strategies least likely to breach propfirm drawdown rules. Pair high-safety strategies with high-recency strategies to get both durability and current-regime fit.</p>\n</div>\n");
      if(PropRecencyHalfLifeDays > 0.0)
      {
         FileWriteString(handle,
            "<div class=\"m-item\">\n<h3>Recency Score</h3>\n" +
            "<p>Exponential time-weighted pass rate. Each run is weighted by <code>w = exp(-&lambda;&middot;age)</code>, where <i>age</i> is days since the run started and <code>&lambda; = ln(2) / " + DoubleToString(PropRecencyHalfLifeDays, 1) + "</code> (the half-life in days). Older runs contribute exponentially less. Score = &Sigma;(passed&middot;w) &divide; &Sigma;(all&middot;w). The ranking uses this score when recency is enabled.</p>\n</div>\n");
      }
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Trend (sparkline)</h3>\n" +
         "<p>Per-day cumulative net = &Sigma;(passes &minus; breaches) up to that day. Each strategy is ranked daily by that day's pass rate; the sparkline plots the running cumulative net &mdash; <span style=\"color:#16a34a\">green</span> = net positive, <span style=\"color:#dc2626\">red</span> = net negative. Hover for the daily breakdown.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Persistence Score (0&ndash;100)</h3>\n" +
         "<p>A composite of how consistently a strategy stays near the top of the daily ranking. It is a weighted blend of four sub-metrics (shown in the five green-tinted columns):</p>\n" +
         "<ul>\n" +
         "<li><b>Top10% (weight 40%)</b> &mdash; share of ranked days the strategy placed in the top 10.</li>\n" +
         "<li><b>Avg Rank (weight 25%)</b> &mdash; mean daily rank normalized to 0&ndash;100 (higher is better): (N &minus; avgRank) / (N &minus; 1) &times; 100.</li>\n" +
         "<li><b>Stability (weight 20%)</b> &mdash; 100 minus rank volatility, where volatility = mean absolute day-to-day rank change normalized by the number of ranked strategies.</li>\n" +
         "<li><b>Momentum (weight 15%)</b> &mdash; compares the average rank of the recent half of days to the earlier half. 50 = no change, &gt;50 = improving, &lt;50 = declining.</li>\n" +
         "</ul>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Profit Factor (PF)</h3>\n" +
         "<p>Gross profit &divide; |gross loss| across all runs of the strategy. PF &ge; 1 indicates net profitable trading.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Avg R:R (Reward : Risk)</h3>\n" +
         "<p>Average win ($) &divide; average loss ($) per strategy, where each trade exits at the Virtual Take Profit / Stop Loss money thresholds.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Net P/L (Avg / Best / Worst)</h3>\n" +
         "<p>End balance &minus; starting balance. <b>Avg Net</b> is the mean across runs; <b>Best</b> and <b>Worst Net</b> are the single most and least profitable runs for the strategy.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Ranking / Sort Order</h3>\n" +
         "<p>Strategies are sorted by <b>recency score</b> when enabled (then all-time pass rate, then average net P/L as tiebreakers); otherwise by all-time pass rate then average net P/L. Click any column header to re-sort the table.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Avg Trades to Hit Target / Blow &mdash; (P) and (B)</h3>\n" +
         "<p><b>(P)</b> = Average number of trades to hit the profit target (passed runs). <b>(B)</b> = Average number of trades before the account blew (breached runs). In the prerun table the column shows both, e.g. <code>2.9 (P) / 3.0 (B)</code>. In per-run detail each run shows only its outcome, e.g. <code>2 (P)</code> for a passed run or <code>3 (B)</code> for a blown run.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Winning &amp; Losing Streaks &mdash; (M) and (A)</h3>\n" +
         "<p><b>(M)</b> = Maximum consecutive wins/losses across all runs of the strategy. <b>(A)</b> = Average of the max streaks per run. Displayed as <code>Max(M) / Avg(A)</code>, e.g. <code>5 (M) / 2.3 (A)</code> means the best run had 5 consecutive wins and the average max win streak across runs was 2.3.</p>\n</div>\n");
      FileWriteString(handle,
         "<div class=\"m-item\">\n<h3>Active Runs &mdash; How to Read</h3>\n" +
         "<p><b>Active Runs</b> are strategies still running at the end of the test period &mdash; they neither passed (hit profit target) nor blew (breached a rule). They remain unresolved.</p>\n" +
         "<ul>\n" +
         "<li><b>Active in Profit / Active in Drawdown</b> &mdash; the split of active runs by whether their current equity is above (<span style=\"color:#059669\">profit</span>) or below (<span style=\"color:#dc2626\">drawdown</span>) the starting balance. E.g. &ldquo;72.9% of 85 active runs are in profit&rdquo;.</li>\n" +
         "<li><b>Avg +2.2% / Avg -2.2%</b> &mdash; the <i>average equity change</i> of those active runs. &ldquo;Avg +2.2%&rdquo; means the profit-side runs are on average 2.2% above start; &ldquo;Avg -2.2%&rdquo; means the drawdown-side runs are on average 2.2% below start. This tells you <i>how deep</i> the active profit/drawdown is, not just how many runs are in each group.</li>\n" +
         "<li><b>Why it matters:</b> A high percentage of active runs in drawdown sounds alarming, but if the average depth is only -1%, those runs are barely underwater. Conversely, a small fraction in drawdown at -10% depth is a bigger concern. Always pair the percentage with the depth.</li>\n" +
         "</ul>\n</div>\n");
      FileWriteString(handle, "</div>\n</div>\n");
   }

