   void IntellUpdateDashboard()
   {
      if(!EnableIntellDashboard) { IntellDeleteDashboard(); return; }
      uint nowTick = GetTickCount();
      if(nowTick - g_intellLastDashboardTick < (uint)IntellDashboardRefreshMs) return;
      g_intellLastDashboardTick = nowTick;

      IntellCreateDashboard();
      ObjectSetString(0, INTELL_PREFIX + "TITLE", OBJPROP_TEXT, " INTELLIGENT LIVE TRADER v1.0");

      int ln = 0;
      if(!EnableIntelligentTrader)
      {
         IntellSetLine(ln++, "INTELLIGENT TRADER DISABLED", IntellWarnColor());
         IntellSetLine(ln++, "Set EnableIntelligentTrader=true to activate", IntellMutedColor());
      }
      else
      {
         string stateStr = "";
         color stateCol = IntellMutedColor();
         switch(g_intellState)
         {
            case INTELL_IDLE:      stateStr = "IDLE";       stateCol = IntellMutedColor(); break;
            case INTELL_SCANNING:  stateStr = "SCANNING";   stateCol = IntellWarnColor();  break;
            case INTELL_SCAN_DONE: stateStr = "SCAN DONE";  stateCol = IntellGoodColor();  break;
            case INTELL_READY:     stateStr = "READY";      stateCol = IntellGoodColor();  break;
            case INTELL_TRADING:   stateStr = "TRADING";    stateCol = IntellGoodColor();  break;
            case INTELL_RETRY_WAIT:stateStr = "RETRY WAIT"; stateCol = IntellBadColor();   break;
         }
         IntellSetLine(ln++, "STATE: " + stateStr, stateCol);
         IntellSetLine(ln++, "Override: normal StrategyMode/SingleStrategy is IGNORED", IntellWarnColor());

         datetime ds = iTime(_Symbol, g_intellTimeframe, g_intellScanStartBar);
         datetime de = iTime(_Symbol, g_intellTimeframe, g_intellScanEndBar);
          string rangeStr = (ds > 0 && de > 0) ? TimeToString(ds, TIME_DATE|TIME_MINUTES) + "  ->  " + TimeToString(de, TIME_DATE|TIME_MINUTES) : "N/A";
         IntellSetLine(ln++, "SCAN RANGE: " + rangeStr + "  [" + IntegerToString(g_intellTotalBars) + " bars]", IntellGoodColor());
         IntellSetLine(ln++, " ");

          if(g_intellState == INTELL_SCANNING)
          {
             string modeStr = IntellSelectWorst ? "WORST" : "BEST";
             int pct = g_intellTotalBars > 0 ? (int)((double)g_intellProcessedBars / g_intellTotalBars * 100.0) : 0;
             IntellSetLine(ln++, "SCAN PROGRESS: " + IntegerToString(pct) + "%  [" + IntegerToString(g_intellProcessedBars) + "/" + IntegerToString(g_intellTotalBars) + "]", IntellWarnColor());
             datetime cur = iTime(_Symbol, g_intellTimeframe, g_intellScanCurrentBar);
             if(cur > 0)
                IntellSetLine(ln++, "Bar date: " + TimeToString(cur, TIME_DATE));
             IntellSetLine(ln++, "Active runs: " + IntegerToString(ArraySize(intellActiveIdx)) + " / Total: " + IntegerToString(ArraySize(intellRuns)));
             IntellSetLine(ln++, "Target: " + modeStr + " @" + IntegerToString(IntellMinPassRateOrBlown) + "%  Spawn: " + IntellSpawnIntervalLabel());

             uint nowTick = GetTickCount();
             if(nowTick - g_intellLastTopBuildTick > 5000)
             {
                g_intellLastTopBuildTick = nowTick;
                IntellBuildTopCandidates();
             }

             if(g_intellTopCount > 0)
             {
                IntellSetLine(ln++, " ", IntellMutedColor());
                int showCount = MathMin(g_intellTopCount, 3);
                for(int ti = 0; ti < showCount; ti++)
                {
                   int sid = g_intellTopIds[ti];
                   string name = StrategyName(sid);
                   if(StringLen(name) > 8) name = StringSubstr(name, 0, 8);
                   string line = "#" + IntegerToString(ti + 1) + " #" + IntegerToString(sid) + " " + name +
                      " R" + IntegerToString(g_intellTopTotalComps[ti] + g_intellTopActive[ti]) +
                      " P" + DoubleToString(g_intellTopPassRate[ti], 1) +
                      "% B" + DoubleToString(g_intellTopBlownRate[ti], 1) +
                      "% WR" + DoubleToString(g_intellTopWR[ti], 1) +
                      "% PF" + DoubleToString(g_intellTopPF[ti], 1);
                   string reject = g_intellTopRejection[ti];
                   color clr = (reject == "✓ QUALIFIED") ? IntellGoodColor() : IntellWarnColor();
                   IntellSetLine(ln++, line, clr);
                   if(reject != "") IntellSetLine(ln++, reject, IntellMutedColor());
                }
             }
             IntellSetLine(ln++, " ");
          }
          else if(g_intellState == INTELL_SCAN_DONE || g_intellState == INTELL_READY || g_intellState == INTELL_TRADING || g_intellState == INTELL_RETRY_WAIT)
         {
            if(g_intellSelectedStratId > 0)
            {
               int sid = g_intellSelectedStratId;
               IntellSetLine(ln++, "SELECTED: #" + IntegerToString(sid) + " " + StrategyName(sid), IntellGoodColor());
               int tc = 0, tw = 0, tl = 0, tp = 0;
               datetime lastClose = 0;
               for(int r = 0; r < ArraySize(intellRuns); r++)
               {
                  if(intellRuns[r].strategyId == sid)
                  {
                     tc += intellRuns[r].trades;
                     tw += intellRuns[r].wins;
                     tl += intellRuns[r].losses;
                     if(intellRuns[r].passed) tp++;
                     if(intellRuns[r].lastClosedTradeTime > lastClose)
                        lastClose = intellRuns[r].lastClosedTradeTime;
                  }
               }
               int closed = tw + tl;
               double wr = closed > 0 ? (double)tw / closed * 100.0 : 0.0;
               IntellSetLine(ln++, "Passes: " + IntegerToString(tp) + " / Trades: " + IntegerToString(tc));
               IntellSetLine(ln++, "Win Rate: " + DoubleToString(wr, 1) + "% (" + IntegerToString(tw) + "W " + IntegerToString(tl) + "L)");
               if(lastClose > 0)
                  IntellSetLine(ln++, "Last Trade: " + TimeToString(lastClose, TIME_DATE | TIME_MINUTES) + " (" + IntegerToString((int)((TimeCurrent() - lastClose) / 60)) + "m ago)");
               else
                  IntellSetLine(ln++, "Last Trade: --");
               IntellSetLine(ln++, " ");
            }
            else
            {
               IntellSetLine(ln++, "No strategy selected yet");
               IntellSetLine(ln++, " ");
            }

            if(g_intellState == INTELL_READY)
            {
               IntellSetLine(ln++, "Waiting for signal from selected strategy...", IntellWarnColor());
            }
            if(g_intellState == INTELL_TRADING)
            {
               if(PositionSelectByTicket(g_intellTradeTicket))
               {
                  string dir = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY ? "BUY" : "SELL";
                  double entry = PositionGetDouble(POSITION_PRICE_OPEN);
                  double sl = PositionGetDouble(POSITION_SL);
                  double tp = PositionGetDouble(POSITION_TP);
                  double profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
                  IntellSetLine(ln++, "TRADE: " + dir + " @" + DoubleToString(entry, (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS)), IntellGoodColor());
                  IntellSetLine(ln++, "SL: " + DoubleToString(sl, (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS)) + " TP: " + DoubleToString(tp, (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS)));
                  color pnlCol = profit >= 0.0 ? IntellGoodColor() : IntellBadColor();
                  IntellSetLine(ln++, "P&L: " + DoubleToString(profit, 2), pnlCol);
               }
               else
               {
                  g_intellTradeTicket = 0;
                  g_intellState = INTELL_SCANNING;
                  g_intellLastRescanTime = TimeCurrent();
                  IntellSetLine(ln++, "Trade closed — rescanning...", IntellWarnColor());
               }
               IntellSetLine(ln++, " ");
            }
            if(g_intellState == INTELL_RETRY_WAIT)
            {
               int secLeft = (int)(g_intellRetryTime - TimeCurrent());
               if(secLeft < 0) secLeft = 0;
               IntellSetLine(ln++, "No strategy met criteria. Retry in " + IntegerToString(secLeft) + "s", IntellBadColor());
            }
         }

         // Top candidates
         if(g_intellTopCount > 0)
         {
            IntellSetLine(ln++, " ", IntellMutedColor());
            string modeLabel = IntellSelectWorst ? "WORST CANDIDATES" : "BEST CANDIDATES";
            IntellSetLine(ln++, modeLabel + " (top " + IntegerToString(g_intellTopCount) + ")", IntellMutedColor());
            int showCount = MathMin(g_intellTopCount, 3);
            for(int ti = 0; ti < showCount; ti++)
            {
               int sid = g_intellTopIds[ti];
               string name = StrategyName(sid);
               if(StringLen(name) > 8) name = StringSubstr(name, 0, 8);
                string line = "#" + IntegerToString(ti + 1) + " #" + IntegerToString(sid) + " " + name +
                   " R" + IntegerToString(g_intellTopTotalComps[ti] + g_intellTopActive[ti]) +
                   " P" + DoubleToString(g_intellTopPassRate[ti], 1) +
                   "% B" + DoubleToString(g_intellTopBlownRate[ti], 1) +
                   "% A" + IntegerToString(g_intellTopActive[ti]) +
                   " WR" + DoubleToString(g_intellTopWR[ti], 1) +
                   "% PF" + DoubleToString(g_intellTopPF[ti], 1);
                string reject = g_intellTopRejection[ti];
               color clr = (reject == "✓ QUALIFIED") ? IntellGoodColor() : IntellWarnColor();
               IntellSetLine(ln++, line, clr);
               if(reject != "") IntellSetLine(ln++, reject, IntellMutedColor());
            }
            IntellSetLine(ln++, " ", IntellMutedColor());
         }

         IntellSetLine(ln++, "SETTINGS", IntellMutedColor());
         IntellSetLine(ln++, "Selection: " + (IntellSelectWorst ? "WORST (BLOWN)" : "BEST (PASS)") + " @ " + IntegerToString(IntellMinPassRateOrBlown) + "%");
          IntellSetLine(ln++, "Max Age: " + IntegerToString(IntellMaxMinutesSinceLastTrade) + "m");
         IntellSetLine(ln++, "Spawn: " + IntellSpawnIntervalLabel() + " (unlimited batches)");
      }

      for(; ln < INTELL_LINE_COUNT; ln++) IntellSetLine(ln, " ");
      ChartRedraw(0);
   }

   void EnsureLogHeader()
   {
      if(!EnableCsvLog)
         return;

      int handle = FileOpen(LogFileName, FILE_READ | FILE_WRITE | FILE_CSV | FILE_COMMON);
      if(handle == INVALID_HANDLE)
         return;

      if(FileSize(handle) == 0)
         FileWrite(handle, "time", "symbol", "period", "magic", "event", "balance", "equity", "message");
      FileClose(handle);
   }

   void LogEvent(const string eventName, const string message)
   {
      string line = TimeToString(TimeCurrent(), TIME_DATE | TIME_SECONDS) + " " + eventName + " " + message;
      if(PrintDetailedLog)
         Print(line);

      if(!EnableCsvLog)
         return;

      int handle = FileOpen(LogFileName, FILE_READ | FILE_WRITE | FILE_CSV | FILE_COMMON);
      if(handle == INVALID_HANDLE)
      {
         Print("Failed to open log file: ", LogFileName, " error=", GetLastError());
         return;
      }

      FileSeek(handle, 0, SEEK_END);
      FileWrite(handle,
               TimeToString(TimeCurrent(), TIME_DATE | TIME_SECONDS),
               _Symbol,
               EnumToString(g_intellTimeframe),
               IntegerToString((int)MagicNumber),
               eventName,
               DoubleToString(AccountInfoDouble(ACCOUNT_BALANCE), 2),
               DoubleToString(AccountInfoDouble(ACCOUNT_EQUITY), 2),
               message);
      FileClose(handle);
   }

   // ── Parallel Backtest Helpers ──────────────────────────────────────────────────

   string PropCsvEscape(const string s)
   {
      string result = "";
      for(int i = 0; i < StringLen(s); i++)
      {
         ushort ch = StringGetCharacter(s, i);
         if(ch == '|')
            result += "\\p";
         else if(ch == '\\')
            result += "\\\\";
         else if(ch == '\n')
            result += "\\n";
         else if(ch == '\r')
            result += "\\r";
         else
            result += ShortToString(ch);
      }
      return result;
   }

   string PropCsvUnescape(const string s)
   {
      string result = "";
      int len = StringLen(s);
      for(int i = 0; i < len; i++)
      {
         ushort ch = StringGetCharacter(s, i);
         if(ch == '\\' && i + 1 < len)
         {
            ushort next = StringGetCharacter(s, i + 1);
            if(next == 'p') { result += "|"; i++; }
            else if(next == '\\') { result += "\\"; i++; }
            else if(next == 'n') { result += "\n"; i++; }
            else if(next == 'r') { result += "\r"; i++; }
            else result += ShortToString(ch);
         }
         else
            result += ShortToString(ch);
      }
      return result;
   }

