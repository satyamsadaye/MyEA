       if(MathAbs(bottom1 - bottom2) / (bottom1 + bottom2) * 200.0 < tolerance && (lo1 - bottom1Pos) > swingLookback / 2 && _Close(1) > (bottom1 + bottom2) / 2.0 + IndicatorValue(iATR(_Symbol, g_intellTimeframe, 14), 1) * 0.5)
