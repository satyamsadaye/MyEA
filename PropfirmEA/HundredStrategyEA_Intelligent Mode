   void MergePartialResults()
   {
      string sessionKey = ParallelSessionKey;
      if(sessionKey == "")
      {
         LogEvent("PARALLEL_ERR", "Session key is required for merge mode");
         return;
      }

      int totalNodes = ParallelTotalNodes;
      if(totalNodes < 1) totalNodes = 1;

      ArrayResize(propRuns, 0);
      ArrayInitialize(propSignalCounts, 0);
      int totalImported = 0;
      bool isRollingMode = true;
      datetime commonTestStart = 0;
      datetime commonTestEnd = 0;
      bool testStartSet = false;
      bool testEndSet = false;

      for(int n = 1; n <= totalNodes; n++)
      {
         string fileName = "Partial_" + sessionKey + "_Node" + IntegerToString(n) + ".csv";
         int handle = FileOpen(fileName, FILE_READ | FILE_TXT | FILE_COMMON);
         if(handle == INVALID_HANDLE)
         {
            LogEvent("PARALLEL_ERR", "Cannot open " + fileName + " (error " + IntegerToString(GetLastError()) + ")");
            continue;
         }

         int runCount = 0;
         bool readingRuns = false;

         while(!FileIsEnding(handle))
         {
            string line = FileReadString(handle);
            StringTrimLeft(line);
            StringTrimRight(line);
            if(line == "")
               continue;

             if(StringFind(line, "#ROLLING_MODE ") == 0)
             {
                isRollingMode = (StringToInteger(StringSubstr(line, 13)) != 0);
                continue;
             }
              if(StringFind(line, "#TEST_START ") == 0)
              {
                 datetime ts = (datetime)StringToInteger(StringSubstr(line, 12));
                 if(testStartSet && ts != commonTestStart)
                 {
                    LogEvent("PARALLEL_ERR", "TEST_START mismatch in " + fileName
                       + ": expected " + IntegerToString((long)commonTestStart)
                       + " got " + IntegerToString((long)ts)
                       + ". All partials must come from the same backtest date range.");
                 }
                 if(!testStartSet)
                 {
                    commonTestStart = ts;
                    testStartSet = true;
                 }
                 continue;
              }
              if(StringFind(line, "#TEST_END ") == 0)
              {
                 datetime te = (datetime)StringToInteger(StringSubstr(line, 10));
                 if(!testEndSet || te > commonTestEnd)
                 {
                    commonTestEnd = te;
                    testEndSet = true;
                 }
                 continue;
              }
              if(StringFind(line, "#SIGNALS") == 0)
            {
               string data = StringSubstr(line, 8);
               StringTrimLeft(data);
               string parts[];
               int pCount = StringSplit(data, (ushort)' ', parts);
               for(int p = 0; p < pCount; p++)
               {
                  string pair = parts[p];
                  StringTrimLeft(pair);
                  StringTrimRight(pair);
                  if(pair == "")
                     continue;
                  int semiPos = StringFind(pair, ";");
                  if(semiPos >= 0)
                  {
                     int id = (int)StringToInteger(StringSubstr(pair, 0, semiPos));
                     int cnt = (int)StringToInteger(StringSubstr(pair, semiPos + 1));
                     if(id >= 1 && id <= PROP_STRATEGY_COUNT)
                        propSignalCounts[id - 1] = cnt;
                  }
               }
               continue;
            }

            if(isRollingMode)
            {
               if(StringFind(line, "#RUN_COUNT ") == 0)
               {
                  runCount = (int)StringToInteger(StringSubstr(line, 10));
                  readingRuns = true;
                  if(runCount > 0)
                  {
                     int oldSize = ArraySize(propRuns);
                     ArrayResize(propRuns, oldSize + runCount);
                  }
                  continue;
               }

               if(readingRuns && StringFind(line, "R|") == 0)
               {
                  string parts[];
                  int pCount = StringSplit(line, (ushort)'|', parts);
                  if(pCount >= 31)
                  {
                     int idx = totalImported;
                     if(idx >= ArraySize(propRuns))
                     {
                        int oldSize = ArraySize(propRuns);
                        ArrayResize(propRuns, oldSize + 1000);
                     }

                     propRuns[idx].strategyId = (int)StringToInteger(parts[1]);
                     propRuns[idx].strategyName = PropCsvUnescape(parts[2]);
                     propRuns[idx].startDay = (datetime)StringToInteger(parts[3]);
                     propRuns[idx].ended = (datetime)StringToInteger(parts[4]);
                     propRuns[idx].breached = (StringToInteger(parts[5]) != 0);
                     propRuns[idx].passed = (StringToInteger(parts[6]) != 0);
                     propRuns[idx].protectionTriggeredToday = (StringToInteger(parts[7]) != 0);
                     propRuns[idx].breachReason = PropCsvUnescape(parts[8]);
                     propRuns[idx].dayReset = (datetime)StringToInteger(parts[9]);
                     propRuns[idx].lastTradeBar = (datetime)StringToInteger(parts[10]);
                     propRuns[idx].balance = StringToDouble(parts[11]);
                     propRuns[idx].equity = StringToDouble(parts[12]);
                     propRuns[idx].dayStartReference = StringToDouble(parts[13]);
                     propRuns[idx].startingBalance = StringToDouble(parts[14]);
                     propRuns[idx].maxDrawdown = StringToDouble(parts[15]);
                     propRuns[idx].maxProfit = StringToDouble(parts[16]);
                     propRuns[idx].grossProfit = StringToDouble(parts[17]);
                     propRuns[idx].grossLoss = StringToDouble(parts[18]);
                     propRuns[idx].daysToTarget = (int)StringToInteger(parts[19]);
                     propRuns[idx].daysToBreach = (int)StringToInteger(parts[20]);
                     propRuns[idx].equityProtectionTriggers = (int)StringToInteger(parts[21]);
                     propRuns[idx].trades = (int)StringToInteger(parts[22]);
                     propRuns[idx].wins = (int)StringToInteger(parts[23]);
                     propRuns[idx].losses = (int)StringToInteger(parts[24]);
                     propRuns[idx].breakevenTrades = (int)StringToInteger(parts[25]);
                     propRuns[idx].pos.open = (StringToInteger(parts[26]) != 0);
                     propRuns[idx].pos.type = (int)StringToInteger(parts[27]);
                     propRuns[idx].pos.entry = StringToDouble(parts[28]);
                     propRuns[idx].pos.lot = StringToDouble(parts[29]);
                     propRuns[idx].pos.openTime = (datetime)StringToInteger(parts[30]);

                     totalImported++;
                  }
               }
            }
            else
            {
               if(StringFind(line, "#RESULT_COUNT ") == 0)
               {
                  runCount = (int)StringToInteger(StringSubstr(line, 13));
                  readingRuns = true;
                  continue;
               }

               if(readingRuns && StringFind(line, "S|") == 0)
               {
                  string parts[];
                  int pCount = StringSplit(line, (ushort)'|', parts);
                  if(pCount >= 30)
                  {
                     int sid = (int)StringToInteger(parts[1]);
                     int idx = sid - 1;
                     if(idx >= 0 && idx < PROP_STRATEGY_COUNT)
                     {
                        propResults[idx].name = PropCsvUnescape(parts[2]);
                        propResults[idx].breached = (StringToInteger(parts[3]) != 0);
                        propResults[idx].passed = (StringToInteger(parts[4]) != 0);
                        propResults[idx].started = (datetime)StringToInteger(parts[5]);
                        propResults[idx].ended = (datetime)StringToInteger(parts[6]);
                        propResults[idx].balance = StringToDouble(parts[7]);
                        propResults[idx].equity = StringToDouble(parts[8]);
                        propResults[idx].dayStartReference = StringToDouble(parts[9]);
                        propResults[idx].maxDrawdown = StringToDouble(parts[10]);
                        propResults[idx].maxProfit = StringToDouble(parts[11]);
                        propResults[idx].daysToTarget = (int)StringToInteger(parts[12]);
                        propResults[idx].daysToBreach = (int)StringToInteger(parts[13]);
                        propResults[idx].equityProtectionTriggers = (int)StringToInteger(parts[14]);
                        propResults[idx].trades = (int)StringToInteger(parts[15]);
                        propResults[idx].wins = (int)StringToInteger(parts[16]);
                        propResults[idx].losses = (int)StringToInteger(parts[17]);
                        propResults[idx].breakevenTrades = (int)StringToInteger(parts[18]);
                        propResults[idx].totalSignals = (int)StringToInteger(parts[19]);
                        propResults[idx].startingBalance = StringToDouble(parts[20]);
                        propResults[idx].grossProfit = StringToDouble(parts[21]);
                        propResults[idx].grossLoss = StringToDouble(parts[22]);
                        propResults[idx].protectionTriggeredToday = (StringToInteger(parts[23]) != 0);
                        propResults[idx].breachReason = PropCsvUnescape(parts[24]);
                        propResults[idx].pos.open = (StringToInteger(parts[25]) != 0);
                        propResults[idx].pos.type = (int)StringToInteger(parts[26]);
                        propResults[idx].pos.entry = StringToDouble(parts[27]);
                        propResults[idx].pos.lot = StringToDouble(parts[28]);
                        propResults[idx].pos.openTime = (datetime)StringToInteger(parts[29]);

                        totalImported++;
                     }
                  }
               }
            }
         }

          FileClose(handle);
          Print("Merge: imported ", IntegerToString(runCount), " items from Node ", IntegerToString(n), " (", fileName, ")");
       }

      if(isRollingMode)
         ArrayResize(propRuns, totalImported);

      Print("Merge: total imported = ", IntegerToString(totalImported), " | rolling mode = ", isRollingMode ? "true" : "false");

      if(totalImported == 0)
      {
         LogEvent("PARALLEL_ERR", "No data imported. Merge aborted.");
         return;
      }

      // Compute the actual test start/end timestamps from imported data
      g_testStartTime = 0;
      g_testEndTime = 0;
      if(testStartSet)
         g_testStartTime = commonTestStart;
      if(testEndSet)
         g_testEndTime = commonTestEnd;
      if(!testEndSet)
      {
         if(isRollingMode)
         {
            for(int i = 0; i < ArraySize(propRuns); i++)
            {
               if(propRuns[i].ended > 0 && propRuns[i].ended > g_testEndTime)
                  g_testEndTime = propRuns[i].ended;
               if(propRuns[i].ended == 0 && propRuns[i].startDay > g_testEndTime)
                  g_testEndTime = propRuns[i].startDay;
            }
         }
         else
         {
            for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
            {
               if(propResults[i].ended > 0 && propResults[i].ended > g_testEndTime)
                  g_testEndTime = propResults[i].ended;
            }
         }
      }

      g_mergeMode = true;
      g_parallelEnabled = false;

      if(isRollingMode)
      {
         ExportPropfirmRollingReport();
         Print("Merged rolling report generated for session: ", sessionKey);
      }
      else
      {
         for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
         {
            if(propResults[i].name == "")
            {
               propResults[i].name = StrategyName(i + 1);
               propResults[i].breached = false;
               propResults[i].passed = false;
               propResults[i].started = 0;
               propResults[i].ended = 0;
               propResults[i].balance = 0;
               propResults[i].equity = 0;
               propResults[i].dayStartReference = 0;
               propResults[i].maxDrawdown = 0;
               propResults[i].maxProfit = 0;
               propResults[i].daysToTarget = 0;
               propResults[i].daysToBreach = 0;
               propResults[i].startingBalance = 0;
               propResults[i].trades = 0;
               propResults[i].wins = 0;
               propResults[i].losses = 0;
               propResults[i].breakevenTrades = 0;
               propResults[i].totalSignals = 0;
               propResults[i].grossProfit = 0;
               propResults[i].grossLoss = 0;
               propResults[i].protectionTriggeredToday = false;
               propResults[i].breachReason = "";
               propResults[i].pos.open = false;
            }
         }
         ExportPropfirmSingleReport();
         Print("Merged single-run report generated for session: ", sessionKey);
      }

      g_mergeMode = false;
   }

