         double recencyScore = (aggRecencyWeightSum[sid] > 0.0) ? aggRecencyPassedWeight[sid] / aggRecencyWeightSum[sid] * 100.0 : 0.0;
         double avgWinRate = (aggWinRateCount[sid] > 0) ? aggWinRateSum[sid] / (double)aggWinRateCount[sid] : 0.0;
         double avgNet = (aggStarts[sid] > 0) ? aggNetSum[sid] / (double)aggStarts[sid] : 0.0;
         double avgDays = (aggPassed[sid] > 0) ? (double)aggDaysToTarget[sid] / (double)aggPassed[sid] : 0.0;
         double profitFactor = (aggGrossLoss[sid] < 0.0) ? aggGrossProfit[sid] / MathAbs(aggGrossLoss[sid]) : 0.0;
         double avgWin = (aggWins[sid] > 0) ? aggGrossProfit[sid] / (double)aggWins[sid] : 0.0;
         double avgLoss = (aggLosses[sid] > 0) ? MathAbs(aggGrossLoss[sid]) / (double)aggLosses[sid] : 0.0;
         double realizedRR = (avgLoss > 0.0) ? avgWin / avgLoss : 0.0;
         string netClass = (avgNet > 0.0) ? "pos" : ((avgNet < 0.0) ? "neg" : "zero");
         string bestClass = (aggBestNet[sid] > 0.0) ? "pos" : "zero";
         string worstClass = (aggWorstNet[sid] < 0.0) ? "neg" : "zero";
         string pfClass = (profitFactor >= 1.0) ? "pos" : "neg";
         string stratName = StrategyName(sid + 1);

         string row = "";
         row += StringFormat("<tr><td class=\"num sticky-col\">%d</td>", rankOut);
         row += "<td class=\"sticky-col\"><a href=\"javascript:void(0)\" onclick=\"filterRuns('" + stratName + "')\" class=\"strat-link\">" + stratName + "</a></td>";
          row += StringFormat("<td class=\"num\">%d</td>", aggStarts[sid]);
          row += StringFormat("<td class=\"num pos\">%d</td>", aggPassed[sid]);
          row += StringFormat("<td class=\"num neg\">%d</td>", aggBlown[sid]);
          row += StringFormat("<td class=\"num\">%d</td>", aggActive[sid]);
          row += "<td data-sort=\"" + IntegerToString((long)aggLastCloseTime[sid]) + "\">" + PropTimeAgo(aggLastCloseTime[sid], testEndTime) + "</td>";
         int resolvedRuns = aggPassed[sid] + aggBlown[sid];
         double trueBlowRisk = (resolvedRuns > 0) ? (double)aggBlown[sid] / (double)resolvedRuns * 100.0 : 0.0;
         double safetyScore = (resolvedRuns > 0) ? 100.0 - trueBlowRisk : 0.0;
         string blowRiskClass = (resolvedRuns > 0) ? (trueBlowRisk < 5.0 ? "pos" : (trueBlowRisk > 15.0 ? "neg" : "")) : "zero";
         string safetyClass = (resolvedRuns > 0) ? (safetyScore >= 95.0 ? "pos" : (safetyScore < 85.0 ? "neg" : "")) : "zero";
         if(resolvedRuns > 0)
         {
            row += StringFormat("<td class=\"num %s\" data-sort=\"%.4f\">%.1f%%</td>", blowRiskClass, trueBlowRisk, trueBlowRisk);
            row += StringFormat("<td class=\"num %s\" data-sort=\"%.4f\">%.1f</td>", safetyClass, safetyScore, safetyScore);
         }
         else
         {
            row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
            row += "<td data-sort=\"-1\" class=\"zero\">n/a</td>";
