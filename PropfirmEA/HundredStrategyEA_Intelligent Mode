    int MaTrendSignal(const int fast, const int slow)
   {
      double f1 = IndicatorValue(iMA(_Symbol, g_intellTimeframe, fast, 0, MODE_EMA, PRICE_CLOSE), 1);
      double f2 = IndicatorValue(iMA(_Symbol, g_intellTimeframe, fast, 0, MODE_EMA, PRICE_CLOSE), 2);
      double s1 = IndicatorValue(iMA(_Symbol, g_intellTimeframe, slow, 0, MODE_EMA, PRICE_CLOSE), 1);
      double s2 = IndicatorValue(iMA(_Symbol, g_intellTimeframe, slow, 0, MODE_EMA, PRICE_CLOSE), 2);
      if(f2 <= s2 && f1 > s1) return 1;
      if(f2 >= s2 && f1 < s1) return -1;
      return 0;
   }

   int RsiSignal(const int period, const double low, const double high)
   {
      double r1 = IndicatorValue(iRSI(_Symbol, g_intellTimeframe, period, PRICE_CLOSE), 1);
      double r2 = IndicatorValue(iRSI(_Symbol, g_intellTimeframe, period, PRICE_CLOSE), 2);
      if(r2 < low && r1 >= low) return 1;
      if(r2 > high && r1 <= high) return -1;
      return 0;
   }

   int BreakoutSignal(const int lookback)
   {
      int hi = _iHighest(lookback);
      int lo = _iLowest(lookback);
      if(hi < 0 || lo < 0) return 0;
      double close1 = _Close(1);
      if(close1 > _High(hi)) return 1;
      if(close1 < _Low(lo)) return -1;
      return 0;
   }

   int BollingerSignal(const int period, const double deviation)
   {
      int handle = iBands(_Symbol, g_intellTimeframe, period, 0, deviation, PRICE_CLOSE);
      double upper = BufferValue(handle, 1, 1);
      double lower = BufferValue(handle, 2, 1);
      double close1 = _Close(1);
      double close2 = _Close(2);
      if(close2 < lower && close1 > lower) return 1;
