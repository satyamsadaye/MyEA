          return 0.0;
       double gains = 0.0, losses = 0.0;
       for(int i = 0; i < period; i++)
       {
          double diff = close[i] - close[i + 1];
          if(diff > 0.0) gains += diff;
          else losses -= diff;
       }
       double sum = gains + losses;
       return (sum > 0.0) ? (gains - losses) / sum * 100.0 : 0.0;
    }

