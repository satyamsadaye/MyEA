            if(recScore > bestRecentStratScore) { bestRecentStratScore = recScore; bestRecentStratName = StrategyName(i + 1); bestRecentAllTimeRate = rate; }
         }
      }
      double overallPassRate = (totalRuns > 0) ? (double)totalPassed / (double)totalRuns * 100.0 : 0.0;
      double completedPassRate = (totalPassed + totalBlown > 0) ? (double)totalPassed / (double)(totalPassed + totalBlown) * 100.0 : 0.0;
      datetime testEnd = TimeCurrent();
