    int RsiBandsSignal(const int rsiPeriod, const int bbPeriod, const double bbDev)
    {
       int hRsi = iRSI(_Symbol, g_intellTimeframe, rsiPeriod, PRICE_CLOSE);
       if(hRsi == INVALID_HANDLE) return 0;
       double rsiBuf[];
       ArrayResize(rsiBuf, bbPeriod + 2);
       for(int i = 1; i <= bbPeriod + 1; i++)
          rsiBuf[i - 1] = BufferValue(hRsi, 0, i);
       double sum = 0.0;
       for(int i = 0; i < bbPeriod; i++) sum += rsiBuf[i];
       double ma = sum / bbPeriod;
       double sqSum = 0.0;
       for(int i = 0; i < bbPeriod; i++) sqSum += (rsiBuf[i] - ma) * (rsiBuf[i] - ma);
       double sd = MathSqrt(sqSum / bbPeriod);
       double upper = ma + sd * bbDev;
       double lower = ma - sd * bbDev;
       double rsi1 = rsiBuf[0];
       double rsi2 = rsiBuf[1];
       if(rsi2 < lower && rsi1 >= lower) return 1;
       if(rsi2 > upper && rsi1 <= upper) return -1;
       if(rsi1 < 30.0) return 1;
       if(rsi1 > 70.0) return -1;
       return 0;
    }

