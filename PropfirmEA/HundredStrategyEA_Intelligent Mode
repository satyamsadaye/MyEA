       double close1 = _Close(1);
       double open1 = _Open(1);
       if(curRange > avgRange * mult && close1 > open1 && MathAbs(close1 - open1) > curRange * 0.6) return 1;
       if(curRange > avgRange * mult && close1 < open1 && MathAbs(close1 - open1) > curRange * 0.6) return -1;
       return 0;
    }

    int VolContractionSignal(const int lookback, const double contractionRatio)
    {
       double avgRange = 0.0;
       for(int i = 1; i <= lookback; i++)
          avgRange += _High(i) - _Low(i);
       avgRange /= lookback;
       if(avgRange <= 0.0) return 0;
       double curRange = _High(1) - _Low(1);
       double curVol = (double)_Volume(1);
       double avgVol = 0.0;
       for(int i = 1; i <= lookback; i++)
          avgVol += (double)_Volume(i);
       avgVol /= lookback;
       if(curRange < avgRange * contractionRatio && curVol < avgVol * 0.8)
       {
          double nextRange = _High(0) - _Low(0);
          double nextVol = (double)_Volume(0);
          if(nextRange > avgRange && nextVol > avgVol)
          {
             double close0 = _Close(0);
             double open0 = _Open(0);
             if(close0 > open0) return 1;
             if(close0 < open0) return -1;
          }
       }
       return 0;
    }

     int SwingBreakSignal(const int swingLookback, const int momPeriod)
     {
        int hiBar = _iHighest(swingLookback);
        int loBar = _iLowest(swingLookback);
        if(hiBar < 0 || loBar < 0) return 0;
        double swingHigh = _High(hiBar);
        double swingLow = _Low(loBar);
        double close1 = _Close(1);
        double close2 = _Close(2);
        double mom1 = IndicatorValue(iMomentum(_Symbol, g_intellTimeframe, momPeriod, PRICE_CLOSE), 1);
        double mom2 = IndicatorValue(iMomentum(_Symbol, g_intellTimeframe, momPeriod, PRICE_CLOSE), 2);
        if(close2 <= swingHigh && close1 > swingHigh && mom1 > mom2) return 1;
        if(close2 >= swingLow && close1 < swingLow && mom1 < mom2) return -1;
        return 0;
     }

    double IndicatorValue(const int handle, const int shift)
    {
       return BufferValue(handle, 0, shift);
    }

   double BufferValue(const int handle, const int buffer, const int shift)
   {
      if(handle == INVALID_HANDLE)
         return 0.0;
      int effectiveShift = shift + g_intellScanShift;
      // Cache lookup: same (handle, buffer, shift) within same bar
      for(int i = 0; i < _bvCacheCount; i++)
      {
         if(_bvCache[i].handle == handle && _bvCache[i].buffer == buffer && _bvCache[i].shift == effectiveShift && _bvCache[i].barTime == _cacheBarTime)
            return _bvCache[i].value;
      }
      double values[];
      ArraySetAsSeries(values, true);
      if(CopyBuffer(handle, buffer, effectiveShift, 1, values) != 1)
         return 0.0;
      double val = values[0];
      // Store in cache
      if(_bvCacheCount < 8000)
      {
         _bvCache[_bvCacheCount].handle = handle;
         _bvCache[_bvCacheCount].buffer = buffer;
         _bvCache[_bvCacheCount].shift = effectiveShift;
         _bvCache[_bvCacheCount].value = val;
         _bvCache[_bvCacheCount].barTime = _cacheBarTime;
         _bvCacheCount++;
      }
      return val;
   }

   double AverageRange(const int lookback)
   {
      if(lookback <= 0 || lookback >= 100) return 0.0;
      if(_avgRangeCacheBar == _cacheBarTime && _avgRangeCache[lookback] != -1.0)
         return _avgRangeCache[lookback];
      double sum = 0.0;
      int count = 0;
      for(int i = 1; i <= lookback; i++)
      {
         double high = _High(i);
         double low = _Low(i);
         if(high > 0 && low > 0)
         {
            sum += high - low;
            count++;
         }
      }
      double result = count > 0 ? sum / count : 0.0;
      _avgRangeCache[lookback] = result;
      if(_avgRangeCacheBar != _cacheBarTime)
      {
         for(int j = 0; j < 100; j++) _avgRangeCache[j] = -1.0;
         _avgRangeCache[lookback] = result;
         _avgRangeCacheBar = _cacheBarTime;
      }
      return result;
   }

