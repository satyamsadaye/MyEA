   double PropRollingPositionProfit(const int index)
   {
      if(!propRuns[index].pos.open)
         return 0.0;
      int type = propRuns[index].pos.type;
      double price = (type == ORDER_TYPE_BUY) ? propCacheBid : propCacheAsk;
      double diff = (type == ORDER_TYPE_BUY) ? price - propRuns[index].pos.entry : propRuns[index].pos.entry - price;
      if(propCacheTickValue <= 0.0 || propCacheTickSize <= 0.0)
         return 0.0;
      return diff / propCacheTickSize * propCacheTickValue * propRuns[index].pos.lot;
   }

