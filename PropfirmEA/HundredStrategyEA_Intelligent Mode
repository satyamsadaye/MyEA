            "<div class=\"card loss\"><div class=\"label\">Active in Drawdown</div><div class=\"value\">" + DoubleToString((double)t5ActiveDD / t5Active * 100.0, 1) + "%</div><div class=\"sub\">" + IntegerToString(t5ActiveDD) + " of " + IntegerToString(t5Active) + (t5ActiveDD > 0 ? " &middot; avg " + DoubleToString(t5ActiveDDDepthSum / t5ActiveDD, 1) + "%" : "") + "</div></div>\n" :
