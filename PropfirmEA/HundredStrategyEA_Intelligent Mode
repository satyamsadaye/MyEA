        double rangeHigh = _High(hiBar);
        double rangeLow = _Low(loBar);
        double range = rangeHigh - rangeLow;
        double breakoutLevel = rangeHigh;
        double pullbackTarget = rangeHigh - range * pullbackPct;
        double close1 = _Close(1);
        double close2 = _Close(2);
        double high1 = _High(1);
        if(close2 <= breakoutLevel && high1 > breakoutLevel && close1 >= pullbackTarget) return 1;
        double bearBreakout = rangeLow;
        double bearPullback = rangeLow + range * pullbackPct;
        if(close2 >= bearBreakout && _Low(1) < bearBreakout && close1 <= bearPullback) return -1;
        return 0;
     }

