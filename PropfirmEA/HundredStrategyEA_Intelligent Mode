      return StringFormat("%dh %02dm", h, m);
   }

   string GlobalFormatCountdownSec(const int totalSeconds)
   {
      int h = totalSeconds / 3600;
      int m = (totalSeconds % 3600) / 60;
      int s = totalSeconds % 60;
      return StringFormat("%dh %02dm %02ds", h, m, s);
   }

   datetime GlobalNextOccurrence(const int targetHour, const int targetMinute)
   {
      MqlDateTime dt;
      TimeToStruct(TimeCurrent(), dt);
      dt.hour = targetHour;
      dt.min = targetMinute;
      dt.sec = 0;
      datetime target = StructToTime(dt);
      if(target <= TimeCurrent())
         target += 86400;
      return target;
   }

   string GlobalDateLabel(const datetime t)
   {
      MqlDateTime nowDt, targetDt;
      TimeToStruct(TimeCurrent(), nowDt);
      TimeToStruct(t, targetDt);
      if(nowDt.year == targetDt.year && nowDt.mon == targetDt.mon && nowDt.day == targetDt.day)
         return "Today";
      datetime tomorrow = TimeCurrent() + 86400;
      MqlDateTime tomDt;
      TimeToStruct(tomorrow, tomDt);
      if(tomDt.year == targetDt.year && tomDt.mon == targetDt.mon && tomDt.day == targetDt.day)
         return "Tomorrow";
      return TimeToString(t, TIME_DATE);
   }

   datetime PropCurrentResetTime(const datetime t)
   {
      MqlDateTime dt;
      TimeToStruct(t, dt);
      dt.hour = PropDailyResetHourUTC;
      dt.min = PropDailyResetMinuteUTC;
      dt.sec = 0;
      datetime reset = StructToTime(dt);
      if(t < reset)
         reset -= 86400;
      return reset;
   }

   void RunPropfirmRollingTick()
   {
      _CacheRefresh();
      _CacheHL();

      datetime now = TimeCurrent();

      propCacheBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      propCacheAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      propCacheTickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
      propCacheTickSize = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);

      while(now >= propCurrentDayReset + 86400)
      {
         propCurrentDayReset += 86400;
         PropRollingResetDaily();
      }

      if(PropEnableForceClose && PropIsCloseTime(now))
         PropRollingCloseAll();

      datetime currentBar = iTime(_Symbol, g_intellTimeframe, 0);
      bool newBar = (currentBar != propSignalCacheBar);
      if(newBar)
         propSignalCacheBar = currentBar;

      if(newBar && (!PropEnablePauseSignals || !PropSignalsPaused(now)))
      {
         for(int id = 1; id <= PROP_STRATEGY_COUNT; id++)
         {
            if(!PropIsCustomStrategy(id))
               continue;

            StrategySignal signal;
            signal.buyVotes = 0;
            signal.sellVotes = 0;
            signal.details = "";
            EvaluateStrategy(id, signal);
            if(signal.buyVotes > 0)
               propSignalCache[id - 1] = ORDER_TYPE_BUY;
            else if(signal.sellVotes > 0)
               propSignalCache[id - 1] = ORDER_TYPE_SELL;
            else
               propSignalCache[id - 1] = 0;
            if(propSignalCache[id - 1] != 0)
               propSignalCounts[id - 1]++;
         }
      }

      PropRollingUpdateAndCheck();

      if(PropRollingShouldSpawn(now))
         PropRollingSpawnRuns(now);

      if(PropEnablePauseSignals && PropSignalsPaused(now))
         return;

      if(OneTradePerBar && !newBar)
         return;

      for(int k = 0; k < ArraySize(propActiveIdx); k++)
      {
         int i = propActiveIdx[k];
         if(propRuns[i].breached || propRuns[i].passed)
            continue;

         int dir = propSignalCache[propRuns[i].strategyId - 1];
         if(dir == 0)
            continue;

          if(propRuns[i].pos.open)
          {
             string skipSigStr = TimeToString(now, TIME_DATE | TIME_SECONDS) + " " + (dir == ORDER_TYPE_BUY ? "BUY" : "SELL");
             if(skipSigStr != propRuns[i].lastTriggeredSignal)
                propRuns[i].lastSkippedSignal = skipSigStr;
             continue;
          }
         if(propRuns[i].protectionTriggeredToday)
            continue;

         if(ReverseSignals)
            dir = (dir == ORDER_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
         if((AllowedDirection == SIGNAL_BUY_ONLY && dir == ORDER_TYPE_SELL) ||
            (AllowedDirection == SIGNAL_SELL_ONLY && dir == ORDER_TYPE_BUY))
            continue;

         PropRollingOpenPosition(i, dir, now);
      }
   }

   bool PropRollingShouldSpawn(const datetime now)
   {
      if(PropEnablePauseSignals && PropSignalsPaused(now))
         return false;

      MqlDateTime dt;
      TimeToStruct(now, dt);
      dt.hour = PropResumeSignalsHourUTC;
      dt.min = PropResumeSignalsMinuteUTC;
      dt.sec = 0;
      datetime resumeToday = StructToTime(dt);

      if(now < resumeToday)
         return false;

      if(propLastResumeSpawn >= resumeToday)
      {
         long intervalSeconds = PropSpawnIntervalSeconds();
         if(intervalSeconds <= 0)
            return false;
         if((long)(now - propLastResumeSpawn) < intervalSeconds)
            return false;
      }

      if(PropMaxStartDays > 0)
      {
         int spawnCount = 0;
         for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
         {
            if(PropIsCustomStrategy(i + 1))
               spawnCount++;
         }
         if(spawnCount == 0)
            return false;
         int totalBatches = ArraySize(propRuns) / spawnCount;
         if(totalBatches >= PropMaxStartDays)
            return false;
      }

      return true;
   }

   void PropRollingSpawnRuns(const datetime now)
   {
      int oldSize = ArraySize(propRuns);
      int spawnCount = 0;
      for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
      {
         if(PropIsCustomStrategy(i + 1))
            spawnCount++;
      }
      if(spawnCount == 0)
         return;

      ArrayResize(propRuns, oldSize + spawnCount);
      ArrayResize(propPosInActive, ArraySize(propRuns));
      datetime dayReset = PropCurrentResetTime(now);
      int spawnIdx = 0;

      for(int i = 0; i < PROP_STRATEGY_COUNT; i++)
      {
         if(!PropIsCustomStrategy(i + 1))
            continue;

         int idx = oldSize + spawnIdx;
         propRuns[idx].strategyId = i + 1;
         propRuns[idx].strategyName = StrategyName(i + 1);
         propRuns[idx].startDay = now;
         propRuns[idx].ended = 0;
         propRuns[idx].breached = false;
         propRuns[idx].passed = false;
         propRuns[idx].protectionTriggeredToday = false;
         propRuns[idx].breachReason = "";
         propRuns[idx].dayReset = dayReset;
         propRuns[idx].lastTradeBar = 0;
         propRuns[idx].balance = PropStartingBalance;
         propRuns[idx].equity = PropStartingBalance;
         propRuns[idx].dayStartReference = PropStartingBalance;
         propRuns[idx].startingBalance = PropStartingBalance;
         propRuns[idx].maxDrawdown = 0.0;
         propRuns[idx].maxProfit = 0.0;
         propRuns[idx].grossProfit = 0.0;
         propRuns[idx].grossLoss = 0.0;
          propRuns[idx].daysToTarget = 0;
          propRuns[idx].daysToBreach = 0;
          propRuns[idx].tradesToTarget = 0;
          propRuns[idx].tradesToBreach = 0;
          propRuns[idx].currentWinStreak = 0;
          propRuns[idx].currentLossStreak = 0;
          propRuns[idx].maxWinStreak = 0;
          propRuns[idx].maxLossStreak = 0;
          propRuns[idx].equityProtectionTriggers = 0;
          propRuns[idx].trades = 0;
          propRuns[idx].wins = 0;
          propRuns[idx].losses = 0;
          propRuns[idx].breakevenTrades = 0;
          propRuns[idx].pos.open = false;
          propRuns[idx].lastClosedTradeTime = 0;
          for(int p = 0; p < 5; p++) propRuns[idx].closedTradePnL[p] = 0.0;
          propRuns[idx].lastTriggeredSignal = "";
          propRuns[idx].lastSkippedSignal = "";

          propPosInActive[idx] = ArraySize(propActiveIdx);
         ArrayResize(propActiveIdx, propPosInActive[idx] + 1);
         propActiveIdx[propPosInActive[idx]] = idx;
         spawnIdx++;
      }

      propLastResumeSpawn = now;
      LogEvent("PROP_SPAWN", "Spawned " + IntegerToString(spawnCount) + " runs at " + TimeToString(now, TIME_DATE | TIME_MINUTES) + ". Total runs: " + IntegerToString(ArraySize(propRuns)));
   }

   void PropRemoveActive(const int index)
   {
      int p = propPosInActive[index];
      if(p < 0)
         return;
      int last = ArraySize(propActiveIdx) - 1;
      if(p != last)
      {
         int movedRun = propActiveIdx[last];
         propActiveIdx[p] = movedRun;
         propPosInActive[movedRun] = p;
      }
      propPosInActive[index] = -1;
      ArrayResize(propActiveIdx, last);
   }

