          "<script>function sortColDesc(t,c){var th=document.getElementById(t).querySelectorAll('thead th')[c];if(!th)return;if(th.classList.contains('sort-desc'))return;th.click();if(th.classList.contains('sort-asc'))th.click();}</script>\n" +
          PropTopScrollHtml("strat") +
         "<div class=\"table-scroll has-top\" id=\"ts_strat\">\n<table id=\"strat\">\n<thead><tr>\n" +
