            "") +
          "</div>\n</div>\n");

      int topN = 5;
      int t5Passed = 0, t5Blown = 0, t5Active = 0, t5ActiveProfit = 0, t5ActiveDD = 0;
      double t5ActiveProfitDepthSum = 0.0, t5ActiveDDDepthSum = 0.0;
      long t5Trades = 0, t5Signals = 0, t5Runs = 0;
