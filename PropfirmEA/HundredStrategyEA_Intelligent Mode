       double rangeHigh = _High(hiBar);
       double rangeLow = _Low(loBar);
       double close1 = _Close(1);
       double close2 = _Close(2);
       if(close2 > rangeHigh && close1 <= rangeHigh) return -1;
       if(close2 < rangeLow && close1 >= rangeLow) return 1;
       for(int i = 3; i <= reversalBars + 2; i++)
       {
          double ci = _Close(i);
          if(ci > rangeHigh)
          {
             for(int j = i - 1; j >= 1 && j >= i - reversalBars; j--)
                if(_Close(j) <= rangeHigh)
                   return -1;
          }
          if(ci < rangeLow)
          {
             for(int j = i - 1; j >= 1 && j >= i - reversalBars; j--)
                if(_Close(j) >= rangeLow)
                   return 1;
          }
       }
       return 0;
    }

