    double VidyaValue(const int period, const int cmoPeriod)
    {
       double close[];
       ArraySetAsSeries(close, true);
       int total = period + cmoPeriod + 1;
       if(CopyClose(_Symbol, g_intellTimeframe, 0, total + 1, close) < total + 1)
          return 0.0;
       double vidya = 0.0;
       for(int i = 0; i < period; i++)
          vidya += close[total - i];
       vidya /= period;
       for(int i = total - period; i >= 1; i--)
       {
          double gains = 0.0, losses = 0.0;
          for(int j = i + cmoPeriod - 1; j >= i; j--)
          {
             double diff = close[j] - close[j + 1];
             if(diff > 0.0) gains += diff;
             else losses -= diff;
          }
          double sum = gains + losses;
          double k = (sum > 0.0) ? 0.5 * MathAbs((gains - losses) / sum) : 0.01;
          if(k < 0.01) k = 0.01;
          vidya = close[i] * k + vidya * (1.0 - k);
       }
       return vidya;
    }

