// ==================== INIT ====================
int OnInit()
{
   return INIT_SUCCEEDED;
}

// ==================== TICK - THE MAIN LOOP (FIXED) ====================
void OnTick()
{
   // ▼ KEY FIX #1: Check if new bar arrived (once per bar only)
   datetime currentBar = iTime(Symbol(), Period(), 0);
   if(currentBar == lastBarProcessed)
      return;  // Already processed this bar
   
   lastBarProcessed = currentBar;

   // Spawn new run every N minutes
   static datetime lastSpawnTime = 0;
   if(TimeCurrent() - lastSpawnTime >= spawnIntervalMinutes * 60)
   {
      SpawnNewRun();
      lastSpawnTime = TimeCurrent();
   }

   // ▼ KEY FIX #2: Process ALL active runs for this bar
   ProcessAllActiveRuns();
}

// ==================== SPAWN NEW RUN ====================
void SpawnNewRun()
{
   if(totalRuns >= 10000)
   {
      Print("Maximum runs reached (10000)");
      return;
   }

   activeRuns[totalRuns].startTime = TimeCurrent();
   activeRuns[totalRuns].lastProcessedBar = 0;  // ← Initialize to 0
   activeRuns[totalRuns].tradeCount = 0;
   activeRuns[totalRuns].signalCount = 0;
   activeRuns[totalRuns].startBalance = startingBalance;
   activeRuns[totalRuns].currentBalance = startingBalance;
   activeRuns[totalRuns].maxProfit = 0;
   activeRuns[totalRuns].maxDrawdown = 0;
   activeRuns[totalRuns].isActive = true;
   activeRuns[totalRuns].status = "ACTIVE";

   Print("Run #", totalRuns, " spawned at ", TimeToString(activeRuns[totalRuns].startTime));
   totalRuns++;
}

// ==================== PROCESS ALL ACTIVE RUNS (THE FIX) ====================
void ProcessAllActiveRuns()
{
   datetime currentBarTime = iTime(Symbol(), Period(), 0);

   // Loop through ALL active runs
   for(int i = 0; i < totalRuns; i++)
   {
      if(!activeRuns[i].isActive)
         continue;  // Skip completed runs

      // ▼ KEY FIX #3: Skip if this run hasn't started yet
      if(currentBarTime < activeRuns[i].startTime)
         continue;

      // ▼ KEY FIX #4: Only process bar once per run
      if(activeRuns[i].lastProcessedBar == currentBarTime)
         continue;

      // NOW process this run for current bar
      ProcessSingleRun(i);

      // Mark this bar as processed for this run
      activeRuns[i].lastProcessedBar = currentBarTime;
   }
}

// ==================== PROCESS SINGLE RUN ====================
void ProcessSingleRun(int runIndex)
{
   RunState &run = activeRuns[runIndex];

   // Get signal from selected strategy
   int signal = GetSignal(selectedStrategy);

   if(signal != 0)
   {
      run.signalCount++;

      // Execute trade
      if((signal == 1 && selectedStrategy != SIGNAL_SELL_ONLY) || 
         (signal == -1 && selectedStrategy != SIGNAL_BUY_ONLY))
      {
         ExecuteTrade(signal, runIndex);
         run.tradeCount++;
      }
   }

   // Update equity metrics
   UpdateRunMetrics(runIndex);

   // Check termination conditions
   CheckTermination(runIndex);
}

// ==================== GET SIGNAL ====================
int GetSignal(int strategyID)
{
   // Example: ADX_RSI_POSITION (799)
   double adx = iADX(Symbol(), Period(), 14, PRICE_CLOSE, 0);
   double rsi = iRSI(Symbol(), Period(), 14, PRICE_CLOSE, 0);

   // If ADX strong and RSI oversold = BUY
   if(adx > 25 && rsi < 30)
      return reverseSignals ? -1 : 1;

   // If ADX strong and RSI overbought = SELL
   if(adx > 25 && rsi > 70)
      return reverseSignals ? 1 : -1;

   return 0;  // No signal
}

// ==================== EXECUTE TRADE ====================
void ExecuteTrade(int signal, int runIndex)
{
   if(!oneTradePerBar)
      return;  // Dummy for now

   // Simulate trade
   Print("Run #", runIndex, " | Signal: ", (signal > 0 ? "BUY" : "SELL"), 
         " | Price: ", SymbolInfoDouble(Symbol(), SYMBOL_ASK));
}

// ==================== UPDATE RUN METRICS ====================
void UpdateRunMetrics(int runIndex)
{
   RunState &run = activeRuns[runIndex];

   // Simple P&L calculation (based on trade count for simulation)
   double pnl = (run.tradeCount * 50.0) - (run.tradeCount * 25.0);  // Simplified
   run.currentBalance = run.startBalance + pnl;

   // Track max profit
   if(pnl > run.maxProfit)
      run.maxProfit = pnl;

   // Track max drawdown
   if(pnl < 0 && MathAbs(pnl) > run.maxDrawdown)
      run.maxDrawdown = MathAbs(pnl);
}

// ==================== CHECK TERMINATION ====================
void CheckTermination(int runIndex)
{
   RunState &run = activeRuns[runIndex];

   // Hit profit target?
   if(run.currentBalance >= run.startBalance + profitTarget)
   {
      run.isActive = false;
      run.status = "PASSED";
      Print("Run #", runIndex, " PASSED | Profit: $", DoubleToString(run.currentBalance - run.startBalance, 2));
      return;
   }

   // Hit loss limit?
   if(run.maxDrawdown >= maxTotalDrawdown)
   {
      run.isActive = false;
      run.status = "BLOWN";
      Print("Run #", runIndex, " BLOWN | Loss: $", DoubleToString(run.maxDrawdown, 2));
      return;
   }
}

// ==================== DEINIT ====================
void OnDeinit(const int reason)
{
   Print("=== FINAL REPORT ===");
   int passed = 0, blown = 0, active = 0;
   
   for(int i = 0; i < totalRuns; i++)
   {
      if(activeRuns[i].status == "PASSED") passed++;
      else if(activeRuns[i].status == "BLOWN") blown++;
      else active++;
      
      Print("Run ", i, " | Status: ", activeRuns[i].status, 
            " | Trades: ", activeRuns[i].tradeCount, 
            " | Signals: ", activeRuns[i].signalCount,
            " | P/L: $", DoubleToString(activeRuns[i].currentBalance - activeRuns[i].startBalance, 2));
   }
   
   Print("Total: ", totalRuns, " | Passed: ", passed, " | Blown: ", blown, " | Active: ", active);
}
