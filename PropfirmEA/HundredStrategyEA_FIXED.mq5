#property strict
#property version   "1.01"
#property description "100-strategy MT5 EA - FIXED: Active runs now receive all bars continuously instead of freezing at spawn time"

#include <Trade/Trade.mqh>

CTrade trade;

// ==================== ENUMS ====================
enum ENUM_SIGNAL_DIRECTION { SIGNAL_BUY_ONLY = 0, SIGNAL_SELL_ONLY = 1, SIGNAL_BOTH = 2 };
enum ENUM_LOT_MODE { LOT_RISK_CURRENT_BALANCE = 0, LOT_RISK_STARTING_BALANCE = 1, LOT_FIXED = 2 };
enum ENUM_STOP_MODE { STOP_ATR_MULTIPLIER = 0, STOP_FIXED_POINTS = 1, STOP_FIXED_MONEY = 2 };
enum ENUM_STRATEGY_MODE { STRATEGY_ALL = 0, STRATEGY_SINGLE = 1 };
enum ENUM_PROP_STRATEGY_MODE { PROP_STRATEGY_ALL = 0, PROP_STRATEGY_CUSTOM = 1 };

// ==================== ACTIVE RUN STATE STRUCT ====================
struct RunState
{
   datetime startTime;           // When this run spawned
   datetime lastProcessedBar;    // Last bar time processed ← KEY FIX
   int tradeCount;              // Cumulative trades
   int signalCount;             // Cumulative signals
   double startBalance;         // Initial balance for this run
   double currentBalance;       // Current equity
   double maxProfit;            // Highest equity reach
   double maxDrawdown;          // Largest loss from start
   bool isActive;               // Still trading?
   string status;               // ACTIVE, PASSED, BLOWN
};

// ==================== GLOBAL RUN TRACKING ====================
RunState activeRuns[10000];      // Support up to 10k concurrent runs
int totalRuns = 0;
static datetime lastBarProcessed = 0;  // ← KEY FIX: Ensure once-per-bar execution

// ==================== INPUT PARAMETERS ====================
input ENUM_NAMED_STRATEGY   selectedStrategy = STRAT_799_ADX_RSI_POSITION;
input ENUM_STRATEGY_MODE    strategyMode = STRATEGY_SINGLE;
input ENUM_PROP_STRATEGY_MODE propMode = PROP_STRATEGY_CUSTOM;
input int spawnIntervalMinutes = 15;
input int maxSpawnBatches = 0;  // 0 = unlimited
input double startingBalance = 5000.0;
input double profitTarget = 250.0;       // 5% of 5000
input double maxTotalDrawdown = 250.0;   // 5% max loss
input double maxDailyDrawdown = 200.0;   // 4% daily loss
input double virtualTakeProfit = 200.0;  // Per trade TP
input double virtualStopLoss = 100.0;    // Per trade SL
input double fixedLotSize = 0.10;
input bool oneTradePerBar = true;
input bool reverseSignals = false;

