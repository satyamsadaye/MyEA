#property strict
#property version   "1.00"
#property description "Local prop-firm style account statistics dashboard."

enum ENUM_PROP_STATS_SCOPE
{
   PROP_STATS_ALL_SYMBOLS = 0,      // All symbols
   PROP_STATS_CURRENT_SYMBOL = 1    // Current chart symbol only
};

enum ENUM_DRAWDOWN_LIMIT_MODE
{
   DD_LIMIT_FIXED_MONEY = 0,         // Limit input is account-currency money
   DD_LIMIT_PERCENT_OF_BASE = 1,     // Limit input is percent of the rule baseline
   DD_LIMIT_PERCENT_OF_START = 2     // Limit input is percent of initial starting balance
};

enum ENUM_MAX_DRAWDOWN_FLOOR_MODE
{
   MAX_DD_FIXED_STARTING_BALANCE = 0, // Starting balance - max DD
   MAX_DD_TRAILING_BALANCE_PEAK = 1,  // Highest closed balance - max DD
   MAX_DD_TRAILING_EQUITY_PEAK = 2    // Highest observed equity - max DD
};

input group "Prop Account Targets"
input double StartingBalance = 5000.0;          // Starting balance
input double TargetEquity = 5500.0;             // Target equity
input ENUM_DRAWDOWN_LIMIT_MODE MaxDrawdownLimitMode = DD_LIMIT_PERCENT_OF_START; // Max DD limit mode
input double MaxTotalDrawdownValue = 10.0;      // Max DD value (money or percent)
input ENUM_MAX_DRAWDOWN_FLOOR_MODE MaxDrawdownFloorMode = MAX_DD_TRAILING_EQUITY_PEAK; // Max DD baseline rule
input ENUM_DRAWDOWN_LIMIT_MODE DailyDrawdownLimitMode = DD_LIMIT_PERCENT_OF_START; // Daily DD limit mode
input double MaxDailyDrawdownValue = 5.0;        // Daily DD value (money or percent)

input group "History Filters"
input ENUM_PROP_STATS_SCOPE StatsScope = PROP_STATS_ALL_SYMBOLS;
input bool FilterByMagicNumber = false;
input long MagicNumber = 0;

input group "Performance Metrics"
input double PlannedWinMoney = 100.0;           // Planned money to make on each win
input double PlannedLossMoney = 100.0;          // Planned money to lose on each loss
input double LagQualificationPercent = 70.0;    // Min percent of planned P/L to count in lag stats

input group "Dashboard"
input bool ShowDashboard = true;
input int PanelCorner = CORNER_LEFT_UPPER;
input int PanelX = 18;
input int PanelY = 28;
input int PanelWidth = 620;
input int FontSize = 9;

#define PS_PREFIX "PROP_STATS_EA_"
#define PS_LINE_COUNT 28

color PanelColor()  { return C'16,18,24'; }
color HeaderColor() { return C'28,32,42'; }
color BorderColor() { return C'74,85,104'; }
color TextColor()   { return C'236,239,244'; }
color MutedColor()  { return C'158,166,180'; }
color GoodColor()   { return C'125,211,252'; }
color WarnColor()   { return C'245,180,85'; }
color BadColor()    { return C'254,202,202'; }

struct ClosedTrade
{
   ulong position_id;
   datetime open_time;
   datetime close_time;
   string symbol;
   long type;
   long magic;
   double volume;
   double open_price;
   double close_price;
   double entry_sl;
   double profit;
   double commission;
   double swap;
   double net;
   double risk_money;
   double rr;
};

datetime g_current_utc_day = 0;
double g_daily_start_equity = 0.0;
double g_daily_min_equity = 0.0;
double g_equity_peak = 0.0;
bool g_objects_created = false;

string Money(double value)
{
   string currency = AccountInfoString(ACCOUNT_CURRENCY);
   return currency + " " + DoubleToString(value, 2);
}

string SignedMoney(double value)
{
   string sign = (value > 0.0 ? "+" : "");
   return sign + Money(value);
}

string SignedPercent(double value)
{
   string sign = (value > 0.0 ? "+" : "");
   return sign + DoubleToString(value, 1) + "%";
}

datetime UtcDayStart(datetime utc_time)
{
   MqlDateTime parts;
   TimeToStruct(utc_time, parts);
   parts.hour = 0;
   parts.min = 0;
   parts.sec = 0;
   return StructToTime(parts);
}

string DateKey(datetime utc_day)
{
   MqlDateTime parts;
   TimeToStruct(utc_day, parts);
   return StringFormat("%04d%02d%02d", parts.year, parts.mon, parts.day);
}

string GlobalPrefix()
{
   return "PropStatsEA_" + (string)AccountInfoInteger(ACCOUNT_LOGIN) + "_";
}

string EquityPeakKey()
{
   return GlobalPrefix() + "equity_peak";
}

string DailyEquityKey(datetime utc_day)
{
   return GlobalPrefix() + "daily_start_equity_" + DateKey(utc_day);
}

string DailyMinEquityKey(datetime utc_day)
{
   return GlobalPrefix() + "daily_min_equity_" + DateKey(utc_day);
}

datetime ServerTimeForUtc(datetime utc_time)
{
   datetime server_now = TimeTradeServer();
   if(server_now <= 0)
      server_now = TimeCurrent();

   return utc_time + (server_now - TimeGMT());
}

bool IsTradeCloseDeal(ulong deal_ticket)
{
   long entry = HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
   if(entry != DEAL_ENTRY_OUT && entry != DEAL_ENTRY_OUT_BY && entry != DEAL_ENTRY_INOUT)
      return false;

   long type = HistoryDealGetInteger(deal_ticket, DEAL_TYPE);
   return (type == DEAL_TYPE_BUY || type == DEAL_TYPE_SELL);
}

bool ScopeAllowsSymbol(string symbol)
{
   if(StatsScope == PROP_STATS_CURRENT_SYMBOL && symbol != _Symbol)
      return false;
   return true;
}

int FindTradeIndex(const ClosedTrade &trades[], ulong position_id)
{
   int count = ArraySize(trades);
   for(int i = 0; i < count; i++)
   {
      if(trades[i].position_id == position_id)
         return i;
   }
   return -1;
}

void InitClosedTrade(ClosedTrade &trade, ulong position_id)
{
   trade.position_id = position_id;
   trade.open_time = 0;
   trade.close_time = 0;
   trade.symbol = "";
   trade.type = -1;
   trade.magic = 0;
   trade.volume = 0.0;
   trade.open_price = 0.0;
   trade.close_price = 0.0;
   trade.entry_sl = 0.0;
   trade.profit = 0.0;
   trade.commission = 0.0;
   trade.swap = 0.0;
   trade.net = 0.0;
   trade.risk_money = 0.0;
   trade.rr = 0.0;
}

void FillEntryDetails(ClosedTrade &trade)
{
   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;

      if((ulong)HistoryDealGetInteger(ticket, DEAL_POSITION_ID) != trade.position_id)
         continue;

      long entry = HistoryDealGetInteger(ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_IN && entry != DEAL_ENTRY_INOUT)
         continue;

      trade.open_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      trade.symbol = HistoryDealGetString(ticket, DEAL_SYMBOL);
      trade.type = HistoryDealGetInteger(ticket, DEAL_TYPE);
      trade.magic = HistoryDealGetInteger(ticket, DEAL_MAGIC);
      trade.volume = HistoryDealGetDouble(ticket, DEAL_VOLUME);
      trade.open_price = HistoryDealGetDouble(ticket, DEAL_PRICE);
      trade.entry_sl = HistoryDealGetDouble(ticket, DEAL_SL);
      return;
   }
}

double EstimateRiskMoney(const ClosedTrade &trade)
{
   if(trade.entry_sl <= 0.0 || trade.open_price <= 0.0 || trade.volume <= 0.0 || trade.symbol == "")
      return 0.0;

   double tick_size = SymbolInfoDouble(trade.symbol, SYMBOL_TRADE_TICK_SIZE);
   double tick_value = SymbolInfoDouble(trade.symbol, SYMBOL_TRADE_TICK_VALUE);
   if(tick_size <= 0.0 || tick_value <= 0.0)
      return 0.0;

   double price_risk = MathAbs(trade.open_price - trade.entry_sl);
   return (price_risk / tick_size) * tick_value * trade.volume;
}

void SortTradesByCloseTimeDesc(ClosedTrade &trades[])
{
   int count = ArraySize(trades);
   for(int i = 0; i < count - 1; i++)
   {
      for(int j = i + 1; j < count; j++)
      {
         if(trades[j].close_time > trades[i].close_time)
         {
            ClosedTrade temp = trades[i];
            trades[i] = trades[j];
            trades[j] = temp;
         }
      }
   }
}

void SortTradesByCloseTimeAsc(ClosedTrade &trades[])
{
   int count = ArraySize(trades);
   for(int i = 0; i < count - 1; i++)
   {
      for(int j = i + 1; j < count; j++)
      {
         if(trades[j].close_time < trades[i].close_time)
         {
            ClosedTrade temp = trades[i];
            trades[i] = trades[j];
            trades[j] = temp;
         }
      }
   }
}

int BuildClosedTrades(datetime from_time, datetime to_time, ClosedTrade &trades[], bool apply_filters = true)
{
   ArrayResize(trades, 0);
   if(!HistorySelect(from_time, to_time))
      return 0;

   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0 || !IsTradeCloseDeal(ticket))
         continue;

      string symbol = HistoryDealGetString(ticket, DEAL_SYMBOL);
      if(apply_filters && !ScopeAllowsSymbol(symbol))
         continue;

      ulong position_id = (ulong)HistoryDealGetInteger(ticket, DEAL_POSITION_ID);
      if(position_id == 0)
         continue;

      int index = FindTradeIndex(trades, position_id);
      if(index < 0)
      {
         index = ArraySize(trades);
         ArrayResize(trades, index + 1);
         InitClosedTrade(trades[index], position_id);
      }

      datetime close_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      if(close_time > trades[index].close_time)
      {
         trades[index].close_time = close_time;
         trades[index].close_price = HistoryDealGetDouble(ticket, DEAL_PRICE);
      }

      trades[index].symbol = symbol;
      trades[index].profit += HistoryDealGetDouble(ticket, DEAL_PROFIT);
      trades[index].commission += HistoryDealGetDouble(ticket, DEAL_COMMISSION);
      trades[index].swap += HistoryDealGetDouble(ticket, DEAL_SWAP);
   }

   int count = ArraySize(trades);
   int kept = 0;
   for(int t = 0; t < count; t++)
   {
      FillEntryDetails(trades[t]);
      if(apply_filters && FilterByMagicNumber && trades[t].magic != MagicNumber)
         continue;

      trades[t].net = trades[t].profit + trades[t].commission + trades[t].swap;
      trades[t].risk_money = EstimateRiskMoney(trades[t]);
      trades[t].rr = (trades[t].risk_money > 0.0 ? trades[t].net / trades[t].risk_money : 0.0);

      if(kept != t)
         trades[kept] = trades[t];
      kept++;
   }

   ArrayResize(trades, kept);
   return kept;
}

double DealBalanceChange(ulong ticket)
{
   return HistoryDealGetDouble(ticket, DEAL_PROFIT) +
          HistoryDealGetDouble(ticket, DEAL_COMMISSION) +
          HistoryDealGetDouble(ticket, DEAL_SWAP);
}

bool BalanceAtTime(datetime balance_time, double &balance)
{
   datetime now = TimeCurrent();
   if(!HistorySelect(0, now))
      return false;

   double later_changes = 0.0;
   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;

      datetime deal_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      if(deal_time < balance_time || deal_time > now)
         continue;

      later_changes += DealBalanceChange(ticket);
   }

   balance = AccountInfoDouble(ACCOUNT_BALANCE) - later_changes;
   return true;
}

void SaveDailyState()
{
   GlobalVariableSet(DailyEquityKey(g_current_utc_day), g_daily_start_equity);
   GlobalVariableSet(DailyMinEquityKey(g_current_utc_day), g_daily_min_equity);
}

void LoadOrResetDailyState()
{
   datetime utc_day = UtcDayStart(TimeGMT());
   bool had_loaded_day = (g_current_utc_day != 0);
   bool new_day = (utc_day != g_current_utc_day);
   g_current_utc_day = utc_day;

   string equity_key = DailyEquityKey(utc_day);
   string min_key = DailyMinEquityKey(utc_day);
   double current_equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double current_balance = AccountInfoDouble(ACCOUNT_BALANCE);

   if(!new_day && GlobalVariableCheck(equity_key))
      g_daily_start_equity = GlobalVariableGet(equity_key);
   else if(GlobalVariableCheck(equity_key))
      g_daily_start_equity = GlobalVariableGet(equity_key);
   else
   {
      double reconstructed_balance = 0.0;
      datetime reset_in_server_time = ServerTimeForUtc(utc_day);
      g_daily_start_equity = (had_loaded_day && new_day ? MathMax(current_balance, current_equity) : (BalanceAtTime(reset_in_server_time, reconstructed_balance) ? reconstructed_balance : MathMax(current_balance, current_equity)));
      GlobalVariableSet(equity_key, g_daily_start_equity);
   }

   if(!new_day && GlobalVariableCheck(min_key))
      g_daily_min_equity = GlobalVariableGet(min_key);
   else if(GlobalVariableCheck(min_key))
      g_daily_min_equity = GlobalVariableGet(min_key);
   else
   {
      g_daily_min_equity = current_equity;
      GlobalVariableSet(min_key, g_daily_min_equity);
   }

   if(current_equity < g_daily_min_equity)
   {
      g_daily_min_equity = current_equity;
      SaveDailyState();
   }
}

string TimeLeftToUtcReset()
{
   datetime now = TimeGMT();
   datetime next_reset = UtcDayStart(now) + 86400;
   int seconds_left = (int)MathMax(0, next_reset - now);
   int hours = seconds_left / 3600;
   int minutes = (seconds_left % 3600) / 60;
   int seconds = seconds_left % 60;
   return StringFormat("%02d:%02d:%02d", hours, minutes, seconds);
}

string FormatAmPm(datetime value)
{
   MqlDateTime parts;
   TimeToStruct(value, parts);

   string suffix = (parts.hour >= 12 ? "PM" : "AM");
   int hour = parts.hour % 12;
   if(hour == 0)
      hour = 12;

   return StringFormat("%02d/%02d %02d:%02d %s", parts.mon, parts.day, hour, parts.min, suffix);
}

string NextUtcResetInIst()
{
   datetime next_reset = UtcDayStart(TimeGMT()) + 86400;
   return FormatAmPm(next_reset + 5 * 3600 + 30 * 60);
}

color StatusColor(double left, double limit)
{
   if(left < 0.0)
      return BadColor();
   if(left <= MathMax(1.0, limit * 0.2))
      return WarnColor();
   return GoodColor();
}

color LagColor(double lag_percent, int sample_count)
{
   if(sample_count <= 0)
      return MutedColor();
   if(lag_percent > 0.0)
      return BadColor();
   if(lag_percent < 0.0)
      return GoodColor();
   return TextColor();
}

double DrawdownLimitMoney(ENUM_DRAWDOWN_LIMIT_MODE mode, double value, double baseline)
{
   if(mode == DD_LIMIT_PERCENT_OF_BASE)
      return MathMax(0.0, baseline * value / 100.0);
   if(mode == DD_LIMIT_PERCENT_OF_START)
      return MathMax(0.0, StartingBalance * value / 100.0);

   return MathMax(0.0, value);
}

void DeleteDashboard()
{
   for(int i = ObjectsTotal(0, 0, -1) - 1; i >= 0; i--)
   {
      string name = ObjectName(0, i, 0, -1);
      if(StringFind(name, PS_PREFIX) == 0)
         ObjectDelete(0, name);
   }
   g_objects_created = false;
}

void EnsureBox(string name, int x, int y, int width, int height, color background, color border)
{
   if(ObjectFind(0, name) < 0)
      ObjectCreate(0, name, OBJ_RECTANGLE_LABEL, 0, 0, 0);

   ObjectSetInteger(0, name, OBJPROP_CORNER, PanelCorner);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetInteger(0, name, OBJPROP_XSIZE, width);
   ObjectSetInteger(0, name, OBJPROP_YSIZE, height);
   ObjectSetInteger(0, name, OBJPROP_BGCOLOR, background);
   ObjectSetInteger(0, name, OBJPROP_BORDER_COLOR, border);
   ObjectSetInteger(0, name, OBJPROP_BACK, false);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
   ObjectSetInteger(0, name, OBJPROP_ZORDER, 0);
   ObjectSetString(0, name, OBJPROP_TEXT, "");
}

void EnsureLabel(string name, int x, int y, int font_size, color text_color, string font = "Consolas")
{
   if(ObjectFind(0, name) < 0)
      ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);

   ObjectSetInteger(0, name, OBJPROP_CORNER, PanelCorner);
   ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
   ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, font_size);
   ObjectSetInteger(0, name, OBJPROP_COLOR, text_color);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, name, OBJPROP_HIDDEN, true);
   ObjectSetInteger(0, name, OBJPROP_ZORDER, 10);
   ObjectSetString(0, name, OBJPROP_FONT, font);
}

void CreateDashboard()
{
   if(!ShowDashboard)
      return;

   int panel_width = PanelWidth;
   if(panel_width < 620)
      panel_width = 620;
   int panel_height = 500;
   EnsureBox(PS_PREFIX + "BG", PanelX, PanelY, panel_width, panel_height, PanelColor(), BorderColor());
   EnsureBox(PS_PREFIX + "HEADER", PanelX, PanelY, panel_width, 42, HeaderColor(), HeaderColor());
   EnsureBox(PS_PREFIX + "ACCENT", PanelX, PanelY, 4, panel_height, GoodColor(), GoodColor());
   EnsureBox(PS_PREFIX + "SEP_1", PanelX + 18, PanelY + 124, panel_width - 36, 1, BorderColor(), BorderColor());
   EnsureBox(PS_PREFIX + "SEP_2", PanelX + 18, PanelY + 214, panel_width - 36, 1, BorderColor(), BorderColor());
   EnsureBox(PS_PREFIX + "SEP_3", PanelX + 18, PanelY + 351, panel_width - 36, 1, BorderColor(), BorderColor());

   EnsureLabel(PS_PREFIX + "TITLE", PanelX + 18, PanelY + 12, FontSize + 4, TextColor(), "Arial Bold");
   for(int i = 0; i < PS_LINE_COUNT; i++)
      EnsureLabel(PS_PREFIX + "LINE_" + (string)i, PanelX + 18, PanelY + 56 + i * 15, FontSize, TextColor());

   g_objects_created = true;
}

void SetLine(int index, string text, color text_color = clrNONE)
{
   if(index < 0 || index >= PS_LINE_COUNT)
      return;

   string name = PS_PREFIX + "LINE_" + (string)index;
   ObjectSetString(0, name, OBJPROP_TEXT, text);
   ObjectSetInteger(0, name, OBJPROP_COLOR, (text_color == clrNONE ? TextColor() : text_color));
}

string TradeLine(const ClosedTrade &trade)
{
   MqlDateTime parts;
   TimeToStruct(trade.close_time, parts);
   string side = (trade.type == DEAL_TYPE_BUY ? "BUY " : (trade.type == DEAL_TYPE_SELL ? "SELL" : "    "));
   return StringFormat("%02d/%02d %02d:%02d   %-8s %-4s   %s",
                       parts.mon, parts.day, parts.hour, parts.min,
                       trade.symbol, side, SignedMoney(trade.net));
}

void RecentLosingTradeStats(const ClosedTrade &trades[], int sample_size, double &average_loss, int &sample_count)
{
   average_loss = 0.0;
   sample_count = 0;

   int count = ArraySize(trades);
   for(int i = 0; i < count && sample_count < sample_size; i++)
   {
      if(trades[i].net >= -0.005)
         continue;

      average_loss += MathAbs(trades[i].net);
      sample_count++;
   }

   if(sample_count > 0)
      average_loss /= sample_count;
}

void SpreadCostLagStats(const ClosedTrade &trades[],
                        double &average_lag,
                        double &average_win_lag,
                        double &average_loss_lag,
                        double &qualified_net,
                        int &sample_count,
                        int &win_sample_count,
                        int &loss_sample_count)
{
   average_lag = 0.0;
   average_win_lag = 0.0;
   average_loss_lag = 0.0;
   qualified_net = 0.0;
   sample_count = 0;
   win_sample_count = 0;
   loss_sample_count = 0;

   int count = ArraySize(trades);
   double qualify_percent = MathMax(0.0, LagQualificationPercent) / 100.0;
   for(int i = 0; i < count; i++)
   {
      double lag = 0.0;
      if(trades[i].net > 0.005)
      {
         if(PlannedWinMoney <= 0.0)
            continue;
         if(trades[i].net < PlannedWinMoney * qualify_percent)
            continue;

         lag = 100.0 * (PlannedWinMoney - trades[i].net) / PlannedWinMoney;
         average_win_lag += lag;
         win_sample_count++;
      }
      else if(trades[i].net < -0.005)
      {
         if(PlannedLossMoney <= 0.0)
            continue;
         if(MathAbs(trades[i].net) < PlannedLossMoney * qualify_percent)
            continue;

         lag = 100.0 * (MathAbs(trades[i].net) - PlannedLossMoney) / PlannedLossMoney;
         average_loss_lag += lag;
         loss_sample_count++;
      }
      else
         continue;

      average_lag += lag;
      qualified_net += trades[i].net;
      sample_count++;
   }

   if(win_sample_count > 0)
      average_win_lag /= win_sample_count;
   if(loss_sample_count > 0)
      average_loss_lag /= loss_sample_count;
   if(sample_count > 0)
      average_lag /= sample_count;
}

void UpdateDashboard()
{
   if(!ShowDashboard)
   {
      DeleteDashboard();
      return;
   }

   if(!g_objects_created)
      CreateDashboard();

   LoadOrResetDailyState();

   datetime now = TimeCurrent();
   ClosedTrade trades[];
   int count = BuildClosedTrades(0, now, trades);
   SortTradesByCloseTimeDesc(trades);

   int wins = 0;
   int losses = 0;
   int breakevens = 0;
   double gross_profit = 0.0;
   double gross_loss = 0.0;
   double net_profit = 0.0;
   for(int i = 0; i < count; i++)
   {
      net_profit += trades[i].net;
      if(MathAbs(trades[i].net) < 0.005)
         breakevens++;
      else if(trades[i].net > 0.0)
      {
         wins++;
         gross_profit += trades[i].net;
      }
      else
      {
         losses++;
         gross_loss += MathAbs(trades[i].net);
      }
   }

   int decisive = wins + losses;
   double win_rate = (decisive > 0 ? 100.0 * wins / decisive : 0.0);
   double avg_win = (wins > 0 ? gross_profit / wins : 0.0);
   double avg_loss = (losses > 0 ? gross_loss / losses : 0.0);
   double ev = (decisive > 0 ? (gross_profit - gross_loss) / decisive : 0.0);
   double average_rr = (avg_loss > 0.0 ? avg_win / avg_loss : 0.0);
   double profit_factor = (gross_loss > 0.0 ? gross_profit / gross_loss : (gross_profit > 0.0 ? 999.0 : 0.0));

   ClosedTrade asc[];
   ArrayResize(asc, count);
   for(int a = 0; a < count; a++)
      asc[a] = trades[a];
   SortTradesByCloseTimeAsc(asc);
   double curve = StartingBalance;
   double peak = StartingBalance;
   double max_realized_dd = 0.0;
   for(int c = 0; c < ArraySize(asc); c++)
   {
      curve += asc[c].net;
      if(curve > peak)
         peak = curve;
      double dd = peak - curve;
      if(dd > max_realized_dd)
         max_realized_dd = dd;
   }

   double account_balance_peak = StartingBalance;
   if(MaxDrawdownFloorMode == MAX_DD_TRAILING_BALANCE_PEAK || MaxDrawdownFloorMode == MAX_DD_TRAILING_EQUITY_PEAK)
   {
      ClosedTrade account_trades[];
      int account_count = BuildClosedTrades(0, now, account_trades, false);
      SortTradesByCloseTimeAsc(account_trades);
      double account_curve = StartingBalance;
      for(int p = 0; p < account_count; p++)
      {
         account_curve += account_trades[p].net;
         if(account_curve > account_balance_peak)
            account_balance_peak = account_curve;
      }
   }

   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double floating = AccountInfoDouble(ACCOUNT_PROFIT);

   if(g_equity_peak <= 0.0)
   {
      if(GlobalVariableCheck(EquityPeakKey()))
         g_equity_peak = GlobalVariableGet(EquityPeakKey());
      else
         g_equity_peak = StartingBalance;
   }

   if(equity > g_equity_peak)
   {
      g_equity_peak = equity;
      GlobalVariableSet(EquityPeakKey(), g_equity_peak);
   }

   double total_baseline = StartingBalance;
   if(MaxDrawdownFloorMode == MAX_DD_TRAILING_BALANCE_PEAK)
      total_baseline = MathMax(StartingBalance, account_balance_peak);
   else if(MaxDrawdownFloorMode == MAX_DD_TRAILING_EQUITY_PEAK)
      total_baseline = MathMax(MathMax(StartingBalance, account_balance_peak), g_equity_peak);

   double total_limit_money = DrawdownLimitMoney(MaxDrawdownLimitMode, MaxTotalDrawdownValue, total_baseline);
   double daily_limit_money = DrawdownLimitMoney(DailyDrawdownLimitMode, MaxDailyDrawdownValue, g_daily_start_equity);
   double total_floor = total_baseline - total_limit_money;
   double daily_floor = g_daily_start_equity - daily_limit_money;
   double total_dd_left = equity - total_floor;
   double daily_dd_left = equity - daily_floor;
   double target_left = MathMax(0.0, TargetEquity - equity);
   double daily_used = MathMax(0.0, g_daily_start_equity - MathMin(equity, g_daily_min_equity));
   double recent_avg_loss = 0.0;
   int recent_loss_count = 0;
   RecentLosingTradeStats(trades, 5, recent_avg_loss, recent_loss_count);
   int losses_left_today = (recent_avg_loss > 0.0 ? (int)MathFloor(MathMax(0.0, daily_dd_left) / recent_avg_loss) : -1);
   string losses_left_text = (recent_loss_count > 0 ? (string)losses_left_today : "--");
   string avg_loss_text = (recent_loss_count > 0 ? Money(recent_avg_loss) : "--");
   double spread_cost_lag = 0.0;
   double win_lag = 0.0;
   double loss_lag = 0.0;
   double lag_actual_pl = 0.0;
   int lag_count = 0;
   int win_lag_count = 0;
   int loss_lag_count = 0;
   SpreadCostLagStats(trades, spread_cost_lag, win_lag, loss_lag, lag_actual_pl, lag_count, win_lag_count, loss_lag_count);
   string spread_cost_lag_text = (lag_count > 0 ? SignedPercent(spread_cost_lag) : "--");
   string win_lag_text = (win_lag_count > 0 ? SignedPercent(win_lag) : "--");
   string loss_lag_text = (loss_lag_count > 0 ? SignedPercent(loss_lag) : "--");
   double split_lag_color_value = 0.0;
   if(win_lag_count > 0 && loss_lag_count > 0)
      split_lag_color_value = (win_lag > loss_lag ? win_lag : loss_lag);
   else if(win_lag_count > 0)
      split_lag_color_value = win_lag;
   else if(loss_lag_count > 0)
      split_lag_color_value = loss_lag;
   int split_lag_count = win_lag_count + loss_lag_count;
   double no_lag_pl = win_lag_count * PlannedWinMoney - loss_lag_count * PlannedLossMoney;
   double no_lag_gap = no_lag_pl - lag_actual_pl;

   ObjectSetString(0, PS_PREFIX + "TITLE", OBJPROP_TEXT, "Prop Stats  |  " + AccountInfoString(ACCOUNT_NAME));

   int line = 0;
   SetLine(line++, "ACCOUNT", MutedColor());
   SetLine(line++, "Balance        " + Money(balance) + "        Equity        " + Money(equity));
   SetLine(line++, "Floating P/L   " + SignedMoney(floating) + "        Net closed    " + SignedMoney(net_profit), (net_profit >= 0.0 ? GoodColor() : BadColor()));
   SetLine(line++, "Target equity  " + Money(TargetEquity) + "        Left          " + Money(target_left), (target_left <= 0.0 ? GoodColor() : TextColor()));
   SetLine(line++, " ");
   SetLine(line++, "RISK LIMITS", MutedColor());
   SetLine(line++, "Max DD floor   " + Money(total_floor) + "        Left          " + Money(total_dd_left), StatusColor(total_dd_left, total_limit_money));
   SetLine(line++, "Daily floor    " + Money(daily_floor) + "        Left          " + Money(daily_dd_left), StatusColor(daily_dd_left, daily_limit_money));
   SetLine(line++, "Losses left    " + losses_left_text + "        Avg L5 loss   " + avg_loss_text, (losses_left_today < 0 ? MutedColor() : StatusColor(daily_dd_left, daily_limit_money)));
   SetLine(line++, "Daily start    " + Money(g_daily_start_equity) + "        Used          " + Money(daily_used));
   SetLine(line++, "UTC reset      00:00 in " + TimeLeftToUtcReset() + "    IST reset  " + NextUtcResetInIst());
   SetLine(line++, " ");
   SetLine(line++, "PERFORMANCE", MutedColor());
   SetLine(line++, "Trades         " + (string)count + "        Wins " + (string)wins + " / Losses " + (string)losses + " / BE " + (string)breakevens);
   SetLine(line++, "Win rate       " + DoubleToString(win_rate, 1) + "%        Avg RR        " + DoubleToString(average_rr, 2) + "R");
   SetLine(line++, "EV / trade     " + Money(ev) + "        Profit factor " + DoubleToString(profit_factor, 2));
   SetLine(line++, "P/L lag avg    " + spread_cost_lag_text + "        Samples       " + (string)lag_count, LagColor(spread_cost_lag, lag_count));
   SetLine(line++, "Win lag        " + win_lag_text + "        Loss lag      " + loss_lag_text, LagColor(split_lag_color_value, split_lag_count));
   SetLine(line++, "No-lag P/L     " + SignedMoney(no_lag_pl) + "        Actual P/L    " + SignedMoney(lag_actual_pl), (no_lag_gap > 0.0 ? BadColor() : GoodColor()));
   SetLine(line++, "Realized DD    " + Money(max_realized_dd) + "        Scope         " + (StatsScope == PROP_STATS_CURRENT_SYMBOL ? _Symbol : "All symbols"));
   SetLine(line++, " ");
   SetLine(line++, "LAST 5 CLOSED TRADES", MutedColor());

   for(int j = 0; j < 5; j++)
   {
      if(j < count)
         SetLine(line++, TradeLine(trades[j]), (trades[j].net >= 0.0 ? GoodColor() : BadColor()));
      else
         SetLine(line++, "--");
   }

   for(; line < PS_LINE_COUNT; line++)
      SetLine(line, " ");

   ChartRedraw(0);
}

int OnInit()
{
   g_current_utc_day = 0;
   g_equity_peak = (GlobalVariableCheck(EquityPeakKey()) ? GlobalVariableGet(EquityPeakKey()) : StartingBalance);
   if(AccountInfoDouble(ACCOUNT_EQUITY) > g_equity_peak)
   {
      g_equity_peak = AccountInfoDouble(ACCOUNT_EQUITY);
      GlobalVariableSet(EquityPeakKey(), g_equity_peak);
   }
   LoadOrResetDailyState();
   CreateDashboard();
   UpdateDashboard();
   EventSetTimer(1);
   return INIT_SUCCEEDED;
}

void OnDeinit(const int reason)
{
   EventKillTimer();
   SaveDailyState();
   DeleteDashboard();
}

void OnTick()
{
   UpdateDashboard();
}

void OnTimer()
{
   UpdateDashboard();
}

void OnChartEvent(const int id, const long &lparam, const double &dparam, const string &sparam)
{
   if(id == CHARTEVENT_CHART_CHANGE)
   {
      g_objects_created = false;
      CreateDashboard();
      UpdateDashboard();
   }
}
