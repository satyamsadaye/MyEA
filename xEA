void CloseTrailingScaleOrders(const ulong base_ticket)
{
   if(base_ticket == 0)
      return;
   int idx = FindTrailingScaleGroupIndex(base_ticket);
   if(idx < 0)
      return;

   for(int i = 0; i < ExtTrailingScaleGroups[idx].scale_count; i++)
   {
      ulong scale_ticket = ExtTrailingScaleGroups[idx].scale_tickets[i];
      if(scale_ticket == 0)
         continue;
