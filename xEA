void MarkTrailingUsage(const ulong ticket)
{
   if(ticket == 0)
      return;

   ulong position_id = 0;
   if(PositionSelectByTicket(ticket))
      position_id = (ulong)PositionGetInteger(POSITION_IDENTIFIER);

   int idx = FindTrailingUsageTrackerIndex(ticket);
   if(idx < 0 && position_id > 0)
      idx = FindTrailingUsageTrackerIndexByPositionId(position_id);

   if(idx < 0)
   {
      int size = ArraySize(ExtTrailingUsageTrackers);
      ArrayResize(ExtTrailingUsageTrackers, size + 1);
      ExtTrailingUsageTrackers[size].ticket = ticket;
      ExtTrailingUsageTrackers[size].position_id = position_id;
      ExtTrailingUsageTrackers[size].used = true;
      return;
   }

   if(ExtTrailingUsageTrackers[idx].ticket == 0)
      ExtTrailingUsageTrackers[idx].ticket = ticket;
   if(ExtTrailingUsageTrackers[idx].position_id == 0 && position_id > 0)
      ExtTrailingUsageTrackers[idx].position_id = position_id;
   ExtTrailingUsageTrackers[idx].used = true;
}

