                    }
                }
                else
                {
                    if ((ORDER_TYPE_SELL == ORDER_TYPE_BUY && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
                        (ORDER_TYPE_SELL == ORDER_TYPE_SELL && InpTradeDirection == TRADE_DIR_BUY_ONLY))
                    {
                        PrintFormat("[DEV MODE] Pattern 5: Would be blocked by direction filter.");
                    } else {
                        PrintFormat("[DEV MODE] Pattern 5: Would place SELL order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                                   entryPrice, stopLoss, takeProfit, lots);
                    }
                    g_lastSignalTime = current_bar_time;
                }
            }
            else
            {
                if ((ORDER_TYPE_SELL == ORDER_TYPE_BUY && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
                    (ORDER_TYPE_SELL == ORDER_TYPE_SELL && InpTradeDirection == TRADE_DIR_BUY_ONLY))
                {
                    PrintFormat("[DEV MODE] Pattern 5: Would be blocked by direction filter.");
                } else {
                    PrintFormat("[DEV MODE] Pattern 5: Would place SELL order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                               entryPrice, stopLoss, takeProfit, lots);
                }
                g_lastSignalTime = current_bar_time;
            }
        }
    }
    else
    {
        PrintFormat("Pattern 5 OLD: No signal for this bar. Current close (%.5f) not above prev high (%.5f) or below prev low (%.5f)",
                   currentClose, prevHigh, prevLow);
    }
