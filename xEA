//+------------------------------------------------------------------+
//| Calculate breakeven price for a multi-recovery group            |
//+------------------------------------------------------------------+
double CalculateGroupBreakevenPrice(MultiOrderGroup &group)
{
   if(group.ticket_count == 0)
      return 0.0;
   
   double total_volume_buy = 0.0;
   double total_volume_sell = 0.0;
   double weighted_avg_buy = 0.0;
   double weighted_avg_sell = 0.0;
   double total_swap = 0.0;
   double total_unrealized_pnl = 0.0;
   
   // Analyze all positions in the group
   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(!PositionSelectByTicket(ticket))
         continue;
         
      ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      double volume = PositionGetDouble(POSITION_VOLUME);
      double open_price = PositionGetDouble(POSITION_PRICE_OPEN);
      double swap = PositionGetDouble(POSITION_SWAP);
      double current_profit = PositionGetDouble(POSITION_PROFIT); // Includes commission automatically
      
      total_swap += swap;
      total_unrealized_pnl += current_profit; // This already includes commission
      
      if(pos_type == POSITION_TYPE_BUY)
      {
         weighted_avg_buy += (open_price * volume);
         total_volume_buy += volume;
      }
      else // SELL
      {
         weighted_avg_sell += (open_price * volume);
         total_volume_sell += volume;
      }
   }
   
   // Check if we have mixed position types (this shouldn't happen in normal recovery)
   if(total_volume_buy > 0 && total_volume_sell > 0)
   {
      PrintFormat("WARNING: Group #%d has mixed position types - cannot calculate single breakeven price", 
                 group.base_ticket);
      return 0.0;
   }
   
   double breakeven_price = 0.0;
   double current_price = SymbolInfoDouble(_Symbol, SYMBOL_BID); // Use current bid price
   double point_value = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tick_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   
   if(total_volume_buy > 0)
   {
      // For BUY positions: Calculate price needed to offset current losses + swap
      weighted_avg_buy = weighted_avg_buy / total_volume_buy;
      
      // Calculate required price movement to achieve breakeven
      // Current P&L = (Current Price - Average Entry) * Volume * Point Value + Swap
      // For breakeven: (Breakeven Price - Average Entry) * Volume * Point Value + Swap = 0
      // Therefore: Breakeven Price = Average Entry - (Swap / (Volume * Point Value))
      
      double required_price_adjustment = 0.0;
      if(point_value > 0 && total_volume_buy > 0)
      {
         // Convert swap cost to price points
         required_price_adjustment = (total_swap * tick_size) / (point_value * total_volume_buy);
      }
      
      breakeven_price = weighted_avg_buy - required_price_adjustment;
      
      PrintFormat("Group #%d BUY Breakeven: Avg Entry: %.5f, Volume: %.2f, Swap: %.2f, Current P&L: %.2f, Breakeven: %.5f", 
                 group.base_ticket, weighted_avg_buy, total_volume_buy, total_swap, total_unrealized_pnl, breakeven_price);
   }
   else if(total_volume_sell > 0)
   {
      // For SELL positions: Calculate price needed to offset current losses + swap
      weighted_avg_sell = weighted_avg_sell / total_volume_sell;
      
      // For SELL positions: (Average Entry - Breakeven Price) * Volume * Point Value + Swap = 0
      // Therefore: Breakeven Price = Average Entry + (Swap / (Volume * Point Value))
      
      double required_price_adjustment = 0.0;
      if(point_value > 0 && total_volume_sell > 0)
      {
         // Convert swap cost to price points  
         required_price_adjustment = (total_swap * tick_size) / (point_value * total_volume_sell);
      }
      
      breakeven_price = weighted_avg_sell + required_price_adjustment;
      
      PrintFormat("Group #%d SELL Breakeven: Avg Entry: %.5f, Volume: %.2f, Swap: %.2f, Current P&L: %.2f, Breakeven: %.5f", 
                 group.base_ticket, weighted_avg_sell, total_volume_sell, total_swap, total_unrealized_pnl, breakeven_price);
   }
   
   return breakeven_price;
}

