//+------------------------------------------------------------------+
//| Send Webhook Request                                             |
//+------------------------------------------------------------------+
bool SendWebhookRequest(string message, bool bypass_rate_limit = false)
{
   if(!InpCopyTradeEnabled || StringLen(InpWebhookURL) == 0)
   {
      PrintFormat("Copy Trade Debug: Cannot send webhook - CopyTradeEnabled: %s, WebhookURL: '%s'", 
                  InpCopyTradeEnabled ? "YES" : "NO", InpWebhookURL);
      return false;
   }
   
   PrintFormat("Copy Trade Debug: Webhook URL: %s", InpWebhookURL);
      
   // Throttle webhook requests to avoid spam (minimum 2 seconds between requests)
   // Unless bypass_rate_limit is true (for critical messages like CLOSEALL)
   datetime current_time = TimeCurrent();
   if(!bypass_rate_limit && current_time - g_lastWebhookTime < 2)
   {
      PrintFormat("Copy Trade: Throttling webhook request. Last request was %.0f seconds ago (need 2+ seconds).", 
                  (double)(current_time - g_lastWebhookTime));
      return false;
   }
   
   string url = InpWebhookURL;
   string headers = "Content-Type: text/plain\r\n";
   string post_data = message; // Send raw message instead of form data
   
   char data[];
   char result[];
   string result_headers;
   
   ArrayResize(data, StringToCharArray(post_data, data) - 1);
   
   PrintFormat("Copy Trade: Sending webhook - %s", message);
   
   int timeout = 5000; // 5 seconds timeout
   int res = WebRequest("POST", url, headers, timeout, data, result, result_headers);
   
   if(res == 200)
   {
      g_lastWebhookTime = current_time;
      PrintFormat("Copy Trade: Webhook sent successfully - %s", message);
      return true;
   }
   else
   {
      PrintFormat("Copy Trade: Webhook failed with code %d - %s", res, message);
      return false;
   }
}

//+------------------------------------------------------------------+
//| Send Webhook Request with Retry Logic                           |
//+------------------------------------------------------------------+
bool SendWebhookWithRetry(string message, bool bypass_rate_limit = false, int max_retries = 2)
{
   bool success = false;
   int attempts = 0;
   
   while(!success && attempts <= max_retries)
   {
      attempts++;
      
      if(attempts > 1)
      {
         PrintFormat("Copy Trade: Retry attempt %d/%d for message: %s", attempts - 1, max_retries, message);
         // Wait 1 second between retries
         Sleep(1000);
      }
      
      success = SendWebhookRequest(message, bypass_rate_limit);
      
      if(!success && attempts <= max_retries)
      {
         PrintFormat("Copy Trade: Attempt %d failed, %s", attempts, 
                     attempts < max_retries + 1 ? "retrying..." : "giving up");
      }
   }
   
   if(success)
   {
      PrintFormat("Copy Trade: Message sent successfully after %d attempt(s)", attempts);
   }
   else
   {
      PrintFormat("Copy Trade: Failed to send message after %d attempts: %s", attempts, message);
   }
   
   return success;
}

//+------------------------------------------------------------------+
//| Reset copy trade tracking for a specific ticket (for manual resend) |
//+------------------------------------------------------------------+
void ResetCopyTradeTracking(ulong ticket_to_reset = 0)
{
   if(ticket_to_reset == 0)
   {
      // Reset all tracking
      ArrayFree(g_copyTradeStates);
      PrintFormat("Copy Trade Debug: All tracking reset. Signals can be resent for all positions.");
   }
   else
   {
      // Reset specific ticket
      for(int i = ArraySize(g_copyTradeStates) - 1; i >= 0; i--)
      {
         if(g_copyTradeStates[i].ticket == ticket_to_reset)
         {
            // Remove this entry
            for(int j = i; j < ArraySize(g_copyTradeStates) - 1; j++)
            {
               g_copyTradeStates[j] = g_copyTradeStates[j + 1];
            }
            ArrayResize(g_copyTradeStates, ArraySize(g_copyTradeStates) - 1);
            PrintFormat("Copy Trade Debug: Tracking reset for ticket %d. Signal can be resent.", ticket_to_reset);
            break;
         }
      }
   }
}
//+------------------------------------------------------------------+
//| Send Trade Open Signal                                           |
//+------------------------------------------------------------------+
void SendTradeOpenSignal(string symbol, ENUM_POSITION_TYPE position_type, double sl_price, ulong ticket, double entry_price = 0)
{
   if(!InpCopyTradeEnabled || !InpSendTradeSignals)
   {
      PrintFormat("Copy Trade Debug: Signal sending disabled - CopyTradeEnabled: %s, SendTradeSignals: %s", 
                  InpCopyTradeEnabled ? "YES" : "NO", InpSendTradeSignals ? "YES" : "NO");
      return;
   }
   
   PrintFormat("Copy Trade Debug: Starting SendTradeOpenSignal for ticket %d, symbol %s, type %s", 
               ticket, symbol, position_type == POSITION_TYPE_BUY ? "BUY" : "SELL");
   
   // If entry price not provided, try to get it from position or market
   if(entry_price == 0)
   {
      if(PositionSelectByTicket(ticket))
      {
         entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
      }
      else
      {
         // If we can't get the position, use current market price as fallback
         if(position_type == POSITION_TYPE_BUY)
            entry_price = SymbolInfoDouble(symbol, SYMBOL_ASK);
         else
            entry_price = SymbolInfoDouble(symbol, SYMBOL_BID);
      }
   }
   
   string direction;
   // Calculate SL distance from entry price
   double sl_distance = MathAbs(entry_price - sl_price);

   // --- SPREAD BUFFER LOGIC ---
   double buffer = 0.0;
   if(InpFollowerSpread > 0) {
      double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
      buffer = InpFollowerSpread * point;
   }
   double trigger_price = entry_price;
   bool is_inverted = InpInvertCopyDirection;

   // Only apply buffer logic if buffer > 0 and waiting for buffer is enabled
   if(buffer > 0 && InpWaitForBufferConfirmation) {
      if(is_inverted) {
         // Invert direction for copy
         direction = (position_type == POSITION_TYPE_BUY) ? "sell" : "buy";
         if(position_type == POSITION_TYPE_BUY) {
            // X BUY, RohitEA SELL: wait for price >= entry + buffer
            trigger_price = entry_price + buffer;
            PrintFormat("[DEBUG] Waiting for buffer: X BUY (inverted to SELL). Waiting for ASK >= %.5f", trigger_price);
            while(SymbolInfoDouble(symbol, SYMBOL_ASK) < trigger_price) {
               // Check if the original trade is still open
               ulong pos_ticket = (ulong)PositionGetInteger(POSITION_TICKET);
               if(pos_ticket != ticket || !PositionSelectByTicket(ticket)) {
                  PrintFormat("[DEBUG] Trade %I64u closed before buffer met. Exiting buffer wait.", ticket);
                  return;
               }
               PrintFormat("[DEBUG] ...ASK = %.5f, Buffer = %.5f, Trigger = %.5f", SymbolInfoDouble(symbol, SYMBOL_ASK), buffer, trigger_price);
               Sleep(500);
            }
            PrintFormat("[DEBUG] Buffer met: ASK >= %.5f (current: %.5f). Sending SELL signal.", trigger_price, SymbolInfoDouble(symbol, SYMBOL_ASK));
         } else {
            // X SELL, RohitEA BUY: wait for price <= entry - buffer
            trigger_price = entry_price - buffer;
            PrintFormat("[DEBUG] Waiting for buffer: X SELL (inverted to BUY). Waiting for BID <= %.5f", trigger_price);
            while(SymbolInfoDouble(symbol, SYMBOL_BID) > trigger_price) {
               // Check if the original trade is still open
               ulong pos_ticket = (ulong)PositionGetInteger(POSITION_TICKET);
               if(pos_ticket != ticket || !PositionSelectByTicket(ticket)) {
                  PrintFormat("[DEBUG] Trade %I64u closed before buffer met. Exiting buffer wait.", ticket);
                  return;
               }
               PrintFormat("[DEBUG] ...BID = %.5f, Buffer = %.5f, Trigger = %.5f", SymbolInfoDouble(symbol, SYMBOL_BID), buffer, trigger_price);
               Sleep(500);
            }
            PrintFormat("[DEBUG] Buffer met: BID <= %.5f (current: %.5f). Sending BUY signal.", trigger_price, SymbolInfoDouble(symbol, SYMBOL_BID));
         }
      } else {
         direction = (position_type == POSITION_TYPE_BUY) ? "buy" : "sell";
         if(position_type == POSITION_TYPE_BUY) {
            // X BUY, RohitEA BUY: wait for price <= entry - buffer
            trigger_price = entry_price - buffer;
            PrintFormat("[DEBUG] Waiting for buffer: X BUY. Waiting for BID <= %.5f", trigger_price);
            while(SymbolInfoDouble(symbol, SYMBOL_BID) > trigger_price) {
               // Check if the original trade is still open
               ulong pos_ticket = (ulong)PositionGetInteger(POSITION_TICKET);
               if(pos_ticket != ticket || !PositionSelectByTicket(ticket)) {
                  PrintFormat("[DEBUG] Trade %I64u closed before buffer met. Exiting buffer wait.", ticket);
                  return;
               }
               PrintFormat("[DEBUG] ...BID = %.5f, Buffer = %.5f, Trigger = %.5f", SymbolInfoDouble(symbol, SYMBOL_BID), buffer, trigger_price);
               Sleep(500);
            }
            PrintFormat("[DEBUG] Buffer met: BID <= %.5f (current: %.5f). Sending BUY signal.", trigger_price, SymbolInfoDouble(symbol, SYMBOL_BID));
         } else {
            // X SELL, RohitEA SELL: wait for price >= entry + buffer
            trigger_price = entry_price + buffer;
            PrintFormat("[DEBUG] Waiting for buffer: X SELL. Waiting for ASK >= %.5f", trigger_price);
            while(SymbolInfoDouble(symbol, SYMBOL_ASK) < trigger_price) {
               // Check if the original trade is still open
               ulong pos_ticket = (ulong)PositionGetInteger(POSITION_TICKET);
               if(pos_ticket != ticket || !PositionSelectByTicket(ticket)) {
                  PrintFormat("[DEBUG] Trade %I64u closed before buffer met. Exiting buffer wait.", ticket);
                  return;
               }
               PrintFormat("[DEBUG] ...ASK = %.5f, Buffer = %.5f, Trigger = %.5f", SymbolInfoDouble(symbol, SYMBOL_ASK), buffer, trigger_price);
               Sleep(500);
            }
            PrintFormat("[DEBUG] Buffer met: ASK >= %.5f (current: %.5f). Sending SELL signal.", trigger_price, SymbolInfoDouble(symbol, SYMBOL_ASK));
         }
      }
   } else {
      // No buffer logic, use original direction logic
      if(is_inverted) {
         direction = (position_type == POSITION_TYPE_BUY) ? "sell" : "buy";
      } else {
         direction = (position_type == POSITION_TYPE_BUY) ? "buy" : "sell";
      }
   }
   // --- END SPREAD BUFFER LOGIC ---

   string message;

   PrintFormat("Copy Trade Debug: SendSLTPPrices mode: %s", InpSendSLTPPrices ? "YES" : "NO");

   // Check if we should send SL/TP prices instead of ATR distance
   if(InpSendSLTPPrices)
   {
      double tp_price = 0;
      if(PositionSelectByTicket(ticket))
         tp_price = PositionGetDouble(POSITION_TP);
      double adjusted_sl = sl_price;
      double adjusted_tp = tp_price;

      // First, swap SL and TP if inverted mode is enabled (BEFORE buffer adjustment)
      if(is_inverted)
      {
         double temp = adjusted_sl;
         adjusted_sl = adjusted_tp;
         adjusted_tp = temp;
         PrintFormat("[DEBUG] Inverted mode: Swapped SL (%.5f) and TP (%.5f) BEFORE spread buffer adjustment", adjusted_sl, adjusted_tp);
      }

      // Then, apply spread buffer adjustment based on FINAL (inverted) direction
      if(InpUseSpreadBuffer && InpFollowerSpread > 0)
      {
         double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
         double buffer_adjustment = InpFollowerSpread * point; // Direct point adjustment for Fixed Points
         
         PrintFormat("[DEBUG] Spread Buffer: BEFORE adjustment - SL: %.5f, TP: %.5f", adjusted_sl, adjusted_tp);
         PrintFormat("[DEBUG] Spread Buffer: Follower spread = %.0f points, adjustment = %.5f price units", 
                    InpFollowerSpread, buffer_adjustment);
         
         // Determine FINAL trade direction (after inversion if applicable)
         bool final_is_buy = (position_type == POSITION_TYPE_BUY && !is_inverted) || (position_type == POSITION_TYPE_SELL && is_inverted);
         
         if(final_is_buy)
         {
            // For FINAL BUY direction: Move SL down (better), TP up (better) 
            adjusted_sl = adjusted_sl - buffer_adjustment; // SL 20 points closer to entry (less risk)
            adjusted_tp = adjusted_tp + buffer_adjustment; // TP 20 points further from entry (more reward)
            PrintFormat("[DEBUG] Spread Buffer: FINAL BUY - Moving SL DOWN by %.5f, TP UP by %.5f", buffer_adjustment, buffer_adjustment);
         }
         else
         {
            // For FINAL SELL direction: Move SL up (better), TP down (better)
            adjusted_sl = adjusted_sl + buffer_adjustment; // SL 20 points closer to entry (less risk)
            adjusted_tp = adjusted_tp - buffer_adjustment; // TP 20 points further from entry (more reward)
            PrintFormat("[DEBUG] Spread Buffer: FINAL SELL - Moving SL UP by %.5f, TP DOWN by %.5f", buffer_adjustment, buffer_adjustment);
         }
         
         PrintFormat("[DEBUG] Spread Buffer: AFTER adjustment - SL: %.5f, TP: %.5f", adjusted_sl, adjusted_tp);
      }
      else
      {
         PrintFormat("[DEBUG] Spread Buffer: DISABLED or no follower spread set (UseBuffer: %s, FollowerSpread: %.0f)", 
                    InpUseSpreadBuffer ? "YES" : "NO", InpFollowerSpread);
      }

      // Build message based on enabled options
      if(InpSendSL && InpSendTP)
         message = StringFormat("%s, %s, %.5f, %.5f", symbol, direction, adjusted_sl, adjusted_tp);
      else if(InpSendSL)
         message = StringFormat("%s, %s, %.5f", symbol, direction, adjusted_sl);
      else if(InpSendTP)
         message = StringFormat("%s, %s, , %.5f", symbol, direction, adjusted_tp);
      else
         message = StringFormat("%s, %s", symbol, direction);
   }
   else
   {
      // Original mode: Send the raw distance (not converted to points)
      // For XAUUSD: Entry 3338.214, SL 3337.227 = Distance 0.987
      message = StringFormat("%s, %s, %.3f", symbol, direction, sl_distance);
      PrintFormat("Copy Trade Debug: Using original ATR distance mode. Message: %s", message);
   }

   PrintFormat("Copy Trade Debug: Final message to send: %s", message);

   bool webhook_sent = SendWebhookWithRetry(message, false, 2); // 1 initial + 2 retries = 3 total attempts

   // Track this trade state regardless of webhook success to prevent infinite retries
   int size = ArraySize(g_copyTradeStates);
   ArrayResize(g_copyTradeStates, size + 1);
   g_copyTradeStates[size].ticket = ticket;
   g_copyTradeStates[size].symbol = symbol;
   g_copyTradeStates[size].sl_price = sl_distance; // Store distance instead of price
   g_copyTradeStates[size].signal_sent = true;

   if(webhook_sent)
   {
      PrintFormat("Copy Trade Signal Sent Successfully: %s (Original: %s, Entry: %.5f, SL Distance: %.3f, Mode: %s, Inverted: %s)", 
                  message, 
                  (position_type == POSITION_TYPE_BUY) ? "BUY" : "SELL",
                  entry_price,
                  sl_distance,
                  InpSendSLTPPrices ? "SL/TP Prices" : "ATR Distance",
                  InpInvertCopyDirection ? "YES" : "NO");
   }
   else
   {
      PrintFormat("Copy Trade Signal Failed (but tracked to prevent retries): %s", message);
   }
}

//+------------------------------------------------------------------+
//| Send Trade Exit Signal (symbol-specific or global)              |
//+------------------------------------------------------------------+
void SendTradeExitSignal(string symbol = "")
{
   if(!InpCopyTradeEnabled || !InpSendExitSignals)
      return;
   
   string close_signal;
   if(symbol != "")
   {
      // Send symbol-specific close command
      close_signal = symbol + "_CLOSEALL";
      PrintFormat("Copy Trade: Sending %s signal 3 times (critical - bypassing rate limits)", close_signal);
   }
   else
   {
      // Send global close command
      close_signal = "CLOSEALL";
      PrintFormat("Copy Trade: Sending CLOSEALL signal 3 times (critical - bypassing rate limits)");
   }
   
   int successful_sends = 0;
   for(int i = 1; i <= 3; i++)
   {
      PrintFormat("Copy Trade: %s attempt %d/3", close_signal, i);
      bool success = SendWebhookWithRetry(close_signal, true, 1); // Bypass rate limit + 1 retry per attempt
      
      if(success)
      {
         successful_sends++;
         PrintFormat("Copy Trade: %s attempt %d/3 - SUCCESS", close_signal, i);
      }
      else
      {
         PrintFormat("Copy Trade: %s attempt %d/3 - FAILED", close_signal, i);
      }
      
      // Small delay between attempts
      if(i < 3) Sleep(500); // 0.5 second delay between attempts
   }
   
   if(successful_sends > 0)
   {
      PrintFormat("Copy Trade: %s signal sent successfully (%d/3 attempts succeeded)", close_signal, successful_sends);
   }
   else
   {
      PrintFormat("Copy Trade: CRITICAL - ALL 3 %s attempts FAILED!", close_signal);
   }
}

//+------------------------------------------------------------------+
//| Check for new positions and send signals                         |
//+------------------------------------------------------------------+
void CheckForNewPositions()
{
   if(!InpCopyTradeEnabled || !InpSendTradeSignals)
      return;
      
   for(int i = 0; i < PositionsTotal(); i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket <= 0) continue;
      
      if(!PositionSelectByTicket(ticket)) continue;
      
      // Only process positions with our magic number
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
      
      // Check if we already sent signal for this position
      bool signal_already_sent = false;
      for(int j = 0; j < ArraySize(g_copyTradeStates); j++)
      {
         if(g_copyTradeStates[j].ticket == ticket)
         {
            signal_already_sent = true;
            break;
         }
      }
      
      if(!signal_already_sent)
      {
         string symbol = PositionGetString(POSITION_SYMBOL);
         ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
         double sl_price = PositionGetDouble(POSITION_SL);
         double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
         
         PrintFormat("Copy Trade Debug: Found new position - Ticket: %d, Symbol: %s, Type: %s, Entry: %.5f, SL: %.5f", 
                     ticket, symbol, pos_type == POSITION_TYPE_BUY ? "BUY" : "SELL", entry_price, sl_price);
         
         // If no SL is set, calculate it based on ATR
         if(sl_price == 0)
         {
            double atr = GetATRValue();
            
            if(pos_type == POSITION_TYPE_BUY)
               sl_price = entry_price - (atr * InpAtrMultiplierSL);
            else
               sl_price = entry_price + (atr * InpAtrMultiplierSL);
               
            PrintFormat("Copy Trade Debug: No SL set, calculated SL: %.5f (ATR: %.5f)", sl_price, atr);
         }
         
         SendTradeOpenSignal(symbol, pos_type, sl_price, ticket, entry_price);
      }
      else
      {
         PrintFormat("Copy Trade Debug: Signal already sent for ticket %d", ticket);
      }
   }
}

//+------------------------------------------------------------------+
//| Check for closed positions and send exit signals                 |
//+------------------------------------------------------------------+
void CheckForClosedPositions()
{
   if(!InpCopyTradeEnabled || !InpSendExitSignals)
      return;
      
   string closed_position_symbols[];
   
   // Debug: Show how many positions we're tracking
   if(ArraySize(g_copyTradeStates) > 0)
   {
      PrintFormat("Copy Trade Debug: Tracking %d positions", ArraySize(g_copyTradeStates));
   }
   
   // Check if any tracked positions are no longer open
   for(int i = ArraySize(g_copyTradeStates) - 1; i >= 0; i--)
   {
      PrintFormat("Copy Trade Debug: Checking ticket #%d for symbol %s", g_copyTradeStates[i].ticket, g_copyTradeStates[i].symbol);
      
      if(!PositionSelectByTicket(g_copyTradeStates[i].ticket))
      {
         // Position is closed, collect symbol for close signal
         string closed_symbol = g_copyTradeStates[i].symbol;
         PrintFormat("Copy Trade: Position #%d closed for symbol %s, will send %s_CLOSEALL signal", 
                     g_copyTradeStates[i].ticket, closed_symbol, closed_symbol);
         
         // Add symbol to closed symbols array (avoid duplicates)
         bool symbol_already_added = false;
         for(int k = 0; k < ArraySize(closed_position_symbols); k++)
         {
            if(closed_position_symbols[k] == closed_symbol)
            {
               symbol_already_added = true;
               break;
            }
         }
         
         if(!symbol_already_added)
         {
            ArrayResize(closed_position_symbols, ArraySize(closed_position_symbols) + 1);
            closed_position_symbols[ArraySize(closed_position_symbols) - 1] = closed_symbol;
         }
         
         // Shift array elements to remove the closed position
         for(int j = i; j < ArraySize(g_copyTradeStates) - 1; j++)
         {
            g_copyTradeStates[j] = g_copyTradeStates[j + 1];
         }
         ArrayResize(g_copyTradeStates, ArraySize(g_copyTradeStates) - 1);
      }
      else
      {
         PrintFormat("Copy Trade Debug: Position #%d still open for symbol %s", g_copyTradeStates[i].ticket, g_copyTradeStates[i].symbol);
      }
   }
   
   // Send symbol-specific close signals for each closed symbol
   for(int sym_idx = 0; sym_idx < ArraySize(closed_position_symbols); sym_idx++)
   {
      string close_signal = closed_position_symbols[sym_idx] + "_CLOSEALL";
      
      // Send symbol-specific close signal 3 times to ensure it's received
      PrintFormat("Copy Trade: Position closed for %s - sending %s signals 3 times", 
                  closed_position_symbols[sym_idx], close_signal);
      
      int successful_sends = 0;
      for(int i = 1; i <= 3; i++)
      {
         PrintFormat("Copy Trade Position Closure: %s attempt %d/3", close_signal, i);
         bool success = SendWebhookRequest(close_signal);
         
         if(success)
         {
            successful_sends++;
            PrintFormat("Copy Trade Position Closure: %s attempt %d/3 - SUCCESS", close_signal, i);
         }
         else
         {
            PrintFormat("Copy Trade Position Closure: %s attempt %d/3 - FAILED", close_signal, i);
         }
         
         // Small delay between attempts
         if(i < 3) Sleep(300); // 0.3 second delay between attempts
      }
      
      if(successful_sends > 0)
      {
         PrintFormat("Copy Trade: %s signals sent successfully (%d/3 attempts succeeded)", close_signal, successful_sends);
      }
      else
      {
         PrintFormat("Copy Trade: CRITICAL - ALL 3 %s attempts FAILED!", close_signal);
      }
   }
}

//+------------------------------------------------------------------+
//| Clean up all EA-related chart objects                           |
//+------------------------------------------------------------------+
void CleanupAllEAObjects()
{
   if(g_is_backtesting)
      return; // No objects to cleanup in backtest
   
   int total_objects = ObjectsTotal(0);
   int deleted_count = 0;
   
   PrintFormat("Cleaning up EA objects... Found %d total objects on chart", total_objects);
   
   // List of EA-specific object name prefixes
   string ea_prefixes[] = {
      "MULTI_RECOVERY_TARGET_LINE_",
      "MULTI_RECOVERY_BREAKEVEN_LINE_", 
      "RECOVERY_TARGET_LINE_",
      "SYNTHETIC_SL_LINE_",
      "OHLC_RECOVERY_LEVEL_",
      "ORIGINAL_TP_LINE_",
      "TRAILING_SL_LINE_",
      "GCTEA_TRAIL_",
      "GCTEA_TRAIL_NEXT_",
      "P20_RETEST_"
   };
   
   // Remove objects with EA-specific prefixes
   for(int i = total_objects - 1; i >= 0; i--)
   {
      string obj_name = ObjectName(0, i);
      
      for(int j = 0; j < ArraySize(ea_prefixes); j++)
      {
         if(StringFind(obj_name, ea_prefixes[j]) == 0) // Starts with prefix
         {
            if(ObjectDelete(0, obj_name))
            {
               deleted_count++;
               PrintFormat("Deleted EA object: %s", obj_name);
            }
            break; // Found matching prefix, no need to check others
         }
      }
   }
   
   // Also clean up any remaining objects that might contain group base tickets
   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      if(MultiOrderGroups[i].base_ticket == 0) continue;
      
      string base_ticket_str = IntegerToString((int)MultiOrderGroups[i].base_ticket);
      
      // Check remaining objects for this base ticket
      for(int j = ObjectsTotal(0) - 1; j >= 0; j--)
      {
         string obj_name = ObjectName(0, j);
         if(StringFind(obj_name, base_ticket_str) >= 0 && 
            (StringFind(obj_name, "MULTI_RECOVERY") >= 0 || 
             StringFind(obj_name, "RECOVERY_") >= 0 ||
             StringFind(obj_name, "SYNTHETIC_") >= 0))
         {
            if(ObjectDelete(0, obj_name))
            {
               deleted_count++;
               PrintFormat("Deleted group-specific object: %s", obj_name);
            }
         }
      }
   }
   
   if(deleted_count > 0)
   {
      PrintFormat("EA Cleanup Complete: Deleted %d objects from chart", deleted_count);
      ChartRedraw(0);
   }
   else
   {
      PrintFormat("EA Cleanup Complete: No EA objects found to delete");
   }
}

//+------------------------------------------------------------------+
//| Close all positions in a group (main, recovery, and hedge)        |
//+------------------------------------------------------------------+
void CloseAllGroupPositions(MultiOrderGroup &group)
{
    // First close the hedge position if it exists
    if(group.hedge_activated && group.hedge_ticket > 0)
    {
        ClosePosition(group.hedge_ticket);
    }

    // Close halt-recovery hedge if present
    if(group.halt_recovery_active && group.halt_hedge_ticket > 0)
    {
        ClosePosition(group.halt_hedge_ticket);
    }
    
    // Close all other positions in the group
    for(int i = 0; i < group.ticket_count; i++)
    {
        if(group.tickets[i] > 0)
        {
            ClosePosition(group.tickets[i]);
        }
    }
}

//+------------------------------------------------------------------+
//| Reset all data for a group                                        |
//+------------------------------------------------------------------+
void ResetGroupData(const int idx)
{
    if(idx >= 0 && idx < ArraySize(MultiOrderGroups))
    {
        MultiOrderGroups[idx].base_ticket = 0;
        MultiOrderGroups[idx].type = WRONG_VALUE;
        MultiOrderGroups[idx].original_entry = 0;
        MultiOrderGroups[idx].original_lot = 0;
        MultiOrderGroups[idx].hedge_ticket = 0;
        MultiOrderGroups[idx].hedge_entry = 0;
        MultiOrderGroups[idx].hedge_lot = 0;
        MultiOrderGroups[idx].hedge_activated = false;
        MultiOrderGroups[idx].halt_recovery_active = false;
        MultiOrderGroups[idx].halt_hedge_ticket = 0;
        MultiOrderGroups[idx].halt_hedge_lot = 0;
        MultiOrderGroups[idx].halt_hedge_open_time = 0;
        MultiOrderGroups[idx].halt_next_trigger_attempt = MathMax(1, InpHaltRecoveryAfterTrades);
        MultiOrderGroups[idx].realized_pnl_memory = 0;
        MultiOrderGroups[idx].ticket_count = 0;
        MultiOrderGroups[idx].total_volume = 0;
        MultiOrderGroups[idx].activated = false;
        
        // Reset the tickets array
        ArrayFill(MultiOrderGroups[idx].tickets, 0, ArraySize(MultiOrderGroups[idx].tickets), 0);
    }
}

//+------------------------------------------------------------------+
//| Calculate lot size based on SL distance and EA risk settings     |
//+------------------------------------------------------------------+
double CalculateLotFromSLDistance(string symbol, double sl_distance_price_abs)
{
   if(sl_distance_price_abs <= 0) return 0.0;

   // Determine risk base metric
   double risk_base = 0.0;
   switch(InpRiskCalcMethod)
   {
      case RISK_CALC_STARTING_BALANCE: risk_base = g_startingBalance; break;
      case RISK_CALC_EQUITY: risk_base = AccountInfoDouble(ACCOUNT_EQUITY); break;
      case RISK_CALC_BALANCE: risk_base = AccountInfoDouble(ACCOUNT_BALANCE); break;
      case RISK_CALC_FIXED_LOT: return InpFixedLotSize > 0 ? InpFixedLotSize : GetEffectiveMinLot(symbol);
      default: risk_base = AccountInfoDouble(ACCOUNT_BALANCE); break;
   }

   double risk_amount = risk_base * (InpRiskPerTradePercentage / 100.0);

   double point_value = SymbolInfoDouble(symbol, SYMBOL_POINT);
   double tick_value = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);

   if(point_value <= 0 || tick_value <= 0) return 0.0;

   double money_lost_per_lot = (sl_distance_price_abs / point_value) * tick_value;
   if(money_lost_per_lot <= 0) return 0.0;

   double lot = risk_amount / money_lost_per_lot;

   double minLot = GetEffectiveMinLot(symbol);
   double maxLot = GetEffectiveMaxLot(symbol);
   double lotStep = SymbolInfoDouble(symbol, SYMBOL_VOLUME_STEP);

   lot = MathMax(lot, minLot);
   lot = MathMin(lot, maxLot);
   if(lotStep > 0) lot = MathFloor(lot / lotStep) * lotStep;
   lot = NormalizeDouble(lot, 2);

   // DEBUG: Log lot calculation details
   PrintFormat("LOT CALC DEBUG | RiskMethod: %s | RiskBase: %.2f | RiskAmt: %.2f | SL_Distance: %.5f | MoneyPerLot: %.2f | CalcLot: %.4f | MinLot: %.4f | MaxLot: %.4f | FinalLot: %.4f", 
               EnumToString(InpRiskCalcMethod), risk_base, risk_amount, sl_distance_price_abs, money_lost_per_lot, risk_amount/money_lost_per_lot, minLot, maxLot, lot);

   return lot;
}

void ApplyCandleColorTrailing()
{
   if(InpGlobalDollarExitEnabled) return;
   if(!InpCandleColorTrailingEnabled) return;

   // Process only on new closed bar
   datetime lastClosed = iTime(_Symbol, _Period, 1);
   if(lastClosed == 0) return;
   if(lastClosed == ExtLastBarTimeForCandleColorTrail) return;
   ExtLastBarTimeForCandleColorTrail = lastClosed;

   double openPrice = iOpen(_Symbol, _Period, 1);
   double closePrice = iClose(_Symbol, _Period, 1);
   bool isGreen = (closePrice > openPrice);
   bool isRed = (closePrice < openPrice);

   int total = PositionsTotal();
   for(int idx = 0; idx < total; idx++)
   {
      ulong ticket = PositionGetTicket(idx);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if((int)PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      double entry = PositionGetDouble(POSITION_PRICE_OPEN);
      double current_sl = PositionGetDouble(POSITION_SL);

      // Get original SL from trackers if available
      double original_sl = 0;
      for(int p = 0; p < ArraySize(ExtPositionTrackers); p++)
      {
         if(ExtPositionTrackers[p].ticket == ticket)
         {
            original_sl = ExtPositionTrackers[p].original_sl;
            break;
         }
      }
      // Fallback to trailing tracker original_sl
      if(original_sl == 0)
      {
         for(int p = 0; p < ArraySize(ExtTrailingTrackers); p++)
         {
            if(ExtTrailingTrackers[p].ticket == ticket)
            {
               original_sl = ExtTrailingTrackers[p].initial_sl;
               break;
            }
         }
      }

      if(original_sl == 0)
         original_sl = current_sl;

      if(original_sl == 0) continue; // cannot compute distance

      double initial_risk = MathAbs(entry - original_sl);
      if(initial_risk <= 0) continue;

      double delta = 0;
      if(InpCandleColorTrailingUseOriginalDistance)
         delta = initial_risk * (InpCandleColorTrailingPercent / 100.0);
      else
         delta = MathAbs(entry - current_sl) * (InpCandleColorTrailingPercent / 100.0);

      if(delta <= 0) continue;

      int stoplevel = (int)SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL);
      double min_distance = (stoplevel + 1) * _Point;
      double user_min = InpCandleColorTrailingMinPoints * _Point;
      if(user_min > min_distance) min_distance = user_min;

      double new_sl = current_sl;
      if(pos_type == POSITION_TYPE_BUY)
      {
         // Trigger on red candle (price pulled back)
         if(isRed || (isGreen && InpCandleColorTrailingRevertOnGreen))
         {
            new_sl = current_sl + delta;
            double max_allowed = entry - min_distance;
            if(new_sl > max_allowed) new_sl = max_allowed;
         }
      }
      else // SELL
      {
         // Trigger on green candle (price pulled up against position)
         if(isGreen || (isRed && InpCandleColorTrailingRevertOnGreen))
         {
            new_sl = current_sl - delta;
            double min_allowed = entry + min_distance;
            if(new_sl < min_allowed) new_sl = min_allowed;
         }
      }

      // Normalize and send modification if we've actually moved SL in protective direction
      int digits = (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS);
      new_sl = NormalizeDouble(new_sl, digits);

      if((pos_type == POSITION_TYPE_BUY && new_sl > current_sl + (_Point * 0.0000001)) ||
         (pos_type == POSITION_TYPE_SELL && new_sl < current_sl - (_Point * 0.0000001)))
      {
         MqlTradeRequest req; MqlTradeResult res; ZeroMemory(req); ZeroMemory(res);
         req.action = TRADE_ACTION_SLTP;
         req.symbol = symbol;
         req.position = ticket;
         req.sl = new_sl;
         req.tp = PositionGetDouble(POSITION_TP);
         req.comment = "RohitEA CandleColorTrail";

         if(SendDollarExitAwareOrder(req, res))
         {
            PrintFormat("CandleColorTrail: Updated SL for %s position #%d to %.5f (delta: %.5f)", (pos_type==POSITION_TYPE_BUY?"BUY":"SELL"), ticket, new_sl, delta);
         }
         else
         {
            PrintFormat("CandleColorTrail: Failed to update SL for position #%d. Error: %d", ticket, GetLastError());
         }
      }
   }
}
