   }

   string file_name = GetStateFileName();
   if(!FileIsExist(file_name))
   {
      return; // No state file to load
   }

   int file_handle = FileOpen(file_name, FILE_READ | FILE_CSV);
   if(file_handle == INVALID_HANDLE)
   {
      PrintFormat("Failed to open recovery state file '%s' for reading. Error: %d", file_name, GetLastError());
      return;
   }

   ArrayResize(MultiOrderGroups, 0);

   FileReadString(file_handle); // Skip header

   while(!FileIsEnding(file_handle))
   {
      MultiOrderGroup new_group;
      ZeroMemory(new_group);

      new_group.base_ticket = (ulong)StringToInteger(FileReadString(file_handle));
      if(new_group.base_ticket == 0) continue; // Invalid line

      new_group.ticket_count = (int)StringToInteger(FileReadString(file_handle));
      string tickets_str = FileReadString(file_handle);
      new_group.symbol = FileReadString(file_handle);
      new_group.type = (ENUM_POSITION_TYPE)StringToInteger(FileReadString(file_handle));
      new_group.original_lot = StringToDouble(FileReadString(file_handle));
      new_group.total_volume = StringToDouble(FileReadString(file_handle));
      new_group.original_sl = StringToDouble(FileReadString(file_handle));
      new_group.original_entry = StringToDouble(FileReadString(file_handle));
      new_group.original_tp = StringToDouble(FileReadString(file_handle));
      new_group.potential_profit = StringToDouble(FileReadString(file_handle));
      new_group.max_allowed_loss = StringToDouble(FileReadString(file_handle));
      new_group.attempts = (int)StringToInteger(FileReadString(file_handle));
      new_group.activated = (bool)StringToInteger(FileReadString(file_handle));
      new_group.original_sl_distance = StringToDouble(FileReadString(file_handle));

      string ticket_values[];
      StringSplit(tickets_str, ',', ticket_values);
      int loaded_ticket_count = 0;
      for(int i = 0; i < ArraySize(ticket_values); i++)
      {
         ulong ticket = (ulong)StringToInteger(ticket_values[i]);
         if(PositionSelectByTicket(ticket))
         {
            new_group.tickets[loaded_ticket_count] = ticket;
            loaded_ticket_count++;
         }
      }
      new_group.ticket_count = loaded_ticket_count;


      if(new_group.ticket_count > 0)
      {
         int current_size = ArraySize(MultiOrderGroups);
         ArrayResize(MultiOrderGroups, current_size + 1);
         MultiOrderGroups[current_size] = new_group;
      }
   }

   FileClose(file_handle);
   PrintFormat("Recovery state loaded from '%s'. Restored %d active groups.", file_name, ArraySize(MultiOrderGroups));
}

