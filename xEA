void ProcessPattern9OpenTriggerTick()
{
    if(!InpPattern9UseOpenPriceTrigger)
        return;

    if(!g_p9_pendingOpenTrigger)
        return;

    if(g_p9_signalProcessed)
    {
        ResetPattern9OpenTriggerState();
        return;
    }

    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    if(current_bar_time != g_p9_pendingBarTime)
    {
        ResetPattern9OpenTriggerState();
        return;
    }

    double triggerPercent = MathMax(0.0, InpPattern9OpenPriceTriggerPercent);
    double buyTriggerPrice = g_p9_pendingBarOpen * (1.0 + triggerPercent / 100.0);
    double sellTriggerPrice = g_p9_pendingBarOpen * (1.0 - triggerPercent / 100.0);
    double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

    if(g_p9_pendingBuy && ask >= buyTriggerPrice)
    {
        PrintFormat("Pattern 9: BUY open trigger hit at %.5f (required %.5f, +%.4f%% from open %.5f)",
                   ask, buyTriggerPrice, triggerPercent, g_p9_pendingBarOpen);
        g_p9_pendingBuy = false;
        ExecutePattern9BuyOrder(g_p9_pendingFallPercent);
        if(g_p9_signalProcessed)
        {
            ResetPattern9OpenTriggerState();
            return;
        }
    }

    if(g_p9_pendingSell && bid <= sellTriggerPrice)
    {
        PrintFormat("Pattern 9: SELL open trigger hit at %.5f (required %.5f, -%.4f%% from open %.5f)",
                   bid, sellTriggerPrice, triggerPercent, g_p9_pendingBarOpen);
        g_p9_pendingSell = false;
        ExecutePattern9SellOrder(g_p9_pendingRisePercent);
        if(g_p9_signalProcessed)
        {
            ResetPattern9OpenTriggerState();
            return;
        }
    }

    if(!g_p9_pendingBuy && !g_p9_pendingSell)
    {
        ResetPattern9OpenTriggerState();
    }
}

//+------------------------------------------------------------------+
//| Handle Pattern 9 - Price Fall Percentage                         |
//+------------------------------------------------------------------+
void HandlePattern9_PriceFall()
{
    // Get current bar time and check for new bar
    static datetime last_bar_time = 0;
    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    bool isNewBar = (current_bar_time != last_bar_time);
    
    // Always update for real-time monitoring
    bool canProcess = true;
    
    // Allow real-time processing for price monitoring
    canProcess = true;
    
    // Only check bar close when actually placing trades
    if(InpPattern9WaitForClose && !g_is_backtesting)
    {
        MqlRates current_rates[];
        ArraySetAsSeries(current_rates, true);
        if(CopyRates(_Symbol, _Period, 0, 1, current_rates) <= 0) return;
    }
    
    // Update last bar time if it's a new bar
    if(isNewBar)
    {
        if(g_p9_pendingOpenTrigger && g_p9_pendingBarTime != current_bar_time)
        {
            PrintFormat("Pattern 9: Open-trigger entry expired for bar %s", TimeToString(g_p9_pendingBarTime, TIME_DATE|TIME_MINUTES));
            ResetPattern9OpenTriggerState();
        }
        last_bar_time = current_bar_time;
        g_p9_signalProcessed = false; // Reset signal processed flag on new bar
    }
    
    // Get price data
    MqlRates rates[];
    ArraySetAsSeries(rates, true);
    if(CopyRates(_Symbol, _Period, 0, InpPattern9LookbackBars + 1, rates) != InpPattern9LookbackBars + 1)
    {
        PrintFormat("Pattern 9: Failed to get enough price data");
        return;
    }
    
    // Find reference prices in lookback period
    // In bidirectional mode, we need both HIGH and LOW references
    // HIGH reference: for detecting FALLS (BUY)
    // LOW reference: for detecting RISES (SELL)
    double refPriceHigh = 0;  // Highest price (for fall detection/BUY)
    double refPriceLow = 9999999;  // Lowest price (for rise detection/SELL)
    int refPriceIndexHigh = 1;
    int refPriceIndexLow = 1;
    
    for(int i = 1; i <= InpPattern9LookbackBars; i++) // Skip current bar (index 0)
    {
        double price = InpPattern9UseHighLow ? rates[i].high : rates[i].close;
        double priceLow = InpPattern9UseHighLow ? rates[i].low : rates[i].close;
        
        // Always track both high and low
        if(price > refPriceHigh)
        {
            refPriceHigh = price;
            refPriceIndexHigh = i;
        }
        if(priceLow < refPriceLow)
        {
            refPriceLow = priceLow;
            refPriceIndexLow = i;
        }
    }
    
    // In unidirectional mode, use the legacy logic based on Invert flag
    double refPrice = InpPattern9Invert ? refPriceLow : refPriceHigh;
    
    // Get current price
    double currentPrice = InpPattern9UseHighLow ? rates[0].low : rates[0].close;
    
    // Calculate percentage changes with correct reference prices
    // For bidirectional mode: use high ref for fall detection, low ref for rise detection
    // For unidirectional mode: use single ref price based on Invert flag
    double fallPercent, risePercent, changePercent;
    
    if(InpPattern9BidirectionalMode)
    {
        // In bidirectional mode, always calculate both directions
        fallPercent = ((refPriceHigh - currentPrice) / refPriceHigh) * 100.0;  // Positive when price fell from high
        risePercent = ((currentPrice - refPriceLow) / refPriceLow) * 100.0;    // Positive when price rose from low
        changePercent = (currentPrice > refPrice) ? risePercent : fallPercent;  // For display
    }
    else
    {
        // In unidirectional mode, use legacy calculation
        changePercent = InpPattern9Invert ?
            ((currentPrice - refPrice) / refPrice) * 100.0 :  // For price rise
            ((refPrice - currentPrice) / refPrice) * 100.0;   // For price fall
        fallPercent = ((refPrice - currentPrice) / refPrice) * 100.0;
        risePercent = ((currentPrice - refPrice) / refPrice) * 100.0;
    }

    if(InpPattern9RetraceEnabled)
        UpdatePattern9RetraceEvent(currentPrice, refPriceHigh, refPriceLow, fallPercent, risePercent);
    else
    {
        g_p9_buyEventActive = false;
        g_p9_sellEventActive = false;
    }

    string mode = InpPattern9Invert ? "Rise" : "Fall";
    
    // Always show real-time monitoring
    string barStatus = canProcess ? "Ready" : "Waiting for close";
    string bdMode = InpPattern9BidirectionalMode ? "Bidirectional" : "Unidirectional";
    string changeColor = (changePercent >= InpPattern9FallPercent) ? "\x1B[32]" : "\x1B[31]"; // Green if reached target, red if not
    
    Comment(StringFormat("\n\x1B[20]Pattern 9 Live Monitor\n"      // Title with size 20
                        "\x1B[16]Mode: %s | %s\n"                  // Size 16 for data
                        "%sCurrent Change: %.4f%%\n"               // Colored change percentage
                        "Target: %.4f%%\n"
                        "\x1B[14]Reference: %.5f\n"                // Size 14 for prices
                        "Current: %.5f\n"
                        "Lookback: %d bars\n"
                        "\x1B[16]Status: %s",                      // Status with larger font
            mode, bdMode, changeColor, changePercent, InpPattern9FallPercent, refPrice, currentPrice, 
            InpPattern9LookbackBars, barStatus));
    
    // Process trade signals when conditions are met
    bool canTrade = true;
    if(InpPattern9WaitForClose && !g_is_backtesting)
    {
        MqlRates current_rates[];
        ArraySetAsSeries(current_rates, true);
        if(CopyRates(_Symbol, _Period, 0, 1, current_rates) > 0)
        {
            canTrade = (current_rates[0].time < TimeCurrent());
        }
    }
    
    // Enhanced debug output with all conditions
    PrintFormat("Pattern 9 Debug: Mode=%s, BiDir=%s, Change=%.4f%%, Target=%.4f%%, Ref=%.5f, Current=%.5f, IsNewBar=%s, CanTrade=%s, Processed=%s",
                mode, InpPattern9BidirectionalMode ? "On" : "Off", changePercent, InpPattern9FallPercent, refPrice, currentPrice,
                isNewBar ? "true" : "false", canTrade ? "true" : "false", g_p9_signalProcessed ? "true" : "false");

      // Determine which signals are currently active
      bool buySignalActive = false;
      bool sellSignalActive = false;

      if(InpPattern9BidirectionalMode)
      {
          if(InpPattern9RetraceEnabled)
          {
              buySignalActive = g_p9_buyEventActive;
              sellSignalActive = g_p9_sellEventActive;
          }
          else
          {
              buySignalActive = (fallPercent >= InpPattern9FallPercent);
              sellSignalActive = (risePercent >= InpPattern9FallPercent);
          }
      }
      else
      {
          if(!InpPattern9Invert)
              buySignalActive = InpPattern9RetraceEnabled ? g_p9_buyEventActive : (changePercent >= InpPattern9FallPercent);
          else
              sellSignalActive = InpPattern9RetraceEnabled ? g_p9_sellEventActive : (changePercent >= InpPattern9FallPercent);
      }

      // Additional confirmation for BUY: wait for a candle whose low > previous candle low
      static bool g_p9_buyConfirmationPending = false;
      static double g_p9_buyConfirmationFallPercent = 0.0;
      static datetime g_p9_buyConfirmationBarTime = 0;
      
      if(buySignalActive && !g_p9_buyConfirmationPending)
      {
          // First time buy condition is met, set pending confirmation
          g_p9_buyConfirmationPending = true;
          g_p9_buyConfirmationFallPercent = fallPercent;
          g_p9_buyConfirmationBarTime = current_bar_time;
          PrintFormat("Pattern 9: BUY condition met (Fall: %.2f%%). Waiting for confirmation candle with low > previous low.", fallPercent);
          buySignalActive = false; // Don't trigger yet, wait for confirmation
      }
      else if(g_p9_buyConfirmationPending)
      {
          // Check if we're still on the same bar
          if(current_bar_time != g_p9_buyConfirmationBarTime)
          {
              // New bar, check for confirmation
              if(rates[0].low > rates[1].low)
              {
                  // Confirmation met! Use the stored fallPercent from when condition was first met
                  PrintFormat("Pattern 9: BUY confirmation met! Current low (%.5f) > previous low (%.5f). Proceeding with trade.", rates[0].low, rates[1].low);
                  buySignalActive = true;
                  fallPercent = g_p9_buyConfirmationFallPercent; // Use the original fall percent
                  g_p9_buyConfirmationPending = false;
              }
              else
              {
                  // Confirmation not met, reset
                  PrintFormat("Pattern 9: BUY confirmation failed. Current low (%.5f) <= previous low (%.5f). Resetting.", rates[0].low, rates[1].low);
                  g_p9_buyConfirmationPending = false;
                  buySignalActive = false;
              }
          }
          else
          {
              // Still on same bar, wait for next bar
              buySignalActive = false;
          }
      }

      bool tradeConditionMet = (buySignalActive || sellSignalActive);

    if(tradeConditionMet)
    {
        bool buyRetraceReady = IsPattern9BuyRetraceReady(currentPrice);
        bool sellRetraceReady = IsPattern9SellRetraceReady(currentPrice);
        bool readyToTrade = (buySignalActive && buyRetraceReady) || (sellSignalActive && sellRetraceReady);

        if(!readyToTrade)
        {
            if(InpPattern9RetraceEnabled)
            {
                if(buySignalActive && !buyRetraceReady)
                    PrintFormat("Pattern 9: Waiting for fall retrace to %.5f (current %.5f)", g_p9_buyRetraceTarget, currentPrice);
                if(sellSignalActive && !sellRetraceReady)
                    PrintFormat("Pattern 9: Waiting for rise retrace to %.5f (current %.5f)", g_p9_sellRetraceTarget, currentPrice);
            }
        }
        else
        {
            if(!isNewBar)
                PrintFormat("Pattern 9: Trade condition met but waiting for new bar");
            else if(g_p9_signalProcessed)
                PrintFormat("Pattern 9: Trade condition met but signal already processed");
            else if(!canTrade)
                PrintFormat("Pattern 9: Trade condition met but waiting for bar close");
                
            if(isNewBar && !g_p9_signalProcessed && canTrade)
            {
                PrintFormat("Pattern 9: Price change detected (Fall: %.2f%% | Rise: %.2f%% | Required: %.2f%%). Ref High: %.5f, Ref Low: %.5f, Current: %.5f",
                           fallPercent, risePercent, InpPattern9FallPercent, refPriceHigh, refPriceLow, currentPrice);
                           
                // Store the current bar time for state reset
                static datetime last_trade_bar = 0;

                bool shouldTradeBuy = buySignalActive && buyRetraceReady;
                bool shouldTradeSell = sellSignalActive && sellRetraceReady;

                if(InpPattern9UseOpenPriceTrigger)
                {
                    double triggerPercent = MathMax(0.0, InpPattern9OpenPriceTriggerPercent);
                    double barOpenPrice = rates[0].open;
                    double buyTriggerPrice = barOpenPrice * (1.0 + triggerPercent / 100.0);
                    double sellTriggerPrice = barOpenPrice * (1.0 - triggerPercent / 100.0);

                    g_p9_pendingOpenTrigger = (shouldTradeBuy || shouldTradeSell);
                    g_p9_pendingBuy = shouldTradeBuy;
                    g_p9_pendingSell = shouldTradeSell;
                    g_p9_pendingBarTime = current_bar_time;
                    g_p9_pendingBarOpen = barOpenPrice;
                    g_p9_pendingFallPercent = fallPercent;
                    g_p9_pendingRisePercent = risePercent;

                    if(g_p9_pendingBuy)
                    {
                        PrintFormat("Pattern 9: BUY signal armed. Waiting for ASK >= %.5f (open %.5f + %.4f%%)",
                                   buyTriggerPrice, barOpenPrice, triggerPercent);
                    }
                    if(g_p9_pendingSell)
                    {
                        PrintFormat("Pattern 9: SELL signal armed. Waiting for BID <= %.5f (open %.5f - %.4f%%)",
                                   sellTriggerPrice, barOpenPrice, triggerPercent);
                    }

                    // Check immediately on first tick of the new candle.
                    ProcessPattern9OpenTriggerTick();
                }
                else
                {
                    if(shouldTradeBuy)
                    {
                        ExecutePattern9BuyOrder(fallPercent);
                    }

                    if(shouldTradeSell)
                    {
                        ExecutePattern9SellOrder(risePercent);
                    }
                }
                
                // Reset states after processing
                if(g_p9_signalProcessed)
                {
                    last_trade_bar = current_bar_time;
                    PrintFormat("Pattern 9: States reset after trade execution. Next pattern will use fresh reference.");
                    ResetPattern9OpenTriggerState();
                }
            }
            else
            {
                if(!isNewBar)
                    PrintFormat("Pattern 9: Trade condition met but waiting for new bar");
                else if(g_p9_signalProcessed)
                    PrintFormat("Pattern 9: Trade condition met but signal already processed");
                else if(!canTrade)
                    PrintFormat("Pattern 9: Trade condition met but waiting for bar close");
            }
        }
    }
    else
    {
        // Reset signal processed flag when price is not falling enough
        g_p9_signalProcessed = false;
    }
}

//+------------------------------------------------------------------+
//| Handle Pattern 10 - Price Movement (Sell-based)                   |
//+------------------------------------------------------------------+
void UpdatePattern10SellRetraceEvent(double currentPrice, double refPrice, double changePercent)
{
    if(!InpPattern10RetraceEnabled)
        return;

    if(changePercent >= InpPattern10MovePercent)
    {
        double move = InpPattern10Invert ? (currentPrice - refPrice) : (refPrice - currentPrice);
        if(move > 0)
        {
            g_p10_sellEventActive = true;
            g_p10_lastMoveRef = refPrice;
            g_p10_lastMoveExtreme = currentPrice;
            if(InpPattern10Invert)
                g_p10_sellRetraceTarget = currentPrice - (move * (InpPattern10RetracePercent / 100.0));
            else
                g_p10_sellRetraceTarget = currentPrice + (move * (InpPattern10RetracePercent / 100.0));
        }
    }

    if(g_p10_sellEventActive)
    {
        bool movedFurther = InpPattern10Invert ? (currentPrice > g_p10_lastMoveExtreme) : (currentPrice < g_p10_lastMoveExtreme);
        if(movedFurther)
        {
            g_p10_lastMoveExtreme = currentPrice;
            double move = InpPattern10Invert ? (currentPrice - g_p10_lastMoveRef) : (g_p10_lastMoveRef - currentPrice);
            if(move > 0)
            {
                if(InpPattern10Invert)
                    g_p10_sellRetraceTarget = currentPrice - (move * (InpPattern10RetracePercent / 100.0));
                else
                    g_p10_sellRetraceTarget = currentPrice + (move * (InpPattern10RetracePercent / 100.0));
            }
        }
    }
}

bool IsPattern10SellRetraceReady(double currentPrice)
{
    if(!InpPattern10RetraceEnabled || !g_p10_sellEventActive)
        return true;

    if(InpPattern10Invert)
        return currentPrice <= g_p10_sellRetraceTarget; // rise then retrace down
    return currentPrice >= g_p10_sellRetraceTarget;     // fall then retrace up
}

void ResetPattern10OpenTriggerState()
{
    g_p10_pendingOpenTrigger = false;
    g_p10_pendingBarTime = 0;
    g_p10_pendingBarOpen = 0.0;
    g_p10_pendingMovePercent = 0.0;
}

bool ExecutePattern10SellOrder(double changePercent)
{
    int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
    double entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    double stopLoss = 0.0;
    double takeProfit = 0.0;
    CalculateSLTP(entryPrice, POSITION_TYPE_SELL, stopLoss, takeProfit);
    stopLoss = NormalizeDouble(stopLoss, digits);
    takeProfit = NormalizeDouble(takeProfit, digits);

    double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
    if(lots <= 0)
    {
        PrintFormat("Pattern 10: Invalid position size calculated for SELL order");
        return false;
    }

    if(!InpDevelopmentMode)
    {
        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);

        request.action = TRADE_ACTION_DEAL;
        request.symbol = _Symbol;
        request.volume = lots;
        request.type = ORDER_TYPE_SELL;
        request.price = entryPrice;
        request.sl = stopLoss;
        request.tp = takeProfit;
        request.deviation = InpMaxSlippagePoints;
        request.magic = InpMagicNumber;
        request.comment = StringFormat("RohitEA P10-%s%.2f", InpPattern10Invert ? "Rise" : "Fall", changePercent);
        request.type_filling = GetSupportedFillingMode(_Symbol);

        if(!IsSpreadAcceptable())
            return false;

        if(SendDollarExitAwareOrder(request, result))
        {
            PrintFormat("Pattern 10: Placed SELL order #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (%s: %.2f%%)",
                        result.order, entryPrice, stopLoss, takeProfit, lots,
                        InpPattern10Invert ? "Rise" : "Fall", changePercent);
            g_p10_lastSellTicket = result.order;
            g_p10_signalProcessed = true;
            g_p10_sellEventActive = false;

            if(result.order > 0)
                CreateDCAOrders(result.order);
            return true;
        }

        PrintFormat("Pattern 10: Failed to place SELL order. Error: %d", GetLastError());
        return false;
    }

    PrintFormat("[DEV MODE] Pattern 10: Would place SELL order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (%s: %.2f%%)",
               entryPrice, stopLoss, takeProfit, lots,
               InpPattern10Invert ? "Rise" : "Fall", changePercent);
    g_p10_signalProcessed = true;
    g_p10_sellEventActive = false;
    return true;
}

void ProcessPattern10OpenTriggerTick()
{
    if(!InpPattern10UseOpenPriceTrigger)
        return;
    if(!g_p10_pendingOpenTrigger)
        return;
    if(g_p10_signalProcessed)
    {
        ResetPattern10OpenTriggerState();
        return;
    }

    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    if(current_bar_time != g_p10_pendingBarTime)
    {
        ResetPattern10OpenTriggerState();
        return;
    }

    double triggerPercent = MathMax(0.0, InpPattern10OpenPriceTriggerPercent);
    double sellTriggerPrice = g_p10_pendingBarOpen * (1.0 - triggerPercent / 100.0);
    double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
    if(bid <= sellTriggerPrice)
    {
        PrintFormat("Pattern 10: SELL open trigger hit at %.5f (required %.5f, -%.4f%% from open %.5f)",
                    bid, sellTriggerPrice, triggerPercent, g_p10_pendingBarOpen);
        ExecutePattern10SellOrder(g_p10_pendingMovePercent);
        if(g_p10_signalProcessed)
        {
            ResetPattern10OpenTriggerState();
            return;
        }
    }
}

void HandlePattern10_PriceMovement()
{
    // Get current bar time and check for new bar
    static datetime last_bar_time = 0;
    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    bool isNewBar = (current_bar_time != last_bar_time);
    
    // Always update for real-time monitoring
    bool canProcess = true;
    
    // Only check bar close when actually placing trades
    if(InpPattern10WaitForClose && !g_is_backtesting)
    {
        MqlRates current_rates[];
        ArraySetAsSeries(current_rates, true);
        if(CopyRates(_Symbol, _Period, 0, 1, current_rates) <= 0) return;
    }
    
    // Update last bar time if it's a new bar
    if(isNewBar)
    {
        last_bar_time = current_bar_time;
        g_p10_signalProcessed = false; // Reset signal processed flag on new bar
        if(g_p10_pendingOpenTrigger && g_p10_pendingBarTime != current_bar_time)
        {
            PrintFormat("Pattern 10: Open-trigger entry expired for bar %s", TimeToString(g_p10_pendingBarTime, TIME_DATE|TIME_MINUTES));
            ResetPattern10OpenTriggerState();
        }
    }
    
    // Get price data
    MqlRates rates[];
    ArraySetAsSeries(rates, true);
    if(CopyRates(_Symbol, _Period, 0, InpPattern10LookbackBars + 1, rates) != InpPattern10LookbackBars + 1)
    {
        PrintFormat("Pattern 10: Failed to get enough price data");
        return;
    }
    
    // Find reference price in lookback period
    double refPrice = 0;
    int refPriceIndex = 1; // Start from previous bar
    
    for(int i = 1; i <= InpPattern10LookbackBars; i++) // Skip current bar (index 0)
    {
        double price = InpPattern10UseHighLow ? 
            (InpPattern10Invert ? rates[i].low : rates[i].high) : 
            rates[i].close;
            
        if(InpPattern10Invert)
        {
            // Looking for lowest price when inverted
            if(refPrice == 0 || price < refPrice)
            {
                refPrice = price;
                refPriceIndex = i;
            }
        }
        else
        {
            // Looking for highest price when not inverted
            if(price > refPrice)
            {
                refPrice = price;
                refPriceIndex = i;
            }
        }
    }
    
    // Get current price
    double currentPrice = InpPattern10UseHighLow ? 
        (InpPattern10Invert ? rates[0].high : rates[0].low) : 
        rates[0].close;
    
    // Calculate percentage change
    double changePercent = InpPattern10Invert ?
        ((currentPrice - refPrice) / refPrice) * 100.0 :  // For price rise
        ((refPrice - currentPrice) / refPrice) * 100.0;   // For price fall

    if(InpPattern10RetraceEnabled)
        UpdatePattern10SellRetraceEvent(currentPrice, refPrice, changePercent);
    
    string mode = InpPattern10Invert ? "Rise" : "Fall";
    
    // Always show real-time monitoring
    string barStatus = canProcess ? "Ready" : "Waiting for close";
    string changeColor = (changePercent >= InpPattern10MovePercent) ? "\x1B[32]" : "\x1B[31]"; // Green if reached target, red if not
    
    Comment(StringFormat("\n\x1B[20]Pattern 10 Live Monitor\n"      // Title with size 20
                        "\x1B[16]Mode: %s\n"                       // Size 16 for data
                        "%sCurrent Change: %.4f%%\n"               // Colored change percentage
                        "Target: %.4f%%\n"
                        "\x1B[14]Reference: %.5f\n"                // Size 14 for prices
                        "Current: %.5f\n"
                        "Lookback: %d bars\n"
                        "\x1B[16]Status: %s",                      // Status with larger font
            mode, changeColor, changePercent, InpPattern10MovePercent, refPrice, currentPrice, 
            InpPattern10LookbackBars, barStatus));
    
    // Process trade signals when conditions are met
    bool canTrade = true;
    if(InpPattern10WaitForClose && !g_is_backtesting)
    {
        MqlRates current_rates[];
        ArraySetAsSeries(current_rates, true);
        if(CopyRates(_Symbol, _Period, 0, 1, current_rates) > 0)
        {
            canTrade = (current_rates[0].time < TimeCurrent());
        }
    }
    
    // Enhanced debug output with all conditions
    PrintFormat("Pattern 10 Debug: Mode=%s, Change=%.4f%%, Target=%.4f%%, Ref=%.5f, Current=%.5f, IsNewBar=%s, CanProcess=%s, CanTrade=%s, Processed=%s",
                mode, changePercent, InpPattern10MovePercent, refPrice, currentPrice,
                isNewBar ? "true" : "false", canProcess ? "true" : "false", 
                canTrade ? "true" : "false", g_p10_signalProcessed ? "true" : "false");
    
    // Check all conditions for trade entry
    bool sellSignalActive = InpPattern10RetraceEnabled ? g_p10_sellEventActive : (changePercent >= InpPattern10MovePercent);
    bool sellRetraceReady = IsPattern10SellRetraceReady(currentPrice);
    bool readyToTrade = sellSignalActive && sellRetraceReady;

    if(readyToTrade)
    {
        if(!isNewBar)
            PrintFormat("Pattern 10: Trade condition met but waiting for new bar");
        else if(g_p10_signalProcessed)
            PrintFormat("Pattern 10: Trade condition met but signal already processed");
        else if(!canTrade)
            PrintFormat("Pattern 10: Trade condition met but waiting for bar close");
             
        if(isNewBar && !g_p10_signalProcessed && canTrade)
        {
            PrintFormat("Pattern 10: Price %s %.2f%% detected (Required: %.2f%%). Ref: %.5f, Current: %.5f",
                       mode, changePercent, InpPattern10MovePercent, refPrice, currentPrice);
            if(InpPattern10UseOpenPriceTrigger)
            {
                double triggerPercent = MathMax(0.0, InpPattern10OpenPriceTriggerPercent);
                double bar_open = iOpen(_Symbol, _Period, 0);
                if(bar_open <= 0.0)
                    bar_open = rates[0].open;

                g_p10_pendingOpenTrigger = true;
                g_p10_pendingBarTime = current_bar_time;
                g_p10_pendingBarOpen = bar_open;
                g_p10_pendingMovePercent = changePercent;

                double sellTriggerPrice = bar_open * (1.0 - triggerPercent / 100.0);
                PrintFormat("Pattern 10: SELL signal armed. Waiting for BID <= %.5f (open %.5f - %.4f%%)",
                            sellTriggerPrice, bar_open, triggerPercent);
                ProcessPattern10OpenTriggerTick();
            }
            else
            {
                if(ExecutePattern10SellOrder(changePercent))
                {
                    PrintFormat("Pattern 10: States reset after trade execution. Next pattern will use fresh reference.");
                    ResetPattern10OpenTriggerState();
                }
            }
        }
    }
    else
    {
        if(InpPattern10RetraceEnabled && sellSignalActive && !sellRetraceReady)
            PrintFormat("Pattern 10: Waiting for %s retrace to %.5f (current %.5f)",
                        InpPattern10Invert ? "rise" : "fall", g_p10_sellRetraceTarget, currentPrice);

        g_p10_signalProcessed = false;
    }
}

//+------------------------------------------------------------------+
//| Check and cleanup pending orders for all patterns                |
//+------------------------------------------------------------------+
//+------------------------------------------------------------------+
//| Handle Pattern 11 - Simple Trendline Breaks (buy above green,   |
//| sell below red)                                                  |
//+------------------------------------------------------------------+
void HandlePattern11_Trendline()
{
   if(!InpPattern11Enabled) return;

   // Process only on new closed bar to avoid repeat triggers
   datetime closedBarTime = iTime(_Symbol, _Period, 1);
   if(closedBarTime == g_p11_lastBarTime) return;
   g_p11_lastBarTime = closedBarTime;
   g_p11_signalProcessed = false;

   double lastClose = iClose(_Symbol, _Period, 1);
   // If drawing is enabled, clear previous Pattern11 objects once per handler run
   if(InpPattern11ShowTrendlines && (InpPattern11UseGreen || InpPattern11UseRed))
      DeletePattern11Objects();

   // GREEN trendline (formed from pivot highs) => BUY when close above
   if(InpPattern11UseGreen)
   {
      int idx1 = iHighest(_Symbol, _Period, MODE_HIGH, InpPattern11HighLookback, 1);
      if(idx1 > 0)
      {
         int idx2 = iHighest(_Symbol, _Period, MODE_HIGH, InpPattern11HighLookback, idx1 + 1);
         if(idx2 > 0 && MathAbs(idx2 - idx1) >= InpPattern11MinBarsBetweenPivots)
         {
            double y1 = iHigh(_Symbol, _Period, idx1);
            double y2 = iHigh(_Symbol, _Period, idx2);
            // Draw green trendline between pivot points (and extend right) if enabled
            if(InpPattern11ShowTrendlines)
            {
               datetime t1 = iTime(_Symbol, _Period, idx1);
               datetime t2 = iTime(_Symbol, _Period, idx2);
               CreatePattern11Trendline("P11_GREEN_", t1, y1, t2, y2, InpPattern11GreenColor, InpPattern11GreenWidth, InpPattern11GreenStyle);
            }
            double slope = (y2 - y1) / (double)(idx2 - idx1);
            double projectedNow = y1 + (0 - idx1) * slope;

            if(InpPattern11WaitForClose)
            {
               if(lastClose > projectedNow && !g_p11_signalProcessed)
               {
                  PrintFormat("Pattern 11: Close above green trend (%.5f > %.5f) - BUY", lastClose, projectedNow);
                  ExecuteTrade("buy");
                  g_p11_signalProcessed = true;
                  g_p11_lastWasBuy = true; g_p11_lastWasSell = false;
               }
            }
            else
            {
               double nowClose = iClose(_Symbol, _Period, 0);
               if(nowClose > projectedNow && !g_p11_signalProcessed)
               {
                  PrintFormat("Pattern 11: Price above green trend (%.5f > %.5f) - BUY", nowClose, projectedNow);
                  ExecuteTrade("buy");
                  g_p11_signalProcessed = true;
                  g_p11_lastWasBuy = true; g_p11_lastWasSell = false;
               }
            }
         }
      }
   }

   // RED trendline (formed from pivot lows) => SELL when close below
   if(InpPattern11UseRed)
   {
      int jdx1 = iLowest(_Symbol, _Period, MODE_LOW, InpPattern11LowLookback, 1);
      if(jdx1 > 0)
      {
         int jdx2 = iLowest(_Symbol, _Period, MODE_LOW, InpPattern11LowLookback, jdx1 + 1);
         if(jdx2 > 0 && MathAbs(jdx2 - jdx1) >= InpPattern11MinBarsBetweenPivots)
         {
            double z1 = iLow(_Symbol, _Period, jdx1);
            double z2 = iLow(_Symbol, _Period, jdx2);
            // Draw red trendline between pivot lows
            if(InpPattern11ShowTrendlines)
            {
               datetime tt1 = iTime(_Symbol, _Period, jdx1);
               datetime tt2 = iTime(_Symbol, _Period, jdx2);
               CreatePattern11Trendline("P11_RED_", tt1, z1, tt2, z2, InpPattern11RedColor, InpPattern11RedWidth, InpPattern11RedStyle);
            }
            double slopeL = (z2 - z1) / (double)(jdx2 - jdx1);
            double projectedNowL = z1 + (0 - jdx1) * slopeL;

            if(InpPattern11WaitForClose)
            {
               if(lastClose < projectedNowL && !g_p11_signalProcessed)
               {
                  PrintFormat("Pattern 11: Close below red trend (%.5f < %.5f) - SELL", lastClose, projectedNowL);
                  ExecuteTrade("sell");
                  g_p11_signalProcessed = true;
                  g_p11_lastWasSell = true; g_p11_lastWasBuy = false;
               }
            }
            else
            {
               double nowClose = iClose(_Symbol, _Period, 0);
               if(nowClose < projectedNowL && !g_p11_signalProcessed)
               {
                  PrintFormat("Pattern 11: Price below red trend (%.5f < %.5f) - SELL", nowClose, projectedNowL);
                  ExecuteTrade("sell");
                  g_p11_signalProcessed = true;
                  g_p11_lastWasSell = true; g_p11_lastWasBuy = false;
               }
            }
         }
      }
   }
}

void CheckAndCleanupPendingOrders()
{
    // Check if we should allow new trades
    int ea_positions = CountPositionsWithMagicNumber();
    bool limit_reached = false;
    
    if(InpMultiOrderEnabled) {
        if(ea_positions > 0) limit_reached = true;
    } else {
        if(ea_positions >= InpMaxOpenPositions && !ShouldAllowAdditionalPosition()) limit_reached = true;
    }
    
    if(limit_reached)
    {
        // Cancel all pending orders if we have max positions for new trades
        if(!InpMultiOrderEnabled)
        {
            PrintFormat("Max positions reached (%d). Cancelling all pending orders.", InpMaxOpenPositions);
        }
        else
        {
            // In multi-order mode, we cancel pending orders to prevent new base trades while a sequence is active.
        }
        CancelAllPendingOrders();

        // Reset all order tickets
        g_buyStopTicket = 0;
        g_sellStopTicket = 0;
        g_p3_buyStopTicket = 0;
        g_p3_sellStopTicket = 0;
        g_p4_buyStopTicket = 0;
        g_p4_sellStopTicket = 0;
        g_p5_lastBuyTicket = 0;
        g_p5_lastSellTicket = 0;
        return;
    }

    // Get total orders in account
    int totalOrders = OrdersTotal();
    int nonDCAOrders = 0;
    
    // Count only non-DCA orders
    for(int i = 0; i < totalOrders; i++)
    {
        ulong ticket = OrderGetTicket(i);
        if(ticket > 0 && OrderSelect(ticket))
        {
            string comment = OrderGetString(ORDER_COMMENT);
            // Skip DCA orders from count
            if(!(StringFind(comment, "DCA") == 0 && StringFind(comment, "-T") > 0 && StringFind(comment, "-M") > 0))
            {
                nonDCAOrders++;
            }
        }
    }

    // If we have more than 2 non-DCA orders, cancel all non-DCA orders and let new orders be placed on next bar
    if(nonDCAOrders > 2)
    {
        PrintFormat("Too many non-DCA pending orders (%d) detected. Maximum should be 2. Cancelling non-DCA orders.", nonDCAOrders);
        CancelAllPendingOrders();

        // Reset all order tickets
        g_buyStopTicket = 0;
        g_sellStopTicket = 0;
        g_p3_buyStopTicket = 0;
        g_p3_sellStopTicket = 0;
        g_p4_buyStopTicket = 0;
        g_p4_sellStopTicket = 0;
        g_p5_lastBuyTicket = 0;
        g_p5_lastSellTicket = 0;
        g_p8_lastBuyTicket = 0;
        g_p8_lastSellTicket = 0;
        // Reset Pattern 8 state variables
        g_p8_has_setup_red = false;
        g_p8_has_setup_green = false;
        g_p8_setup_candle_index = -1;
        return;
    }

    // Check if any ticket is no longer valid - if so, an order was triggered
    if((g_buyStopTicket > 0 && !OrderSelect(g_buyStopTicket)) ||
       (g_sellStopTicket > 0 && !OrderSelect(g_sellStopTicket)) ||
       (g_p3_buyStopTicket > 0 && !OrderSelect(g_p3_buyStopTicket)) ||
       (g_p3_sellStopTicket > 0 && !OrderSelect(g_p3_sellStopTicket)) ||
       (g_p4_buyStopTicket > 0 && !OrderSelect(g_p4_buyStopTicket)) ||
       (g_p4_sellStopTicket > 0 && !OrderSelect(g_p4_sellStopTicket)) ||
       (g_p5_lastBuyTicket > 0 && !OrderSelect(g_p5_lastBuyTicket)) ||
       (g_p5_lastSellTicket > 0 && !OrderSelect(g_p5_lastSellTicket)) ||
       (g_p8_lastBuyTicket > 0 && !OrderSelect(g_p8_lastBuyTicket)) ||
       (g_p8_lastSellTicket > 0 && !OrderSelect(g_p8_lastSellTicket)))
    {
        PrintFormat("Order was triggered or removed. Cancelling all remaining pending orders.");
        CancelAllPendingOrders();

        // Reset all order tickets
        g_buyStopTicket = 0;
        g_sellStopTicket = 0;
        g_p3_buyStopTicket = 0;
        g_p3_sellStopTicket = 0;
        g_p4_buyStopTicket = 0;
        g_p4_sellStopTicket = 0;
        g_p5_lastBuyTicket = 0;
        g_p5_lastSellTicket = 0;
        g_p8_lastBuyTicket = 0;
        g_p8_lastSellTicket = 0;
        // Reset Pattern 8 state variables
        g_p8_has_setup_red = false;
        g_p8_has_setup_green = false;
        g_p8_setup_candle_index = -1;
    }
}

// Delete any existing Pattern11 objects (prefix P11_GREEN_ or P11_RED_)
void DeletePattern11Objects()
{
   long chart_id = ChartID();
   int total = ObjectsTotal(chart_id);
   for(int i = total - 1; i >= 0; i--)
   {
      string nm = ObjectName(chart_id, i);
      if(StringFind(nm, "P11_GREEN_") == 0 || StringFind(nm, "P11_RED_") == 0)
         ObjectDelete(chart_id, nm);
   }
}

// Create a trendline object with right ray (extended)
void CreatePattern11Trendline(const string prefix, datetime t1, double p1, datetime t2, double p2, color col, int width, ENUM_LINE_STYLE style)
{
   string name = prefix + IntegerToString((int)t1) + "_" + IntegerToString((int)t2);
   // remove existing with same name
   long chart_id = ChartID();
   if(ObjectFind(chart_id, name) != -1) ObjectDelete(chart_id, name);
   if(!ObjectCreate(chart_id, name, OBJ_TREND, 0, t1, p1, t2, p2))
   {
      PrintFormat("Pattern11: Failed to create trendline %s, err=%d", name, GetLastError());
      return;
   }
   ObjectSetInteger(chart_id, name, OBJPROP_COLOR, col);
   ObjectSetInteger(chart_id, name, OBJPROP_RAY_RIGHT, true);
   ObjectSetInteger(chart_id, name, OBJPROP_WIDTH, width);
   ObjectSetInteger(chart_id, name, OBJPROP_STYLE, style);
}

//+------------------------------------------------------------------+
//| Handle Pattern 13 - Previous Candle Color Buy/Sell              |
//| BUY: if previous candle closes red (down)                       |
//| SELL: if previous candle closes green (up)                      |
//| Can analyze candles from a different timeframe than trading TF  |
//+------------------------------------------------------------------+
void HandlePattern13_PrevCandleColor()
{
    if(!InpPattern13Enabled) return;
    
    // Get current bar time from TRADING timeframe to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    
    // Check if we've already processed a signal for this bar
    if(current_bar_time == g_p13_lastBarTime)
    {
        if(!g_is_backtesting)
            PrintFormat("Pattern 13: Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
        return;
    }
    
    // Update last bar time (based on trading timeframe)
    g_p13_lastBarTime = current_bar_time;
    g_p13_signalProcessed = false;
    
    // Determine which timeframe to use for candle analysis
    ENUM_TIMEFRAMES analysis_tf = InpPattern13CandleTimeframe;
    if(analysis_tf == PERIOD_CURRENT)
        analysis_tf = _Period;
    
    // Get previous candle (bar 1) OHLC data from the specified timeframe
    double prev_open  = iOpen(_Symbol, analysis_tf, 1);
    double prev_close = iClose(_Symbol, analysis_tf, 1);
    double current_open = iOpen(_Symbol, _Period, 0);  // Trading entry at current trading timeframe
    
    // Validate data
    if(prev_open == 0 || prev_close == 0 || current_open == 0)
    {
        if(!g_is_backtesting)
            PrintFormat("Pattern 13: Invalid price data from timeframe %s", EnumToString(analysis_tf));
        return;
    }
    
    // Determine if previous candle is red (close < open) or green (close > open)
    bool prev_is_red   = (prev_close < prev_open);  // Red candle = down
    bool prev_is_green = (prev_close > prev_open);  // Green candle = up
    
    if(!g_is_backtesting)
    {
        PrintFormat("Pattern 13: Analyzing %s timeframe - Previous candle: Open: %.5f, Close: %.5f, Color: %s | Trading on %s",
                   EnumToString(analysis_tf),
                   prev_open, prev_close, 
                   prev_is_red ? "RED (DOWN)" : (prev_is_green ? "GREEN (UP)" : "NEUTRAL"),
                   EnumToString(_Period));
    }
    
    // Calculate ATR for SL/TP (use trading timeframe for ATR)
    double atr_values[];
    if(CopyBuffer(iATR(_Symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) <= 0)
    {
        PrintFormat("Pattern 13: Could not get ATR value. Error %d", GetLastError());
        return;
    }
    double atr = atr_values[0];
    
    // BUY LOGIC: Previous candle is RED (close < open)
    if(prev_is_red)
    {
        if(!g_is_backtesting)
            PrintFormat("Pattern 13: Previous candle is RED - Triggering BUY signal");
        
        // Check trade direction filter
        if(InpReverseSignal)
        {
            if(InpTradeDirection == TRADE_DIR_SELL_ONLY)
            {
                PrintFormat("Pattern 13: Reversed BUY action blocked by Trade Direction Filter (SELL ONLY)");
                return;
            }
            
            // Reversed: Take SELL
            if(InpTradeDirection != TRADE_DIR_BUY_ONLY && InpTradeDirection != TRADE_DIR_ALWAYS_BUY)
            {
                PrintFormat("Pattern 13: Signal Reversal ON. Taking SELL on RED candle");
                double sellSL = current_open + (atr * InpAtrMultiplierSL);
                double sellTP = current_open - (atr * InpAtrMultiplierTP);
                double sellLots = CalculatePositionSize(_Symbol, current_open, sellSL);
                
                if(sellLots > 0)
                {
                    ExecutePatternTrade("sell", current_open, sellSL, sellTP);
                    g_p13_lastSellTicket = GetLastTradeTicket();
                    g_p13_signalProcessed = true;
                }
            }
        }
        else
        {
            // Normal: Take BUY
            if(InpTradeDirection != TRADE_DIR_SELL_ONLY && InpTradeDirection != TRADE_DIR_ALWAYS_SELL)
            {
                PrintFormat("Pattern 13: Taking BUY on RED candle at open price %.5f", current_open);
                double buySL = current_open - (atr * InpAtrMultiplierSL);
                double buyTP = current_open + (atr * InpAtrMultiplierTP);
                double buyLots = CalculatePositionSize(_Symbol, current_open, buySL);
                
                if(buyLots > 0)
                {
                    ExecutePatternTrade("buy", current_open, buySL, buyTP);
                    g_p13_lastBuyTicket = GetLastTradeTicket();
                    g_p13_signalProcessed = true;
                }
            }
        }
    }
    
    // SELL LOGIC: Previous candle is GREEN (close > open)
    else if(prev_is_green)
    {
        if(!g_is_backtesting)
            PrintFormat("Pattern 13: Previous candle is GREEN - Triggering SELL signal");
        
        // Check trade direction filter
        if(InpReverseSignal)
        {
            if(InpTradeDirection == TRADE_DIR_BUY_ONLY)
            {
                PrintFormat("Pattern 13: Reversed SELL action blocked by Trade Direction Filter (BUY ONLY)");
                return;
            }
            
            // Reversed: Take BUY
            if(InpTradeDirection != TRADE_DIR_SELL_ONLY && InpTradeDirection != TRADE_DIR_ALWAYS_SELL)
            {
                PrintFormat("Pattern 13: Signal Reversal ON. Taking BUY on GREEN candle");
                double buySL = current_open - (atr * InpAtrMultiplierSL);
                double buyTP = current_open + (atr * InpAtrMultiplierTP);
                double buyLots = CalculatePositionSize(_Symbol, current_open, buySL);
                
                if(buyLots > 0)
                {
                    ExecutePatternTrade("buy", current_open, buySL, buyTP);
                    g_p13_lastBuyTicket = GetLastTradeTicket();
                    g_p13_signalProcessed = true;
                }
            }
        }
        else
        {
            // Normal: Take SELL (or close existing BUY positions)
            if(InpTradeDirection != TRADE_DIR_BUY_ONLY && InpTradeDirection != TRADE_DIR_ALWAYS_BUY)
            {
                PrintFormat("Pattern 13: Taking SELL on GREEN candle at open price %.5f", current_open);
                double sellSL = current_open + (atr * InpAtrMultiplierSL);
                double sellTP = current_open - (atr * InpAtrMultiplierTP);
                double sellLots = CalculatePositionSize(_Symbol, current_open, sellSL);
                
                if(sellLots > 0)
                {
                    ExecutePatternTrade("sell", current_open, sellSL, sellTP);
                    g_p13_lastSellTicket = GetLastTradeTicket();
                    g_p13_signalProcessed = true;
                }
            }
        }
    }
}

//+------------------------------------------------------------------+
//| Execute a pattern trade                                          |
//+------------------------------------------------------------------+
void ExecutePatternTrade(const string trade_type, double entry_price, double sl_price, double tp_price)
{
    double lots = CalculatePositionSize(_Symbol, entry_price, sl_price);
    
    if(lots <= 0)
    {
        PrintFormat("Pattern 13: Invalid lot size calculated: %.2f", lots);
        return;
    }
    
    if(InpDevelopmentMode)
    {
        PrintFormat("Pattern 13 [DEVELOPMENT MODE]: %s trade - Entry: %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                   trade_type, entry_price, sl_price, tp_price, lots);
        return;
    }
    
    MqlTradeRequest request;
    MqlTradeResult result;
    ZeroMemory(request);
    ZeroMemory(result);
    
    request.magic = InpMagicNumber;
    request.symbol = _Symbol;
    request.volume = lots;
    request.sl = sl_price;
    request.tp = tp_price;
    request.deviation = InpMaxSlippagePoints;
    request.type_filling = ORDER_FILLING_FOK;
    request.action = TRADE_ACTION_DEAL;
    request.comment = "Pattern13-PrevCandleColor";
    
    if(StringCompare(trade_type, "buy") == 0)
    {
        request.type = ORDER_TYPE_BUY;
        request.price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
        
        if(SendDollarExitAwareOrder(request, result))
        {
            if(!g_is_backtesting)
                PrintFormat("Pattern 13: BUY order placed - Ticket: %d, Entry: %.5f, SL: %.5f, TP: %.5f",
                           result.order, result.price, sl_price, tp_price);
        }
        else
        {
            PrintFormat("Pattern 13: BUY order failed - Error: %d, Comment: %s",
                       result.retcode, result.comment);
        }
    }
    else if(StringCompare(trade_type, "sell") == 0)
    {
        request.type = ORDER_TYPE_SELL;
        request.price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
        
        if(SendDollarExitAwareOrder(request, result))
        {
            if(!g_is_backtesting)
                PrintFormat("Pattern 13: SELL order placed - Ticket: %d, Entry: %.5f, SL: %.5f, TP: %.5f",
                           result.order, result.price, sl_price, tp_price);
        }
        else
        {
            PrintFormat("Pattern 13: SELL order failed - Error: %d, Comment: %s",
                       result.retcode, result.comment);
        }
    }
}

//+------------------------------------------------------------------+
//| Handle Pattern 14 - Break Low + Volume (BUY on next candle open) |
//+------------------------------------------------------------------+
void HandlePattern14_BreakLowVolume()
{
   if(!IsTradingHour() || IsNewsTime()) return; // respect global filters

   // Use previous closed candle (bar 1) as the "current" candle described by the user
   datetime prevBarTime = iTime(_Symbol, _Period, 1);
   if(prevBarTime == g_p14_lastBarTime) return; // already processed for that closed bar
   g_p14_lastBarTime = prevBarTime;

   // Need enough bars to evaluate: we read bar 1 (previous) and bars 2..(N+1) as the previous candles
   if(Bars(_Symbol, _Period) < InpPattern14PrevCandles + 3) return;

   double prevOpen  = iOpen(_Symbol, _Period, 1);
   double prevClose = iClose(_Symbol, _Period, 1);
   long vol1 = (long)iVolume(_Symbol, _Period, 1);
   long vol2 = (long)iVolume(_Symbol, _Period, 2);

   bool isRed = (prevClose < prevOpen);

   // Compute minimum low among the configured number of previous candles (bars 2..(InpPattern14PrevCandles+1))
   double minLow = iLow(_Symbol, _Period, 2);
   for(int idx = 3; idx <= InpPattern14PrevCandles + 1; idx++)
   {
      double l = iLow(_Symbol, _Period, idx);
      minLow = MathMin(minLow, l);
   }

   // Determine buy/sell candidates
   double maxHigh = iHigh(_Symbol, _Period, 2);
   for(int j = 3; j <= InpPattern14PrevCandles + 1; j++) maxHigh = MathMax(maxHigh, iHigh(_Symbol, _Period, j));

   bool isGreen = (prevClose > prevOpen);

   bool condBuy = (isRed && prevClose < minLow && vol1 > vol2);
   bool condSell = (isGreen && prevClose > maxHigh && vol1 > vol2);

   bool doBuy = false, doSell = false;

   if(InpPattern14Bidirectional)
   {
      doBuy = condBuy;
      doSell = condSell;
   }
   else
   {
      // default: only BUY as original behaviour
      doBuy = condBuy;
      doSell = false;
   }

   // Respect signal reversal
   if(InpReverseSignal)
   {
      bool tmp = doBuy; doBuy = doSell; doSell = tmp;
   }

   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);

   // Place BUY if allowed and not blocked by master direction filter
   if(doBuy && InpTradeDirection != TRADE_DIR_SELL_ONLY)
   {
      PrintFormat("Pattern 14: BUY condition met on closed bar %s. Placing BUY at next open.", TimeToString(prevBarTime));
      double entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      double stopLoss = 0.0, takeProfit = 0.0;
      CalculateSLTP(entryPrice, POSITION_TYPE_BUY, stopLoss, takeProfit);
      stopLoss = NormalizeDouble(stopLoss, digits);
      takeProfit = NormalizeDouble(takeProfit, digits);
      double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
      if(lots > 0)
      {
         if(!InpDevelopmentMode)
         {
            MqlTradeRequest request; MqlTradeResult result; ZeroMemory(request); ZeroMemory(result);
            request.action = TRADE_ACTION_DEAL;
            request.symbol = _Symbol;
            request.volume = lots;
            request.type = ORDER_TYPE_BUY;
            request.price = entryPrice;
            request.sl = stopLoss;
            request.tp = takeProfit;
            request.deviation = InpMaxSlippagePoints;
            request.magic = InpMagicNumber;
            request.comment = "RohitEA P14-Buy";
            request.type_filling = GetSupportedFillingMode(_Symbol);
            if(IsSpreadAcceptable())
            {
               if(SendDollarExitAwareOrder(request, result))
               {
                  PrintFormat("Pattern 14: Placed BUY order #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                              result.order, entryPrice, stopLoss, takeProfit, lots);
                  g_p14_lastBuyTicket = result.order;
                  g_p14_signalProcessed = true;
                  if(result.order > 0) CreateDCAOrders(result.order);
               }
               else PrintFormat("Pattern 14: Failed to place BUY order. Error: %d", GetLastError());
            }
         }
         else
         {
            PrintFormat("[DEV MODE] Pattern 14: Would place BUY at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        entryPrice, stopLoss, takeProfit, lots);
            g_p14_signalProcessed = true;
         }
      }
   }

   // Place SELL if allowed and not blocked by master direction filter
   if(doSell && InpTradeDirection != TRADE_DIR_BUY_ONLY)
   {
      PrintFormat("Pattern 14: SELL condition met on closed bar %s. Placing SELL at next open.", TimeToString(prevBarTime));
      double entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double stopLoss = 0.0, takeProfit = 0.0;
      CalculateSLTP(entryPrice, POSITION_TYPE_SELL, stopLoss, takeProfit);
      stopLoss = NormalizeDouble(stopLoss, digits);
      takeProfit = NormalizeDouble(takeProfit, digits);
      double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
      if(lots > 0)
      {
         if(!InpDevelopmentMode)
         {
            MqlTradeRequest request; MqlTradeResult result; ZeroMemory(request); ZeroMemory(result);
            request.action = TRADE_ACTION_DEAL;
            request.symbol = _Symbol;
            request.volume = lots;
            request.type = ORDER_TYPE_SELL;
            request.price = entryPrice;
            request.sl = stopLoss;
            request.tp = takeProfit;
            request.deviation = InpMaxSlippagePoints;
            request.magic = InpMagicNumber;
            request.comment = "RohitEA P14-Sell";
            request.type_filling = GetSupportedFillingMode(_Symbol);
            if(IsSpreadAcceptable())
            {
               if(SendDollarExitAwareOrder(request, result))
               {
                  PrintFormat("Pattern 14: Placed SELL order #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                              result.order, entryPrice, stopLoss, takeProfit, lots);
                  g_p14_lastSellTicket = result.order;
                  g_p14_signalProcessed = true;
                  if(result.order > 0) CreateDCAOrders(result.order);
               }
               else PrintFormat("Pattern 14: Failed to place SELL order. Error: %d", GetLastError());
            }
         }
         else
         {
            PrintFormat("[DEV MODE] Pattern 14: Would place SELL at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        entryPrice, stopLoss, takeProfit, lots);
            g_p14_signalProcessed = true;
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Handle Pattern 15 - Volume Oscillation Pattern                   |
//| Detects alternating volume peaks and valleys across 8 bars       |
//| Pattern: cv < pv, pv > pv1, pv1 < pv2, pv2 < pv3,               |
//|          pv3 > pv4, pv4 < pv5, pv5 > pv6, pv6 < pv7             |
//| BUY Entry: when current candle closes                             |
//+------------------------------------------------------------------+
void HandlePattern15_VolumeOscillation()
{
   if(!InpPattern15Enabled) return;
   if(!IsTradingHour() || IsNewsTime()) return; // respect global filters

   datetime currentTime = TimeCurrent();

   // First, check if there's a pending pattern from previous bar to execute
   if(g_p15_patternDetected && InpPattern15WaitForClose)
   {
      datetime currentBarTime = iTime(_Symbol, _Period, 0);
      if(currentBarTime != g_p15_patternDetectionTime)
      {
         // New bar has arrived, execute the pending trade
         ENUM_POSITION_TYPE tradeType = g_p15_pendingTradeType;
         string tradeTypeStr = (tradeType == POSITION_TYPE_BUY) ? "BUY" : "SELL";
         if(InpPattern15LogDetails)
            PrintFormat("Pattern 15: New candle opened, executing pending %s from pattern detected on %s", 
                       tradeTypeStr, TimeToString(g_p15_patternDetectionTime));
         ExecutePattern15Trade(tradeType);
         return; // Exit after executing to avoid redundant processing
      }
   }

   // Now analyze the previous closed candle (bar 1) for pattern detection
   datetime barTime = iTime(_Symbol, _Period, 1);
   if(barTime == g_p15_lastBarTime) return; // already processed for that closed bar
   g_p15_lastBarTime = barTime;

   // Need at least 9 bars: current + 8 previous
   if(Bars(_Symbol, _Period) < 9) return;

   // Get volumes for 8+ bars
   long cv  = (long)iVolume(_Symbol, _Period, 0);  // current (bar 0)
   long pv  = (long)iVolume(_Symbol, _Period, 1);  // 1 bar ago
   long pv1 = (long)iVolume(_Symbol, _Period, 2);  // 2 bars ago
   long pv2 = (long)iVolume(_Symbol, _Period, 3);  // 3 bars ago
   long pv3 = (long)iVolume(_Symbol, _Period, 4);  // 4 bars ago
   long pv4 = (long)iVolume(_Symbol, _Period, 5);  // 5 bars ago
   long pv5 = (long)iVolume(_Symbol, _Period, 6);  // 6 bars ago
   long pv6 = (long)iVolume(_Symbol, _Period, 7);  // 7 bars ago
   long pv7 = (long)iVolume(_Symbol, _Period, 8);  // 8 bars ago

   // Check the oscillation pattern
   bool cond1 = (cv < pv);      // Current volume down
   bool cond2 = (pv > pv1);     // Volume up from pv1
   bool cond3 = (pv1 < pv2);    // Volume up from pv1 (valley followed by rise)
   bool cond4 = (pv2 < pv3);    // Volume up (continues rising)
   bool cond5 = (pv3 > pv4);    // Volume down (peak)
   bool cond6 = (pv4 < pv5);    // Volume up (valley)
   bool cond7 = (pv5 > pv6);    // Volume down (peak)
   bool cond8 = (pv6 < pv7);    // Volume up (valley)

   // All conditions must be met for the pattern
   bool patternDetected = cond1 && cond2 && cond3 && cond4 && cond5 && cond6 && cond7 && cond8;

   if(InpPattern15LogDetails)
   {
      PrintFormat("Pattern 15 Analysis - Time: %s", TimeToString(barTime));
      PrintFormat("  Volumes: CV=%ld, PV=%ld, PV1=%ld, PV2=%ld, PV3=%ld, PV4=%ld, PV5=%ld, PV6=%ld, PV7=%ld",
                  cv, pv, pv1, pv2, pv3, pv4, pv5, pv6, pv7);
      PrintFormat("  Conditions: %d%d%d%d%d%d%d%d (Pattern: %s)",
                  (cond1?1:0), (cond2?1:0), (cond3?1:0), (cond4?1:0),
                  (cond5?1:0), (cond6?1:0), (cond7?1:0), (cond8?1:0),
                  patternDetected ? "DETECTED" : "NOT DETECTED");
   }

   if(!patternDetected) return;

   // Pattern detected - now determine direction based on price close
   double currentClose = iClose(_Symbol, _Period, 1);  // Close of bar 1 (the checked bar)
   double previousClose = iClose(_Symbol, _Period, 2); // Close of bar 2 (previous to checked bar)

   ENUM_POSITION_TYPE tradeType = POSITION_TYPE_BUY;
   string priceAction = "";

   if(currentClose > previousClose)
   {
      tradeType = POSITION_TYPE_BUY;
      priceAction = "BULLISH (Close > Previous Close) → BUY";
   }
   else if(currentClose < previousClose)
   {
      tradeType = POSITION_TYPE_SELL;
      priceAction = "BEARISH (Close < Previous Close) → SELL";
   }
   else
   {
      // Close equals previous close - neutral, don't trade
      if(InpPattern15LogDetails)
         PrintFormat("Pattern 15: Oscillation found but neutral price action (Close == Previous Close). No trade.");
      return;
   }

   if(InpPattern15LogDetails)
      PrintFormat("Pattern 15: %s detected. Stored trade signal.", priceAction);

   // Pattern detected with valid price action
   if(InpPattern15WaitForClose)
   {
      // Wait for next candle to open/close before executing trade
      g_p15_patternDetected = true;
      g_p15_patternDetectionTime = iTime(_Symbol, _Period, 0); // Store current bar time
      g_p15_pendingTradeType = tradeType; // Store the trade direction
      if(InpPattern15LogDetails)
         PrintFormat("Pattern 15: %s pattern detected at %s. Will execute on next candle open...", 
                    priceAction, TimeToString(barTime));
      return;
   }

   // If not waiting for close, execute immediately
   ExecutePattern15Trade(tradeType);
}

//+------------------------------------------------------------------+
//| Execute Pattern 15 Trade                                         |
//+------------------------------------------------------------------+
void ExecutePattern15Trade(ENUM_POSITION_TYPE tradeType = POSITION_TYPE_BUY)
{
   // Reset the flags
   g_p15_patternDetected = false;
   g_p15_patternDetectionTime = 0;

   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   
   // Determine entry price and order type based on trade direction
   double entryPrice;
   ENUM_ORDER_TYPE orderType;
   string tradeTypeStr;

   if(tradeType == POSITION_TYPE_BUY)
   {
      // Check if BUY is allowed
      if(InpTradeDirection == TRADE_DIR_SELL_ONLY) return;
      
      entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      orderType = ORDER_TYPE_BUY;
      tradeTypeStr = "BUY";
   }
   else // SELL
   {
      // Check if SELL is allowed
      if(InpTradeDirection == TRADE_DIR_BUY_ONLY) return;
      
      entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      orderType = ORDER_TYPE_SELL;
      tradeTypeStr = "SELL";
   }

   double stopLoss = 0.0, takeProfit = 0.0;

   // Calculate SL and TP
   CalculateSLTP(entryPrice, tradeType, stopLoss, takeProfit);
   stopLoss = NormalizeDouble(stopLoss, digits);
   takeProfit = NormalizeDouble(takeProfit, digits);

   // Calculate position size
   double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
   if(lots <= 0) return;

   if(InpPattern15LogDetails)
      PrintFormat("Pattern 15: Executing %s at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                  tradeTypeStr, entryPrice, stopLoss, takeProfit, lots);

   if(!InpDevelopmentMode)
   {
      MqlTradeRequest request; MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);

      request.action = TRADE_ACTION_DEAL;
      request.symbol = _Symbol;
      request.volume = lots;
      request.type = orderType;
      request.price = entryPrice;
      request.sl = stopLoss;
      request.tp = takeProfit;
      request.deviation = InpMaxSlippagePoints;
      request.magic = InpMagicNumber;
      request.comment = "RohitEA P15-VolOsc";
      request.type_filling = GetSupportedFillingMode(_Symbol);

      if(IsSpreadAcceptable())
      {
         if(SendDollarExitAwareOrder(request, result))
         {
            PrintFormat("Pattern 15: %s order placed #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        tradeTypeStr, result.order, entryPrice, stopLoss, takeProfit, lots);
            if(tradeType == POSITION_TYPE_BUY)
               g_p15_lastBuyTicket = result.order;
            else
               g_p15_lastSellTicket = result.order;
            g_p15_signalProcessed = true;
            if(result.order > 0) CreateDCAOrders(result.order);
         }
         else
            PrintFormat("Pattern 15: Failed to place %s order. Error: %d", tradeTypeStr, GetLastError());
      }
   }
   else
   {
      PrintFormat("[DEV MODE] Pattern 15: Would place %s at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                  tradeTypeStr, entryPrice, stopLoss, takeProfit, lots);
      g_p15_signalProcessed = true;
   }
}

//+------------------------------------------------------------------+
//| Handle Pattern 16 - Green Candle Breakout with Volume            |
//| Conditions: cv < pv, pv > pv1, cv_close > pv_high,               |
//|             cv is green, pv is green                              |
//| Action: BUY on next candle opening                               |
//+------------------------------------------------------------------+
void HandlePattern16_GreenCandleBreakout()
{
   if(!InpPattern16Enabled) return;
   if(!IsTradingHour() || IsNewsTime()) return; // respect global filters

   // Check if there's a pending pattern from previous bar to execute
   if(g_p16_patternDetected)
   {
      datetime currentBarTime = iTime(_Symbol, _Period, 0);
      if(currentBarTime != g_p16_patternDetectionTime)
      {
         // New bar has arrived, execute the pending trade
         if(InpPattern16LogDetails)
            PrintFormat("Pattern 16: New candle opened, executing pending BUY from pattern detected on %s", 
                       TimeToString(g_p16_patternDetectionTime));
         ExecutePattern16Trade();
         return;
      }
   }

   // Analyze the previous closed candle (bar 1) for pattern detection
   datetime barTime = iTime(_Symbol, _Period, 1);
   if(barTime == g_p16_lastBarTime) return; // already processed
   g_p16_lastBarTime = barTime;

   // Need at least 3 bars
   if(Bars(_Symbol, _Period) < 3) return;

   // Get prices for bar 1 (analyzed bar), bar 2 (previous), bar 3 (previous-previous)
   double cv_open  = iOpen(_Symbol, _Period, 1);   // analyzed bar open
   double cv_close = iClose(_Symbol, _Period, 1);  // analyzed bar close
   
   double pv_open  = iOpen(_Symbol, _Period, 2);   // previous bar open
   double pv_close = iClose(_Symbol, _Period, 2);  // previous bar close
   double pv_high  = iHigh(_Symbol, _Period, 2);   // previous bar high
   
   double pv1_close = iClose(_Symbol, _Period, 3); // previous-previous close

   long cv  = (long)iVolume(_Symbol, _Period, 1);  // analyzed bar volume
   long pv  = (long)iVolume(_Symbol, _Period, 2);  // previous bar volume
   long pv1 = (long)iVolume(_Symbol, _Period, 3);  // previous-previous volume

   // Check conditions - ALL MUST BE TRUE
   bool cond1 = (cv < pv);               // Current volume < Previous volume
   bool cond2 = (pv > pv1);              // Previous volume > Previous-Previous volume
   bool cond3 = (cv_close > pv_high);    // Current close > Previous HIGH (this is the key breakout!)
   bool cond4 = (cv_close > cv_open);    // Current candle is GREEN
   bool cond5 = (pv_close > pv_open);    // Previous candle is GREEN

   bool patternDetected = cond1 && cond2 && cond3 && cond4 && cond5;

   if(InpPattern16LogDetails)
   {
      PrintFormat("Pattern 16 Analysis - Time: %s", TimeToString(barTime));
      PrintFormat("  Volumes: CV=%ld, PV=%ld, PV1=%ld", cv, pv, pv1);
      PrintFormat("  Prices: CV.Close=%.5f, PV.High=%.5f, CV.Open=%.5f, PV.Close=%.5f, PV.Open=%.5f",
                  cv_close, pv_high, cv_open, pv_close, pv_open);
      PrintFormat("  Conditions: vol_down(cv<pv=%d) vol_strong(pv>pv1=%d) breakout(cv.c>pv.h=%d) cv_green=%d pv_green=%d → Pattern: %s",
                  (cond1?1:0), (cond2?1:0), (cond3?1:0), (cond4?1:0), (cond5?1:0),
                  patternDetected ? "DETECTED" : "NOT DETECTED");
   }

   if(!patternDetected) return;

   // Pattern detected
   if(InpPattern16WaitForClose)
   {
      g_p16_patternDetected = true;
      g_p16_patternDetectionTime = iTime(_Symbol, _Period, 0); // Store current bar time
      if(InpPattern16LogDetails)
         PrintFormat("Pattern 16: Green candle breakout detected at %s. Will execute BUY on next candle open...", 
                    TimeToString(barTime));
      return;
   }

   // If not waiting for close, execute immediately
   ExecutePattern16Trade();
}

//+------------------------------------------------------------------+
//| Execute Pattern 16 Trade                                         |
//+------------------------------------------------------------------+
void ExecutePattern16Trade()
{
   // Reset the flags
   g_p16_patternDetected = false;
   g_p16_patternDetectionTime = 0;

   // Check if BUY is allowed
   if(InpTradeDirection == TRADE_DIR_SELL_ONLY) return;

   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   double entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double stopLoss = 0.0, takeProfit = 0.0;

   // Calculate SL and TP
   CalculateSLTP(entryPrice, POSITION_TYPE_BUY, stopLoss, takeProfit);
   stopLoss = NormalizeDouble(stopLoss, digits);
   takeProfit = NormalizeDouble(takeProfit, digits);

   // Calculate position size
   double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
   if(lots <= 0) return;

   if(InpPattern16LogDetails)
      PrintFormat("Pattern 16: Executing BUY at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                  entryPrice, stopLoss, takeProfit, lots);

   if(!InpDevelopmentMode)
   {
      MqlTradeRequest request; MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);

      request.action = TRADE_ACTION_DEAL;
      request.symbol = _Symbol;
      request.volume = lots;
      request.type = ORDER_TYPE_BUY;
      request.price = entryPrice;
      request.sl = stopLoss;
      request.tp = takeProfit;
      request.deviation = InpMaxSlippagePoints;
      request.magic = InpMagicNumber;
      request.comment = "RohitEA P16-GrnBrk";
      request.type_filling = GetSupportedFillingMode(_Symbol);

      if(IsSpreadAcceptable())
      {
         if(SendDollarExitAwareOrder(request, result))
         {
            PrintFormat("Pattern 16: BUY order placed #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        result.order, entryPrice, stopLoss, takeProfit, lots);
            g_p16_lastBuyTicket = result.order;
            g_p16_signalProcessed = true;
            if(result.order > 0) CreateDCAOrders(result.order);
         }
         else
            PrintFormat("Pattern 16: Failed to place BUY order. Error: %d", GetLastError());
      }
   }
   else
   {
      PrintFormat("[DEV MODE] Pattern 16: Would place BUY at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                  entryPrice, stopLoss, takeProfit, lots);
      g_p16_signalProcessed = true;
   }
}

