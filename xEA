//+------------------------------------------------------------------+
//| Clean up orphan chart objects (objects for closed positions)     |
//+------------------------------------------------------------------+
void CleanupOrphanChartObjects()
{
   // Skip drawing during backtesting
   if(g_is_backtesting) return;
   
   int total_objects = ObjectsTotal(0);
   int orphan_objects_removed = 0;
   
   for(int i = total_objects - 1; i >= 0; i--)
   {
      string obj_name = ObjectName(0, i);
      
      // Check if this object belongs to a closed position
      bool is_orphan = false;
      
      // Extract ticket number from object name
      if(StringFind(obj_name, "SYNTHETIC_SL_LINE_") >= 0 ||
         StringFind(obj_name, "ORIGINAL_TP_LINE_") >= 0 ||
         StringFind(obj_name, "RECOVERY_TARGET_LINE_") >= 0 ||
         StringFind(obj_name, "MULTI_RECOVERY_TARGET_LINE_") >= 0 ||
         StringFind(obj_name, OHLC_RECOVERY_LINE_PREFIX) >= 0 ||
         StringFind(obj_name, "DCA_LINE_") >= 0)
      {
         // Extract ticket number from object name
         string ticket_str = "";
         int pos = -1;
         
         if(StringFind(obj_name, "SYNTHETIC_SL_LINE_") >= 0)
         {
            pos = StringFind(obj_name, "SYNTHETIC_SL_LINE_") + StringLen("SYNTHETIC_SL_LINE_");
         }
         else if(StringFind(obj_name, "ORIGINAL_TP_LINE_") >= 0)
         {
            pos = StringFind(obj_name, "ORIGINAL_TP_LINE_") + StringLen("ORIGINAL_TP_LINE_");
         }
         else if(StringFind(obj_name, "RECOVERY_TARGET_LINE_") >= 0)
         {
            pos = StringFind(obj_name, "RECOVERY_TARGET_LINE_") + StringLen("RECOVERY_TARGET_LINE_");
         }
         else if(StringFind(obj_name, "MULTI_RECOVERY_TARGET_LINE_") >= 0)
         {
            pos = StringFind(obj_name, "MULTI_RECOVERY_TARGET_LINE_") + StringLen("MULTI_RECOVERY_TARGET_LINE_");
         }
         else if(StringFind(obj_name, "DCA_LINE_") >= 0)
         {
            pos = StringFind(obj_name, "DCA_LINE_") + StringLen("DCA_LINE_");
         }
         else if(StringFind(obj_name, OHLC_RECOVERY_LINE_PREFIX) >= 0)
         {
            pos = StringFind(obj_name, OHLC_RECOVERY_LINE_PREFIX) + StringLen(OHLC_RECOVERY_LINE_PREFIX);
         }
         
         if(pos >= 0)
         {
            ticket_str = StringSubstr(obj_name, pos);
            ulong ticket = (ulong)StringToInteger(ticket_str);
            
            // Check if this position still exists
            if(ticket > 0 && !PositionSelectByTicket(ticket))
            {
               // Position doesn't exist, this is an orphan object
               is_orphan = true;
            }
         }
      }
      else if(StringFind(obj_name, PATTERN17_OBJECT_PREFIX) >= 0)
      {
         // Pattern 17 level and summary objects are transient chart UI objects.
         is_orphan = true;
      }
      // Also clean up label objects that might be orphaned
      else if(StringFind(obj_name, "_Label") >= 0)
      {
         // Check if the parent object exists
         string parent_name = StringSubstr(obj_name, 0, StringFind(obj_name, "_Label"));
         if(ObjectFind(0, parent_name) < 0)
         {
            is_orphan = true; // Parent object doesn't exist
         }
      }
      
      if(is_orphan)
      {
         if(ObjectDelete(0, obj_name))
         {
            orphan_objects_removed++;
         }
      }
   }
   
   if(orphan_objects_removed > 0)
   {
      PrintFormat("Orphan chart cleanup: Removed %d orphan drawing objects", orphan_objects_removed);
      ChartRedraw(0);
   }
}

