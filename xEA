//+------------------------------------------------------------------+
//| Trims leading and trailing spaces from a string                  |
//+------------------------------------------------------------------+
string StringTrim(const string str)
{
   int start = 0, end = StringLen(str) - 1;
   while(start <= end && StringGetCharacter(str, start) == ' ') start++;
   while(end >= start && StringGetCharacter(str, end) == ' ') end--;
   if(start > end) return "";
   return StringSubstr(str, start, end - start + 1);
}

//+------------------------------------------------------------------+
//| News Filter Logic (full integration)                             |
//+------------------------------------------------------------------+
bool IsNewsTime()
{
   if(!InpNewsFilterEnabled)
      return false;
   LoadNewsEvents();
   string keywords[];
   ushort separator = StringGetCharacter(InpNewsSeparator, 0);
   StringSplit(InpNewsKeywords, separator, keywords);
   string currencies[];
   StringSplit(InpNewsCurrencies, separator, currencies);
   datetime now = TimeCurrent();
   for(int i=0; i<NewsEventCount; i++) {
      // Check currency
      bool currency_match = false;
      for(int c=0; c<ArraySize(currencies); c++) {
         string current_filter_currency = currencies[c];
         string trimmedCurrency = StringTrim(current_filter_currency);
         if(StringFind(NewsEvents[i].currency, trimmedCurrency) >= 0) {
            currency_match = true;
            break;
         }
      }
      if(!currency_match) continue;
      // Check keywords
      bool keyword_match = false;
      for(int k=0; k<ArraySize(keywords); k++) {
         string current_filter_keyword = keywords[k];
         string trimmedKeyword = StringTrim(current_filter_keyword);
         if(StringFind(NewsEvents[i].headline, trimmedKeyword) >= 0) {
            keyword_match = true;
            break;
         }
      }
      if(!keyword_match) continue;
      // Check time window
      int minutes_to_event = (int)((NewsEvents[i].event_time - now) / 60);
      if(minutes_to_event >= -InpNewsStartAfterMin && minutes_to_event <= InpNewsStopBeforeMin) {
         PrintFormat("News Filter: Blocking trading due to event '%s' in %d min.", NewsEvents[i].headline, minutes_to_event);
         return true;
      }
   }
   return false;
}

