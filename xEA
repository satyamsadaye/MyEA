int FindPattern18RecoveryOpenTriggerIndex(ulong base_ticket, bool create_if_missing)
{
   for(int i = 0; i < ArraySize(g_pattern18RecoveryOpenTriggers); i++)
   {
      if(g_pattern18RecoveryOpenTriggers[i].base_ticket == base_ticket)
         return i;
   }

   if(!create_if_missing)
      return -1;

   int idx = ArraySize(g_pattern18RecoveryOpenTriggers);
   ArrayResize(g_pattern18RecoveryOpenTriggers, idx + 1);
   g_pattern18RecoveryOpenTriggers[idx].base_ticket = base_ticket;
   g_pattern18RecoveryOpenTriggers[idx].symbol = "";
   g_pattern18RecoveryOpenTriggers[idx].timeframe = PERIOD_CURRENT;
   g_pattern18RecoveryOpenTriggers[idx].pending_bar_time = 0;
   g_pattern18RecoveryOpenTriggers[idx].bar_open = 0.0;
   g_pattern18RecoveryOpenTriggers[idx].trigger_percent = 0.0;
   g_pattern18RecoveryOpenTriggers[idx].order_type = ORDER_TYPE_BUY;
   g_pattern18RecoveryOpenTriggers[idx].pending = false;
   g_pattern18RecoveryOpenTriggers[idx].attempts_before_open = 0;
   return idx;
}

bool IsPattern18RecoveryOpenTriggerPending(ulong base_ticket)
{
   int idx = FindPattern18RecoveryOpenTriggerIndex(base_ticket, false);
   return (idx >= 0 && g_pattern18RecoveryOpenTriggers[idx].pending);
}

void ResetPattern18RecoveryOpenTrigger(ulong base_ticket)
{
   int idx = FindPattern18RecoveryOpenTriggerIndex(base_ticket, false);
   if(idx < 0)
      return;

   g_pattern18RecoveryOpenTriggers[idx].pending = false;
   g_pattern18RecoveryOpenTriggers[idx].base_ticket = 0;
   g_pattern18RecoveryOpenTriggers[idx].symbol = "";
   g_pattern18RecoveryOpenTriggers[idx].timeframe = PERIOD_CURRENT;
   g_pattern18RecoveryOpenTriggers[idx].pending_bar_time = 0;
   g_pattern18RecoveryOpenTriggers[idx].bar_open = 0.0;
   g_pattern18RecoveryOpenTriggers[idx].trigger_percent = 0.0;
   g_pattern18RecoveryOpenTriggers[idx].order_type = ORDER_TYPE_BUY;
   g_pattern18RecoveryOpenTriggers[idx].attempts_before_open = 0;
}

bool QueuePattern18RecoveryOpenTrigger(MultiOrderGroup &group, int attempts_before_open, string ohlc_level_key)
{
   if(group.base_ticket == 0)
      return false;

   ENUM_TIMEFRAMES p18_tf = GetPattern18RecoveryTimeframe();
   double bar_open = iOpen(group.symbol, p18_tf, 0);
   if(bar_open <= 0.0)
   {
      if(!g_is_backtesting)
      {
         PrintFormat("Pattern 18 Recovery: Unable to read current candle open for group #%d on %s. Falling back to immediate recovery entry.",
                     group.base_ticket,
                     EnumToString(p18_tf));
      }
      return false;
   }

   int idx = FindPattern18RecoveryOpenTriggerIndex(group.base_ticket, true);
   g_pattern18RecoveryOpenTriggers[idx].symbol = group.symbol;
   g_pattern18RecoveryOpenTriggers[idx].timeframe = p18_tf;
   g_pattern18RecoveryOpenTriggers[idx].pending_bar_time = iTime(group.symbol, p18_tf, 0);
   g_pattern18RecoveryOpenTriggers[idx].bar_open = bar_open;
   g_pattern18RecoveryOpenTriggers[idx].trigger_percent = MathMax(0.0, InpPattern18RecoveryOpenPriceTriggerPercent);
   g_pattern18RecoveryOpenTriggers[idx].order_type = DetermineRecoveryOrderType(group);
   g_pattern18RecoveryOpenTriggers[idx].pending = true;
   g_pattern18RecoveryOpenTriggers[idx].attempts_before_open = attempts_before_open;

   if(InpOHLCLevelRecoveryConfirmationEnabled && ohlc_level_key != "")
      TrackPendingOHLCRecoveryLevel(group.base_ticket, ohlc_level_key);

   double target_price = (g_pattern18RecoveryOpenTriggers[idx].order_type == ORDER_TYPE_BUY) ?
                         bar_open * (1.0 + g_pattern18RecoveryOpenTriggers[idx].trigger_percent / 100.0) :
                         bar_open * (1.0 - g_pattern18RecoveryOpenTriggers[idx].trigger_percent / 100.0);

   PrintFormat("Pattern 18 Recovery: Open trigger armed for group #%d (%s, TF=%s). Waiting for %.2f%% move from %.5f to %.5f before recovery trade.",
               group.base_ticket,
               EnumToString(g_pattern18RecoveryOpenTriggers[idx].order_type),
               EnumToString(p18_tf),
               g_pattern18RecoveryOpenTriggers[idx].trigger_percent,
               bar_open,
               target_price);

   return true;
}

void ProcessPattern18RecoveryOpenTriggers()
{
   if(!InpMultiOrderEnabled || !InpPattern18RecoveryConfirmationEnabled || !InpPattern18RecoveryUseOpenPriceTrigger)
      return;

   for(int i = ArraySize(g_pattern18RecoveryOpenTriggers) - 1; i >= 0; i--)
   {
      if(!g_pattern18RecoveryOpenTriggers[i].pending)
         continue;

      ulong base_ticket = g_pattern18RecoveryOpenTriggers[i].base_ticket;
      int group_idx = FindMultiOrderGroupIndexByTicket(base_ticket);
      if(group_idx < 0)
      {
         ResetPattern18RecoveryOpenTrigger(base_ticket);
         continue;
      }

      string symbol = g_pattern18RecoveryOpenTriggers[i].symbol;
      if(symbol == "")
         symbol = MultiOrderGroups[group_idx].symbol;

      ENUM_TIMEFRAMES trigger_tf = g_pattern18RecoveryOpenTriggers[i].timeframe;
      if(trigger_tf == PERIOD_CURRENT)
         trigger_tf = GetPattern18RecoveryTimeframe();

      datetime current_bar_time = iTime(symbol, trigger_tf, 0);
      if(current_bar_time == 0)
         continue;

      if(current_bar_time != g_pattern18RecoveryOpenTriggers[i].pending_bar_time)
      {
         if(!g_is_backtesting)
         {
            PrintFormat("Pattern 18 Recovery: Open trigger expired for group #%d on %s (bar advanced). Resetting trigger.",
                        base_ticket,
                        EnumToString(trigger_tf));
         }
         if(InpOHLCLevelRecoveryConfirmationEnabled)
            CommitPendingOHLCRecoveryLevel(base_ticket, false);
         ResetPattern18RecoveryOpenTrigger(base_ticket);
         continue;
      }

      double trigger_price = (g_pattern18RecoveryOpenTriggers[i].order_type == ORDER_TYPE_BUY) ?
                             g_pattern18RecoveryOpenTriggers[i].bar_open * (1.0 + g_pattern18RecoveryOpenTriggers[i].trigger_percent / 100.0) :
                             g_pattern18RecoveryOpenTriggers[i].bar_open * (1.0 - g_pattern18RecoveryOpenTriggers[i].trigger_percent / 100.0);

      double current_price = (g_pattern18RecoveryOpenTriggers[i].order_type == ORDER_TYPE_BUY) ?
                             SymbolInfoDouble(symbol, SYMBOL_ASK) :
                             SymbolInfoDouble(symbol, SYMBOL_BID);

      if(current_price == 0)
         continue;

      bool triggered = (g_pattern18RecoveryOpenTriggers[i].order_type == ORDER_TYPE_BUY) ?
                       (current_price >= trigger_price) :
                       (current_price <= trigger_price);

      if(!triggered)
         continue;

      if(!g_is_backtesting)
      {
         PrintFormat("Pattern 18 Recovery: Open trigger hit for group #%d (%s). Price %.5f reached target %.5f. Executing recovery.",
                     base_ticket,
                     EnumToString(g_pattern18RecoveryOpenTriggers[i].order_type),
                     current_price,
                     trigger_price);
      }

      int attempts_before_open = g_pattern18RecoveryOpenTriggers[i].attempts_before_open;
      OpenRecoveryPosition(MultiOrderGroups[group_idx]);

      if(InpOHLCLevelRecoveryConfirmationEnabled)
      {
         bool trade_opened = (MultiOrderGroups[group_idx].attempts > attempts_before_open);
         CommitPendingOHLCRecoveryLevel(base_ticket, trade_opened);
      }

      ResetPattern18RecoveryOpenTrigger(base_ticket);
   }
}

//+------------------------------------------------------------------+
//| Calculate dynamic Pattern 9 required percentage                   |
//+------------------------------------------------------------------+
double GetPattern9RequiredPercent(bool is_buy_recovery, bool use_fall_mode, int completed_recoveries)
{
   double base_required_percent = 0.0;
   if(InpPattern9RecoveryUseTradeDirectionMode)
      base_required_percent = MathMax(0.0, is_buy_recovery ? InpPattern9RecoveryFallPercent : InpPattern9RecoveryRisePercent);
   else
      base_required_percent = MathMax(0.0, use_fall_mode ? InpPattern9RecoveryFallPercent : InpPattern9RecoveryRisePercent);

   if(!InpPattern9RecoveryPercentStepEnabled)
      return base_required_percent;

   // Use step input as the first stepped level and auto-derive increment from base.
   // Example: base=0.10, step=0.12 -> increments of 0.02 => 0.12, 0.14, 0.16...
   double first_step_required = MathMax(base_required_percent, InpPattern9RecoveryPercentStep);
   double per_trade_increment = first_step_required - base_required_percent;
   if(per_trade_increment <= 0.0)
      return base_required_percent;

   int next_recovery_number = MathMax(1, completed_recoveries + 1); // 1 = next recovery trade
   return base_required_percent + (per_trade_increment * next_recovery_number);
}

//+------------------------------------------------------------------+
//| Calculate dynamic Pattern 9 wait-candle requirement              |
//+------------------------------------------------------------------+
int GetPattern9WaitCandles(int completed_recoveries)
{
   int base_wait = MathMax(0, InpPattern9RecoveryWaitCandles);
   if(!InpPattern9RecoveryWaitStepEnabled || base_wait <= 0)
      return base_wait;

   // Example: base=10, step=0.11 => +1.1 bars per recovery, rounded => 11, 12, 13...
   double step_multiplier = MathMax(0.0, InpPattern9RecoveryWaitStepMultiplier);
   int next_recovery_number = MathMax(1, completed_recoveries + 1); // 1 = next recovery trade
   double extra_wait = ((double)base_wait) * step_multiplier * next_recovery_number;
   int dynamic_wait = (int)MathRound((double)base_wait + extra_wait);
   return MathMax(1, dynamic_wait);
}

//+------------------------------------------------------------------+
//| Pattern 9 style recovery confirmation core                        |
//+------------------------------------------------------------------+
bool IsPattern9FallConfirmingRecoveryCore(ulong base_ticket, bool is_buy_recovery, int completed_recoveries)
{
   if(!InpPattern9RecoveryConfirmationEnabled)
      return true;

   ENUM_TIMEFRAMES p9_tf = InpPattern9RecoveryTimeframe;
   if(p9_tf == PERIOD_CURRENT)
      p9_tf = (ENUM_TIMEFRAMES)_Period;

   int lookbackBars = MathMax(1, InpPattern9RecoveryLookbackBars);
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, p9_tf, 0, lookbackBars + 1, rates) != lookbackBars + 1)
      return false;

   int tracker_idx = FindPattern9RecoveryTrackerIndex(base_ticket, true);
   if(tracker_idx < 0)
      return false;

   datetime current_bar_time = rates[0].time;
   bool isNewBar = (current_bar_time != ExtPattern9RecoveryTrackers[tracker_idx].last_bar_time);
   if(isNewBar)
   {
      ExtPattern9RecoveryTrackers[tracker_idx].last_bar_time = current_bar_time;
      ExtPattern9RecoveryTrackers[tracker_idx].signal_processed = false;
   }

   if(!isNewBar || ExtPattern9RecoveryTrackers[tracker_idx].signal_processed)
      return false;

   int wait_candles = GetPattern9WaitCandles(completed_recoveries);
   datetime last_recovery_trade_bar = ExtPattern9RecoveryTrackers[tracker_idx].last_recovery_trade_bar;
   if(wait_candles > 0 && last_recovery_trade_bar > 0)
   {
      int bars_since_last_recovery = iBarShift(_Symbol, p9_tf, last_recovery_trade_bar, false);
      if(bars_since_last_recovery >= 0 && bars_since_last_recovery < wait_candles)
      {
         if(!g_is_backtesting)
         {
            PrintFormat("Pattern9 Recovery %s: WAITING for base #%d on %s (%d/%d bars elapsed since last recovery trade)",
                        is_buy_recovery ? "BUY" : "SELL",
                        base_ticket,
                        EnumToString(p9_tf),
                        bars_since_last_recovery,
                        wait_candles);
         }
         return false;
      }
   }

   double refPriceHigh = 0.0;
   double refPriceLow = 99999999.0;
   for(int i = 1; i <= lookbackBars; i++)
   {
      double priceHigh = InpPattern9RecoveryUseHighLow ? rates[i].high : rates[i].close;
      double priceLow = InpPattern9RecoveryUseHighLow ? rates[i].low : rates[i].close;

      if(priceHigh > refPriceHigh)
         refPriceHigh = priceHigh;
      if(priceLow < refPriceLow)
         refPriceLow = priceLow;
   }

   if(refPriceHigh <= 0.0 || refPriceLow <= 0.0 || refPriceLow == 99999999.0)
      return false;

   bool use_fall_mode = InpPattern9RecoveryUseTradeDirectionMode
                        ? is_buy_recovery
                        : (InpPattern9RecoveryTriggerMode == P9_RECOVERY_TRIGGER_FALL);

   // In high/low mode, use candle low for fall checks and candle high for rise checks.
   double currentPrice = rates[0].close;
   if(InpPattern9RecoveryUseHighLow)
      currentPrice = use_fall_mode ? rates[0].low : rates[0].high;

   double fallPercent = ((refPriceHigh - currentPrice) / refPriceHigh) * 100.0;
   double risePercent = ((currentPrice - refPriceLow) / refPriceLow) * 100.0;
   double requiredPercent = GetPattern9RequiredPercent(is_buy_recovery, use_fall_mode, completed_recoveries);

   double selectedMovePercent = use_fall_mode ? fallPercent : risePercent;
   bool confirmed = (selectedMovePercent >= requiredPercent);
   if(confirmed)
   {
      ExtPattern9RecoveryTrackers[tracker_idx].signal_processed = true;

      if(!g_is_backtesting)
      {
         PrintFormat("Pattern9 Recovery %s: CONFIRMED for base #%d (Mode=%s, DirMode=%s, TF=%s, Move=%.2f%%, Fall=%.2f%% Rise=%.2f%% Req=%.2f%% Lookback=%d NextRecovery#=%d WaitBars=%d)",
                     is_buy_recovery ? "BUY" : "SELL",
                     base_ticket,
                     use_fall_mode ? "Fall" : "Rise",
                     InpPattern9RecoveryUseTradeDirectionMode ? "AUTO_BY_TRADE" : "MANUAL_MODE",
                     EnumToString(p9_tf),
                     selectedMovePercent,
                     fallPercent,
                     risePercent,
                     requiredPercent,
                     lookbackBars,
                     MathMax(1, completed_recoveries + 1),
                     wait_candles);
      }
   }

   return confirmed;
}

