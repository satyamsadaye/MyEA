        // Use the new unified SL/TP calculation method
        CalculateSLTP(entryPrice, POSITION_TYPE_SELL, stopLoss, takeProfit);
        
        double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
        if(lots <= 0)
        {
            PrintFormat("Pattern 5: Invalid position size calculated for SELL order");
            return;
        }
        
        if(!InpDevelopmentMode)
        {
            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);
            
            request.action = TRADE_ACTION_DEAL;
            request.symbol = _Symbol;
            request.volume = lots;
            request.type = final_order_type;
            request.price = entryPrice;
            request.sl = stopLoss;
            request.tp = takeProfit;
            request.deviation = InpMaxSlippagePoints;
            request.magic = InpMagicNumber;
            request.comment = "RohitEA ST-Stoch SELL";
            request.type_filling = GetSupportedFillingMode(_Symbol);
            
            if(!IsSpreadAcceptable()) return;
            if(SendDollarExitAwareOrder(request, result))
            {
                PrintFormat("Pattern 5: Placed SELL order #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                           result.order, entryPrice, stopLoss, takeProfit, lots);
                g_p5_lastSellTicket = result.order;
                g_lastSignalTime = current_bar_time;
                
                // Create DCA protection orders for this main trade
                if(result.order > 0)
                {
                    CreateDCAOrders(result.order);
                }
            }
            else
            {
                PrintFormat("Pattern 5: Failed to place SELL order. Error: %d", GetLastError());
            }
        }
        else
