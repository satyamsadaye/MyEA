void OnDeinit(const int reason)
{
   // Release indicator handles
   if(g_rsi_handle != INVALID_HANDLE) IndicatorRelease(g_rsi_handle);
   if(g_atr_handle != INVALID_HANDLE) IndicatorRelease(g_atr_handle);
   if(g_sar_handle != INVALID_HANDLE) IndicatorRelease(g_sar_handle);
   if(g_stoch_rsi_handle != INVALID_HANDLE) IndicatorRelease(g_stoch_rsi_handle);
   if(g_stochastic_handle != INVALID_HANDLE) IndicatorRelease(g_stochastic_handle);
   if(g_supertrend_atr_handle != INVALID_HANDLE) IndicatorRelease(g_supertrend_atr_handle);
   if(g_macd_handle != INVALID_HANDLE) IndicatorRelease(g_macd_handle);
   if(g_roc_handle != INVALID_HANDLE) IndicatorRelease(g_roc_handle);
   
   // Save recovery state before deinitializing
   SaveRecoveryState();
   SaveGlobalDollarLossStreakState();
   GDPanelSaveDailyState();
   ClearChartDisplayObjects();
   GDPanelDeleteDashboard();
   
   // Clean up all EA-related chart objects
   CleanupAllEAObjects();
   
   // Cleanup copy trading states - REMOVED CLOSEALL SIGNALS TO PREVENT UNWANTED SIGNALS WHEN EA IS ADDED/REMOVED
   if(InpCopyTradeEnabled)
   {
      // Just cleanup the tracking array without sending any signals
      ArrayResize(g_copyTradeStates, 0);
      PrintFormat("COPY TRADING: Cleanup completed (signals disabled to prevent unwanted CLOSEALL)");
   }
   
   // Final cleanup of any remaining DCA orders
   CleanupOrphanDCAOrders();
   CleanupOrphanRecoveryTrades();
   CleanupAllDCAObjects();
   
   // Final cleanup of all chart objects
   CleanupAllChartObjects();
   RemoveTrailLine();
   RemoveTrailTriggerLine();
   
   EventKillTimer();
   long current_chart_id = ChartID();
   
   // Only clean up display objects if not in backtesting
   if(!g_is_backtesting)
   {
      // Clean up display objects
      for(int i = 0; i < ExtTotalDisplayLines + 5; i++)
      {
         string object_name = DISPLAY_OBJECT_PREFIX + IntegerToString(i);
         ObjectDelete(current_chart_id, object_name);
      }
      
      // Clean up synthetic SL lines
      int total = ObjectsTotal(current_chart_id, 0, OBJ_HLINE);
      for(int i = total - 1; i >= 0; i--)
      {
         string object_name = ObjectName(current_chart_id, i, 0, OBJ_HLINE);
         if(StringFind(object_name, SYNTHETIC_SL_LINE_PREFIX) >= 0)
         {
            ObjectDelete(current_chart_id, object_name);
            ObjectDelete(current_chart_id, object_name + "_Label");
         }
         else if(StringFind(object_name, "ORIGINAL_TP_LINE_") >= 0)
         {
            ObjectDelete(current_chart_id, object_name);
            ObjectDelete(current_chart_id, object_name + "_Label");
         }
         else if(StringFind(object_name, "MULTI_RECOVERY_TARGET_LINE_") >= 0)
         {
            ObjectDelete(current_chart_id, object_name);
         }
         else if(StringFind(object_name, OHLC_RECOVERY_LINE_PREFIX) >= 0)
         {
            ObjectDelete(current_chart_id, object_name);
         }
      }
      
      // Clean up all DCA objects
      CleanupAllDCAObjects();
      
      ChartRedraw(current_chart_id);
   }

      // Clean up manual trading UI objects
      ObjectDelete(current_chart_id, MAN_BTN_BUY);
      ObjectDelete(current_chart_id, MAN_BTN_SELL);
      ObjectDelete(current_chart_id, MAN_BTN_CLOSE);
      ObjectDelete(current_chart_id, MAN_BTN_BE);
      ObjectDelete(current_chart_id, MAN_DASH_PREFIX + "BG");
      for(int _i = 0; _i < 6; _i++) ObjectDelete(current_chart_id, MAN_DASH_PREFIX + "TEXT_" + (string)_i);
   
   Print("RohitEA deinitialized. Reason: ", reason);
}

