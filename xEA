//+------------------------------------------------------------------+
bool WasTrailingUsed(const ulong ticket);
void CloseTrailingScaleOrders(ulong base_ticket);

ulong OpenPosition(string symbol, ENUM_POSITION_TYPE position_type, double volume, double sl = 0, double tp = 0, string comment = "")
{
    MqlTradeRequest request = {};
    MqlTradeResult result = {};
    
    request.action = TRADE_ACTION_DEAL;
    request.symbol = symbol;
    request.volume = volume;
    
    // Convert position type to order type
    request.type = (position_type == POSITION_TYPE_BUY) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
    
    // Get market price for the order
    request.price = SymbolInfoDouble(symbol, (position_type == POSITION_TYPE_BUY) ? SYMBOL_ASK : SYMBOL_BID);
    
    // Global dollar exit replaces these with dollar-based visible SL/TP in SendDollarExitAwareOrder().
    if(!InpGlobalDollarExitEnabled)
    {
        if(sl != 0) request.sl = sl;
        if(tp != 0) request.tp = tp;
    }
    
    // Set other parameters
    request.deviation = InpMaxSlippagePoints;
    request.magic = InpMagicNumber;
    request.comment = comment;
    request.type_filling = GetSupportedFillingMode(symbol);
    
    // Check spread before executing
    if(!IsSpreadAcceptable()) return 0;
    
    // Send the order
    if(!SendDollarExitAwareOrder(request, result))
    {
        PrintFormat("Error opening position: %d", GetLastError());
        return 0;
    }
    
    if(result.retcode == TRADE_RETCODE_DONE)
    {
        PrintFormat("Position opened successfully: Ticket #%d", result.order);
        return result.order;
    }
    
    PrintFormat("Failed to open position: RetCode=%d, Comment=%s", result.retcode, result.comment);
    return 0;
}

//+------------------------------------------------------------------+
//| Centralized ClosePosition function                                 |
//+------------------------------------------------------------------+
bool ClosePositionWithComment(ulong ticket, string close_comment = "")
{
    if(!PositionSelectByTicket(ticket))
    {
        PrintFormat("Cannot close position #%d - not found", ticket);
        return false;
    }

    CloseTrailingScaleOrders(ticket);

    string symbol = PositionGetString(POSITION_SYMBOL);
    double volume = PositionGetDouble(POSITION_VOLUME);
    ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
    
    MqlTradeRequest request = {};
    MqlTradeResult result = {};
    
    request.action = TRADE_ACTION_DEAL;
    request.position = ticket;
    request.symbol = symbol;
    request.volume = volume;
    request.deviation = InpMaxSlippagePoints;
    request.magic = InpMagicNumber;
    request.type_filling = GetSupportedFillingMode(symbol);
    if(close_comment != "")
    {
        request.comment = close_comment;
    }
    else if(WasTrailingUsed(ticket))
    {
        request.comment = "RohitEA TRAILING_EXIT";
    }
    
    // Get original position comment to check if it's a hedge
    string orig_comment = PositionGetString(POSITION_COMMENT);
    if(StringFind(orig_comment, "⚡HEDGE") >= 0)
    {
        request.comment = StringFormat("✨HEDGE CLOSED P&L:%.2f$", 
                                     PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP));
    }

    if(close_comment != "")
    {
        request.comment = close_comment;
    }
    
    // Set closing order type (opposite to position type)
    if(pos_type == POSITION_TYPE_BUY)
    {
        request.type = ORDER_TYPE_SELL;
        request.price = SymbolInfoDouble(symbol, SYMBOL_BID);
    }
    else
    {
        request.type = ORDER_TYPE_BUY;
        request.price = SymbolInfoDouble(symbol, SYMBOL_ASK);
    }
    
    // Send the order
    if(!SendDollarExitAwareOrder(request, result))
    {
        PrintFormat("Error closing position #%d: %d", ticket, GetLastError());
        return false;
    }
    
    if(result.retcode == TRADE_RETCODE_DONE)
    {
        PrintFormat("Position #%d closed successfully", ticket);
        return true;
    }
    
    PrintFormat("Failed to close position #%d: RetCode=%d, Comment=%s", ticket, result.retcode, result.comment);
    return false;
}

bool ClosePosition(ulong ticket)
{
    return ClosePositionWithComment(ticket, "");
}

