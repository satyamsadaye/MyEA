bool IsSpreadAcceptable()
{
   double spread = (double)SymbolInfoInteger(_Symbol, SYMBOL_SPREAD);
   if(spread > InpMaxAllowedSpread)
   {
      PrintFormat("[SPREAD FILTER] Trade blocked: Current spread %.1f > allowed max %.1f points", spread, InpMaxAllowedSpread);
      return false;
   }
   return true;
}
//+------------------------------------------------------------------+
//| Handle Pattern 4 - Box Breakout                                  |
//+------------------------------------------------------------------+
void HandlePattern4()
{
    // Get current bar time to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);

    // Check if we've already processed a signal for this bar
    if(current_bar_time == g_lastSignalTime)
    {
        PrintFormat("Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
        return;
    }

    // Reset Pattern 4 tickets
    g_p4_buyStopTicket = 0;
    g_p4_sellStopTicket = 0;

    // Validate input parameter
    int numBoxCandles = MathMax(2, MathMin(10, InpPattern4BoxCandles));

    // Get price data for the candles (current + box candles)
    double highs[], lows[], closes[];
    ArrayResize(highs, numBoxCandles + 1);
    ArrayResize(lows, numBoxCandles + 1);
    ArrayResize(closes, numBoxCandles + 1);

    for(int i = 0; i <= numBoxCandles; i++)
    {
        highs[i] = iHigh(_Symbol, _Period, i);
        lows[i] = iLow(_Symbol, _Period, i);
        closes[i] = iClose(_Symbol, _Period, i);
    }

    // Initialize SAR indicator for Pattern 4
    int sarHandle = iSAR(_Symbol, _Period, InpPattern4SARStep, InpPattern4SARMax);
    if(sarHandle == INVALID_HANDLE)
    {
        PrintFormat("Failed to create SAR indicator handle. Error code: %d", GetLastError());
        return;
    }

    // Get SAR values for current bar
    double sarValues[];
    if(CopyBuffer(sarHandle, 0, 0, 2, sarValues) < 2)
    {
        PrintFormat("Failed to get SAR values. Error code: %d", GetLastError());
        IndicatorRelease(sarHandle);
        return;
    }

    double currentSAR = sarValues[0];
    IndicatorRelease(sarHandle); // Release the indicator handle after use

    // If box not yet formed or expired, check for new box formation
    datetime currentBarTime = iTime(_Symbol, _Period, 0);
    if(!g_p4_boxFormed || currentBarTime - g_p4_boxStartTime > 20 * PeriodSeconds(_Period))
    {
        // Check if consecutive candles form a consolidation box
        bool isConsolidation = true;

        // Get the high and low of the box (previous candles)
        double boxHigh = highs[1]; // Start with first previous candle
        double boxLow = lows[1];

        // Find highest high and lowest low of the candles
        for(int i = 1; i <= numBoxCandles; i++)
        {
            boxHigh = MathMax(boxHigh, highs[i]);
            boxLow = MathMin(boxLow, lows[i]);
        }

        // Check if all closes are within the range
        for(int i = 1; i <= numBoxCandles; i++)
        {
            if(closes[i] > boxHigh || closes[i] < boxLow)
            {
                isConsolidation = false;
                break;
            }
        }

        // If consolidation found, mark the box
        if(isConsolidation)
        {
            g_p4_boxFormed = true;
            g_p4_boxStartTime = currentBarTime;
            g_p4_boxHigh = boxHigh;
            g_p4_boxLow = boxLow;
            g_p4_consecutiveBars = 0;

            PrintFormat("Pattern 4: Box formed with %d candles. High: %.5f, Low: %.5f",
                numBoxCandles, g_p4_boxHigh, g_p4_boxLow);
        }
    }

    // If box is formed, look for trading opportunities
    if(g_p4_boxFormed)
    {
        // Count consecutive bars in the pattern
        g_p4_consecutiveBars++;

        // Calculate ATR for SL/TP
        double atr_values[];
        if(CopyBuffer(iATR(_Symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) <= 0)
        {
            PrintFormat("Could not get ATR value. Error %d", GetLastError());
            return;
        }
        double atr = atr_values[0];

        // Check if price closes above the box high (BUY signal) AND price is above SAR
        if(closes[0] > g_p4_boxHigh && closes[0] > currentSAR)
        {
            PrintFormat("Pattern 4: Original BUY signal - Price closed above box high and above SAR. Close: %.5f > Box High: %.5f, SAR: %.5f",
                closes[0], g_p4_boxHigh, currentSAR);

            bool isReversed = InpReverseSignal;
            // Create SELL order if reversed, otherwise BUY
            double entryPrice = isReversed ? SymbolInfoDouble(_Symbol, SYMBOL_BID) : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
            double stopLoss   = isReversed ? (entryPrice + (atr * InpAtrMultiplierSL)) : (entryPrice - (atr * InpAtrMultiplierSL));
            double takeProfit = isReversed ? (entryPrice - (atr * InpAtrMultiplierTP)) : (entryPrice + (atr * InpAtrMultiplierTP));

            // Calculate lot size
            double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
            if(lots <= 0)
            {
                PrintFormat("Invalid position size calculated for order");
                return;
            }

            // Place order
            if(!InpDevelopmentMode)
            {
                MqlTradeRequest request;
                MqlTradeResult result;
                ZeroMemory(request);
                ZeroMemory(result);

                request.action = TRADE_ACTION_DEAL;
                request.symbol = _Symbol;
                request.volume = lots;
                request.type = isReversed ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
                request.price = entryPrice;
                request.sl = stopLoss;
                request.tp = takeProfit;
                request.deviation = InpMaxSlippagePoints;
                request.magic = InpMagicNumber;
                request.comment = isReversed ? "RohitEA Iota" : "RohitEA Kappa";
                request.type_filling = GetSupportedFillingMode(_Symbol);

                // Apply master trade direction filter
                if ((request.type == ORDER_TYPE_BUY && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
                    (request.type == ORDER_TYPE_SELL && InpTradeDirection == TRADE_DIR_BUY_ONLY))
                {
                    PrintFormat("Pattern 4: Trade blocked by direction filter. Action: %s, Filter: %s",
                                EnumToString(request.type), EnumToString(InpTradeDirection));
                }
                else if(!IsSpreadAcceptable()) return;
                else if(SendDollarExitAwareOrder(request, result))
                {
                    PrintFormat("Pattern 4: Placed %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        isReversed ? "reversed sell" : "buy", entryPrice, stopLoss, takeProfit, lots);
                    g_lastSignalTime = current_bar_time;
                    
                    // Create DCA protection orders for this main trade
                    if(result.order > 0)
                    {
                        CreateDCAOrders(result.order);
                    }
                }
                else
                {
                    ENUM_ORDER_TYPE orderType = isReversed ? GetReversedOrderType(ORDER_TYPE_BUY) : ORDER_TYPE_BUY;
                if (!IsTradeDirectionAllowed(orderType))
                    {
                        PrintFormat("[DEV MODE] Pattern 4: Would be blocked by direction filter.");
                    } else {
                        PrintFormat("Pattern 4: Failed to place order. Error: %d", GetLastError());
                    }
                    g_lastSignalTime = current_bar_time;
                }
            }
            else
            {
                if (((isReversed ? ORDER_TYPE_SELL : ORDER_TYPE_BUY) == ORDER_TYPE_BUY && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
                    ((isReversed ? ORDER_TYPE_SELL : ORDER_TYPE_BUY) == ORDER_TYPE_SELL && InpTradeDirection == TRADE_DIR_BUY_ONLY))
                {
                    PrintFormat("[DEV MODE] Pattern 4: Would be blocked by direction filter.");
                } else {
                    PrintFormat("[DEV MODE] Pattern 4: Would place %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        isReversed ? "REVERSED SELL" : "BUY", entryPrice, stopLoss, takeProfit, lots);
                }
                g_lastSignalTime = current_bar_time;
            }

            // Reset box detection
            g_p4_boxFormed = false;
        }
        // Check if price closes below the box low (SELL signal) AND price is below SAR
        else if(closes[0] < g_p4_boxLow && closes[0] < currentSAR)
        {
            PrintFormat("Pattern 4: Original SELL signal - Price closed below box low and below SAR. Close: %.5f < Box Low: %.5f, SAR: %.5f",
                closes[0], g_p4_boxLow, currentSAR);

            bool isReversed = InpReverseSignal;
            // Create BUY order if reversed, otherwise SELL
            double entryPrice = isReversed ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
            double stopLoss   = isReversed ? (entryPrice - (atr * InpAtrMultiplierSL)) : (entryPrice + (atr * InpAtrMultiplierSL));
            double takeProfit = isReversed ? (entryPrice + (atr * InpAtrMultiplierTP)) : (entryPrice - (atr * InpAtrMultiplierTP));

            // Calculate lot size
            double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
            if(lots <= 0)
            {
                PrintFormat("Invalid position size calculated for order");
                return;
            }

            // Place order
            if(!InpDevelopmentMode)
            {
                MqlTradeRequest request;
                MqlTradeResult result;
                ZeroMemory(request);
                ZeroMemory(result);

                request.action = TRADE_ACTION_DEAL;
                request.symbol = _Symbol;
                request.volume = lots;
                request.type = isReversed ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
                request.price = entryPrice;
                request.sl = stopLoss;
                request.tp = takeProfit;
                request.deviation = InpMaxSlippagePoints;
                request.magic = InpMagicNumber;
                request.comment = isReversed ? "RohitEA Lambda" : "RohitEA Mu";
                request.type_filling = GetSupportedFillingMode(_Symbol);

                // Apply master trade direction filter
                if ((request.type == ORDER_TYPE_BUY && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
                    (request.type == ORDER_TYPE_SELL && InpTradeDirection == TRADE_DIR_BUY_ONLY))
                {
                    PrintFormat("Pattern 4: Trade blocked by direction filter. Action: %s, Filter: %s",
                                EnumToString(request.type), EnumToString(InpTradeDirection));
                }
                else if(!IsSpreadAcceptable()) return;
                else if(SendDollarExitAwareOrder(request, result))
                {
                    PrintFormat("Pattern 4: Placed %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        isReversed ? "reversed buy" : "sell", entryPrice, stopLoss, takeProfit, lots);
                    g_lastSignalTime = current_bar_time;
                    
                    // Create DCA protection orders for this main trade
                    if(result.order > 0)
                    {
                        CreateDCAOrders(result.order);
                    }
                }
                else
                {
                    ENUM_ORDER_TYPE orderType = isReversed ? GetReversedOrderType(ORDER_TYPE_SELL) : ORDER_TYPE_SELL;
                if (!IsTradeDirectionAllowed(orderType))
                    {
                        PrintFormat("[DEV MODE] Pattern 4: Would be blocked by direction filter.");
                    } else {
                        PrintFormat("[DEV MODE] Pattern 4: Would place %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                            isReversed ? "REVERSED BUY" : "SELL", entryPrice, stopLoss, takeProfit, lots);
                    }
                    g_lastSignalTime = current_bar_time;
                }
            }
            else
            {
                if (((isReversed ? ORDER_TYPE_BUY : ORDER_TYPE_SELL) == ORDER_TYPE_BUY && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
                    ((isReversed ? ORDER_TYPE_BUY : ORDER_TYPE_SELL) == ORDER_TYPE_SELL && InpTradeDirection == TRADE_DIR_BUY_ONLY))
                {
                    PrintFormat("[DEV MODE] Pattern 4: Would be blocked by direction filter.");
                } else {
                    PrintFormat("[DEV MODE] Pattern 4: Would place %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f",
                        isReversed ? "REVERSED BUY" : "SELL", entryPrice, stopLoss, takeProfit, lots);
                }
                g_lastSignalTime = current_bar_time;
            }

            // Reset box detection
            g_p4_boxFormed = false;
        }

        // If the pattern has been running for too long, reset it
        if(g_p4_consecutiveBars > 20)
        {
            PrintFormat("Pattern 4: Box pattern timed out after %d bars", g_p4_consecutiveBars);
            g_p4_boxFormed = false;
        }
    }
}

//+------------------------------------------------------------------+
//| Calculate SuperTrend indicator (TradingView Logic)               |
//+------------------------------------------------------------------+
bool CalculateSuperTrend(int shift, double &supertrend_value, int &supertrend_direction)
{
    datetime current_time = iTime(_Symbol, _Period, shift);
    
    // Return cached value if still valid for the same bar (fix cache condition)
    if(shift == 0 && current_time == g_cached_supertrend_time && g_cached_supertrend_time > 0)
    {
        supertrend_value = g_cached_supertrend_value;
        supertrend_direction = g_cached_supertrend_direction;
        return true;
    }
    
    // Check if we have enough bars for calculation
    if(Bars(_Symbol, _Period) < InpSupertrendPeriod + 5)
        return false;
    
    // Get sufficient historical data for proper SuperTrend calculation
    int bars_needed = InpSupertrendPeriod * 2 + 5;
    
    double atr_buffer[];
    double high_buffer[];
    double low_buffer[];
    double close_buffer[];
    
    // Use ArraySetAsSeries to match MT5 indexing (0 = current bar)
    ArraySetAsSeries(atr_buffer, true);
    ArraySetAsSeries(high_buffer, true);
    ArraySetAsSeries(low_buffer, true);
    ArraySetAsSeries(close_buffer, true);
    
    if(CopyBuffer(g_supertrend_atr_handle, 0, shift, bars_needed, atr_buffer) <= 0 ||
       CopyHigh(_Symbol, _Period, shift, bars_needed, high_buffer) <= 0 ||
       CopyLow(_Symbol, _Period, shift, bars_needed, low_buffer) <= 0 ||
       CopyClose(_Symbol, _Period, shift, bars_needed, close_buffer) <= 0)
    {
        PrintFormat("SuperTrend: Failed to copy data buffers. Error: %d", GetLastError());
        return false;
    }
    
    // Calculate SuperTrend for multiple bars to ensure proper trend determination
    double supertrend_values[2];
    int directions[2];
    
    // Calculate for current bar (shift) and previous bar (shift+1)
    for(int i = 0; i < 2; i++)
    {
        int bar_index = i; // 0 = current bar, 1 = previous bar relative to shift
        
        double atr = atr_buffer[bar_index];
        double hl2 = (high_buffer[bar_index] + low_buffer[bar_index]) / 2.0;
        double close_price = close_buffer[bar_index];
        
        // Calculate basic bands
        double basic_upper = hl2 + (InpSupertrendFactor * atr);
        double basic_lower = hl2 - (InpSupertrendFactor * atr);
        
        // For the first calculation or if we have previous data
        if(i == 0)
        {
            // Use simplified logic for current bar
            // Check price position relative to bands to determine trend
            double prev_close = (bars_needed > 1) ? close_buffer[1] : close_price;
            
            // Determine trend based on price action
            if(close_price > basic_lower && prev_close > basic_lower)
                directions[i] = 1; // Uptrend
            else if(close_price < basic_upper && prev_close < basic_upper)
                directions[i] = -1; // Downtrend
            else
            {
                // Use previous direction if available, otherwise determine from price position
                if(close_price > hl2)
                    directions[i] = 1;
                else
                    directions[i] = -1;
            }
            
            // Set SuperTrend value based on direction
            if(directions[i] == 1)
                supertrend_values[i] = basic_lower; // Uptrend uses lower band as support
            else
                supertrend_values[i] = basic_upper; // Downtrend uses upper band as resistance
        }
    }
    
    // Use the calculated values
    supertrend_value = supertrend_values[0];
    supertrend_direction = directions[0];
    
    // Additional validation: Ensure direction makes sense with current price
    double current_close = close_buffer[0];
    double price_vs_supertrend_tolerance = atr_buffer[0] * 0.1; // 10% of ATR as tolerance
    
    // More strict validation: Price must be clearly on the correct side of SuperTrend
    if(supertrend_direction == 1)
    {
        // In uptrend, price should be above SuperTrend line
        if(current_close < (supertrend_value - price_vs_supertrend_tolerance))
        {
            // Price is clearly below SuperTrend, this should be downtrend
            supertrend_direction = -1;
            supertrend_value = (high_buffer[0] + low_buffer[0]) / 2.0 + (InpSupertrendFactor * atr_buffer[0]);
            
            if(!g_is_backtesting && shift == 0)
            {
                PrintFormat("SuperTrend CORRECTION: Changed to DOWNTREND - Price %.5f is below ST line %.5f", 
                           current_close, supertrend_value);
            }
        }
    }
    else if(supertrend_direction == -1)
    {
        // In downtrend, price should be below SuperTrend line  
        if(current_close > (supertrend_value + price_vs_supertrend_tolerance))
        {
            // Price is clearly above SuperTrend, this should be uptrend
            supertrend_direction = 1;
            supertrend_value = (high_buffer[0] + low_buffer[0]) / 2.0 - (InpSupertrendFactor * atr_buffer[0]);
            
            if(!g_is_backtesting && shift == 0)
            {
                PrintFormat("SuperTrend CORRECTION: Changed to UPTREND - Price %.5f is above ST line %.5f", 
                           current_close, supertrend_value);
            }
        }
    }
    
    // Cache the result if this is for current bar (shift = 0)
    if(shift == 0)
    {
        g_cached_supertrend_value = supertrend_value;
        g_cached_supertrend_direction = supertrend_direction;
        g_cached_supertrend_time = current_time;
    }
    
    // Debug output (only in live trading)
    if(!g_is_backtesting && shift == 0)
    {
        PrintFormat("SuperTrend DEBUG: Close=%.5f, ST_Value=%.5f, Direction=%s, Price vs ST: %s",
                   current_close, supertrend_value,
                   (supertrend_direction == 1) ? "UP" : "DOWN",
                   (current_close > supertrend_value) ? "ABOVE" : "BELOW");
    }
    
    return true;
}
//+------------------------------------------------------------------+
//| Handle Pattern 5 - SuperTrend + Stochastic Strategy             |
//+------------------------------------------------------------------+
void HandlePattern5()
{
    // PATTERN 5 STRATEGY: SuperTrend for Direction + Stochastic for Entry
    // ================================================================
    // BUY SIGNALS:  Only when SuperTrend shows UPTREND (direction=1) AND Stochastic K < 30 (oversold)
    // SELL SIGNALS: Only when SuperTrend shows DOWNTREND (direction=-1) AND Stochastic K > 70 (overbought)
    // 
    // NO COUNTER-TREND TRADES: SuperTrend direction MUST match trade direction
    // - In UPTREND: Only BUY when Stochastic oversold (price pullback in uptrend)
    // - In DOWNTREND: Only SELL when Stochastic overbought (price pullback in downtrend)
    // ================================================================
    
    // Performance optimization: Early exit for backtesting speed
    if(g_is_backtesting)
    {
        // In backtesting, use simplified logic for better performance
        static datetime last_check_time = 0;
        datetime current_bar_time = iTime(_Symbol, _Period, 0);
        
        // Only check once per bar in backtesting
        if(current_bar_time == last_check_time)
            return;
        last_check_time = current_bar_time;
    }

    // Check if trade direction settings will interfere with SuperTrend direction filtering
    if(InpTradeDirection == TRADE_DIR_ALWAYS_BUY || InpTradeDirection == TRADE_DIR_ALWAYS_SELL)
    {
        static bool direction_warning_shown = false;
        if(!direction_warning_shown && !g_is_backtesting)
        {
            PrintFormat("Pattern 5 WARNING: Trade Direction is set to '%s' which will OVERRIDE SuperTrend direction filtering!", 
                       EnumToString(InpTradeDirection));
            PrintFormat("Pattern 5 WARNING: This will cause BUY trades even when SuperTrend shows RED (downtrend)!");
            PrintFormat("Pattern 5 WARNING: For proper SuperTrend direction filtering, set Trade Direction to 'TRADE_DIR_BOTH'");
            direction_warning_shown = true;
        }
    }

    // Get current bar time to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);

    // Basic debug logging
    if(!g_is_backtesting)
    {
        PrintFormat("Pattern 5: HandlePattern5() called for bar time %s", TimeToString(current_bar_time));
    }

    // Check if we've already processed a signal for this bar
    if(current_bar_time == g_lastSignalTime)
    {
        if(!g_is_backtesting)
        {
            PrintFormat("Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
        }
        return;
    }

    // Reset Pattern 5 tickets
    g_p5_lastBuyTicket = 0;
    g_p5_lastSellTicket = 0;
    
    // Get SuperTrend values with optimized caching
    double supertrend_value;
    int supertrend_direction;
    if(!CalculateSuperTrend(0, supertrend_value, supertrend_direction))
    {
        PrintFormat("Pattern 5: Failed to calculate SuperTrend values");
        return;
    }
    
    // Debug: Display SuperTrend calculation results
    if(!g_is_backtesting)
    {
        // Display current SuperTrend parameters and results for verification
        PrintFormat("Pattern 5: SuperTrend Period=%d, Factor=%.1f => Value=%.5f, Direction=%s", 
                   InpSupertrendPeriod, InpSupertrendFactor, supertrend_value,
                   (supertrend_direction == 1) ? "UPTREND" : "DOWNTREND");
    }
    
    // Get Stochastic values
    double stoch_main[], stoch_signal[];
    if(CopyBuffer(g_stochastic_handle, 0, 0, 1, stoch_main) <= 0 ||
       CopyBuffer(g_stochastic_handle, 1, 0, 1, stoch_signal) <= 0)
    {
        PrintFormat("Pattern 5: Failed to get Stochastic values. Error: %d", GetLastError());
        return;
    }
    
    double stoch_k = stoch_main[0];
    double stoch_d = stoch_signal[0];
    
    // Get current price for comparison
    double current_price = iClose(_Symbol, _Period, 0);
    
    // Enhanced debugging - always show when conditions are met but signal is blocked
    if(!g_is_backtesting)
    {
        PrintFormat("Pattern 5: SuperTrend Direction: %s (Value: %.5f), Current Price: %.5f, Stochastic K: %.2f, D: %.2f", 
                   (supertrend_direction == 1) ? "UPTREND" : "DOWNTREND", supertrend_value, current_price, stoch_k, stoch_d);
                   
        // Show when correct conditions would trigger signals
        if(supertrend_direction == 1 && stoch_k < InpStochasticLowLevel)
        {
            PrintFormat("Pattern 5: ✓ VALID BUY CONDITIONS - SuperTrend UPTREND and Stochastic K (%.2f) < %.2f", 
                       stoch_k, InpStochasticLowLevel);
        }
        else if(supertrend_direction == -1 && stoch_k > InpStochasticHighLevel)
        {
            PrintFormat("Pattern 5: ✓ VALID SELL CONDITIONS - SuperTrend DOWNTREND and Stochastic K (%.2f) > %.2f", 
                       stoch_k, InpStochasticHighLevel);
        }
        
        // Show when wrong direction signals would be blocked
        if(supertrend_direction == 1 && stoch_k > InpStochasticHighLevel)
        {
            PrintFormat("Pattern 5: ✗ SELL BLOCKED - SuperTrend is UPTREND (only BUY allowed), but Stochastic K (%.2f) > %.2f", 
                       stoch_k, InpStochasticHighLevel);
        }
        else if(supertrend_direction == -1 && stoch_k < InpStochasticLowLevel)
        {
            PrintFormat("Pattern 5: ✗ BUY BLOCKED - SuperTrend is DOWNTREND (only SELL allowed), but Stochastic K (%.2f) < %.2f", 
                       stoch_k, InpStochasticLowLevel);
        }
        
        // Show when Stochastic is in neutral zone
        if(stoch_k >= InpStochasticLowLevel && stoch_k <= InpStochasticHighLevel)
        {
            PrintFormat("Pattern 5: ⏸ NO SIGNAL - Stochastic K (%.2f) in neutral zone (%.2f to %.2f)", 
                       stoch_k, InpStochasticLowLevel, InpStochasticHighLevel);
        }
    }
    
    // Check BUY signal: SuperTrend UPTREND (direction = 1) and Stochastic below 30
    if(supertrend_direction == 1 && stoch_k < InpStochasticLowLevel)
    {
        // ADDITIONAL SAFETY CHECK: Verify SuperTrend direction is actually UPTREND
        double current_close = iClose(_Symbol, _Period, 0);
        if(current_close < supertrend_value)
        {
            PrintFormat("Pattern 5: BUY signal REJECTED - Price %.5f is below SuperTrend line %.5f (not truly uptrend)", 
                       current_close, supertrend_value);
            return;
        }
        
        // CRITICAL CHECK: Prevent BUY trades if trade direction settings would force SELL
        if(InpTradeDirection == TRADE_DIR_ALWAYS_SELL || InpTradeDirection == TRADE_DIR_SELL_ONLY)
        {
            PrintFormat("Pattern 5: BUY signal BLOCKED by trade direction setting (%s). SuperTrend shows UPTREND but trade direction is set to SELL only.", 
                       EnumToString(InpTradeDirection));
            return;
        }
        
        if(!g_is_backtesting)
        {
            PrintFormat("Pattern 5: BUY signal CONFIRMED - SuperTrend UPTREND (Price %.5f > ST %.5f) and Stochastic K (%.2f) below %.2f", 
                       current_close, supertrend_value, stoch_k, InpStochasticLowLevel);
        }
                   
        // Force BUY order type regardless of GetFinalOrderType to respect SuperTrend direction
        ENUM_ORDER_TYPE final_order_type = ORDER_TYPE_BUY;
        
        // Only check against restrictive filters, not override filters
        if(InpTradeDirection == TRADE_DIR_SELL_ONLY)
        {
            PrintFormat("Pattern 5: BUY signal blocked by SELL_ONLY trade direction filter");
            return;
        }
        
        // Calculate entry, SL, and TP
        double entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
        double stopLoss, takeProfit;
        
        // Use the new unified SL/TP calculation method
        CalculateSLTP(entryPrice, POSITION_TYPE_BUY, stopLoss, takeProfit);
        
        // --- DEBUG: Symbol lot constraints ---
        double min_lot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
        double max_lot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
        double lot_step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
        PrintFormat("[DEBUG] Symbol: %s | MinLot: %.2f | MaxLot: %.2f | LotStep: %.2f", _Symbol, min_lot, max_lot, lot_step);
        PrintFormat("[DEBUG] Entry: %.5f | SL: %.5f | TP: %.5f", entryPrice, stopLoss, takeProfit);
        
        double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
        PrintFormat("[DEBUG] CalculatePositionSize returned: %.4f", lots);
        
        if(lots <= 0)
        {
            PrintFormat("Pattern 5: Invalid position size calculated for BUY order (lots=%.4f)", lots);
            return;
        }
        
        // Properly normalize lot size to meet broker requirements
        if(lot_step > 0)
        {
            lots = MathRound(lots / lot_step) * lot_step;  // Round to nearest step
        }
        lots = MathMax(min_lot, MathMin(max_lot, lots));  // Clamp to valid range
        lots = NormalizeDouble(lots, 2);  // Normalize to 2 decimal places
        
        PrintFormat("[DEBUG] Final normalized lots: %.4f", lots);
        
        // Final validation before order
        if(lots < min_lot || lots > max_lot)
        {
            PrintFormat("Pattern 5: Lot size %.4f is outside valid range [%.2f - %.2f]", lots, min_lot, max_lot);
            return;
        }
        
        if(lot_step > 0)
        {
            double remainder = MathMod(lots - min_lot, lot_step);
            if(MathAbs(remainder) > 1e-8 && MathAbs(remainder - lot_step) > 1e-8)
            {
                PrintFormat("Pattern 5: Lot size %.4f is not a multiple of step %.2f (remainder: %.8f)", lots, lot_step, remainder);
                return;
            }
        }
        
        if(!InpDevelopmentMode)
        {
            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);
            
            request.action = TRADE_ACTION_DEAL;
            request.symbol = _Symbol;
            request.volume = lots;
            request.type = final_order_type;
            request.price = entryPrice;
            request.sl = stopLoss;
            request.tp = takeProfit;
            request.deviation = InpMaxSlippagePoints;
            request.magic = InpMagicNumber;
            request.comment = "RohitEA ST-Stoch BUY";
            
            // Try different filling modes based on broker support
            int filling_modes = (int)SymbolInfoInteger(_Symbol, SYMBOL_FILLING_MODE);
            if((filling_modes & SYMBOL_FILLING_FOK) != 0)
                request.type_filling = ORDER_FILLING_FOK;
            else if((filling_modes & SYMBOL_FILLING_IOC) != 0)
                request.type_filling = ORDER_FILLING_IOC;
            else
                request.type_filling = ORDER_FILLING_RETURN;  // Default fallback
            
            // --- COMPREHENSIVE DEBUG: Log entire trade request ---
            PrintFormat("[DEBUG] TRADE REQUEST:");
            PrintFormat("  Action: %d | Symbol: %s | Volume: %.4f", request.action, request.symbol, request.volume);
            PrintFormat("  Type: %d | Price: %.5f | SL: %.5f | TP: %.5f", request.type, request.price, request.sl, request.tp);
