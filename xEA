//+------------------------------------------------------------------+
//| Update ROC Recovery Ready State                                  |
//+------------------------------------------------------------------+
void UpdateROCRecoveryReadyState()
{
   if(!InpROCRecoveryConfirmationEnabled) return;
   
   datetime current_time = iTime(_Symbol, _Period, 0);
   
   // Skip if we already checked on this bar
   if(current_time == g_roc_recovery_last_check_time)
      return;
   
   g_roc_recovery_last_check_time = current_time;
   
   // Need at least 2 bars for ROC calculation
   if(Bars(_Symbol, _Period) < InpROCLength + 1)
      return;
   
   if(g_roc_handle == INVALID_HANDLE)
   {
      PrintFormat("ROC Recovery: Handle not initialized");
      return;
   }
   
   double roc_buffer[2];
   if(CopyBuffer(g_roc_handle, 0, 0, 2, roc_buffer) <= 0)
   {
      PrintFormat("ROC Recovery: Failed to copy ROC buffer");
      return;
   }
   
   double current_roc = roc_buffer[0];
   double previous_roc = roc_buffer[1];
   
   // Convert momentum indicator to ROC percentage
   // ROC = ((Current Price - Price N periods ago) / Price N periods ago) * 100
   // Momentum indicator returns (Current Price / Price N periods ago) * 100
   // So ROC = Momentum - 100
   current_roc = current_roc - 100.0;
   previous_roc = previous_roc - 100.0;
   
   // Check for BUY condition: ROC crosses above 0 or is positive
   if(current_roc > 0.0 && !g_roc_recovery_buy_ready)
   {
      g_roc_recovery_buy_ready = true;
      PrintFormat("ROC BUY recovery ready: ROC = %.4f (crossed above 0)", current_roc);
   }
   
   // Check for SELL condition: ROC crosses below 0 or is negative  
   if(current_roc < 0.0 && !g_roc_recovery_sell_ready)
   {
      g_roc_recovery_sell_ready = true;
      PrintFormat("ROC SELL recovery ready: ROC = %.4f (crossed below 0)", current_roc);
   }
   
   // Store current value for next comparison
   g_roc_prev_value = current_roc;
}

//+------------------------------------------------------------------+
//| Check if Volume confirms BUY recovery                            |
//| Conditions: Current candle volume < Previous candle volume       |
//|             Current candle close < Synthetic SL (loss area)      |
//| ONE recovery trade per unique volume pattern (per candle)        |
//| WAITS FOR CANDLE CLOSE - checks bar 1 vs bar 2                  |
//+------------------------------------------------------------------+
bool IsVolumeConfirmingBuyRecovery(double synthetic_sl)
{
   if(!InpVolumeRecoveryConfirmationEnabled)
      return true;
   
   // Get current bar time
   datetime current_bar_time = iTime(_Symbol, _Period, 0);
   
   // Check if we've already triggered recovery on this bar
   if(ExtVolumeRecoveryTracker.last_volume_recovery_bar == current_bar_time && 
      ExtVolumeRecoveryTracker.volume_recovery_triggered)
   {
      // Same bar where we already triggered recovery - don't trigger again
      return false;
   }
   
   // Get volumes using CopyTickVolume - check CLOSED candles only
   // Bar 0 = forming, Bar 1 = just closed, Bar 2 = previous closed
   long volumes[4];
   if(CopyTickVolume(_Symbol, _Period, 0, 4, volumes) < 4)
   {
      PrintFormat("Volume Recovery: Failed to get volume data. Error: %d", GetLastError());
      return false;
   }
   
   long just_closed_volume = volumes[1];   // Bar 1 (just closed)
   long prev_closed_volume = volumes[2];   // Bar 2 (previous closed)
   
   // Get CLOSED candle close price (bar 1), not forming candle (bar 0)
   double just_closed_price = iClose(_Symbol, _Period, 1);
   
   // Check volume condition: just-closed candle volume < previous candle volume
   bool volume_decreasing = just_closed_volume < prev_closed_volume;
   
   if(!InpVolumeRequireDecrease)
   {
      volume_decreasing = true;  // Skip volume check if not required
   }
   
   // Check price condition: for BUY recovery, price should be below synthetic SL
   // (in the loss area, indicating weakness/selling)
   bool price_below_sl = false;
   if(InpVolumePriceBelow)
   {
      price_below_sl = just_closed_price < synthetic_sl;
   }
   else
   {
      price_below_sl = true;  // Skip price check if not required
   }
   
   bool confirmed = volume_decreasing && price_below_sl;
   
   if(confirmed)
   {
      // Mark that recovery was triggered on this bar
      ExtVolumeRecoveryTracker.last_volume_recovery_bar = current_bar_time;
      ExtVolumeRecoveryTracker.volume_recovery_triggered = true;
      
      if(!g_is_backtesting)
      {
         PrintFormat("Volume Recovery BUY: CONFIRMED (Closed Bar %s) - JustClosedVol=%lld < PrevClosedVol=%lld, ClosedPrice=%.5f < SyntheticSL=%.5f", 
                     TimeToString(iTime(_Symbol, _Period, 1)), just_closed_volume, prev_closed_volume, just_closed_price, synthetic_sl);
      }
   }
   
   return confirmed;
}

