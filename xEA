double GDPanelTradeLagPercent(const GDPanelClosedTrade &trade, bool &has_lag)
{
   has_lag = false;
   if(trade.net > 0.005)
   {
      if(InpGlobalDollarPanelPlannedWinMoney <= 0.0)
         return 0.0;
      has_lag = true;
      return 100.0 * (InpGlobalDollarPanelPlannedWinMoney - trade.net) / InpGlobalDollarPanelPlannedWinMoney;
   }

   if(trade.net < -0.005)
   {
      if(InpGlobalDollarPanelPlannedLossMoney <= 0.0)
         return 0.0;
      has_lag = true;
      return 100.0 * (MathAbs(trade.net) - InpGlobalDollarPanelPlannedLossMoney) / InpGlobalDollarPanelPlannedLossMoney;
   }

   return 0.0;
}

string GDPanelTradeLine(const GDPanelClosedTrade &trade)
{
   MqlDateTime parts;
   TimeToStruct(trade.close_time, parts);
   string side = (trade.type == DEAL_TYPE_BUY ? "BUY " : (trade.type == DEAL_TYPE_SELL ? "SELL" : "    "));
   bool has_lag = false;
   double lag = GDPanelTradeLagPercent(trade, has_lag);
   string lag_text = (has_lag ? GDPanelSignedPercent(lag) : "--");
   return StringFormat("%02d/%02d %02d:%02d   %-8s %-4s   %-14s Lag %s",
                       parts.mon, parts.day, parts.hour, parts.min,
                       trade.symbol, side, GDPanelSignedMoney(trade.net), lag_text);
}

void GDPanelRecentLosingTradeStats(const GDPanelClosedTrade &trades[], int sample_size, double &average_loss, int &sample_count)
{
   average_loss = 0.0;
   sample_count = 0;
   int count = ArraySize(trades);
   for(int i = 0; i < count && sample_count < sample_size; i++)
   {
      if(trades[i].net >= -0.005)
         continue;
      average_loss += MathAbs(trades[i].net);
      sample_count++;
   }
   if(sample_count > 0)
      average_loss /= sample_count;
}

void GDPanelSpreadCostLagStats(const GDPanelClosedTrade &trades[],
                               double &average_lag,
                               double &average_win_lag,
                               double &average_loss_lag,
                               double &qualified_net,
                               int &sample_count,
                               int &win_sample_count,
                               int &loss_sample_count)
{
   average_lag = 0.0;
   average_win_lag = 0.0;
   average_loss_lag = 0.0;
   qualified_net = 0.0;
   sample_count = 0;
   win_sample_count = 0;
   loss_sample_count = 0;

   int count = ArraySize(trades);
   double qualify_percent = MathMax(0.0, InpGlobalDollarPanelLagQualificationPercent) / 100.0;
   for(int i = 0; i < count; i++)
   {
      double lag = 0.0;
      if(trades[i].net > 0.005)
      {
         if(InpGlobalDollarPanelPlannedWinMoney <= 0.0)
            continue;
         if(trades[i].net < InpGlobalDollarPanelPlannedWinMoney * qualify_percent)
            continue;

         lag = 100.0 * (InpGlobalDollarPanelPlannedWinMoney - trades[i].net) / InpGlobalDollarPanelPlannedWinMoney;
         average_win_lag += lag;
         win_sample_count++;
      }
      else if(trades[i].net < -0.005)
      {
         if(InpGlobalDollarPanelPlannedLossMoney <= 0.0)
            continue;
         if(MathAbs(trades[i].net) < InpGlobalDollarPanelPlannedLossMoney * qualify_percent)
            continue;

         lag = 100.0 * (MathAbs(trades[i].net) - InpGlobalDollarPanelPlannedLossMoney) / InpGlobalDollarPanelPlannedLossMoney;
         average_loss_lag += lag;
         loss_sample_count++;
      }
      else
         continue;

      average_lag += lag;
      qualified_net += trades[i].net;
      sample_count++;
   }

   if(win_sample_count > 0)
      average_win_lag /= win_sample_count;
   if(loss_sample_count > 0)
      average_loss_lag /= loss_sample_count;
   if(sample_count > 0)
      average_lag /= sample_count;
}

void GDPanelUpdateDashboard()
{
   if(!InpGlobalDollarExitEnabled || !InpGlobalDollarShowPanel)
   {
      GDPanelDeleteDashboard();
      return;
   }

   if(!g_gdPanelObjectsCreated)
      GDPanelCreateDashboard();

   GDPanelLoadOrResetDailyState();

   datetime now = TimeCurrent();
   GDPanelClosedTrade trades[];
   int count = GDPanelBuildClosedTrades(0, now, trades);
   GDPanelSortTradesByCloseTimeDesc(trades);

   int wins = 0;
   int losses = 0;
   int breakevens = 0;
   double gross_profit = 0.0;
   double gross_loss = 0.0;
   double net_profit = 0.0;
   for(int i = 0; i < count; i++)
   {
      net_profit += trades[i].net;
      if(MathAbs(trades[i].net) < 0.005)
         breakevens++;
      else if(trades[i].net > 0.0)
      {
         wins++;
         gross_profit += trades[i].net;
      }
      else
      {
         losses++;
         gross_loss += MathAbs(trades[i].net);
      }
   }

   int decisive = wins + losses;
   double win_rate = (decisive > 0 ? 100.0 * wins / decisive : 0.0);
   double avg_win = (wins > 0 ? gross_profit / wins : 0.0);
   double avg_loss = (losses > 0 ? gross_loss / losses : 0.0);
   double ev = (decisive > 0 ? (gross_profit - gross_loss) / decisive : 0.0);
   double average_rr = (avg_loss > 0.0 ? avg_win / avg_loss : 0.0);
   double profit_factor = (gross_loss > 0.0 ? gross_profit / gross_loss : (gross_profit > 0.0 ? 999.0 : 0.0));

   GDPanelClosedTrade asc[];
   ArrayResize(asc, count);
   for(int a = 0; a < count; a++)
      asc[a] = trades[a];
   GDPanelSortTradesByCloseTimeAsc(asc);
   double curve = InpGlobalDollarPanelStartingBalance;
   double peak = InpGlobalDollarPanelStartingBalance;
   double max_realized_dd = 0.0;
   for(int c = 0; c < ArraySize(asc); c++)
   {
      curve += asc[c].net;
      if(curve > peak)
         peak = curve;
      double dd = peak - curve;
      if(dd > max_realized_dd)
         max_realized_dd = dd;
   }

   double account_balance_peak = InpGlobalDollarPanelStartingBalance;
   if(InpGlobalDollarPanelMaxDrawdownFloorMode == MAX_DD_TRAILING_BALANCE_PEAK || InpGlobalDollarPanelMaxDrawdownFloorMode == MAX_DD_TRAILING_EQUITY_PEAK)
   {
      GDPanelClosedTrade account_trades[];
      int account_count = GDPanelBuildClosedTrades(0, now, account_trades, false);
      GDPanelSortTradesByCloseTimeAsc(account_trades);
      double account_curve = InpGlobalDollarPanelStartingBalance;
      for(int p = 0; p < account_count; p++)
      {
         account_curve += account_trades[p].net;
         if(account_curve > account_balance_peak)
            account_balance_peak = account_curve;
      }
   }

   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double floating = AccountInfoDouble(ACCOUNT_PROFIT);

   if(g_gdPanelEquityPeak <= 0.0)
   {
      if(GlobalVariableCheck(GDPanelEquityPeakKey()))
         g_gdPanelEquityPeak = GlobalVariableGet(GDPanelEquityPeakKey());
      else
         g_gdPanelEquityPeak = InpGlobalDollarPanelStartingBalance;
   }

   if(equity > g_gdPanelEquityPeak)
   {
      g_gdPanelEquityPeak = equity;
      GlobalVariableSet(GDPanelEquityPeakKey(), g_gdPanelEquityPeak);
   }

   double total_baseline = InpGlobalDollarPanelStartingBalance;
   if(InpGlobalDollarPanelMaxDrawdownFloorMode == MAX_DD_TRAILING_BALANCE_PEAK)
      total_baseline = MathMax(InpGlobalDollarPanelStartingBalance, account_balance_peak);
   else if(InpGlobalDollarPanelMaxDrawdownFloorMode == MAX_DD_TRAILING_EQUITY_PEAK)
      total_baseline = MathMax(MathMax(InpGlobalDollarPanelStartingBalance, account_balance_peak), g_gdPanelEquityPeak);

   double total_limit_money = GDPanelDrawdownLimitMoney(InpGlobalDollarPanelMaxDrawdownLimitMode, InpGlobalDollarPanelMaxTotalDrawdownValue, total_baseline);
   double daily_limit_money = GDPanelDrawdownLimitMoney(InpGlobalDollarPanelDailyDrawdownLimitMode, InpGlobalDollarPanelMaxDailyDrawdownValue, g_gdPanelDailyStartEquity);
   double total_floor = total_baseline - total_limit_money;
   double daily_floor = g_gdPanelDailyStartEquity - daily_limit_money;
   double total_dd_left = equity - total_floor;
   double daily_dd_left = equity - daily_floor;
   double target_left = MathMax(0.0, InpGlobalDollarPanelTargetEquity - equity);
   double daily_used = MathMax(0.0, g_gdPanelDailyStartEquity - MathMin(equity, g_gdPanelDailyMinEquity));

   double recent_avg_loss = 0.0;
   int recent_loss_count = 0;
   GDPanelRecentLosingTradeStats(trades, 5, recent_avg_loss, recent_loss_count);
   int losses_left_today = (recent_avg_loss > 0.0 ? (int)MathFloor(MathMax(0.0, daily_dd_left) / recent_avg_loss) : -1);
   string losses_left_text = (recent_loss_count > 0 ? (string)losses_left_today : "--");
   string avg_loss_text = (recent_loss_count > 0 ? GDPanelMoney(recent_avg_loss) : "--");
   double planned_loss_money = MathAbs(InpGlobalDollarPanelPlannedLossMoney);
   int planned_loss_trades_left = (planned_loss_money > 0.0 ? (int)MathFloor(MathMax(0.0, daily_dd_left) / planned_loss_money) : -1);
   string planned_loss_trades_left_text = (planned_loss_trades_left >= 0 ? (string)planned_loss_trades_left : "--");

   double spread_cost_lag = 0.0;
   double win_lag = 0.0;
