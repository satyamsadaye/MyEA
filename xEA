//+------------------------------------------------------------------+
//| Check for one-sided trend and close all trades if needed        |
//+------------------------------------------------------------------+
void CheckTrendProtection()
{
    if(!InpTrendProtectionEnabled) return;
    
    // Only check when multi-order recovery is enabled and we have active groups
    if(!InpMultiOrderEnabled || ArraySize(MultiOrderGroups) == 0) return;
    
    // Safety check for valid percentage
    if(InpTrendProtectionPercent <= 0.0 || InpTrendProtectionPercent > 100.0)
    {
        static bool warning_shown = false;
        if(!warning_shown)
        {
            PrintFormat("TREND PROTECTION: Invalid percentage %.2f%%. Must be between 0.1 and 100.0. Feature disabled.", 
                       InpTrendProtectionPercent);
            warning_shown = true;
        }
        return;
    }
    
    for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
    {
        // Skip inactive groups or groups with only main trade
        if(!MultiOrderGroups[i].activated || MultiOrderGroups[i].ticket_count < 2) continue;
        
        // Check if main trade still exists
        if(!PositionSelectByTicket(MultiOrderGroups[i].base_ticket)) continue;
        
        double main_entry = MultiOrderGroups[i].original_entry;
        double furthest_distance_percent = 0.0;
        double furthest_entry_price = 0.0;
        ulong furthest_ticket = 0;
        int recovery_positions = 0;
        string position_type_str = (MultiOrderGroups[i].type == POSITION_TYPE_BUY) ? "BUY" : "SELL";
        
        // Find the furthest recovery trade from main entry
        for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
        {
            ulong ticket = MultiOrderGroups[i].tickets[j];
            if(ticket == MultiOrderGroups[i].base_ticket) continue; // Skip main trade
            
            if(PositionSelectByTicket(ticket))
            {
                recovery_positions++;
                double recovery_entry = PositionGetDouble(POSITION_PRICE_OPEN);
                
                // Calculate percentage distance from main entry
                double distance_percent = MathAbs(recovery_entry - main_entry) / main_entry * 100.0;
                
                if(distance_percent > furthest_distance_percent)
                {
                    furthest_distance_percent = distance_percent;
                    furthest_entry_price = recovery_entry;
                    furthest_ticket = ticket;
                }
            }
        }
        
        // Only proceed if we have recovery positions
        if(recovery_positions == 0) continue;
        
        // Log information if enabled
        if(InpTrendProtectionLogInfo)
        {
            static datetime last_log_time = 0;
            if(TimeCurrent() - last_log_time >= 60) // Log every minute
            {
                PrintFormat("TREND PROTECTION: %s Group %d - Main #%d: %.5f, Furthest Recovery #%d: %.5f, Distance: %.2f%% (Limit: %.2f%%)",
                           position_type_str, i+1, MultiOrderGroups[i].base_ticket, main_entry, furthest_ticket, furthest_entry_price, 
                           furthest_distance_percent, InpTrendProtectionPercent);
                last_log_time = TimeCurrent();
            }
        }
        
        // Check if distance exceeds threshold
        if(furthest_distance_percent >= InpTrendProtectionPercent)
        {
            PrintFormat("🚨 TREND PROTECTION TRIGGERED! 🚨");
            PrintFormat("Main %s trade #%d at %.5f, furthest recovery #%d at %.5f", 
                       position_type_str, MultiOrderGroups[i].base_ticket, main_entry, furthest_ticket, furthest_entry_price);
            PrintFormat("Distance: %.2f%% > %.2f%% limit - Strong one-sided trend detected!", 
                       furthest_distance_percent, InpTrendProtectionPercent);
            PrintFormat("Closing %d positions in group to accept loss and prevent further damage", MultiOrderGroups[i].ticket_count);
            
            // Close all positions in this group
            CloseAllPositionsInGroup(MultiOrderGroups[i]);
            
            // VALIDATION: Check if all positions were closed successfully
            Sleep(400);
            ValidateGroupClosure(MultiOrderGroups[i], "Trend Protection");
            
            // Clean up chart objects for this group
            CleanupGroupChartObjects(MultiOrderGroups[i]);
            
            // Mark as closed due to trend protection
            MultiOrderGroups[i].close_reason = "trend_protection";
            
            PrintFormat("✅ TREND PROTECTION: Emergency exit completed for group with base ticket #%d", MultiOrderGroups[i].base_ticket);
            PrintFormat("💡 Tip: Consider adjusting your strategy for trending markets or increase the protection percentage");
        }
    }
}

//+------------------------------------------------------------------+
//| Check if we should allow additional position despite max reached |
//+------------------------------------------------------------------+
bool ShouldAllowAdditionalPosition()
{
    // If feature is not enabled, don't allow additional positions
    if(!InpAllowSecondPositionOnLoss)
        return false;
        
    // Get current position count
    int ea_positions = CountPositionsWithMagicNumber();
    
    // If we already have 2 positions, don't allow any more regardless of loss
    if(ea_positions >= 2)
        return false;
        
    // If we have no positions, no need to check
    if(ea_positions == 0)
        return false;
        
    // At this point, we have exactly 1 position and need to check if it's in loss by 0.5R
    bool found_losing_position = false;
    
    int total_positions = PositionsTotal();
    for(int i = 0; i < total_positions; i++)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket == 0) continue;
        
        if(!PositionSelectByTicket(ticket)) continue;
        
        // Only check positions with our magic number
        if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber)
            continue;
            
        string symbol = PositionGetString(POSITION_SYMBOL);
        double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
        double current_price = PositionGetDouble(POSITION_PRICE_CURRENT);
        double sl_price = PositionGetDouble(POSITION_SL);
        
        // Skip if no stop loss
        if(sl_price == 0) continue;
        
        ENUM_POSITION_TYPE position_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
        
        // Calculate risk in points
        double risk_distance = MathAbs(entry_price - sl_price);
        
        // Calculate current loss in points
        double current_loss = 0;
        if(position_type == POSITION_TYPE_BUY)
        {
            current_loss = entry_price - current_price; // Negative if profit, positive if loss
        }
        else
        {
            current_loss = current_price - entry_price; // Negative if profit, positive if loss
        }
        
        // If loss is greater than 0.5 times the risk (0.5R), allow additional position
        if(current_loss > 0 && current_loss >= (risk_distance * 0.5))
        {
            PrintFormat("Position #%d is in loss by %.2fR. Allowing ONE additional position (max 2 total).",
                      ticket, current_loss/risk_distance);
            found_losing_position = true;
            break;
        }
    }
    
    g_positionInLoss = found_losing_position;
    return found_losing_position;
}

