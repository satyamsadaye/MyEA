            PrintFormat("  Comment: %s", request.comment);
            PrintFormat("  Supported filling modes: %d (FOK=%s, IOC=%s)", filling_modes, 
                       ((filling_modes & SYMBOL_FILLING_FOK) != 0) ? "YES" : "NO",
                       ((filling_modes & SYMBOL_FILLING_IOC) != 0) ? "YES" : "NO");
            
            // Check symbol trading mode and session
            bool trading_allowed = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_MODE) == SYMBOL_TRADE_MODE_FULL;
            bool session_active = SymbolInfoInteger(_Symbol, SYMBOL_SESSION_DEALS) > 0;
            PrintFormat("[DEBUG] Trading allowed: %s | Session active: %s", trading_allowed ? "YES" : "NO", session_active ? "YES" : "NO");
            
