bool QueuePattern9RecoveryOpenTrigger(MultiOrderGroup &group, int attempts_before_open, string ohlc_level_key)
{
   if(group.base_ticket == 0)
      return false;

   double bar_open = iOpen(group.symbol, _Period, 0);
   if(bar_open <= 0.0)
   {
      if(!g_is_backtesting)
      {
         PrintFormat("Pattern 9 Recovery: Unable to read current candle open for group #%d. Falling back to immediate recovery entry.",
                     group.base_ticket);
      }
      return false;
   }

   int idx = FindPattern9RecoveryOpenTriggerIndex(group.base_ticket, true);
   g_pattern9RecoveryOpenTriggers[idx].symbol = group.symbol;
   g_pattern9RecoveryOpenTriggers[idx].pending_bar_time = iTime(group.symbol, _Period, 0);
   g_pattern9RecoveryOpenTriggers[idx].bar_open = bar_open;
   g_pattern9RecoveryOpenTriggers[idx].trigger_percent = MathMax(0.0, InpPattern9RecoveryOpenPriceTriggerPercent);
   g_pattern9RecoveryOpenTriggers[idx].order_type = DetermineRecoveryOrderType(group);
   g_pattern9RecoveryOpenTriggers[idx].pending = true;
   g_pattern9RecoveryOpenTriggers[idx].attempts_before_open = attempts_before_open;

   if(InpOHLCLevelRecoveryConfirmationEnabled && ohlc_level_key != "")
      TrackPendingOHLCRecoveryLevel(group.base_ticket, ohlc_level_key);

   double target_price = (g_pattern9RecoveryOpenTriggers[idx].order_type == ORDER_TYPE_BUY) ?
                         bar_open * (1.0 + g_pattern9RecoveryOpenTriggers[idx].trigger_percent / 100.0) :
                         bar_open * (1.0 - g_pattern9RecoveryOpenTriggers[idx].trigger_percent / 100.0);

   PrintFormat("Pattern 9 Recovery: Open trigger armed for group #%d (%s). Waiting for %.2f%% move from %.5f to %.5f before recovery trade.",
               group.base_ticket,
               EnumToString(g_pattern9RecoveryOpenTriggers[idx].order_type),
               g_pattern9RecoveryOpenTriggers[idx].trigger_percent,
               bar_open,
               target_price);

   return true;
}

void ProcessPattern9RecoveryOpenTriggers()
{
   if(!InpMultiOrderEnabled || !InpPattern9RecoveryConfirmationEnabled || !InpPattern9RecoveryUseOpenPriceTrigger)
      return;

   for(int i = ArraySize(g_pattern9RecoveryOpenTriggers) - 1; i >= 0; i--)
   {
      if(!g_pattern9RecoveryOpenTriggers[i].pending)
         continue;

      ulong base_ticket = g_pattern9RecoveryOpenTriggers[i].base_ticket;
      int group_idx = FindMultiOrderGroupIndexByTicket(base_ticket);
      if(group_idx < 0)
      {
         ResetPattern9RecoveryOpenTrigger(base_ticket);
         continue;
      }

      string symbol = g_pattern9RecoveryOpenTriggers[i].symbol;
      if(symbol == "")
         symbol = MultiOrderGroups[group_idx].symbol;

      datetime current_bar_time = iTime(symbol, _Period, 0);
      if(current_bar_time == 0)
         continue;

      if(current_bar_time != g_pattern9RecoveryOpenTriggers[i].pending_bar_time)
      {
         if(!g_is_backtesting)
         {
            PrintFormat("Pattern 9 Recovery: Open trigger expired for group #%d (bar advanced). Resetting trigger.", base_ticket);
         }
         if(InpOHLCLevelRecoveryConfirmationEnabled)
            CommitPendingOHLCRecoveryLevel(base_ticket, false);
         ResetPattern9RecoveryOpenTrigger(base_ticket);
         continue;
      }

      double trigger_price = (g_pattern9RecoveryOpenTriggers[i].order_type == ORDER_TYPE_BUY) ?
                             g_pattern9RecoveryOpenTriggers[i].bar_open * (1.0 + g_pattern9RecoveryOpenTriggers[i].trigger_percent / 100.0) :
                             g_pattern9RecoveryOpenTriggers[i].bar_open * (1.0 - g_pattern9RecoveryOpenTriggers[i].trigger_percent / 100.0);

      double current_price = (g_pattern9RecoveryOpenTriggers[i].order_type == ORDER_TYPE_BUY) ?
                             SymbolInfoDouble(symbol, SYMBOL_ASK) :
                             SymbolInfoDouble(symbol, SYMBOL_BID);

      if(current_price == 0)
         continue;

      bool triggered = (g_pattern9RecoveryOpenTriggers[i].order_type == ORDER_TYPE_BUY) ?
                       (current_price >= trigger_price) :
                       (current_price <= trigger_price);

      if(!triggered)
         continue;

      if(!g_is_backtesting)
      {
         PrintFormat("Pattern 9 Recovery: Open trigger hit for group #%d (%s). Price %.5f reached target %.5f. Executing recovery.",
                     base_ticket,
                     EnumToString(g_pattern9RecoveryOpenTriggers[i].order_type),
                     current_price,
                     trigger_price);
      }

      int attempts_before_open = g_pattern9RecoveryOpenTriggers[i].attempts_before_open;
      OpenRecoveryPosition(MultiOrderGroups[group_idx]);

      if(InpOHLCLevelRecoveryConfirmationEnabled)
      {
         bool trade_opened = (MultiOrderGroups[group_idx].attempts > attempts_before_open);
         CommitPendingOHLCRecoveryLevel(base_ticket, trade_opened);
      }

      ResetPattern9RecoveryOpenTrigger(base_ticket);
   }
}

