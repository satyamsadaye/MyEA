//+------------------------------------------------------------------+
//| Update the ready state of stochastic RSI triggers                |
//+------------------------------------------------------------------+
void UpdateStochasticRSIReadyState()
{
   double k_value, d_value;
   if(!GetStochasticRSIValues(k_value, d_value))
      return;
      
   // Track state changes for better logging
   static bool logged_buy_ready = true;
   static bool logged_sell_ready = true;
   static double last_k_value = -1;
   
   // Show comprehensive state on K value changes
   if(MathAbs(k_value - last_k_value) > 0.5) // Log when K changes significantly
   {
      PrintFormat("🎯 STOCH RSI STATE: K=%.1f | BUY Ready=%s (Reset@%.1f) | SELL Ready=%s (Reset@%.1f)", 
                  k_value, 
                  g_stochastic_buy_ready ? "✅" : "🔒", InpStochRSIBuyResetLevel,
                  g_stochastic_sell_ready ? "✅" : "🔒", InpStochRSIResetLevel);
      last_k_value = k_value;
   }
      
   // Update BUY ready state - becomes ready when stochastic goes ABOVE the reset level
   bool old_buy_ready = g_stochastic_buy_ready;
   if(!g_stochastic_buy_ready && k_value > InpStochRSIBuyResetLevel)
   {
      g_stochastic_buy_ready = true;
      PrintFormat("🔓 BUY RE-ARMED: K(%.1f) crossed above %.1f → BUY recovery available when K<%.1f", 
                  k_value, InpStochRSIBuyResetLevel, InpStochRSILowLevel);
      logged_buy_ready = false; // Allow next lock message
   }
   
   // Log when BUY becomes locked (only once per lock cycle)
   if(g_stochastic_buy_ready != logged_buy_ready && !g_stochastic_buy_ready)
   {
      PrintFormat("🔒 BUY LOCKED: Recovery blocked until K > %.1f", InpStochRSIBuyResetLevel);
      logged_buy_ready = g_stochastic_buy_ready;
   }
   
   // Update SELL ready state - becomes ready when stochastic goes BELOW the reset level
   bool old_sell_ready = g_stochastic_sell_ready;
   if(!g_stochastic_sell_ready && k_value < InpStochRSIResetLevel)
   {
      g_stochastic_sell_ready = true;
      PrintFormat("🔓 SELL RE-ARMED: K(%.1f) crossed below %.1f → SELL recovery available when K>%.1f", 
                  k_value, InpStochRSIResetLevel, InpStochRSIHighLevel);
      logged_sell_ready = false; // Allow next lock message
   }
   
   // Log when SELL becomes locked (only once per lock cycle)
   if(g_stochastic_sell_ready != logged_sell_ready && !g_stochastic_sell_ready)
   {
      PrintFormat("🔒 SELL LOCKED: Recovery blocked until K < %.1f", InpStochRSIResetLevel);
      logged_sell_ready = g_stochastic_sell_ready;
   }
   
   // CRITICAL DEBUG: Log any unexpected state changes
   if(old_buy_ready != g_stochastic_buy_ready || old_sell_ready != g_stochastic_sell_ready)
   {
      PrintFormat("⚠️ STATE CHANGE DETECTED: BUY %s→%s | SELL %s→%s at K=%.1f", 
                  old_buy_ready ? "Ready" : "Locked", g_stochastic_buy_ready ? "Ready" : "Locked",
                  old_sell_ready ? "Ready" : "Locked", g_stochastic_sell_ready ? "Ready" : "Locked",
                  k_value);
   }
}

//+------------------------------------------------------------------+
//| Check if Stochastic RSI confirms BUY recovery                    |
//+------------------------------------------------------------------+
bool IsStochasticRSIConfirmingBuy()
{
   if(!InpStochRSIConfirmationEnabled)
      return true;
      
   // CRITICAL DEBUG: Track function calls
   static int call_count = 0;
   static bool last_ready_state = true;
   call_count++;
   
   // Get current values BEFORE updating state
   double k_value, d_value;
   if(!GetStochasticRSIValues(k_value, d_value))
      return false;
   
   // Store the ready state before any updates
   bool ready_before_update = g_stochastic_buy_ready;
   
   // AGGRESSIVE STATE PROTECTION: Detect unexpected ready state changes
   if(last_ready_state && !g_stochastic_buy_ready && k_value < InpStochRSIBuyResetLevel)
   {
      PrintFormat("🚨 CRITICAL: BUY ready state was CORRUPTED! Was=true, Now=false at K=%.1f", k_value);
      PrintFormat("🔧 FORCING ready state back to TRUE (protection mechanism)");
      g_stochastic_buy_ready = true; // Force it back to true
   }
   
   // Update ONLY the BUY ready state (prevent cross-contamination)
   if(!g_stochastic_buy_ready && k_value > InpStochRSIBuyResetLevel)
   {
      g_stochastic_buy_ready = true;
      PrintFormat("🔓 BUY RE-ARMED: K(%.1f) crossed above %.1f → BUY recovery available when K<%.1f", 
                  k_value, InpStochRSIBuyResetLevel, InpStochRSILowLevel);
   }
   
   // Track significant state changes
   if(g_stochastic_buy_ready != last_ready_state)
   {
      PrintFormat("🔄 BUY READY STATE CHANGE: %s → %s at K=%.1f (Check #%d)", 
                  last_ready_state ? "TRUE" : "FALSE",
                  g_stochastic_buy_ready ? "TRUE" : "FALSE",
                  k_value, call_count);
   }
   
   // Enhanced logging - show every check with clear status
   static double last_logged_k = -1;
   bool state_changed = (MathAbs(k_value - last_logged_k) > 0.5) || (g_stochastic_buy_ready != last_ready_state);
   
   if(state_changed)
   {
      PrintFormat("📊 BUY CHECK #%d: K=%.1f | Trigger<%.1f | Reset>%.1f | Ready=%s", 
                  call_count, k_value, InpStochRSILowLevel, InpStochRSIBuyResetLevel, 
                  g_stochastic_buy_ready ? "✅" : "❌");
      
      if(k_value <= InpStochRSILowLevel && g_stochastic_buy_ready)
         PrintFormat("🚨 CONDITIONS MET: K(%.1f)≤%.1f + Ready=true → Should trigger!", k_value, InpStochRSILowLevel);
      else if(k_value <= InpStochRSILowLevel && !g_stochastic_buy_ready)
         PrintFormat("🔒 BLOCKED: K(%.1f)≤%.1f but Ready=false", k_value, InpStochRSILowLevel);
      else if(g_stochastic_buy_ready)
         PrintFormat("⏳ WAITING: Ready=true but K(%.1f)>%.1f", k_value, InpStochRSILowLevel);
         
      last_logged_k = k_value;
   }
   
   // Critical debug: Check for unexpected ready state changes
   if(ready_before_update && !g_stochastic_buy_ready && k_value < InpStochRSIBuyResetLevel)
   {
      PrintFormat("⚠️ BUY READY STATE CORRUPTION: Was Ready=true, now Ready=false at K=%.1f (should only reset after trigger or K>%.1f)", 
                  k_value, InpStochRSIBuyResetLevel);
   }
   
   // For BUY, we need to be "ready" (previously crossed above the reset level)
   // AND current value needs to be below the low threshold   
   bool confirmed = g_stochastic_buy_ready && (k_value < InpStochRSILowLevel);
   
   // If confirmed, mark as "not ready" until it goes above reset level again
   if(confirmed)
   {
      g_stochastic_buy_ready = false;
      PrintFormat("🚀 BUY RECOVERY TRIGGERED! K(%.1f)<%.1f + Ready was true → Opening recovery trade", 
                 k_value, InpStochRSILowLevel);
      PrintFormat("🔒 BUY state locked until K crosses above %.1f again", InpStochRSIBuyResetLevel);
   }
   
   // Update state tracking
   last_ready_state = g_stochastic_buy_ready;
   
   return confirmed;
}

