                }
                else
                {
                    PrintFormat("Pattern 8: Failed to place %s order. Error: %d", 
                               (final_order_type == ORDER_TYPE_BUY) ? "BUY" : "SELL", GetLastError());
                }
            }
            else
            {
                PrintFormat("[DEV MODE] Pattern 8: Would place %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (GREEN→%dRED HA)",
                           (final_order_type == ORDER_TYPE_BUY) ? "BUY" : "SELL",
                           entryPrice, stopLoss, takeProfit, lots, g_p8_consecutiveRed);
            }
            
            // Mark signal as processed
            g_lastSignalTime = current_bar_time;
        }
        else
        {
            if(!g_is_backtesting)
            {
                PrintFormat("Pattern 8: SELL pattern available but %s", 
                           sell_pattern_used ? "already used" : "too soon after last trigger");
            }
        }
    }
    else
    {
        // Reset pattern usage flags when no valid pattern is found
        buy_pattern_used = false;
        sell_pattern_used = false;
        last_buy_pattern_time = 0;
        last_sell_pattern_time = 0;
        
        // Reset signal flags
        g_p8_buySignalReady = false;
        g_p8_sellSignalReady = false;
        
        if(!g_is_backtesting)
        {
            PrintFormat("Pattern 8: No valid patterns found - waiting for setup candle + %d consecutive", 
                       consecutiveCandles);
        }
    }
}
//+------------------------------------------------------------------+
//| Timer function for risk management and display updates           |
//+------------------------------------------------------------------+
void OnTimer()
{
   UpdateGlobalDollarLossStreakPause();
   LogGlobalDollarUtcResetCountdown(false);
   if(IsGlobalDollarLossStreakPauseActive())
      CancelGlobalDollarStopTradingPendingOrders();
   if(IsGlobalDollarDailyDrawdownTradePauseActive())
      CancelGlobalDollarStopTradingPendingOrders();

   // Skip timer updates during backtesting except for essential functions
   if(g_is_backtesting)
   {
      // Only run essential risk management functions during backtesting
      CheckCandleExitConditions();
      if(!InpGlobalDollarExitEnabled)
      {
         ApplyLossProtection();
         ApplyBreakeven();
         ApplyTrailingStop();
      }
      EnforceGlobalDollarStopTrading();
      EnforceGlobalDollarExit();
      
      // Process multi-order recovery and synthetic SL
      if(InpMultiOrderEnabled || InpUseSyntheticSL)
         ProcessMultiOrderRecovery();
         
      // Check for one-sided trends and trigger emergency exit if needed
      CheckTrendProtection();
         
      // Process DCA protection orders
      ProcessDCAGroups();
      
      // Force cleanup any orphan DCA orders
      CleanupOrphanDCAOrders();
      CleanupOrphanRecoveryTrades();
         
      return;
   }
   
   // Run all functions during live trading
   // Check if we've reached max positions for new trades - if so, cancel all pending orders
   int ea_positions = CountPositionsWithMagicNumber();
   bool limit_reached = false;

   if(InpMultiOrderEnabled) {
      if(ea_positions > 0) limit_reached = true;
   } else {
      if(ea_positions >= InpMaxOpenPositions && !ShouldAllowAdditionalPosition()) limit_reached = true;
   }

   if(limit_reached)
   {
      CancelAllPendingOrders();

      // Reset all order tickets
      g_buyStopTicket = 0;
      g_sellStopTicket = 0;
      g_p3_buyStopTicket = 0;
      g_p3_sellStopTicket = 0;
      g_p4_buyStopTicket = 0;
      g_p4_sellStopTicket = 0;
      g_p5_lastBuyTicket = 0;
      g_p5_lastSellTicket = 0;
   }

   // Check if we have more than 2 non-DCA orders - which is the maximum allowed (buy stop and sell stop)
   int totalOrders = OrdersTotal();
   int nonDCAOrders = 0;
   
   // Count only non-DCA orders
   for(int i = 0; i < totalOrders; i++)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket > 0 && OrderSelect(ticket))
      {
         string comment = OrderGetString(ORDER_COMMENT);
         // Skip DCA orders from count
         if(!(StringFind(comment, "DCA") == 0 && StringFind(comment, "-T") > 0 && StringFind(comment, "-M") > 0))
         {
            nonDCAOrders++;
         }
      }
   }
   
   if(nonDCAOrders > 2)
   {
      PrintFormat("Timer detected excess non-DCA orders (%d). Maximum should be 2. Cancelling non-DCA orders.", nonDCAOrders);
      CancelAllPendingOrders();

      // Reset all order tickets
      g_buyStopTicket = 0;
      g_sellStopTicket = 0;
      g_p3_buyStopTicket = 0;
      g_p3_sellStopTicket = 0;
      g_p4_buyStopTicket = 0;
      g_p4_sellStopTicket = 0;
      g_p5_lastBuyTicket = 0;
      g_p5_lastSellTicket = 0;
   }

   // Original timer function code
   CheckCandleExitConditions();
   if(!InpGlobalDollarExitEnabled)
   {
      ApplyLossProtection();
      ApplyBreakeven();
      ApplyTrailingStop();
      ApplyCandleColorTrailing();
      ApplyCandleColorTrailing();
   }
   EnforceGlobalDollarStopTrading();
   EnforceGlobalDollarExit();
   
   // Force cleanup any orphan DCA orders (timer check)
   CleanupOrphanDCAOrders();
   CleanupOrphanRecoveryTrades();
   ValidateDCAGroups();
   ValidateMultiOrderGroups();
   
   // Apply Kill Switch for all positions (closes trades if price moves X times SL in ATR terms)
   if(InpKillSwitchEnabled)
   {
      ApplyKillSwitch();
   }
   
   // Add Multi-Order Recovery monitoring
   if(InpMultiOrderEnabled)
   {
      ProcessMultiOrderRecovery();
      
      // Check for one-sided trends and trigger emergency exit if needed
      CheckTrendProtection();
   }
   
   // Process DCA protection orders
   ProcessDCAGroups();
   
   // Force cleanup any orphan DCA orders
   CleanupOrphanDCAOrders();
   CleanupOrphanRecoveryTrades();
   
   // Clean up orphan chart objects periodically (every 5 minutes)
   static datetime last_chart_cleanup = 0;
   if(TimeCurrent() - last_chart_cleanup >= 300) // 5 minutes
   {
      CleanupOrphanChartObjects();
      last_chart_cleanup = TimeCurrent();
   }
   
   // If no EA positions remain, clean up all chart objects (every 30 seconds check)
   static datetime last_no_positions_check = 0;
   if(TimeCurrent() - last_no_positions_check >= 30) // Check every 30 seconds
   {
      int ea_positions = CountPositionsWithMagicNumber();
      if(ea_positions == 0 && ArraySize(MultiOrderGroups) == 0 && ArraySize(DCAGroups) == 0)
      {
         static bool already_cleaned = false;
         if(!already_cleaned)
         {
            CleanupAllChartObjects();
            already_cleaned = true;
            PrintFormat("No EA positions detected - cleaned up all chart objects");
         }
      }
      else
      {
         static bool already_cleaned = false;
         already_cleaned = false; // Reset the flag when we have positions again
      }
      last_no_positions_check = TimeCurrent();
   }
   
   UpdateChartDisplay();
}


//+------------------------------------------------------------------+
//| Execute Trade                                                    |
//+------------------------------------------------------------------+
void ExecuteTrade(string trade_action)
  {
   if(IsGlobalDollarStopTradingActive())
   {
      PrintFormat("Trade action '%s' blocked because Global Dollar Stop Trading is active: %s",
                  trade_action, g_globalDollarStopTradingReason);
      return;
   }

   // Apply Master Trade Direction Filter
   if ((trade_action == "buy" && InpTradeDirection == TRADE_DIR_SELL_ONLY) ||
       (trade_action == "sell" && InpTradeDirection == TRADE_DIR_BUY_ONLY))
   {
      PrintFormat("Trade action '%s' blocked by Master Trade Direction Filter setting (%s).",
                  trade_action, EnumToString(InpTradeDirection));
      return;
   }

   // Block trading if news or outside trading hours
   if(IsNewsTime() || !IsTradingHour()) {
      Print("Trade blocked due to news or outside trading hours.");
      return;
   }
   // 1. Determine Actual Symbol
   string actual_trade_symbol = _Symbol;

   // 2. Symbol Validation & Info
   MqlTick current_tick;
   if(!SymbolInfoTick(actual_trade_symbol, current_tick))
     {
      PrintFormat("Symbol %s not found, not available in Market Watch, or failed to get tick. Error %d", actual_trade_symbol, GetLastError());
      return;
     }
   int digits = (int)SymbolInfoInteger(actual_trade_symbol, SYMBOL_DIGITS);
   double point_value = SymbolInfoDouble(actual_trade_symbol, SYMBOL_POINT);
   if(point_value == 0) { PrintFormat("Point value for %s is zero. Cannot proceed.", actual_trade_symbol); return; }

   // 3. Get ATR value
   double atr_values[];
   if(CopyBuffer(iATR(actual_trade_symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) <= 0)
   {
       PrintFormat("Could not get ATR value for %s. Error %d", actual_trade_symbol, GetLastError());
       return;
   }
   double calculated_atr = atr_values[0];

   // 4. Determine Entry Price, SL, TP
   double entry_price_basis;
   double order_request_price;
   ENUM_ORDER_TYPE mt5_order_type;

   if(InpOrderExecutionType == ORDER_EXEC_MARKET)
     {
      // Get initial order type based on trade action
      mt5_order_type = (trade_action == "buy") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
      
      // Apply direction filters and reversals
      mt5_order_type = GetFinalOrderType(mt5_order_type);
      
      if(mt5_order_type == WRONG_VALUE)
      {
         PrintFormat("Trade blocked by direction filter. Action: %s, Direction Setting: %s",
                     trade_action, EnumToString(InpTradeDirection));
         return;
      }
      
      // Set price based on final order type
      order_request_price = (mt5_order_type == ORDER_TYPE_BUY) ? 
                           SymbolInfoDouble(actual_trade_symbol, SYMBOL_ASK) :
                           SymbolInfoDouble(actual_trade_symbol, SYMBOL_BID);
      entry_price_basis = order_request_price;
     }
   else // ORDER_EXEC_LIMIT
     {
      // Get initial order type based on trade action
      mt5_order_type = (trade_action == "buy") ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
      
      // Apply direction filters and reversals
      ENUM_ORDER_TYPE base_type = (mt5_order_type == ORDER_TYPE_BUY_LIMIT) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
      base_type = GetFinalOrderType(base_type);
      
      if(base_type == WRONG_VALUE)
      {
         PrintFormat("Trade blocked by direction filter. Action: %s, Direction Setting: %s",
                     trade_action, EnumToString(InpTradeDirection));
         return;
      }
      
      // Convert base type back to limit order type
      mt5_order_type = (base_type == ORDER_TYPE_BUY) ? ORDER_TYPE_BUY_LIMIT : ORDER_TYPE_SELL_LIMIT;
      
      // Set price based on final order type
      order_request_price = (mt5_order_type == ORDER_TYPE_BUY_LIMIT) ? 
                           NormalizeDouble(SymbolInfoDouble(actual_trade_symbol, SYMBOL_BID) - (InpLimitOrderOffsetPoints * point_value), digits) :
                           NormalizeDouble(SymbolInfoDouble(actual_trade_symbol, SYMBOL_ASK) + (InpLimitOrderOffsetPoints * point_value), digits);
      entry_price_basis = order_request_price;
     }

   double sl_price, tp_price;
   
   // Calculate SL and TP using standard ATR multipliers
   if(trade_action == "buy")
   {
      sl_price = NormalizeDouble(entry_price_basis - (calculated_atr * InpAtrMultiplierSL), digits);
      tp_price = NormalizeDouble(entry_price_basis + (calculated_atr * InpAtrMultiplierTP), digits);
   }
   else // sell
   {
      sl_price = NormalizeDouble(entry_price_basis + (calculated_atr * InpAtrMultiplierSL), digits);
      tp_price = NormalizeDouble(entry_price_basis - (calculated_atr * InpAtrMultiplierTP), digits);
   }
   
   // Multi-order recovery settings do not affect original trades
   // They are applied separately in the OpenRecoveryPosition function

   PrintFormat("Prices: EntryBasis=%.*f, OrderReq=%.*f, SL=%.*f, TP=%.*f, ATR=%.*f",
                digits, entry_price_basis, digits, order_request_price, digits, sl_price, digits, tp_price, digits, calculated_atr);

   // 5. Volume Calculation
   double sl_distance_price_abs = MathAbs(entry_price_basis - sl_price);
   if(sl_distance_price_abs < point_value)
     {
      PrintFormat("SL distance (%.*f) is too small. Min is 1 point. ATR was %.*f. Skipping trade.", digits, sl_distance_price_abs, digits, calculated_atr);
      return;
     }

   double tick_value_per_lot = SymbolInfoDouble(actual_trade_symbol, SYMBOL_TRADE_TICK_VALUE);
   if(tick_value_per_lot == 0) { PrintFormat("Tick value for %s is zero. Cannot calculate volume.", actual_trade_symbol); return; }

   double money_lost_at_sl_per_lot = (sl_distance_price_abs / point_value) * tick_value_per_lot;
   if(money_lost_at_sl_per_lot <= 0) { PrintFormat("Calculated loss at SL per lot is %.2f. Cannot calculate volume.", money_lost_at_sl_per_lot); return; }

   // 6. Risk Calculation
   double risk_base_metric = 0;
   string risk_metric_name = "";

   switch(InpRiskCalcMethod)
     {
      case RISK_CALC_STARTING_BALANCE:
         risk_base_metric = g_startingBalance;
         risk_metric_name = "Starting Balance";
         break;
      case RISK_CALC_EQUITY:
         risk_base_metric = AccountInfoDouble(ACCOUNT_EQUITY);
         risk_metric_name = "Current Equity";
         break;
      case RISK_CALC_BALANCE:
         risk_base_metric = AccountInfoDouble(ACCOUNT_BALANCE);
         risk_metric_name = "Current Balance";
         break;
     }

   double risk_amount_for_this_trade = risk_base_metric * (InpRiskPerTradePercentage / 100.0);

   PrintFormat("Risk Calc: Metric=%s (%.2f) * RiskPct (%.2f%%) = Risk Amount (%.2f)",
                risk_metric_name, risk_base_metric, InpRiskPerTradePercentage, risk_amount_for_this_trade);

   double calculated_volume = risk_amount_for_this_trade / money_lost_at_sl_per_lot;

   // Normalize and clamp volume
   double vol_min = GetEffectiveMinLot(actual_trade_symbol);
   double vol_max = GetEffectiveMaxLot(actual_trade_symbol);
   double vol_step = SymbolInfoDouble(actual_trade_symbol, SYMBOL_VOLUME_STEP);

   calculated_volume = MathMax(vol_min, calculated_volume);
   calculated_volume = MathMin(vol_max, calculated_volume);
   if (vol_step > 0) calculated_volume = MathFloor(calculated_volume / vol_step) * vol_step;
   calculated_volume = NormalizeDouble(calculated_volume, 2);

   if(calculated_volume < vol_min || calculated_volume == 0)
     {
      PrintFormat("Calculated volume %.2f is less than min_vol %.2f or zero for %s. Skipping trade.",
                  calculated_volume, vol_min, actual_trade_symbol);
      return;
     }
   PrintFormat("Volume: Calc Vol=%.2f (Min:%.2f, Max:%.2f, Step:%.2f)", calculated_volume, vol_min, vol_max, vol_step);

   if(InpCandleExitEnabled)
     {
      tp_price = 0.0;
      PrintFormat("Candle Exit Mode is ON: Take Profit will not be set for this trade.");
     }

   // 7. Order Placement
   if(InpDevelopmentMode)
     {
      if(InpUseSyntheticSL)
      {
         PrintFormat("[DEV MODE] Would place %s order for %s: Vol=%.2f, Price=%.*f, Synthetic SL=%.*f, TP=%.*f, Magic=%d",
                     EnumToString(mt5_order_type), actual_trade_symbol, calculated_volume,
                     digits, order_request_price, digits, sl_price, digits, tp_price, InpMagicNumber);
      }
      else
      {
         PrintFormat("[DEV MODE] Would place %s order for %s: Vol=%.2f, Price=%.*f, SL=%.*f, TP=%.*f, Magic=%d",
                     EnumToString(mt5_order_type), actual_trade_symbol, calculated_volume,
                     digits, order_request_price, digits, sl_price, digits, tp_price, InpMagicNumber);
      }
      return;
     }

   MqlTradeRequest request;
   MqlTradeResult result;
   ZeroMemory(request);
   ZeroMemory(result);

   request.action   = (InpOrderExecutionType == ORDER_EXEC_MARKET) ? TRADE_ACTION_DEAL : TRADE_ACTION_PENDING;
   request.symbol   = actual_trade_symbol;
   request.volume   = calculated_volume;
   request.type     = mt5_order_type;
   request.price    = order_request_price;
   
   // Global dollar exit replaces these with dollar-based visible SL/TP in SendDollarExitAwareOrder().
   if(!InpGlobalDollarExitEnabled && InpUseSyntheticSL)
      request.sl = 0; // No real SL if using synthetic SL
   else
      request.sl = sl_price; // Use calculated SL

   if(!InpGlobalDollarExitEnabled)
      request.tp = tp_price;
   request.deviation= InpMaxSlippagePoints;
   request.magic    = InpMagicNumber;
   request.comment  = "RohitEA";
   request.type_filling = GetSupportedFillingMode(_Symbol);
   request.type_time    = ORDER_TIME_GTC;

   if(InpUseSyntheticSL)
   {
      PrintFormat("Attempting to send %s order: %s %s, Vol:%.2f, Px:%.*f, Synthetic SL=%.*f, TP=%.*f, Slip:%d, Magic:%d",
                  EnumToString(request.action), EnumToString(request.type), request.symbol, request.volume,
                  digits, request.price, digits, sl_price, digits, tp_price, request.deviation, request.magic);
   }
   else
   {
      PrintFormat("Attempting to send %s order: %s %s, Vol:%.2f, Px:%.*f, SL=%.*f, TP=%.*f, Slip:%d, Magic:%d",
                  EnumToString(request.action), EnumToString(request.type), request.symbol, request.volume,
                  digits, request.price, digits, sl_price, digits, tp_price, request.deviation, request.magic);
   }

   if(!IsSpreadAcceptable()) return;
   if(!SendDollarExitAwareOrder(request, result))
     {
      PrintFormat("OrderSend failed for %s %s. Error code: %d. Retcode: %d. Message: %s",
                  EnumToString(request.type), request.symbol, GetLastError(), result.retcode, result.comment);
     }
   else
     {
      PrintFormat("%s order for %s %.2f lots of %s sent successfully. Order #%d. Retcode: %d. Deal: %d. Price: %.*f",
                  EnumToString(request.type), trade_action, request.volume, request.symbol, result.order,
                  result.retcode, result.deal, digits, result.price);
      
      // Send copy trading signal for immediate market orders
      if(InpOrderExecutionType == ORDER_EXEC_MARKET && result.deal > 0)
      {
         // For market orders, we can send the signal immediately
         ENUM_POSITION_TYPE pos_type = (mt5_order_type == ORDER_TYPE_BUY) ? POSITION_TYPE_BUY : POSITION_TYPE_SELL;
         double actual_entry_price = (result.price > 0) ? result.price : entry_price_basis;
         SendTradeOpenSignal(actual_trade_symbol, pos_type, sl_price, result.order, actual_entry_price);
      }
                  
      // If using synthetic SL and the order was executed successfully, draw the synthetic SL line
      if(InpUseSyntheticSL && result.retcode == TRADE_RETCODE_DONE && result.deal > 0)
      {
         // For market orders, the position is created immediately
         if(InpOrderExecutionType == ORDER_EXEC_MARKET)
         {
            ENUM_POSITION_TYPE position_type = (request.type == ORDER_TYPE_BUY) ? POSITION_TYPE_BUY : POSITION_TYPE_SELL;
            DrawSyntheticSLLine(result.deal, sl_price, position_type);
            PrintFormat("Created synthetic SL line at %.5f for position #%d", sl_price, result.deal);
         }
         // For pending orders, we need to store the SL for when the order is triggered
         else
         {
            PrintFormat("Pending order placed with synthetic SL. SL line will be drawn when order is triggered.");
         }
      }
      
      // Create DCA protection orders for successful market orders
      if(InpOrderExecutionType == ORDER_EXEC_MARKET && result.retcode == TRADE_RETCODE_DONE && result.deal > 0)
      {
         CreateDCAOrders(result.deal);
      }
     }
  }


