void CalculateActivePositionMetrics()
{
   ExtCurrentMaxLoss = 0.0;
   ExtCurrentMaxProfit = 0.0;
   ExtCurrentProfit = 0.0;
   ExtCurrentRRatio = 0.0;
   ExtStaticMaxLoss = 0.0;
   ExtStaticMaxProfit = 0.0;
   ExtStaticRRatio = 0.0;
   ExtLastCalcSymbol = "N/A";
   ExtLastCalcAction = "N/A";
   ExtLastCalcVolume = 0.0;

   int total_positions = PositionsTotal();
   if(total_positions <= 0)
   {
      ExtSignalProcessedForDisplay = false;
      return;
   }

   double total_current_max_loss = 0;
   double total_current_max_profit = 0;
   double total_static_max_loss = 0;
   double total_static_max_profit = 0;
   double total_current_profit = 0;
   string positions_info = "";

   for(int i = 0; i < total_positions; i++)
   {
      if(!PositionSelectByTicket(PositionGetTicket(i)))
         continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      double volume = PositionGetDouble(POSITION_VOLUME);
      double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
      double current_price = PositionGetDouble(POSITION_PRICE_CURRENT);
      double sl = PositionGetDouble(POSITION_SL);
      double tp = PositionGetDouble(POSITION_TP);
      double profit = PositionGetDouble(POSITION_PROFIT);
      ENUM_POSITION_TYPE position_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);

      string position_type_str = (position_type == POSITION_TYPE_BUY) ? "BUY" : "SELL";
      if(i == 0)
      {
         ExtLastCalcSymbol = symbol;
         ExtLastCalcAction = position_type_str;
         ExtLastCalcVolume = volume;
      }
      else
      {
         positions_info += ", " + symbol + " " + position_type_str + " (" + DoubleToString(volume, 2) + ")";
      }

      double tick_value = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);
      double point = SymbolInfoDouble(symbol, SYMBOL_POINT);

      double current_potential_loss = 0;
      if(sl != 0)
      {
         if(position_type == POSITION_TYPE_BUY)
            current_potential_loss = (current_price - sl) * volume * tick_value / point;
         else
            current_potential_loss = (sl - current_price) * volume * tick_value / point;
         current_potential_loss = MathAbs(current_potential_loss);
      }

      double current_potential_profit = 0;
      if(tp != 0)
      {
         if(position_type == POSITION_TYPE_BUY)
            current_potential_profit = (tp - current_price) * volume * tick_value / point;
         else
            current_potential_profit = (current_price - tp) * volume * tick_value / point;
         current_potential_profit = MathAbs(current_potential_profit);
      }

      double static_potential_loss = 0;
      if(sl != 0)
      {
         if(position_type == POSITION_TYPE_BUY)
            static_potential_loss = (entry_price - sl) * volume * tick_value / point;
         else
            static_potential_loss = (sl - entry_price) * volume * tick_value / point;
         static_potential_loss = MathAbs(static_potential_loss);
      }

      double static_potential_profit = 0;
      if(tp != 0)
      {
         if(position_type == POSITION_TYPE_BUY)
            static_potential_profit = (tp - entry_price) * volume * tick_value / point;
         else
            static_potential_profit = (entry_price - tp) * volume * tick_value / point;
         static_potential_profit = MathAbs(static_potential_profit);
      }

      total_current_max_loss += current_potential_loss;
      total_current_max_profit += current_potential_profit;
      total_static_max_loss += static_potential_loss;
      total_static_max_profit += static_potential_profit;
      total_current_profit += profit;
   }

   ExtCurrentMaxLoss = total_current_max_loss;
   ExtCurrentMaxProfit = total_current_max_profit;
   ExtCurrentProfit = total_current_profit;
   ExtStaticMaxLoss = total_static_max_loss;
   ExtStaticMaxProfit = total_static_max_profit;

   if(ExtCurrentMaxLoss > 0) ExtCurrentRRatio = ExtCurrentMaxProfit / ExtCurrentMaxLoss;
   if(ExtStaticMaxLoss > 0) ExtStaticRRatio = ExtStaticMaxProfit / ExtStaticMaxLoss;

   if(positions_info != "") ExtLastCalcSymbol += positions_info;

   ExtSignalProcessedForDisplay = true;
}
