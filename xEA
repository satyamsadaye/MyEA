//+------------------------------------------------------------------+
bool TryTimeBasedExitForMultiOrderBase(MultiOrderGroup &group)
{
   if(!InpTimeBasedExitEnabled || InpTimeBasedExitSeconds <= 0)
      return false;

   if(group.base_ticket == 0 || group.attempts > 0 || group.recovery_triggered || group.activated)
      return false;

   if(!PositionSelectByTicket(group.base_ticket))
      return false;

   double base_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
   if(base_profit >= 0.0)
      return false;

   datetime entry_time = (datetime)PositionGetInteger(POSITION_TIME);
   if(entry_time <= 0)
      return false;

   int elapsed_seconds = (int)(TimeCurrent() - entry_time);
   if(elapsed_seconds < InpTimeBasedExitSeconds)
      return false;

   PrintFormat("Time-Based Exit: Group #%d base trade #%d losing for %d sec (limit %d). Closing base trade before recovery.",
              group.base_ticket, group.base_ticket, elapsed_seconds, InpTimeBasedExitSeconds);
   ClosePosition(group.base_ticket);
   group.close_reason = "time_based_exit";
   return true;
}

bool TryTimeBasedExitForStandalonePosition(ulong ticket)
{
   if(!InpTimeBasedExitEnabled || InpTimeBasedExitSeconds <= 0)
      return false;
   if(ticket == 0)
      return false;
   if(!PositionSelectByTicket(ticket))
      return false;
   if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber)
      return false;
   if(StringCompare(PositionGetString(POSITION_SYMBOL), _Symbol) != 0)
      return false;

   double position_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
   if(position_profit >= 0.0)
      return false;

   datetime entry_time = (datetime)PositionGetInteger(POSITION_TIME);
   if(entry_time <= 0)
      return false;

   int elapsed_seconds = (int)(TimeCurrent() - entry_time);
   if(elapsed_seconds < InpTimeBasedExitSeconds)
      return false;

   PrintFormat("Time-Based Exit: Position #%d losing for %d sec (limit %d). Closing before recovery.",
               ticket, elapsed_seconds, InpTimeBasedExitSeconds);
   ClosePosition(ticket);
   return true;
}

void ProcessStandaloneTimeBasedExit()
{
   if(!InpTimeBasedExitEnabled || InpTimeBasedExitSeconds <= 0)
      return;
   if(InpMultiOrderEnabled)
      return;

   for(int pos = PositionsTotal() - 1; pos >= 0; pos--)
   {
      ulong ticket = PositionGetTicket(pos);
      if(ticket == 0)
         continue;
      if(TryTimeBasedExitForStandalonePosition(ticket))
         break; // stop once we closed a losing position
   }
}

bool IsHaltRecoveryComment(const string comment)
{
   string comment_lower = comment;
   StringToLower(comment_lower);
   return (StringFind(comment_lower, "halt by multi recovery") >= 0);
}

void EnsureHaltRecoveryTriggerInitialized(MultiOrderGroup &group)
{
   int trigger_step = MathMax(1, InpHaltRecoveryAfterTrades);
   if(group.halt_next_trigger_attempt <= 0)
   {
      int completed_cycles = group.attempts / trigger_step;
      group.halt_next_trigger_attempt = (completed_cycles + 1) * trigger_step;
   }
   if(group.halt_next_trigger_attempt < trigger_step)
      group.halt_next_trigger_attempt = trigger_step;
}

void RemoveTicketFromGroup(MultiOrderGroup &group, const ulong ticket)
{
   if(ticket == 0 || group.ticket_count <= 0)
      return;

   for(int i = 0; i < group.ticket_count; i++)
   {
      if(group.tickets[i] != ticket)
         continue;

      for(int j = i; j < group.ticket_count - 1; j++)
         group.tickets[j] = group.tickets[j + 1];

      group.tickets[group.ticket_count - 1] = 0;
      group.ticket_count--;
      return;
   }
}

double CalculateActiveRecoveryExposureLots(MultiOrderGroup &group)
{
   double total_lots = 0.0;

   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(ticket == 0 || !PositionSelectByTicket(ticket))
         continue;

      string pos_comment = PositionGetString(POSITION_COMMENT);
      string pos_comment_lower = pos_comment;
      StringToLower(pos_comment_lower);
      if(IsHaltRecoveryComment(pos_comment))
         continue;
      if(StringFind(pos_comment, "Hedge") >= 0 || StringFind(pos_comment_lower, "hedge") >= 0)
         continue;

      total_lots += PositionGetDouble(POSITION_VOLUME);
   }

   return total_lots;
}

double CalculateBaseRecoveryPnLWithoutHedges(MultiOrderGroup &group)
{
   double total_pnl = 0.0;

   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(ticket == 0 || !PositionSelectByTicket(ticket))
         continue;

      string pos_comment = PositionGetString(POSITION_COMMENT);
      string pos_comment_lower = pos_comment;
      StringToLower(pos_comment_lower);

      if(IsHaltRecoveryComment(pos_comment))
         continue;
      if(StringFind(pos_comment_lower, "hedge") >= 0)
         continue;

      total_pnl += PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
   }

   return total_pnl;
}

bool TryHaltTrendOneSidedExit(MultiOrderGroup &group, const double hedge_profit)
{
   if(!InpHaltTrendExitOnProfitMultiple && !InpHaltTrendExitOnLossMultiple)
      return false;

   double base_recovery_pnl = CalculateBaseRecoveryPnLWithoutHedges(group);
   double base_recovery_abs = MathAbs(base_recovery_pnl);
   if(base_recovery_abs < 0.01)
      return false;

   bool trigger_profit = false;
   bool trigger_loss = false;

   if(InpHaltTrendExitOnProfitMultiple && hedge_profit > 0.0)
   {
      double profit_multiple = MathMax(1.1, InpHaltTrendProfitMultiple);
      trigger_profit = (hedge_profit >= base_recovery_abs * profit_multiple);
   }

   if(InpHaltTrendExitOnLossMultiple && hedge_profit < 0.0)
   {
      double loss_multiple = MathMax(1.1, InpHaltTrendLossMultiple);
      trigger_loss = (MathAbs(hedge_profit) >= base_recovery_abs * loss_multiple);
   }

   if(!trigger_profit && !trigger_loss)
      return false;

   group.close_reason = "trend one sided halt exit";
   PrintFormat("Halt Multi-Recovery: One-sided trend exit triggered for group #%d. Base+Recovery P&L: %.2f, Halt Hedge P&L: %.2f",
              group.base_ticket, base_recovery_pnl, hedge_profit);
   CloseAllPositionsInGroup(group);
   return true;
}

void ResetHaltRecoveryState(MultiOrderGroup &group)
{
   group.halt_recovery_active = false;
   group.halt_hedge_ticket = 0;
   group.halt_hedge_lot = 0.0;
   group.halt_hedge_open_time = 0;
}

void SyncHaltRecoveryStateFromPositions(MultiOrderGroup &group)
{
   ulong found_halt_ticket = 0;
   double found_halt_lot = 0.0;
   datetime found_halt_time = 0;

   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(ticket == 0 || !PositionSelectByTicket(ticket))
         continue;

      string pos_comment = PositionGetString(POSITION_COMMENT);
      if(!IsHaltRecoveryComment(pos_comment))
         continue;

      found_halt_ticket = ticket;
      found_halt_lot = PositionGetDouble(POSITION_VOLUME);
      found_halt_time = (datetime)PositionGetInteger(POSITION_TIME);
      break;
   }

   if(found_halt_ticket > 0)
   {
      group.halt_recovery_active = true;
      group.halt_hedge_ticket = found_halt_ticket;
      group.halt_hedge_lot = found_halt_lot;
      if(group.halt_hedge_open_time == 0)
         group.halt_hedge_open_time = found_halt_time;
      EnsureHaltRecoveryTriggerInitialized(group);
      return;
   }

   if(group.halt_hedge_ticket > 0)
   {
      RemoveTicketFromGroup(group, group.halt_hedge_ticket);
      group.total_volume = MathMax(0.0, group.total_volume - group.halt_hedge_lot);
   }
   ResetHaltRecoveryState(group);
   EnsureHaltRecoveryTriggerInitialized(group);
}

bool ManageHaltRecoveryState(MultiOrderGroup &group)
{
   SyncHaltRecoveryStateFromPositions(group);
   if(!group.halt_recovery_active || group.halt_hedge_ticket == 0)
      return false;

   if(!PositionSelectByTicket(group.halt_hedge_ticket))
   {
      SyncHaltRecoveryStateFromPositions(group);
      return false;
   }

   int wait_candles = MathMax(0, InpHaltRecoveryWaitCandles);
   int bars_since_open = iBarShift(group.symbol, _Period, group.halt_hedge_open_time, false);
   if(bars_since_open < 0)
      bars_since_open = 0;

   double hedge_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
   if(TryHaltTrendOneSidedExit(group, hedge_profit))
   {
      return true;
   }

   int force_close_candles = MathMax(0, InpHaltRecoveryForceCloseAfterCandles);
   bool force_close_due_to_timeout = (InpHaltRecoveryForceCloseEnabled && force_close_candles > 0 && bars_since_open >= force_close_candles);
   if(force_close_due_to_timeout)
   {
      group.close_reason = StringFormat("halt recovery timeout %d candles", force_close_candles);
      PrintFormat("Halt Multi-Recovery: Timeout reached for group #%d (%d/%d candles, hedge P&L %.2f). Force-closing full group.",
                 group.base_ticket, bars_since_open, force_close_candles, hedge_profit);
      CloseAllPositionsInGroup(group);
      return true;
   }

   if(bars_since_open < wait_candles)
   {
      if(!g_is_backtesting)
      {
         PrintFormat("Halt Multi-Recovery: Group #%d paused (%d/%d candles elapsed).",
                    group.base_ticket, bars_since_open, wait_candles);
      }
      return true;
   }

   double exit_min = MathMin(InpHaltRecoveryHedgeExitMinUSD, InpHaltRecoveryHedgeExitMaxUSD);
   double exit_max = MathMax(InpHaltRecoveryHedgeExitMinUSD, InpHaltRecoveryHedgeExitMaxUSD);
   bool use_positive_threshold = (exit_min >= 0.0 && exit_max >= 0.0);
   bool use_negative_threshold = (exit_min <= 0.0 && exit_max <= 0.0);
   bool should_exit_halt = false;
   string wait_text = "";

   if(use_positive_threshold)
   {
      // Profit-only mode: close once hedge reaches or exceeds target.
      should_exit_halt = (hedge_profit >= exit_max);
      wait_text = StringFormat("to reach >= %.2f USD", exit_max);
   }
   else if(use_negative_threshold)
   {
      // Loss-only mode: close once hedge reaches or falls below target.
      should_exit_halt = (hedge_profit <= exit_min);
      wait_text = StringFormat("to reach <= %.2f USD", exit_min);
   }
   else
   {
      // Mixed-sign mode: keep legacy behavior (must enter configured band).
      should_exit_halt = (hedge_profit >= exit_min && hedge_profit <= exit_max);
      wait_text = StringFormat("to enter exit band [%.2f, %.2f] USD", exit_min, exit_max);
   }

   if(!should_exit_halt)
   {
      if(!g_is_backtesting)
      {
         PrintFormat("Halt Multi-Recovery: Group #%d waiting hedge P&L %.2f %s.",
                    group.base_ticket, hedge_profit, wait_text);
      }
      return true;
   }

   ulong halt_ticket = group.halt_hedge_ticket;
   double halt_lot = group.halt_hedge_lot;
   if(ForceClosePosition(halt_ticket, "saved by halt multi recovery"))
   {
      RememberRealizedGroupPnL(group, hedge_profit, "halt hedge close");
      RemoveTicketFromGroup(group, halt_ticket);
      group.total_volume = MathMax(0.0, group.total_volume - halt_lot);
      ResetHaltRecoveryState(group);
      EnsureHaltRecoveryTriggerInitialized(group);
      PrintFormat("Halt Multi-Recovery: Closed hedge #%d for group #%d at %.2f USD. Memory %.2f USD. Recovery resumed.",
                 halt_ticket, group.base_ticket, hedge_profit, group.realized_pnl_memory);
      return false;
   }

   PrintFormat("Halt Multi-Recovery: Failed to close hedge #%d for group #%d. Keeping recovery paused.",
              halt_ticket, group.base_ticket);
   return true;
}

bool TryActivateHaltRecoveryHedge(MultiOrderGroup &group)
{
   if(!InpHaltRecoveryEnabled || group.base_ticket == 0)
      return false;

   SyncHaltRecoveryStateFromPositions(group);
   if(group.halt_recovery_active)
      return true;

   EnsureHaltRecoveryTriggerInitialized(group);
   if(group.attempts < group.halt_next_trigger_attempt)
      return false;

   double hedge_volume = CalculateActiveRecoveryExposureLots(group);
   if(hedge_volume <= 0.0)
   {
      PrintFormat("Halt Multi-Recovery: Exposure lot calculation failed for group #%d. Skipping halt hedge.",
                 group.base_ticket);
      return false;
   }

   double halt_hedge_multiplier = 1.0;
   if(InpHaltHedgeLotMultiplierEnabled)
      halt_hedge_multiplier = MathMax(0.01, InpHaltHedgeLotMultiplier);

   if(halt_hedge_multiplier != 1.0)
      hedge_volume *= halt_hedge_multiplier;

   double min_lot = GetEffectiveMinLot(group.symbol);
   double max_lot = GetEffectiveMaxLot(group.symbol);
   double lot_step = SymbolInfoDouble(group.symbol, SYMBOL_VOLUME_STEP);
   hedge_volume = MathMax(min_lot, hedge_volume);
   hedge_volume = MathMin(max_lot, hedge_volume);
   if(lot_step > 0.0)
      hedge_volume = MathFloor(hedge_volume / lot_step) * lot_step;
   hedge_volume = NormalizeDouble(hedge_volume, 2);

   ENUM_ORDER_TYPE hedge_type = (group.type == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
   double hedge_price = (hedge_type == ORDER_TYPE_BUY) ?
                        SymbolInfoDouble(group.symbol, SYMBOL_ASK) :
                        SymbolInfoDouble(group.symbol, SYMBOL_BID);

   MqlTradeRequest request;
   MqlTradeResult result;
   ZeroMemory(request);
   ZeroMemory(result);

   request.action = TRADE_ACTION_DEAL;
   request.symbol = group.symbol;
   request.volume = hedge_volume;
   request.type = hedge_type;
   request.price = hedge_price;
   request.sl = 0.0;
   request.tp = 0.0;
   request.deviation = InpMaxSlippagePoints;
   request.magic = InpMagicNumber;
   request.comment = StringFormat("halt by multi recovery #%d", group.base_ticket);
   request.type_filling = GetSupportedFillingMode(group.symbol);

   if(!IsSpreadAcceptable())
      return true;

   if(!SendDollarExitAwareOrder(request, result))
   {
      PrintFormat("Halt Multi-Recovery: Failed to open halt hedge for group #%d. Error: %d",
                 group.base_ticket, GetLastError());
      return false;
   }

   group.halt_recovery_active = true;
   group.halt_hedge_ticket = result.order;
   group.halt_hedge_lot = hedge_volume;
   group.halt_hedge_open_time = TimeCurrent();
   group.halt_next_trigger_attempt += MathMax(1, InpHaltRecoveryAfterTrades);

   if(group.ticket_count < 500)
   {
      group.tickets[group.ticket_count] = result.order;
      group.ticket_count++;
   }
   group.total_volume += hedge_volume;

   if(halt_hedge_multiplier != 1.0)
   {
      PrintFormat("Halt Multi-Recovery: Activated for group #%d at attempt %d. Hedge #%d (%s %.2f lots, %.2fx) opened.",
                 group.base_ticket, group.attempts, result.order, EnumToString(hedge_type), hedge_volume, halt_hedge_multiplier);
   }
   else
   {
      PrintFormat("Halt Multi-Recovery: Activated for group #%d at attempt %d. Hedge #%d (%s %.2f lots) opened.",
                 group.base_ticket, group.attempts, result.order, EnumToString(hedge_type), hedge_volume);
   }
   return true;
}

void ProcessMultiOrderRecovery()
{
   // Early exit conditions
   if(!InpMultiOrderEnabled) return;
   
   datetime current_time = TimeCurrent();
   
   // PHASE 1: Check and process hedge positions first
   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      if(!MultiOrderGroups[i].hedge_activated || MultiOrderGroups[i].base_ticket == 0) 
         continue;
         
      double hedge_profit = 0.0;
      ulong hedge_ticket = 0;
      bool hedge_found = false;
      
      // Find the hedge position in the group
      for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
      {
         if(PositionSelectByTicket(MultiOrderGroups[i].tickets[j]))
         {
            string comment = PositionGetString(POSITION_COMMENT);
            if(StringFind(comment, "🛡️ Hedge") >= 0)
            {
               hedge_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
               hedge_ticket = MultiOrderGroups[i].tickets[j];
               hedge_found = true;
               break;
            }
         }
      }
      
      // If hedge position found and it reaches its exit threshold (profit or loss)
      if(hedge_found && ((InpGlobalHedgeExitThreshold < 0 && hedge_profit <= InpGlobalHedgeExitThreshold) || 
                        (InpGlobalHedgeExitThreshold > 0 && hedge_profit >= InpGlobalHedgeExitThreshold)))
      {
         PrintFormat("Hedge position %d P&L (%.2f) reached %s threshold (%.2f) - closing hedge and resuming recovery",
                    hedge_ticket, hedge_profit,
                    InpGlobalHedgeExitThreshold > 0 ? "profit" : "loss",
                    InpGlobalHedgeExitThreshold);
         
         // Close only the hedge position
          if(ForceClosePosition(hedge_ticket, "Hedge threshold reached"))
          {
             RememberRealizedGroupPnL(MultiOrderGroups[i], hedge_profit, "global hedge close");
             MultiOrderGroups[i].hedge_activated = false;
             MultiOrderGroups[i].hedge_ticket = 0;
             // Restore pre-hedge recovery attempts to continue from where it left off
             if(MultiOrderGroups[i].pre_hedge_attempts > 0)
             {
               MultiOrderGroups[i].attempts = MultiOrderGroups[i].pre_hedge_attempts;
            }
            PrintFormat("Hedge closed successfully - resuming recovery from attempt %d", MultiOrderGroups[i].attempts);
         }
      }
   }
   
   // First, check hedge positions' P&L and manage recovery behavior
   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      if(!MultiOrderGroups[i].hedge_activated || MultiOrderGroups[i].base_ticket == 0) continue;
      
      double group_profit = 0;
      double hedge_profit = 0;
      ulong hedge_ticket = 0;
      
      // Calculate group's main positions P&L
      for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
      {
         ulong ticket = MultiOrderGroups[i].tickets[j];
         if(PositionSelectByTicket(ticket))
         {
            string comment = PositionGetString(POSITION_COMMENT);
            if(StringFind(comment, "🛡️ Hedge") < 0) // Not a hedge position
            {
               group_profit += PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
            }
            else // Hedge position
            {
               hedge_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
               hedge_ticket = ticket;
            }
         }
      }
      
      // If hedge P&L drops below threshold, close hedge and resume normal recovery
      if(hedge_ticket > 0 && hedge_profit < InpGlobalHedgeExitThreshold)
      {
         PrintFormat("Hedge P&L (%.2f) below threshold (%.2f) - closing hedge and resuming normal recovery",
                    hedge_profit, InpGlobalHedgeExitThreshold);
         
         // Close only the hedge position
         ForceClosePosition(hedge_ticket, "Hedge threshold reached");
         
         // Deactivate hedge mode and reset counters
         MultiOrderGroups[i].hedge_activated = false;
         MultiOrderGroups[i].hedge_ticket = 0;
         
         // Reset recovery attempts to continue from where it was before hedge
         if(MultiOrderGroups[i].pre_hedge_attempts > 0)
         {
            MultiOrderGroups[i].attempts = MultiOrderGroups[i].pre_hedge_attempts;
         }
         
         continue; // Skip to next group
      }
   }
   
   // Now check and handle any orphaned hedge positions
   for(int h = 0; h < ArraySize(MultiOrderGroups); h++)
   {
      if(!MultiOrderGroups[h].hedge_activated) continue;
      
      // Check if the main position group still exists
      bool main_group_exists = false;
      for(int t = 0; t < MultiOrderGroups[h].ticket_count; t++)
      {
         if(PositionSelectByTicket(MultiOrderGroups[h].tickets[t]))
         {
            main_group_exists = true;
            break;
         }
      }
      
      // If main group is closed but hedge is still open, close the hedge
      if(!main_group_exists && PositionSelectByTicket(MultiOrderGroups[h].hedge_ticket))
      {
         PrintFormat("⚠️ Found orphaned hedge #%d - closing it as main group is closed",
                    MultiOrderGroups[h].hedge_ticket);
         ClosePosition(MultiOrderGroups[h].hedge_ticket);
         MultiOrderGroups[h].hedge_activated = false;
         MultiOrderGroups[h].hedge_ticket = 0;
      }
   }
   
   // Update all groups first
   UpdateMultiOrderGroups();
   
   // Count active hedged groups for logging
   int active_hedged_groups = 0;
   for(int check_idx = 0; check_idx < ArraySize(MultiOrderGroups); check_idx++)
   {
      if(MultiOrderGroups[check_idx].hedge_activated)
         active_hedged_groups++;
   }
   
   // Log recovery processing status
   static datetime last_process_log = 0;
   if(active_hedged_groups > 0 && (current_time - last_process_log >= 30))
   {
      PrintFormat("⚡ Recovery Status: %d total groups, %d with active hedges at %s",
                 ArraySize(MultiOrderGroups), active_hedged_groups, TimeToString(current_time));
      last_process_log = current_time;
   }
   
   // EMERGENCY PROFIT CHECK: Quick scan for hedged groups with positive profit
   for(int emergency_idx = 0; emergency_idx < ArraySize(MultiOrderGroups); emergency_idx++)
   {
      if(InpHedgingEnabled && MultiOrderGroups[emergency_idx].hedge_activated)
      {
         double emergency_profit = CalculateEffectiveGroupProfit(MultiOrderGroups[emergency_idx]);
         
         if(emergency_profit >= 0.0)
         {
            PrintFormat("EMERGENCY CHECK: Hedged group #%d has positive profit %.2f - triggering immediate closure check!",
                       MultiOrderGroups[emergency_idx].base_ticket, emergency_profit);
         }
      }
   }
   
   // Process each group
   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      // Skip empty groups
      if(MultiOrderGroups[i].base_ticket == 0) continue;

      if(ManageHaltRecoveryState(MultiOrderGroups[i]))
      {
         // Halt hedge is active: keep all positions and pause new recovery entries.
         continue;
      }
      
      //--- CRITICAL: Skip all recovery processing if hedge is active and exists
      if(MultiOrderGroups[i].hedge_activated)
      {
         // Verify if the hedge position still exists
         bool hedge_exists = false;
         if(MultiOrderGroups[i].hedge_ticket > 0)
         {
            if(PositionSelectByTicket(MultiOrderGroups[i].hedge_ticket))
            {
               hedge_exists = true;
               if(!g_is_backtesting)
               {
                  PrintFormat("⚡ Group #%d: Recovery paused - Hedge #%d active",
                            MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].hedge_ticket);
               }
            }
            else
            {
               // Hedge position no longer exists, reset hedge flags
               MultiOrderGroups[i].hedge_activated = false;
               MultiOrderGroups[i].hedge_ticket = 0;
               MultiOrderGroups[i].hedge_entry = 0;
               MultiOrderGroups[i].hedge_lot = 0;
               MultiOrderGroups[i].hedge_time = 0;
               MultiOrderGroups[i].hedge_trigger_distance = 0;
               PrintFormat("⚡ Group #%d: Hedge position closed - Resuming recovery trades",
                         MultiOrderGroups[i].base_ticket);
            }
         }
         
         if(hedge_exists)
         {
            continue; // Skip recovery processing only if hedge actually exists
         }
      }
      
      // Skip if this is a hedge position to prevent recursive recovery
      if(MultiOrderGroups[i].hedge_ticket > 0 && PositionSelectByTicket(MultiOrderGroups[i].hedge_ticket))
      {
         PrintFormat("⚠️ Preventing recovery on hedge position #%d",
                    MultiOrderGroups[i].hedge_ticket);
         continue;
      }
      
      // Skip if group has reached max attempts
      if(MultiOrderGroups[i].attempts >= InpMultiOrderMaxAttempts)
      {
         if(!g_is_backtesting)
            PrintFormat("Group #%d: Max recovery attempts (%d) reached", 
                      MultiOrderGroups[i].base_ticket, InpMultiOrderMaxAttempts);
         continue;
      }
         
      // Get the last position's details
      int last_idx = MultiOrderGroups[i].ticket_count - 1;
      if(last_idx < 0) continue;
      
      ulong last_ticket = MultiOrderGroups[i].tickets[last_idx];
      if(!PositionSelectByTicket(last_ticket))
         continue;
         
      ENUM_ORDER_TYPE planned_recovery_type = DetermineRecoveryOrderType(MultiOrderGroups[i]);
      bool is_buy_recovery = (planned_recovery_type == ORDER_TYPE_BUY);

      // Draw OHLC recovery levels for active groups before trigger checks,
      // so users can see all potential recovery levels in advance.
      if(InpOHLCLevelRecoveryConfirmationEnabled && InpOHLCRecoveryDrawLevels)
      {
         DrawOHLCRecoveryLevelsForBase(MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].symbol);
      }
      
      // Skip if this position is part of a group with a hedge position
      if(MultiOrderGroups[i].hedge_activated)
      {
         PrintFormat("Multi-Order Recovery: Skipping group #%d - has active hedge position", 
                    MultiOrderGroups[i].base_ticket);
         continue;
      }

      if(TryTimeBasedExitForMultiOrderBase(MultiOrderGroups[i]))
         continue;

      double base_position_profit = 0.0;
      // Keep recovery trigger SL aligned with the tightest live SL reference (if broker-side SL still exists).
      if(PositionSelectByTicket(MultiOrderGroups[i].base_ticket))
      {
         base_position_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
         double live_base_sl = PositionGetDouble(POSITION_SL);
         if(live_base_sl > 0.0)
         {
            bool sync_to_live_sl = (MultiOrderGroups[i].original_sl <= 0.0);
            if(!sync_to_live_sl)
            {
               if(MultiOrderGroups[i].type == POSITION_TYPE_BUY)
                  sync_to_live_sl = (live_base_sl > MultiOrderGroups[i].original_sl);
               else
                  sync_to_live_sl = (live_base_sl < MultiOrderGroups[i].original_sl);
            }

            if(sync_to_live_sl)
            {
               MultiOrderGroups[i].original_sl = live_base_sl;
               MultiOrderGroups[i].original_sl_distance = MathAbs(MultiOrderGroups[i].original_entry - live_base_sl);
               DrawSyntheticSLLine(MultiOrderGroups[i].base_ticket, live_base_sl, MultiOrderGroups[i].type);

               if(!g_is_backtesting)
               {
                  PrintFormat("Multi-Order Recovery: Synced group #%d SL reference to live SL %.5f for trailing alignment.",
                              MultiOrderGroups[i].base_ticket, live_base_sl);
               }
            }
         }
      }

      // Trigger recovery when synthetic/original SL is actually hit.
      // Fallback to legacy trigger-percent logic only when no SL reference exists.
      double current_price = 0.0;
      bool trigger_distance_reached = false;
      bool synthetic_sl_hit = false;
      
      if(PositionSelectByTicket(MultiOrderGroups[i].base_ticket))
      {
         if(MultiOrderGroups[i].type == POSITION_TYPE_BUY)
            current_price = SymbolInfoDouble(MultiOrderGroups[i].symbol, SYMBOL_BID);
         else
            current_price = SymbolInfoDouble(MultiOrderGroups[i].symbol, SYMBOL_ASK);
            
         double entry_price = MultiOrderGroups[i].original_entry;
         double sl_price = MultiOrderGroups[i].original_sl;
         
         if(sl_price > 0.0)
         {
            if(MultiOrderGroups[i].type == POSITION_TYPE_BUY)
               synthetic_sl_hit = (current_price <= sl_price);
            else
               synthetic_sl_hit = (current_price >= sl_price);

            trigger_distance_reached = synthetic_sl_hit;

            double current_distance = 0.0;
            if(MultiOrderGroups[i].type == POSITION_TYPE_BUY)
               current_distance = entry_price - current_price;
            else
               current_distance = current_price - entry_price;
            
            if(!g_is_backtesting)
            {
               PrintFormat("Multi-Order Recovery: Synthetic SL check - Price: %.5f, SL: %.5f, DistanceFromEntry: %.5f, Hit: %s",
                          current_price, sl_price, current_distance,
                          trigger_distance_reached ? "YES" : "NO");
            }
         }
         else
         {
            // No SL reference available: keep legacy distance trigger behavior.
            double current_distance = 0.0;
            if(MultiOrderGroups[i].type == POSITION_TYPE_BUY)
               current_distance = entry_price - current_price;
            else
               current_distance = current_price - entry_price;

            double trigger_threshold = 0.0;
            double sl_distance = MultiOrderGroups[i].original_sl_distance;
            if(sl_distance > 0.0)
               trigger_threshold = sl_distance * (InpMultiOrderTriggerPercent / 100.0);

            trigger_distance_reached = (trigger_threshold <= 0.0) ? (current_distance > 0.0)
                                                                   : (current_distance >= trigger_threshold && current_distance > 0.0);

            if(!g_is_backtesting)
            {
               PrintFormat("Multi-Order Recovery: Fallback trigger check (no SL) - Distance: %.5f, Threshold: %.5f, Reached: %s",
                          current_distance, trigger_threshold,
                          trigger_distance_reached ? "YES" : "NO");
            }
         }
      }
      
      // Remember that recovery was triggered at least once (even if trade waits for confirmations)
      if(trigger_distance_reached)
      {
         MultiOrderGroups[i].recovery_triggered = true;
      }
      
      // If trigger is not reached, skip.
      if(!trigger_distance_reached)
      {
         if(!g_is_backtesting)
         {
            PrintFormat("Multi-Order Recovery: Trigger not reached for group #%d. Waiting...",
                       MultiOrderGroups[i].base_ticket);
         }
         continue;
      }

      // For fallback-distance trigger (no SL reference), require base trade in loss.
      // For synthetic-SL hit, allow recovery regardless of temporary P&L state.
      if(!synthetic_sl_hit && base_position_profit >= 0.0)
      {
         if(!g_is_backtesting)
         {
            PrintFormat("Multi-Order Recovery: Main trade #%d is in PROFIT (%.2f USD). Skipping fallback recovery check.",
                       MultiOrderGroups[i].base_ticket, base_position_profit);
         }
         continue;
      }
      
      if(!g_is_backtesting)
      {
         PrintFormat("Multi-Order Recovery: Main trade #%d trigger reached (%s), current P&L: %.2f USD. Proceeding with recovery checks.",
                    MultiOrderGroups[i].base_ticket,
                    synthetic_sl_hit ? "synthetic SL hit" : "fallback",
                    base_position_profit);
      }

      // Once trailing starts controlling the base trade, recovery must not interfere.
      if(InpEnableTrailSL &&
         (HasTrailingStarted(MultiOrderGroups[i].base_ticket) || WasTrailingUsed(MultiOrderGroups[i].base_ticket)))
      {
         if(!g_is_backtesting)
         {
            PrintFormat("Multi-Order Recovery: Skipping recovery for group #%d because trailing control is active on base ticket #%d.",
                        MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].base_ticket);
         }
         continue;
      }
      
      // Get current ATR
      double atr_values[];
      if(CopyBuffer(g_atr_handle, 0, 1, 1, atr_values) <= 0)
      {
         PrintFormat("Could not get ATR value. Error: %d", GetLastError());
         continue;
      }
      double atr = atr_values[0];
      
      // HEDGING TRIGGER CHECK: Before processing any recovery logic, check if we should activate hedging
      if(InpHedgingEnabled && !MultiOrderGroups[i].hedge_activated && MultiOrderGroups[i].attempts >= InpHedgingTriggerAfter)
      {
         PrintFormat("Multi-Order Recovery: Checking hedge conditions for group #%d. Attempts: %d, Required: %d",
                    MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].attempts, InpHedgingTriggerAfter);
         
         if(CheckAndActivateHedging(MultiOrderGroups[i]))
         {
            PrintFormat("Multi-Order Recovery: Hedging activated for group #%d. %s",
                       MultiOrderGroups[i].base_ticket, 
                       InpHedgingStopRecovery ? "Recovery trades stopped." : "Recovery trades will continue.");
            
            // If hedging stops recovery, skip to next group
            if(InpHedgingStopRecovery)
            {
               continue;
            }
         }
         else
         {
            PrintFormat("Multi-Order Recovery: Hedge conditions not met for group #%d",
                       MultiOrderGroups[i].base_ticket);
         }
      }
      
      // Check Stochastic RSI conditions first
      bool stochastic_confirmed = false;
      if(InpStochRSIConfirmationEnabled)
      {
         if(is_buy_recovery)
         {
            stochastic_confirmed = IsStochasticRSIConfirmingBuy();
         }
         else // SELL recovery
         {
            stochastic_confirmed = IsStochasticRSIConfirmingSell();
         }
      }
      
      // Check HeikinAshi Recovery confirmation
      bool heikinashi_confirmed = false;
      if(InpHARecoveryConfirmationEnabled)
      {
         if(is_buy_recovery)
         {
            heikinashi_confirmed = IsHeikinAshiConfirmingBuy();
         }
         else // SELL recovery
         {
            heikinashi_confirmed = IsHeikinAshiConfirmingSell();
         }
      }
      
      // Check MACD Recovery confirmation
      bool macd_confirmed = false;
      if(InpMACDRecoveryConfirmationEnabled)
      {
         if(is_buy_recovery)
         {
            macd_confirmed = IsMACDConfirmingBuy();
         }
         else // SELL recovery
         {
            macd_confirmed = IsMACDConfirmingSell();
         }
      }
      
      // Check ROC Recovery confirmation
      bool roc_confirmed = false;
      if(InpROCRecoveryConfirmationEnabled)
      {
         if(is_buy_recovery)
         {
            roc_confirmed = IsROCConfirmingBuy();
         }
         else // SELL recovery
         {
            roc_confirmed = IsROCConfirmingSell();
         }
      }
      
      // Check Volume Recovery confirmation
      bool volume_confirmed = false;
      if(InpVolumeRecoveryConfirmationEnabled)
      {
         if(is_buy_recovery)
         {
            volume_confirmed = IsVolumeConfirmingBuyRecovery(MultiOrderGroups[i].original_sl);
         }
         else // SELL recovery
         {
            volume_confirmed = IsVolumeConfirmingSellRecovery(MultiOrderGroups[i].original_sl);
         }
      }
      
      // Check Percentage Distance Recovery confirmation
      bool percentage_confirmed = false;
      if(InpPercentageRecoveryConfirmationEnabled)
      {
         if(is_buy_recovery)
         {
            percentage_confirmed = IsPercentageConfirmingBuyRecovery(MultiOrderGroups[i].base_ticket, 
                                                                      MultiOrderGroups[i].original_entry,
                                                                      MultiOrderGroups[i].original_sl);
         }
         else // SELL recovery
         {
            percentage_confirmed = IsPercentageConfirmingSellRecovery(MultiOrderGroups[i].base_ticket,
                                                                       MultiOrderGroups[i].original_entry,
                                                                       MultiOrderGroups[i].original_sl);
         }
      }

      // Check Pattern 9 fall/rise recovery confirmation
      bool pattern9_move_confirmed = false;
      if(InpPattern9RecoveryConfirmationEnabled)
      {
         int completed_recoveries = MathMax(0, MultiOrderGroups[i].attempts);
         if(is_buy_recovery)
         {
            pattern9_move_confirmed = IsPattern9FallConfirmingBuyRecovery(MultiOrderGroups[i].base_ticket, completed_recoveries);
         }
         else // SELL recovery
         {
            pattern9_move_confirmed = IsPattern9FallConfirmingSellRecovery(MultiOrderGroups[i].base_ticket, completed_recoveries);
         }
      }

      // Check Pattern 18 signature-volume recovery confirmation
      bool pattern18_move_confirmed = false;
      if(InpPattern18RecoveryConfirmationEnabled)
      {
         int completed_recoveries = MathMax(0, MultiOrderGroups[i].attempts);
         if(is_buy_recovery)
         {
            pattern18_move_confirmed = IsPattern18ConfirmingBuyRecovery(MultiOrderGroups[i].base_ticket, completed_recoveries);
         }
         else // SELL recovery
         {
            pattern18_move_confirmed = IsPattern18ConfirmingSellRecovery(MultiOrderGroups[i].base_ticket, completed_recoveries);
         }
      }

      // Check D/W/M OHLC level touch recovery confirmation
      bool ohlc_level_confirmed = false;
      string ohlc_matched_level_key = "";
      if(InpOHLCLevelRecoveryConfirmationEnabled)
      {
         ohlc_level_confirmed = IsOHLCLevelsConfirmingRecovery(MultiOrderGroups[i].base_ticket,
                                                               is_buy_recovery,
                                                               MultiOrderGroups[i].symbol,
                                                               ohlc_matched_level_key);
      }
      
      // Determine if recovery should proceed based on enabled confirmations
      bool recovery_confirmed = true; // Default to true if no confirmations enabled
      
      // Count enabled confirmations
      int enabled_confirmations = 0;
      if(InpStochRSIConfirmationEnabled) enabled_confirmations++;
      if(InpHARecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpMACDRecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpROCRecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpVolumeRecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpPercentageRecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpPattern9RecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpPattern18RecoveryConfirmationEnabled) enabled_confirmations++;
      if(InpOHLCLevelRecoveryConfirmationEnabled) enabled_confirmations++;
      
      if(enabled_confirmations > 1)
      {
         // Multiple confirmations enabled - require ALL to confirm
         recovery_confirmed = true;
         if(InpStochRSIConfirmationEnabled) recovery_confirmed = recovery_confirmed && stochastic_confirmed;
         if(InpHARecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && heikinashi_confirmed;
         if(InpMACDRecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && macd_confirmed;
         if(InpROCRecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && roc_confirmed;
         if(InpVolumeRecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && volume_confirmed;
          if(InpPercentageRecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && percentage_confirmed;
          if(InpPattern9RecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && pattern9_move_confirmed;
          if(InpPattern18RecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && pattern18_move_confirmed;
          if(InpOHLCLevelRecoveryConfirmationEnabled) recovery_confirmed = recovery_confirmed && ohlc_level_confirmed;
         
         if(!g_is_backtesting)
         {
            string status_msg = "Multi-Order Recovery: Multiple confirmations required - ";
            if(InpStochRSIConfirmationEnabled) status_msg += StringFormat("Stochastic RSI: %s ", stochastic_confirmed ? "CONFIRMED" : "WAITING");
            if(InpHARecoveryConfirmationEnabled) status_msg += StringFormat("HeikinAshi: %s ", heikinashi_confirmed ? "CONFIRMED" : "WAITING");
            if(InpMACDRecoveryConfirmationEnabled) status_msg += StringFormat("MACD: %s ", macd_confirmed ? "CONFIRMED" : "WAITING");
            if(InpROCRecoveryConfirmationEnabled) status_msg += StringFormat("ROC: %s ", roc_confirmed ? "CONFIRMED" : "WAITING");
            if(InpVolumeRecoveryConfirmationEnabled) status_msg += StringFormat("Volume: %s ", volume_confirmed ? "CONFIRMED" : "WAITING");
             if(InpPercentageRecoveryConfirmationEnabled) status_msg += StringFormat("Percentage: %s ", percentage_confirmed ? "CONFIRMED" : "WAITING");
             if(InpPattern9RecoveryConfirmationEnabled) status_msg += StringFormat("P9%s: %s ",
                                                                                  InpPattern9RecoveryUseTradeDirectionMode ? (is_buy_recovery ? "Fall(BUY)" : "Rise(SELL)") :
                                                                                  (InpPattern9RecoveryTriggerMode == P9_RECOVERY_TRIGGER_FALL ? "Fall" : "Rise"),
                                                                                  pattern9_move_confirmed ? "CONFIRMED" : "WAITING");
             if(InpPattern18RecoveryConfirmationEnabled) status_msg += StringFormat("P18 Signature: %s ", pattern18_move_confirmed ? "CONFIRMED" : "WAITING");
             if(InpOHLCLevelRecoveryConfirmationEnabled) status_msg += StringFormat("OHLC Levels: %s ", ohlc_level_confirmed ? "CONFIRMED" : "WAITING");
             status_msg += StringFormat("Combined: %s", recovery_confirmed ? "CONFIRMED" : "WAITING");
             PrintFormat(status_msg);
         }
      }
      else if(InpStochRSIConfirmationEnabled)
      {
         // Only Stochastic RSI confirmation enabled
         recovery_confirmed = stochastic_confirmed;
      }
      else if(InpHARecoveryConfirmationEnabled)
      {
         // Only HeikinAshi confirmation enabled
         recovery_confirmed = heikinashi_confirmed;
      }
      else if(InpMACDRecoveryConfirmationEnabled)
      {
         // Only MACD confirmation enabled
         recovery_confirmed = macd_confirmed;
      }
      else if(InpROCRecoveryConfirmationEnabled)
      {
         // Only ROC confirmation enabled
         recovery_confirmed = roc_confirmed;
      }
      else if(InpVolumeRecoveryConfirmationEnabled)
      {
         // Only Volume confirmation enabled
         recovery_confirmed = volume_confirmed;
      }
      else if(InpPercentageRecoveryConfirmationEnabled)
      {
         // Only Percentage confirmation enabled
         recovery_confirmed = percentage_confirmed;
      }
      else if(InpPattern9RecoveryConfirmationEnabled)
      {
         // Only Pattern 9 fall/rise confirmation enabled
         recovery_confirmed = pattern9_move_confirmed;
      }
      else if(InpPattern18RecoveryConfirmationEnabled)
      {
         // Only Pattern 18 signature confirmation enabled
         recovery_confirmed = pattern18_move_confirmed;
      }
      else if(InpOHLCLevelRecoveryConfirmationEnabled)
      {
         // Only OHLC level confirmation enabled
         recovery_confirmed = ohlc_level_confirmed;
      }
      // If none is enabled, recovery_confirmed remains true

      if(recovery_confirmed)
      {
         // Double-check: Don't open recovery if hedging is active and recovery is stopped
         if(InpHedgingEnabled && MultiOrderGroups[i].hedge_activated && InpHedgingStopRecovery)
         {
            PrintFormat("Multi-Order Recovery: Recovery confirmed but hedging is active - recovery stopped for group #%d",
                       MultiOrderGroups[i].base_ticket);
            continue; // Skip this group
         }
         
         string confirmation_details = "";
         if(InpStochRSIConfirmationEnabled) confirmation_details += "Stochastic RSI ";
         if(InpHARecoveryConfirmationEnabled) confirmation_details += "HeikinAshi ";
         if(InpMACDRecoveryConfirmationEnabled) confirmation_details += "MACD ";
         if(InpROCRecoveryConfirmationEnabled) confirmation_details += "ROC ";
         if(InpVolumeRecoveryConfirmationEnabled) confirmation_details += "Volume ";
          if(InpPercentageRecoveryConfirmationEnabled) confirmation_details += "Percentage ";
          if(InpPattern9RecoveryConfirmationEnabled) confirmation_details += StringFormat("P9%s ",
                                                                                          InpPattern9RecoveryUseTradeDirectionMode ? (is_buy_recovery ? "Fall(BUY)" : "Rise(SELL)") :
                                                                                          (InpPattern9RecoveryTriggerMode == P9_RECOVERY_TRIGGER_FALL ? "Fall" : "Rise"));
          if(InpPattern18RecoveryConfirmationEnabled) confirmation_details += "P18Signature ";
          if(InpOHLCLevelRecoveryConfirmationEnabled) confirmation_details += "OHLC Levels ";
          if(confirmation_details == "") confirmation_details = "No confirmation required ";

          PrintFormat("Multi-Order Recovery: %sconfirmed for %s recovery. Opening recovery position. Group #%d, Hedge Active: %s", 
                     confirmation_details,
                     is_buy_recovery ? "BUY" : "SELL",
                     MultiOrderGroups[i].base_ticket,
                     MultiOrderGroups[i].hedge_activated ? "YES" : "NO");
         int attempts_before_open = MultiOrderGroups[i].attempts;
          bool waiting_for_p9_open_trigger = InpPattern9RecoveryUseOpenPriceTrigger && pattern9_move_confirmed;
          bool waiting_for_p18_open_trigger = InpPattern18RecoveryUseOpenPriceTrigger && pattern18_move_confirmed;

          if(waiting_for_p9_open_trigger)
          {
             if(IsPattern9RecoveryOpenTriggerPending(MultiOrderGroups[i].base_ticket))
            {
               if(!g_is_backtesting)
               {
                  PrintFormat("Multi-Order Recovery: Pattern 9 open trigger already pending for group #%d. Waiting for price move.",
                              MultiOrderGroups[i].base_ticket);
               }
               continue;
            }

             if(QueuePattern9RecoveryOpenTrigger(MultiOrderGroups[i], attempts_before_open, ohlc_matched_level_key))
                continue;
          }

          if(waiting_for_p18_open_trigger)
          {
             if(IsPattern18RecoveryOpenTriggerPending(MultiOrderGroups[i].base_ticket))
             {
                if(!g_is_backtesting)
                {
                   PrintFormat("Multi-Order Recovery: Pattern 18 open trigger already pending for group #%d. Waiting for price move.",
                               MultiOrderGroups[i].base_ticket);
                }
                continue;
             }

             if(QueuePattern18RecoveryOpenTrigger(MultiOrderGroups[i], attempts_before_open, ohlc_matched_level_key))
                continue;
          }

         if(InpOHLCLevelRecoveryConfirmationEnabled)
            TrackPendingOHLCRecoveryLevel(MultiOrderGroups[i].base_ticket, ohlc_matched_level_key);
         OpenRecoveryPosition(MultiOrderGroups[i]);
         if(InpOHLCLevelRecoveryConfirmationEnabled)
         {
            bool trade_opened = (MultiOrderGroups[i].attempts > attempts_before_open);
            CommitPendingOHLCRecoveryLevel(MultiOrderGroups[i].base_ticket, trade_opened);
         }
         continue; // Move to next group after opening recovery
      }
      
      // --- PROFIT TARGET LOGIC ---
      double group_profit = CalculateGroupProfit(MultiOrderGroups[i]);
      double target = 0;
      if(InpMultiOrderProfitTarget > 0)
         target = MultiOrderGroups[i].potential_profit * (InpMultiOrderProfitTarget / 100.0);
      else if(InpMultiOrderProfitTarget == 0)
         target = 0.01; // Any profit
      else // negative: accept loss
         target = MultiOrderGroups[i].potential_profit * (MathAbs(InpMultiOrderProfitTarget) / 100.0) * (-1);
      
      // CONTINUOUS MONITORING FOR HEDGED GROUPS - Log every few ticks for debugging
      if(InpHedgingEnabled && MultiOrderGroups[i].hedge_activated)
      {
         static datetime last_hedge_log_time = 0;
         datetime current_time = TimeCurrent();
         
         // Log hedge status every 10 seconds
         if(current_time - last_hedge_log_time >= 10 || group_profit >= 0.0)
         {
            double account_balance = AccountInfoDouble(ACCOUNT_BALANCE);
            double profit_threshold = account_balance * (InpHedgingProfitThreshold / 100.0);
            
            PrintFormat("HEDGE MONITOR: Group #%d | Profit: %.2f | Threshold: %.2f (%.1f%%) | Breakeven Check: %s | CloseOnBreakeven: %s",
                       MultiOrderGroups[i].base_ticket, 
                       group_profit, 
                       profit_threshold, 
                       InpHedgingProfitThreshold,
                       (group_profit >= 0.0) ? "READY" : "WAITING",
                       InpHedgingCloseOnBreakeven ? "ENABLED" : "DISABLED");
            
            last_hedge_log_time = current_time;
         }
      }
      
      // Draw the target profit line for multi-recovery trades
      if(target > 0)
      {
         DrawMultiRecoveryTargetLine(MultiOrderGroups[i].base_ticket, target);
      }
      
      // Draw the breakeven price line for multi-recovery trades
      if(InpMultiOrderEnabled && MultiOrderGroups[i].ticket_count > 1)
      {
         DrawMultiRecoveryBreakevenLine(MultiOrderGroups[i]);
      }
      
      bool should_close = false;
      
      // --- GLOBAL P&L MONITOR ---
      // When Global P&L monitoring is enabled, ALL recovery groups use the same exit threshold
      // IMPORTANT: Only apply when recovery has been triggered (actual recovery trades OR trigger fired on base trade)
      if(InpGlobalPnLMonitorEnabled)
      {
         // AGGRESSIVE DEBUG: Always log when we have significant profit
         if(group_profit >= 1.0) // Log any group with profit >= $1
         {
            PrintFormat("GLOBAL P&L DEBUG: Group #%d - Profit: %.2f USD | Monitor Enabled: YES | Threshold: %.2f | Positions: %d",
                       MultiOrderGroups[i].base_ticket, group_profit, InpGlobalPnLExitThreshold, MultiOrderGroups[i].ticket_count);
         }
         
         // Allow exit when recovery mode is engaged:
         // 1) recovery trades exist, OR
         // 2) a recovery trigger has fired (synthetic SL/distance) even if confirmation is still pending
         bool has_recovery_trades = (MultiOrderGroups[i].ticket_count > 1);
         bool recovery_engaged = has_recovery_trades ||
                                 MultiOrderGroups[i].attempts > 0 ||
                                 MultiOrderGroups[i].activated ||
                                 MultiOrderGroups[i].recovery_triggered;
         
         if(recovery_engaged && group_profit >= InpGlobalPnLExitThreshold)
         {
            should_close = true;
            int recovery_count = MathMax(0, MultiOrderGroups[i].ticket_count - 1);
            PrintFormat("GLOBAL P&L EXIT: Group #%d reached PROFIT THRESHOLD (%.2f >= %.2f USD) with %d recovery trades. CLOSING ALL POSITIONS!",
                       MultiOrderGroups[i].base_ticket, group_profit, InpGlobalPnLExitThreshold, recovery_count);
                        
            if(InpGlobalPnLLogDetails)
            {
               PrintFormat("GLOBAL P&L DETAILS: Group #%d - Positions: %d, Recovery attempts: %d, Hedge active: %s",
                          MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].ticket_count, 
                          MultiOrderGroups[i].attempts, MultiOrderGroups[i].hedge_activated ? "YES" : "NO");
            }
         }
         else if(InpGlobalPnLLogDetails && group_profit > 0.0 && recovery_engaged)
         {
            // Log positive progress towards threshold
            PrintFormat("GLOBAL P&L MONITOR: Group #%d profit: %.2f USD (%.2f USD away from %.2f USD threshold)",
                       MultiOrderGroups[i].base_ticket, group_profit, 
                       InpGlobalPnLExitThreshold - group_profit, InpGlobalPnLExitThreshold);
         }
      }
      
      // --- GLOBAL DRAWDOWN MONITOR ---
      // When Global Drawdown monitoring is enabled, close positions if total drawdown exceeds threshold
      if(InpGlobalDrawdownMonitorEnabled && !should_close)
      {
         // Calculate total drawdown across all active groups
         double total_drawdown = 0.0;
         for(int dd_idx = 0; dd_idx < ArraySize(MultiOrderGroups); dd_idx++)
         {
            if(MultiOrderGroups[dd_idx].base_ticket == 0) continue;
            double dd_group_profit = CalculateGroupProfit(MultiOrderGroups[dd_idx]);
            total_drawdown += dd_group_profit;
         }
         
         // Add single positions not in groups
         for(int pos = 0; pos < PositionsTotal(); pos++)
         {
            ulong ticket = PositionGetTicket(pos);
            if(ticket == 0) continue;
            
            if(!PositionSelectByTicket(ticket)) continue;
            
            long magic = PositionGetInteger(POSITION_MAGIC);
            
            if(magic != InpMagicNumber) continue;
            
            // Check if this position is already counted in a group
            bool in_group = false;
            for(int g = 0; g < ArraySize(MultiOrderGroups); g++)
            {
               if(MultiOrderGroups[g].base_ticket == 0) continue;
               if(MultiOrderGroups[g].base_ticket == ticket) { in_group = true; break; }
               for(int r = 0; r < MultiOrderGroups[g].attempts; r++)
               {
                  if(MultiOrderGroups[g].tickets[r] == ticket) { in_group = true; break; }
               }
               if(in_group) break;
               if(MultiOrderGroups[g].hedge_ticket == ticket) { in_group = true; break; }
            }
            
            if(!in_group)
            {
               double pos_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
               total_drawdown += pos_profit;
            }
         }
         
         // AGGRESSIVE DEBUG: Always log when we have significant losses
         if(total_drawdown <= -5.0) // Log any total loss >= $5
         {
            PrintFormat("GLOBAL DRAWDOWN DEBUG: Total drawdown: %.2f USD | Monitor Enabled: YES | Threshold: %.2f",
                       total_drawdown, InpGlobalDrawdownExitThreshold);
         }
         
         if(total_drawdown <= InpGlobalDrawdownExitThreshold)
         {
            should_close = true;
            PrintFormat("GLOBAL DRAWDOWN EXIT: Total drawdown reached LOSS THRESHOLD (%.2f <= %.2f USD). CLOSING ALL POSITIONS!",
                       total_drawdown, InpGlobalDrawdownExitThreshold);
                       
            if(InpGlobalDrawdownLogDetails)
            {
               int active_groups = 0;
               for(int ag = 0; ag < ArraySize(MultiOrderGroups); ag++)
               {
                  if(MultiOrderGroups[ag].base_ticket != 0) active_groups++;
               }
               PrintFormat("GLOBAL DRAWDOWN DETAILS: Total groups: %d, Total drawdown: %.2f USD, Threshold: %.2f USD",
                          active_groups, total_drawdown, InpGlobalDrawdownExitThreshold);
            }
            
            // Set close reason for current group
            MultiOrderGroups[i].close_reason = "global_drawdown";
         }
         else if(InpGlobalDrawdownLogDetails && total_drawdown < 0.0)
         {
            // Log negative progress towards threshold
            PrintFormat("GLOBAL DRAWDOWN MONITOR: Total drawdown: %.2f USD (%.2f USD away from %.2f USD threshold)",
                       total_drawdown, total_drawdown - InpGlobalDrawdownExitThreshold, InpGlobalDrawdownExitThreshold);
         }
      }
      
      // Continue with existing exit logic only if global P&L hasn't triggered closure
      if(!should_close)
      {
         // PRIORITY CHECK: If Global P&L monitoring is enabled, ONLY use global P&L threshold for ALL groups
         if(InpGlobalPnLMonitorEnabled)
         {
            // Global P&L mode: Only close when threshold is reached, ignore other profit targets
            // This ensures ALL recovery trades use the same exit criteria (global P&L threshold)
            if(!g_is_backtesting)
            {
               PrintFormat("GLOBAL P&L MODE: Group #%d profit: %.2f USD, waiting for global threshold: %.2f USD",
                          MultiOrderGroups[i].base_ticket, group_profit, InpGlobalPnLExitThreshold);
            }
            // Don't set should_close here - it's already handled by global P&L logic above
         }
         else
         {
            // Traditional mode: Use hedge-specific or regular profit targets
            if(MultiOrderGroups[i].hedge_activated && InpHedgingEnabled)
            {
               // HEDGING PROFIT THRESHOLD LOGIC: If hedge is active, check for profit threshold
               double account_balance = AccountInfoDouble(ACCOUNT_BALANCE);
               double profit_threshold = account_balance * (InpHedgingProfitThreshold / 100.0);
               // PRIORITY 1: Check profit threshold (if set > 0)
               if(InpHedgingProfitThreshold > 0.0 && group_profit >= profit_threshold)
               {
                  should_close = true;
                  PrintFormat("HEDGE EXIT: Group #%d reached PROFIT THRESHOLD (%.2f >= %.2f = %.1f%% of balance %.2f). CLOSING ALL POSITIONS!",
                             MultiOrderGroups[i].base_ticket, group_profit, profit_threshold, InpHedgingProfitThreshold, account_balance);
               }
               // PRIORITY 2: Check breakeven (if enabled OR if no profit threshold set)
               else if((InpHedgingCloseOnBreakeven || InpHedgingProfitThreshold <= 0.0) && group_profit >= 0.0)
               {
                  should_close = true;
                  PrintFormat("HEDGE EXIT: Group #%d reached BREAKEVEN/PROFIT (%.2f >= 0.0) with hedge active. CLOSING ALL POSITIONS!",
                             MultiOrderGroups[i].base_ticket, group_profit);
               }
               // SAFETY NET: Force closure if profit is significantly positive (>= 0.1% of balance) regardless of settings
               else if(group_profit >= (account_balance * 0.001)) // 0.1% of balance
               {
                  should_close = true;
                  PrintFormat("HEDGE SAFETY EXIT: Group #%d has significant profit (%.2f >= %.2f = 0.1%% of balance). FORCING CLOSURE!",
                             MultiOrderGroups[i].base_ticket, group_profit, account_balance * 0.001);
               }
               // DEBUG: Log why we're NOT closing (if profit is positive but we're not closing)
               if(!should_close && group_profit >= 0.0)
               {
                  PrintFormat("HEDGE DEBUG: Group #%d has positive profit (%.2f) but NOT closing. ProfitThreshold: %.1f%%, CloseOnBreakeven: %s, Calculated Threshold: %.2f",
                             MultiOrderGroups[i].base_ticket, group_profit, InpHedgingProfitThreshold, 
                             InpHedgingCloseOnBreakeven ? "TRUE" : "FALSE", profit_threshold);
               }
            }
            else
            {
               // Check regular profit target (ONLY if hedge is NOT activated AND global P&L is disabled)
               if(InpMultiOrderProfitTarget >= 0 && group_profit >= target)
                  should_close = true;
               if(InpMultiOrderProfitTarget < 0 && group_profit >= target)
                  should_close = true;
            }
         }
      } // Close the if(!should_close) block from global P&L monitor
      
      if(should_close)
      {
         string close_reason = "";
         
         // Check if this was closed by Global P&L Monitor (only if recovery trades exist)
         bool has_recovery_trades_check = (MultiOrderGroups[i].ticket_count > 1);
         bool recovery_engaged_check = has_recovery_trades_check ||
                                       MultiOrderGroups[i].attempts > 0 ||
                                       MultiOrderGroups[i].activated ||
                                       MultiOrderGroups[i].recovery_triggered;
         if(InpGlobalPnLMonitorEnabled && recovery_engaged_check && group_profit >= InpGlobalPnLExitThreshold)
         {
            close_reason = "global_pnl_target";
            int recovery_count = MathMax(0, MultiOrderGroups[i].ticket_count - 1);
            PrintFormat("Multi-Order Recovery: Global P&L target reached (%.2f >= %.2f USD) with %d recovery trades (trigger engaged: %s). Closing all positions.", 
                       group_profit, InpGlobalPnLExitThreshold, recovery_count,
                       MultiOrderGroups[i].recovery_triggered ? "YES" : "NO");
         }
         // Check if this was closed by Global Drawdown Monitor
         else if(InpGlobalDrawdownMonitorEnabled && StringFind(MultiOrderGroups[i].close_reason, "global_drawdown") >= 0)
         {
            close_reason = "global_drawdown_protection";
            
            // Calculate total drawdown again for logging
            double total_drawdown = 0.0;
            for(int dd_idx = 0; dd_idx < ArraySize(MultiOrderGroups); dd_idx++)
            {
               if(MultiOrderGroups[dd_idx].base_ticket == 0) continue;
               double dd_group_profit = CalculateGroupProfit(MultiOrderGroups[dd_idx]);
               total_drawdown += dd_group_profit;
            }
            
            // Add single positions
            for(int pos = 0; pos < PositionsTotal(); pos++)
            {
               ulong ticket = PositionGetTicket(pos);
               if(ticket == 0) continue;
               
               if(!PositionSelectByTicket(ticket)) continue;
               
               long magic = PositionGetInteger(POSITION_MAGIC);
               if(magic != InpMagicNumber) continue;
               
               bool in_group = false;
               for(int g = 0; g < ArraySize(MultiOrderGroups); g++)
               {
                  if(MultiOrderGroups[g].base_ticket == 0) continue;
                  if(MultiOrderGroups[g].base_ticket == ticket) { in_group = true; break; }
                  for(int r = 0; r < MultiOrderGroups[g].attempts; r++)
                  {
                     if(MultiOrderGroups[g].tickets[r] == ticket) { in_group = true; break; }
                  }
                  if(in_group) break;
                  if(MultiOrderGroups[g].hedge_ticket == ticket) { in_group = true; break; }
               }
               
               if(!in_group)
               {
                  double pos_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
                  total_drawdown += pos_profit;
               }
            }
            
            PrintFormat("Multi-Order Recovery: Global Drawdown protection triggered (%.2f <= %.2f USD). Closing all positions.", 
                       total_drawdown, InpGlobalDrawdownExitThreshold);
                       
            // IMPORTANT: Close ALL positions globally, not just the current group
            CloseAllPositionsGlobally("global_drawdown_protection");
            return; // Exit function after global closure
         }
         else if(!InpGlobalPnLMonitorEnabled)
         {
            // Traditional mode: Determine close reason based on hedge status or regular profit target
            // Calculate profit threshold for potential use in logging
            double account_balance = AccountInfoDouble(ACCOUNT_BALANCE);
            double profit_threshold = account_balance * (InpHedgingProfitThreshold / 100.0);
            
            if(MultiOrderGroups[i].hedge_activated)
            {
               if(group_profit >= profit_threshold)
               {
                  close_reason = "hedge_profit_target";
                  PrintFormat("Multi-Order Recovery: Closing hedged group with base ticket #%d. Profit target reached: %.2f >= %.2f (%.1f%%)",
                             MultiOrderGroups[i].base_ticket, group_profit, profit_threshold, InpHedgingProfitThreshold);
               }
               else
               {
                  close_reason = "hedge_breakeven";
                  PrintFormat("Multi-Order Recovery: Closing hedged group with base ticket #%d. Breakeven reached: %.2f >= 0.0",
                             MultiOrderGroups[i].base_ticket, group_profit);
               }
            }
            else
            {
               close_reason = "profit_target";
               PrintFormat("Multi-Order Recovery: Group profit target reached (%.2f >= %.2f). Closing all positions.", 
                          group_profit, target);
            }
         }
         else
         {
            // Global P&L mode enabled but threshold not reached - this should not happen
            close_reason = "unexpected_close";
            PrintFormat("WARNING: Group #%d closed unexpectedly in Global P&L mode (profit: %.2f, threshold: %.2f)",
                       MultiOrderGroups[i].base_ticket, group_profit, InpGlobalPnLExitThreshold);
         }
         
         MultiOrderGroups[i].close_reason = close_reason;
         CloseAllPositionsInGroup(MultiOrderGroups[i]);
         
         // VALIDATION: Check if all positions were closed successfully
         Sleep(300); // Brief pause to allow closure completion
         ValidateGroupClosure(MultiOrderGroups[i], close_reason);
      }
   }
   CleanupMultiOrderGroups();
}
//+------------------------------------------------------------------+
//| Update Multi-Order Groups tracking                               |
//+------------------------------------------------------------------+
void UpdateMultiOrderGroups()
{
   // Don't run if Multi-Order Recovery is disabled
   if(!InpMultiOrderEnabled) return;
   
   // Check existing groups for equity hard stop
   for(int i = ArraySize(MultiOrderGroups) - 1; i >= 0; i--)
   {
      if(InpEquityHardStopEnabled && MultiOrderGroups[i].max_allowed_loss > 0)
      {
         double current_loss = -CalculateGroupProfit(MultiOrderGroups[i]); // Negative profit = loss
         if(current_loss > MultiOrderGroups[i].max_allowed_loss)
         {
            PrintFormat("Multi-Order Recovery: Group with base ticket #%d has exceeded max allowed loss (Current: %.2f, Max: %.2f)",
                       MultiOrderGroups[i].base_ticket, current_loss, MultiOrderGroups[i].max_allowed_loss);
            MultiOrderGroups[i].close_reason = "equity_stop";
            CloseAllPositionsInGroup(MultiOrderGroups[i]);
            
            // VALIDATION: Check if all positions were closed successfully
            Sleep(300);
            ValidateGroupClosure(MultiOrderGroups[i], "Equity Hard Stop");
            
            continue;
         }
      }
   }
   
   // First, scan for positions not in any group
   int total_positions = PositionsTotal();
   
   for(int i = 0; i < total_positions; i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      
      if(!PositionSelectByTicket(ticket))
         continue;
         
      // Only track positions with our magic number
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber)
         continue;
         
      // Get position comment to check if it's a hedge position
      string comment = PositionGetString(POSITION_COMMENT);
      bool is_hedge = StringFind(comment, "🛡️ Hedge") >= 0;
         
      // Check if position is already in a group
      bool found = false;
      for(int j = 0; j < ArraySize(MultiOrderGroups); j++)
      {
         for(int k = 0; k < MultiOrderGroups[j].ticket_count; k++)
         {
            if(MultiOrderGroups[j].tickets[k] == ticket)
            {
               found = true;
               if(is_hedge)
               {
                   MultiOrderGroups[j].hedge_activated = true; // Mark group as having a hedge
               }
               break;
            }
         }
         if(found) break;
      }
      
      // If not found, create a new group for this position
      if(!found)
      {
         int new_index = ArraySize(MultiOrderGroups);
         ArrayResize(MultiOrderGroups, new_index + 1);
         
         // Initialize the new group
         MultiOrderGroups[new_index].base_ticket = ticket;
         MultiOrderGroups[new_index].tickets[0] = ticket;
         MultiOrderGroups[new_index].ticket_count = 1;
         MultiOrderGroups[new_index].symbol = PositionGetString(POSITION_SYMBOL);
         MultiOrderGroups[new_index].type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
         MultiOrderGroups[new_index].original_lot = PositionGetDouble(POSITION_VOLUME);
         MultiOrderGroups[new_index].total_volume = PositionGetDouble(POSITION_VOLUME);
         
         // Check if this is a hedge position
         string comment = PositionGetString(POSITION_COMMENT);
         if(StringFind(comment, "🛡️ Hedge") >= 0)
         {
            MultiOrderGroups[new_index].hedge_activated = true;
         }
         
         // Store the original SL even if we're using synthetic SL
         MultiOrderGroups[new_index].original_entry = PositionGetDouble(POSITION_PRICE_OPEN);
         MultiOrderGroups[new_index].original_tp = PositionGetDouble(POSITION_TP);
         MultiOrderGroups[new_index].attempts = 0;
         MultiOrderGroups[new_index].activated = false;
         MultiOrderGroups[new_index].recovery_triggered = false;
         MultiOrderGroups[new_index].halt_recovery_active = false;
         MultiOrderGroups[new_index].halt_hedge_ticket = 0;
          MultiOrderGroups[new_index].halt_hedge_lot = 0.0;
          MultiOrderGroups[new_index].halt_hedge_open_time = 0;
          MultiOrderGroups[new_index].halt_next_trigger_attempt = MathMax(1, InpHaltRecoveryAfterTrades);
          MultiOrderGroups[new_index].realized_pnl_memory = 0.0;
         
         // FIX for synthetic SL with fixed points: Calculate original SL correctly
         double position_sl = PositionGetDouble(POSITION_SL);
         double original_entry = MultiOrderGroups[new_index].original_entry;
         string position_symbol = MultiOrderGroups[new_index].symbol;
         ENUM_POSITION_TYPE position_type = MultiOrderGroups[new_index].type;
         
         // If SL is 0 (synthetic SL), calculate it based on SLTP method
         if(position_sl == 0.0 && InpUseSyntheticSL)
         {
            if(InpSLTPMethod == SLTP_FIXED_POINTS)
            {
               // Calculate SL using fixed points
               double point_value = SymbolInfoDouble(position_symbol, SYMBOL_POINT);
               if(position_type == POSITION_TYPE_BUY)
                  position_sl = original_entry - (InpFixedSLPoints * point_value);
               else
                  position_sl = original_entry + (InpFixedSLPoints * point_value);
               
               PrintFormat("Multi-Order Recovery: Calculated synthetic SL using fixed points (%.0f pts) = %.5f for main trade #%d",
                          InpFixedSLPoints, position_sl, ticket);
            }
            else
            {
               // Calculate SL using ATR multiplier
               double atr_values[];
               if(CopyBuffer(iATR(position_symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) > 0)
               {
                  double atr = atr_values[0];
                  if(position_type == POSITION_TYPE_BUY)
                     position_sl = original_entry - (atr * InpAtrMultiplierSL);
                  else
                     position_sl = original_entry + (atr * InpAtrMultiplierSL);
                  
                  PrintFormat("Multi-Order Recovery: Calculated synthetic SL using ATR multiplier (%.2f × ATR %.5f) = %.5f for main trade #%d",
                             InpAtrMultiplierSL, atr, position_sl, ticket);
               }
            }
         }
         
         MultiOrderGroups[new_index].original_sl = position_sl;
         
         // Calculate and store original SL distance for recovery trades
         if(position_sl != 0.0)
         {
            MultiOrderGroups[new_index].original_sl_distance = MathAbs(original_entry - position_sl);
            PrintFormat("Multi-Order Recovery: Stored original SL distance: %.5f for group #%d",
                       MultiOrderGroups[new_index].original_sl_distance, ticket);
         }
         else
         {
            MultiOrderGroups[new_index].original_sl_distance = 0.0;
            PrintFormat("Multi-Order Recovery: No original SL found, SL distance set to 0 for group #%d", ticket);
         }
         
         // Initialize hedging variables
         MultiOrderGroups[new_index].hedge_activated = false;
         MultiOrderGroups[new_index].hedge_ticket = 0;
         MultiOrderGroups[new_index].hedge_entry = 0.0;
         MultiOrderGroups[new_index].hedge_lot = 0.0;
         MultiOrderGroups[new_index].hedge_time = 0;
         MultiOrderGroups[new_index].hedge_trigger_distance = 0.0;
         
         // Debug logging to see what's happening with the SL/TP values
         PrintFormat("Multi-Order Recovery: Original position values - Entry: %.5f, SL: %.5f, TP: %.5f",
                    MultiOrderGroups[new_index].original_entry, 
                    MultiOrderGroups[new_index].original_sl,
                    MultiOrderGroups[new_index].original_tp);
         
         // Only validate/correct SL if using ATR method, not fixed points
         // For fixed points method, trust the original SL distance
         if(MultiOrderGroups[new_index].original_sl != 0 && InpSLTPMethod == SLTP_ATR_MULTIPLIER)
         {
            double entry = MultiOrderGroups[new_index].original_entry;
            double sl = MultiOrderGroups[new_index].original_sl;
            ENUM_POSITION_TYPE pos_type = MultiOrderGroups[new_index].type;
            
            // Calculate ATR
            double atr_values[];
            if(CopyBuffer(iATR(MultiOrderGroups[new_index].symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) > 0)
            {
               double atr = atr_values[0];
               double expected_sl = 0;
               
               // Calculate what the SL should be based on ATR multiplier
               if(pos_type == POSITION_TYPE_BUY)
                  expected_sl = entry - (atr * InpAtrMultiplierSL);
               else
                  expected_sl = entry + (atr * InpAtrMultiplierSL);
               
               // Check if the SL is significantly different from what we expect
               double point = SymbolInfoDouble(MultiOrderGroups[new_index].symbol, SYMBOL_POINT);
               double sl_diff_points = MathAbs(sl - expected_sl) / point;
               
               if(sl_diff_points > 10) // If difference is more than 10 points
               {
                  PrintFormat("Multi-Order Recovery: Original SL (%.5f) appears incorrect. Expected SL based on ATR: %.5f. Difference: %.1f points",
                             sl, expected_sl, sl_diff_points);
                  
                  // Store the expected SL based on ATR instead
                  MultiOrderGroups[new_index].original_sl = expected_sl;
                  
                  PrintFormat("Multi-Order Recovery: Updated original SL to %.5f based on ATR (%.5f × %.2f)",
                             expected_sl, atr, InpAtrMultiplierSL);
               }
            }
         }
         else if(InpSLTPMethod == SLTP_FIXED_POINTS)
         {
            PrintFormat("Multi-Order Recovery: Using fixed points method - preserving original SL (%.5f) without ATR validation",
                       MultiOrderGroups[new_index].original_sl);
         }
         
         // Calculate potential profit of original trade
         string symbol = MultiOrderGroups[new_index].symbol;
         double entry = MultiOrderGroups[new_index].original_entry;
         double tp = MultiOrderGroups[new_index].original_tp;
         double volume = MultiOrderGroups[new_index].original_lot;
         double tick_value = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);
         double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
         
         if(tp != 0 && point != 0 && tick_value != 0)
         {
            double tp_distance_points = MathAbs(tp - entry) / point;
            MultiOrderGroups[new_index].potential_profit = tp_distance_points * tick_value * volume;
            PrintFormat("Multi-Order Recovery: Potential profit for base ticket #%d calculated as %.2f",
                       ticket, MultiOrderGroups[new_index].potential_profit);
         }
         else
         {
            MultiOrderGroups[new_index].potential_profit = 0;
         }
         
         // Calculate max allowed loss based on original trade's risk
         if(InpEquityHardStopEnabled)
         {
            double entry = MultiOrderGroups[new_index].original_entry;
            double sl = MultiOrderGroups[new_index].original_sl;
            double volume = MultiOrderGroups[new_index].original_lot;
            double tick_value = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);
            double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
            
            if(sl != 0 && point != 0 && tick_value != 0)
            {
               double sl_distance_points = MathAbs(sl - entry) / point;
               double original_max_loss = sl_distance_points * tick_value * volume;
               MultiOrderGroups[new_index].max_allowed_loss = original_max_loss * InpEquityHardStopMultiplier;
               PrintFormat("Multi-Order Recovery: Set max allowed loss for group #%d to %.2f (%.2f × %.1f)",
                          ticket, MultiOrderGroups[new_index].max_allowed_loss,
                          original_max_loss, InpEquityHardStopMultiplier);
            }
         }
         
         PrintFormat("Multi-Order Recovery: Created new group with base ticket #%d, Symbol: %s, Type: %s, Lot: %.2f",
                    ticket, MultiOrderGroups[new_index].symbol, 
                    EnumToString(MultiOrderGroups[new_index].type),
                    MultiOrderGroups[new_index].original_lot);
         
         // If multi-order recovery is enabled, keep real TP but use synthetic SL for original position
         if(InpMultiOrderEnabled)
         {
            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);
            
            request.action = TRADE_ACTION_SLTP;
            request.position = ticket;
            request.symbol = MultiOrderGroups[new_index].symbol;
            request.comment = "RohitEA Multi-Order Recovery";
            
            // Keep the original TP but remove the SL (use synthetic SL)
            request.tp = MultiOrderGroups[new_index].original_tp; // Keep the original TP
            request.sl = 0; // Remove the actual SL to use synthetic SL
            
            if(!IsSpreadAcceptable())
            {
               PrintFormat("Multi-Order Recovery: Spread too high to convert base #%d to synthetic SL right now. Keeping group active.",
                          ticket);
               continue;
            }
            if(SendDollarExitAwareOrder(request, result))
            {
               PrintFormat("Multi-Order Recovery: Kept original TP (%.5f) but using synthetic SL for position #%d",
                          MultiOrderGroups[new_index].original_tp, ticket);
                          
               // Calculate and draw the synthetic SL line
               double synthetic_sl = 0;
               
               // Use the same SL/TP method as the original trade
               if(InpSLTPMethod == SLTP_FIXED_POINTS)
               {
                  // Use fixed points method for synthetic SL
                  double point_value = SymbolInfoDouble(MultiOrderGroups[new_index].symbol, SYMBOL_POINT);
                  
                  if(MultiOrderGroups[new_index].type == POSITION_TYPE_BUY)
                  {
                     synthetic_sl = MultiOrderGroups[new_index].original_entry - (InpFixedSLPoints * point_value);
                  }
                  else
                  {
                     synthetic_sl = MultiOrderGroups[new_index].original_entry + (InpFixedSLPoints * point_value);
                  }
                  
                  PrintFormat("Multi-Order Recovery: Original trade synthetic SL uses fixed points: %.0f points (SL: %.5f)",
                            InpFixedSLPoints, synthetic_sl);
               }
               else
               {
                  // Use ATR-based method for synthetic SL
                  double atr = 0;
                  double atr_values[];
                  
                  if(CopyBuffer(iATR(MultiOrderGroups[new_index].symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) > 0)
                  {
                     atr = atr_values[0];
                     
                     // Original (base) position - ALWAYS use standard ATR multipliers, never custom ones
                     if(MultiOrderGroups[new_index].type == POSITION_TYPE_BUY)
                     {
                        synthetic_sl = MultiOrderGroups[new_index].original_entry - (atr * InpAtrMultiplierSL);
                     }
                     else
                     {
                        synthetic_sl = MultiOrderGroups[new_index].original_entry + (atr * InpAtrMultiplierSL);
                     }
                     
                     PrintFormat("Multi-Order Recovery: Original trade synthetic SL uses standard ATR multiplier: %.2f (ATR: %.5f, SL: %.5f)",
                               InpAtrMultiplierSL, atr, synthetic_sl);
                  }
               }
               
               // Draw the synthetic SL line on the chart
               DrawSyntheticSLLine(ticket, synthetic_sl, MultiOrderGroups[new_index].type);
               
               PrintFormat("Multi-Order Recovery: Created synthetic SL at %.5f for position #%d",
                          synthetic_sl, ticket);
               
               // Draw the original trade TP line in blue
               if(MultiOrderGroups[new_index].original_tp != 0)
               {
                  DrawOriginalTradeTPLine(ticket, MultiOrderGroups[new_index].original_tp);
                  PrintFormat("Multi-Order Recovery: Created original trade TP line at %.5f for position #%d",
                             MultiOrderGroups[new_index].original_tp, ticket);
               }
            }
            else
            {
               PrintFormat("Multi-Order Recovery: Failed to update SL/TP for position #%d. Error: %d",
                          ticket, GetLastError());
            }
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Calculate total profit/loss for a group                          |
//+------------------------------------------------------------------+
double CalculateGroupProfit(MultiOrderGroup &group)
{
   double total_profit = 0;
   bool original_position_closed = false;
   bool has_recovery_trades = false;
   int active_positions = 0;
   double hedge_profit = 0;
   
   // First check if the original position exists
   if(!PositionSelectByTicket(group.base_ticket))
   {
      // Original position is closed
      original_position_closed = true;
      if(!g_is_backtesting)
      {
         PrintFormat("Multi-Order Recovery: Original position #%d is closed.",
                    group.base_ticket);
      }
   }
   
   // Calculate profit for all positions and check for recovery trades
   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(PositionSelectByTicket(ticket))
      {
         double position_profit = PositionGetDouble(POSITION_PROFIT);
         total_profit += position_profit;
         active_positions++;
         
         // Check if this is the hedge trade
         if(group.hedge_activated && ticket == group.hedge_ticket)
         {
            hedge_profit = position_profit;
            if(!g_is_backtesting)
            {
               PrintFormat("Multi-Order Recovery: Hedge position #%d profit: %.2f", ticket, hedge_profit);
            }
         }
         
         // Check if this is a recovery trade (not the original trade)
         if(ticket != group.base_ticket)
         {
            has_recovery_trades = true;
         }
      }
   }
   
   // Debug information for hedged groups - More frequent logging
   if(group.hedge_activated)
   {
      static datetime last_detailed_log = 0;
      datetime current_time = TimeCurrent();
      
      // Log detailed breakdown every 15 seconds, or immediately if profit is positive
      if(current_time - last_detailed_log >= 15 || total_profit >= 0.0)
      {
         PrintFormat("Multi-Order Recovery: Group #%d PROFIT BREAKDOWN - Active positions: %d, TOTAL PROFIT: %.2f, Hedge profit: %.2f",
                    group.base_ticket, active_positions, total_profit, hedge_profit);
         
         // Detailed breakdown of all positions
         PrintFormat("Multi-Order Recovery: Position breakdown for hedged group #%d:", group.base_ticket);
         for(int j = 0; j < group.ticket_count; j++)
         {
            ulong ticket = group.tickets[j];
            if(PositionSelectByTicket(ticket))
            {
               double pos_profit = PositionGetDouble(POSITION_PROFIT);
               double pos_volume = PositionGetDouble(POSITION_VOLUME);
               ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
               string pos_comment = PositionGetString(POSITION_COMMENT);
               
               string position_label = "";
               if(ticket == group.base_ticket)
                  position_label = "MAIN";
               else if(ticket == group.hedge_ticket)
                  position_label = "HEDGE";
               else
                  position_label = "RECOVERY";
                  
               PrintFormat("  %s #%d: %s %.2f lots, Profit: %.2f (%s)",
                          position_label, ticket, EnumToString(pos_type), pos_volume, pos_profit, pos_comment);
            }
         }
         
         last_detailed_log = current_time;
      }
      
      // Always log when profit becomes positive for the first time
      static bool profit_positive_logged = false;
      if(total_profit >= 0.0 && !profit_positive_logged)
      {
         PrintFormat("*** HEDGED GROUP #%d HAS TURNED POSITIVE! Total Profit: %.2f ***", group.base_ticket, total_profit);
         profit_positive_logged = true;
      }
      else if(total_profit < 0.0)
      {
         profit_positive_logged = false; // Reset flag when profit goes negative again
      }
   }
   
   // If original position was closed and we have recovery positions,
   // close all remaining positions immediately
   if(original_position_closed && has_recovery_trades)
   {
      PrintFormat("Multi-Order Recovery: Original position #%d is closed. Found active recovery trades - closing all remaining positions.",
                group.base_ticket);
      group.close_reason = "original_closed";
      CloseAllPositionsInGroup(group);
   }
   
   return total_profit;
}

void RememberRealizedGroupPnL(MultiOrderGroup &group, const double realized_pnl, string reason)
{
   if(MathAbs(realized_pnl) < 0.0000001)
      return;

   group.realized_pnl_memory += realized_pnl;

   string reason_tag = (StringLen(reason) > 0) ? reason : "realized adjustment";
   PrintFormat("Group #%d memory updated (%s): add %.2f USD, memory now %.2f USD",
              group.base_ticket, reason_tag, realized_pnl, group.realized_pnl_memory);
}

double CalculateEffectiveGroupProfit(MultiOrderGroup &group)
{
   return CalculateGroupProfit(group) + group.realized_pnl_memory;
}

//+------------------------------------------------------------------+
//| Close all positions globally (across all groups and singles)     |
//+------------------------------------------------------------------+
void CloseAllPositionsGlobally(string reason = "global_protection")
{
   int total_groups_closed = 0;
   int total_single_positions_closed = 0;
   
   PrintFormat("GLOBAL CLOSURE: Starting to close ALL positions. Reason: %s", reason);
   
   // First close all positions in groups
   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      if(MultiOrderGroups[i].base_ticket == 0) continue;
      
      MultiOrderGroups[i].close_reason = reason;
      CloseAllPositionsInGroup(MultiOrderGroups[i]);
      total_groups_closed++;
      
      PrintFormat("GLOBAL CLOSURE: Closed group #%d (%d of %d groups)", 
                 MultiOrderGroups[i].base_ticket, i+1, ArraySize(MultiOrderGroups));
   }
   
   // Then close any remaining single positions not in groups
   for(int pos = 0; pos < PositionsTotal(); pos++)
   {
      ulong ticket = PositionGetTicket(pos);
      if(ticket == 0) continue;
      
      if(!PositionSelectByTicket(ticket)) continue;
      
      long magic = PositionGetInteger(POSITION_MAGIC);
      if(magic != InpMagicNumber) continue;
      
      string symbol = PositionGetString(POSITION_SYMBOL);
      
      // Check if this position is in any group
      bool in_group = false;
      for(int g = 0; g < ArraySize(MultiOrderGroups); g++)
      {
         if(MultiOrderGroups[g].base_ticket == 0) continue;
         if(MultiOrderGroups[g].base_ticket == ticket) { in_group = true; break; }
         for(int r = 0; r < MultiOrderGroups[g].attempts; r++)
         {
            if(MultiOrderGroups[g].tickets[r] == ticket) { in_group = true; break; }
         }
         if(in_group) break;
         if(MultiOrderGroups[g].hedge_ticket == ticket) { in_group = true; break; }
      }
      
      if(!in_group)
      {
         // Use OrderSend for closing instead of trade.PositionClose
         MqlTradeRequest request;
         MqlTradeResult result;
         ZeroMemory(request);
         ZeroMemory(result);
         
         request.action = TRADE_ACTION_DEAL;
         request.position = ticket;
         request.symbol = symbol;
         request.volume = PositionGetDouble(POSITION_VOLUME);
         request.type = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
         request.type_filling = ORDER_FILLING_IOC;
         request.comment = reason;
         
         if(!SendDollarExitAwareOrder(request, result))
         {
            PrintFormat("ERROR: Failed to close single position #%d in global closure: %d - Retcode: %d",
                       ticket, GetLastError(), result.retcode);
         }
         else
         {
            PrintFormat("GLOBAL CLOSURE: Closed single position #%d on %s (%s)",
                       ticket, symbol, reason);
            total_single_positions_closed++;
         }
      }
   }
   
   PrintFormat("GLOBAL CLOSURE COMPLETE: Closed %d groups and %d single positions. Reason: %s", 
              total_groups_closed, total_single_positions_closed, reason);
}

//+------------------------------------------------------------------+
//| Close all positions in a group                                   |
//+------------------------------------------------------------------+
void CloseAllPositionsInGroup(MultiOrderGroup &group)
{
   int closed_count = 0;
   int total_to_close = 0;
   int max_close_attempts = 5; // Increased from 3 to 5 attempts per position
   int final_validation_retries = 3; // Additional validation rounds
   
   // First close hedge position if active
   if(group.hedge_activated && group.hedge_ticket != 0)
   {
      if(PositionSelectByTicket(group.hedge_ticket))
      {
         PrintFormat("⚡ Closing hedge position #%d before closing group #%d",
                    group.hedge_ticket, group.base_ticket);
         if(ClosePosition(group.hedge_ticket))
         {
            group.hedge_activated = false;
            group.hedge_ticket = 0;
         }
      }
   }
   
   // Count positions that need to be closed
   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(PositionSelectByTicket(ticket))
      {
         total_to_close++;
      }
   }
   
   if(total_to_close == 0)
   {
      PrintFormat("Multi-Order Recovery: No positions to close in group with base ticket #%d", group.base_ticket);
      return;
   }
   
   PrintFormat("Multi-Order Recovery: Attempting to close %d position(s) in group with base ticket #%d (ENHANCED METHOD)", 
               total_to_close, group.base_ticket);
   
   // PHASE 1: Initial close attempts with delays
   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(!PositionSelectByTicket(ticket))
         continue;
         
      // If this is the original trade and there are no recovery trades, do not close it
      if(ticket == group.base_ticket && total_to_close == 1)
      {
         PrintFormat("Multi-Order Recovery: Skipping closure of original trade #%d (no recovery trades present)", ticket);
         continue;
      }
      
      bool position_closed = false;
      int retry_count = 0;
      
      while(!position_closed && retry_count < max_close_attempts)
      {
         // Re-check if position still exists before each attempt
         if(!PositionSelectByTicket(ticket))
         {
            position_closed = true;
            closed_count++;
            break;
         }
         
         MqlTradeRequest request;
         MqlTradeResult result;
         ZeroMemory(request);
         ZeroMemory(result);
         
         request.action = TRADE_ACTION_DEAL;
         request.position = ticket;
         request.symbol = PositionGetString(POSITION_SYMBOL);
         request.volume = PositionGetDouble(POSITION_VOLUME);
         request.deviation = InpMaxSlippagePoints;
         request.magic = InpMagicNumber;
         request.comment = StringFormat("RohitEA Close (%s)", group.close_reason);
         
         // Try different filling modes on retries
         if(retry_count == 0)
            request.type_filling = GetSupportedFillingMode(_Symbol);
         else if(retry_count == 1)
            request.type_filling = ORDER_FILLING_FOK;
         else if(retry_count == 2)
            request.type_filling = ORDER_FILLING_IOC;
         else
            request.type_filling = ORDER_FILLING_RETURN;
         
         if((ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
         {
            request.price = SymbolInfoDouble(request.symbol, SYMBOL_BID);
            request.type = ORDER_TYPE_SELL;
         }
         else
         {
            request.price = SymbolInfoDouble(request.symbol, SYMBOL_ASK);
            request.type = ORDER_TYPE_BUY;
         }
         
         if(!IsSpreadAcceptable()) 
         {
            Sleep(200); // Wait for spread to improve
            retry_count++;
            continue;
         }
         
         if(SendDollarExitAwareOrder(request, result))
         {
            PrintFormat("Multi-Order Recovery: Successfully closed %s position #%d on attempt %d (reason: %s)",
               (ticket == group.base_ticket ? "ORIGINAL" : "RECOVERY"), ticket, retry_count + 1, group.close_reason);
            position_closed = true;
            closed_count++;
         }
         else
         {
            retry_count++;
            int error_code = GetLastError();
            PrintFormat("Multi-Order Recovery: Failed to close position #%d. Error: %d. Attempt %d of %d",
                       ticket, error_code, retry_count, max_close_attempts);
            
            // Progressive delay - longer waits for later attempts
            if(retry_count < max_close_attempts)
            {
               int delay = (retry_count <= 2) ? 200 : (retry_count * 300);
               Sleep(delay);
            }
         }
      }
      
      if(!position_closed)
      {
         PrintFormat("Multi-Order Recovery: CRITICAL - Position #%d still open after %d attempts", 
                    ticket, max_close_attempts);
      }
      
      // Small delay between positions to prevent overwhelming the broker
      if(i < group.ticket_count - 1) Sleep(50);
   }
   
   // PHASE 2: Validation and cleanup of remaining open positions
   PrintFormat("Multi-Order Recovery: PHASE 1 completed. Closed %d/%d positions. Starting validation...", 
               closed_count, total_to_close);
   
   for(int validation_round = 1; validation_round <= final_validation_retries; validation_round++)
   {
      int remaining_positions = 0;
      ulong remaining_tickets[];
      
      // Count remaining open positions
      for(int i = 0; i < group.ticket_count; i++)
      {
         ulong ticket = group.tickets[i];
         if(PositionSelectByTicket(ticket))
         {
            // Skip original trade if it's the only one left
            if(ticket == group.base_ticket && remaining_positions == 0)
            {
               bool has_other_positions = false;
               for(int j = 0; j < group.ticket_count; j++)
               {
                  if(j != i && PositionSelectByTicket(group.tickets[j]))
                  {
                     has_other_positions = true;
                     break;
                  }
               }
               if(!has_other_positions) continue;
            }
            
            remaining_positions++;
            ArrayResize(remaining_tickets, remaining_positions);
            remaining_tickets[remaining_positions - 1] = ticket;
         }
      }
      
      if(remaining_positions == 0)
      {
         PrintFormat("Multi-Order Recovery: SUCCESS - All positions closed after validation round %d", validation_round);
         break;
      }
      
      PrintFormat("Multi-Order Recovery: PHASE 2 Round %d - Found %d remaining positions, attempting force close...", 
                  validation_round, remaining_positions);
      
      // Force close remaining positions using alternative methods
      for(int i = 0; i < remaining_positions; i++)
      {
         ulong ticket = remaining_tickets[i];
         if(!PositionSelectByTicket(ticket)) continue;
         
         PrintFormat("Multi-Order Recovery: Force closing remaining position #%d (validation round %d)", 
                    ticket, validation_round);
         
         // Use the enhanced ForceClosePosition function
         bool force_success = ForceClosePosition(ticket, "Multi-Order Group Cleanup");
         if(force_success)
         {
            closed_count++;
         }
         
         Sleep(100); // Delay between force closures
      }
      
      // Wait before next validation round
      if(validation_round < final_validation_retries)
      {
         Sleep(500);
      }
   }
   
   // PHASE 3: Final verification and reporting
   int final_remaining = 0;
   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      if(PositionSelectByTicket(ticket))
      {
         // Don't count original trade if it's alone
         if(ticket == group.base_ticket)
         {
            bool has_recovery_positions = false;
            for(int j = 0; j < group.ticket_count; j++)
            {
               if(j != i && PositionSelectByTicket(group.tickets[j]))
               {
                  has_recovery_positions = true;
                  break;
               }
            }
            if(!has_recovery_positions) continue;
         }
         final_remaining++;
      }
   }
   
   if(final_remaining == 0)
   {
      PrintFormat("Multi-Order Recovery: COMPLETE SUCCESS - All %d positions closed in group (base: #%d)", 
                 total_to_close, group.base_ticket);
   }
   else
   {
      PrintFormat("Multi-Order Recovery: PARTIAL CLOSURE - %d positions remain open out of %d total (ORPHAN ALERT!)", 
                 final_remaining, total_to_close);
      
      // Log remaining positions for manual intervention
      for(int i = 0; i < group.ticket_count; i++)
      {
         ulong ticket = group.tickets[i];
         if(PositionSelectByTicket(ticket))
         {
            PrintFormat("Multi-Order Recovery: ORPHAN POSITION - Ticket #%d (%s) still open - Manual intervention required",
                       ticket, (ticket == group.base_ticket ? "ORIGINAL" : "RECOVERY"));
         }
      }
   }
   
   // Clean up all chart objects for this group when positions are closed
   CleanupGroupChartObjects(group);
}

//+------------------------------------------------------------------+
//| Check if hedging conditions are met and activate hedge           |
//+------------------------------------------------------------------+
bool CheckAndActivateHedging(MultiOrderGroup &group)
{
   // Skip if hedging is disabled or already activated for this group
   if(!InpHedgingEnabled || group.hedge_activated)
      return false;
      
   // Check if we have enough recovery trades to trigger hedging
   if(group.attempts < InpHedgingTriggerAfter)
      return false;
      
   // Check if we should stop recovery trades after hedging
   if(InpHedgingStopRecovery && group.hedge_activated)
      return false;
   
   // Get current price
   double current_price = 0;
   if(group.type == POSITION_TYPE_BUY)
      current_price = SymbolInfoDouble(group.symbol, SYMBOL_BID);
   else
      current_price = SymbolInfoDouble(group.symbol, SYMBOL_ASK);
   
   // Calculate distance from main trade entry
   double distance = MathAbs(current_price - group.original_entry);
   bool should_hedge = false;
   
   if(InpHedgingUseATRDistance)
   {
      // Use ATR-based distance calculation
      double atr_values[];
      if(CopyBuffer(g_atr_handle, 0, 1, 1, atr_values) <= 0)
      {
         PrintFormat("Hedging: Could not get ATR value. Error: %d", GetLastError());
         return false;
      }
      double atr = atr_values[0];
      double trigger_distance = atr * InpHedgingDistanceATR;
      
      if(distance >= trigger_distance)
      {
         should_hedge = true;
         group.hedge_trigger_distance = distance;
         PrintFormat("Hedging: ATR-based trigger condition met. Distance: %.5f >= Trigger: %.5f (%.1f × ATR %.5f)",
                    distance, trigger_distance, InpHedgingDistanceATR, atr);
      }
   }
   else
   {
      // Use percentage-based distance calculation
      double trigger_distance = group.original_entry * (InpHedgingDistancePercent / 100.0);
      
      if(distance >= trigger_distance)
      {
         should_hedge = true;
         group.hedge_trigger_distance = distance;
         PrintFormat("Hedging: Percentage-based trigger condition met. Distance: %.5f >= Trigger: %.5f (%.1f%%)",
                    distance, trigger_distance, InpHedgingDistancePercent);
      }
   }
   
   if(!should_hedge)
      return false;
   
   // Activate hedging - open opposite position
   PrintFormat("Hedging: Activating hedge for group with base ticket #%d after %d recovery trades. Distance from entry: %.5f",
              group.base_ticket, group.attempts, distance);
   
   // Calculate hedge position size
   double hedge_volume = group.total_volume * InpHedgingSizeMultiplier;
   
   // Normalize hedge volume
   double min_lot = GetEffectiveMinLot(group.symbol);
   double max_lot = GetEffectiveMaxLot(group.symbol);
   double lot_step = SymbolInfoDouble(group.symbol, SYMBOL_VOLUME_STEP);
   
   hedge_volume = MathMax(min_lot, hedge_volume);
   hedge_volume = MathMin(max_lot, hedge_volume);
   if(lot_step > 0)
   {
      hedge_volume = MathFloor(hedge_volume / lot_step) * lot_step;
   }
   hedge_volume = NormalizeDouble(hedge_volume, 2);
   
   // Determine hedge direction (opposite to main trade)
   ENUM_ORDER_TYPE hedge_order_type = (group.type == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
   
   // Calculate hedge entry price
   double hedge_entry = 0;
   if(hedge_order_type == ORDER_TYPE_BUY)
      hedge_entry = SymbolInfoDouble(group.symbol, SYMBOL_ASK);
   else
      hedge_entry = SymbolInfoDouble(group.symbol, SYMBOL_BID);
   
   // Prepare hedge trade request
   MqlTradeRequest request;
   MqlTradeResult result;
   ZeroMemory(request);
   ZeroMemory(result);
   
   request.action = TRADE_ACTION_DEAL;
   request.symbol = group.symbol;
   request.volume = hedge_volume;
   request.type = hedge_order_type;
   request.price = hedge_entry;
   request.sl = 0; // No SL for hedge - we'll manage it manually
   request.tp = 0; // No TP for hedge - we'll close when overall P&L is favorable
   request.deviation = InpMaxSlippagePoints;
   request.magic = InpMagicNumber;
   request.comment = StringFormat("🛡️ Hedge for #%d", group.base_ticket);
   request.type_filling = GetSupportedFillingMode(_Symbol);
   
   if(!IsSpreadAcceptable()) return false;
   if(!SendDollarExitAwareOrder(request, result))
   {
      PrintFormat("Hedging: Failed to open hedge position. Error: %d", GetLastError());
      return false;
   }
   
   // Update group with hedge information
   group.pre_hedge_attempts = group.attempts;  // Store current recovery attempts
   group.hedge_activated = true;
   group.hedge_ticket = result.order;
   group.hedge_entry = hedge_entry;
   group.hedge_lot = hedge_volume;
   group.hedge_time = TimeCurrent();
   
   // Close all existing recovery trades when hedge is activated (if enabled)
   int recovery_trades_closed = 0;
   
   if(InpHedgingCloseRecoveryTrades)
   {
      PrintFormat("Hedging: Closing all recovery trades since hedge is now active...");
      
      for(int i = 0; i < group.ticket_count; i++)
      {
         ulong ticket = group.tickets[i];
         
         // Skip the base trade (original position) - keep it open
         if(ticket == group.base_ticket) continue;
         
         // Skip if this is the hedge ticket we just created
         if(ticket == result.order) continue;
         
         // This is a recovery trade - close it
         if(PositionSelectByTicket(ticket))
         {
            if(ForceClosePosition(ticket, "Hedge activated - closing recovery trade"))
            {
               recovery_trades_closed++;
               PrintFormat("Hedging: Closed recovery trade #%d", ticket);
               
               // Clean up chart objects for this recovery trade
               CleanupSyntheticSLLine(ticket);
               CleanupOriginalTradeTPLine(ticket);
            }
         }
      }
   }
   else
   {
      PrintFormat("Hedging: Recovery trades will remain open (InpHedgingCloseRecoveryTrades=false)");
   }
   
   if(InpHedgingCloseRecoveryTrades && recovery_trades_closed > 0)
   {
      PrintFormat("Hedging: Successfully closed %d recovery trades. Only base trade #%d and hedge #%d remain.", 
                 recovery_trades_closed, group.base_ticket, result.order);
      
      // Update the group to reflect only the base trade and hedge
      // Reset ticket array with only base trade and hedge
      group.tickets[0] = group.base_ticket;
      group.tickets[1] = result.order;
      group.ticket_count = 2;
      group.total_volume = group.original_lot + hedge_volume;
      
      // Optional: Reset attempts counter since hedge strategy is now active
      // This prevents further recovery attempts beyond hedge
      PrintFormat("Hedging: Recovery attempts reset from %d to 0 - hedge strategy now active", group.attempts);
      group.attempts = 0;
   }
   else
   {
      // Add hedge ticket to the group's ticket array (keep existing recovery trades)
      if(group.ticket_count < 500)
      {
         group.tickets[group.ticket_count] = result.order;
         group.ticket_count++;
         group.total_volume += hedge_volume;
      }
      
      if(!InpHedgingCloseRecoveryTrades)
      {
         PrintFormat("Hedging: Recovery trades kept open. Group now has base trade + %d recovery trades + hedge.", 
                    group.ticket_count - 2); // -2 for base trade and hedge
      }
   }
   
   PrintFormat("Hedging: Successfully opened hedge position #%d. Direction: %s, Volume: %.2f, Entry: %.5f",
              result.order, EnumToString(hedge_order_type), hedge_volume, hedge_entry);
   
   if(InpHedgingCloseRecoveryTrades && recovery_trades_closed > 0)
   {
      PrintFormat("Hedging: Strategy complete - Base trade #%d + Hedge #%d (total: %d positions). Recovery trades closed.",
                 group.base_ticket, result.order, group.ticket_count);
   }
   else if(!InpHedgingCloseRecoveryTrades)
   {
      PrintFormat("Hedging: Group has %d positions total (base + recovery trades + hedge). Recovery trades kept open.",
                 group.ticket_count);
   }
   else
   {
      PrintFormat("Hedging: Group now has %d positions total. Hedge added to existing positions.",
                 group.ticket_count);
   }
   
   return true;
}
//+------------------------------------------------------------------+
//| Determine recovery order direction, respecting reverse flag       |
//+------------------------------------------------------------------+
ENUM_ORDER_TYPE DetermineRecoveryOrderType(const MultiOrderGroup &group)
{
   if(InpMultiOrderReverseDirection)
      return (group.type == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
   
   return (group.type == POSITION_TYPE_BUY) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
}

//+------------------------------------------------------------------+
//| Open a new recovery position                                     |
//+------------------------------------------------------------------+
void OpenRecoveryPosition(MultiOrderGroup &group)
{
   // *** STRICT HEDGE CHECK ***
   // Check if this group or any other group has active hedging - prevent ALL recovery trades
   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      if(MultiOrderGroups[i].hedge_activated)
      {
         PrintFormat("❌ RECOVERY BLOCKED: Cannot open recovery trades while hedge position #%d is active",
                    MultiOrderGroups[i].hedge_ticket);
         return;  // Exit immediately - no recovery trades allowed
      }
   }
   
   // SAFEGUARD 0: Additional check for this specific group
   if(InpHedgingEnabled && group.hedge_activated && InpHedgingStopRecovery)
   {
      PrintFormat("Multi-Order Recovery: Recovery trades blocked - hedge is active for group #%d", group.base_ticket);
      return;
   }
   
   // SAFEGUARD 1: Time-based throttling - only one recovery per 3 seconds
   datetime current_time = TimeCurrent();
   if(current_time - g_lastRecoveryTime < 3)
   {
      PrintFormat("Multi-Order Recovery: Throttling recovery - last one opened %d seconds ago", 
                 current_time - g_lastRecoveryTime);
      return;
   }
   
   // SAFEGUARD 1A: Additional throttling for HeikinAshi recovery - 10 seconds minimum gap
   if(InpHARecoveryConfirmationEnabled && current_time - g_lastRecoveryTime < 10)
   {
      PrintFormat("Multi-Order Recovery: HeikinAshi throttling - minimum 10 seconds between HA recovery trades. Last: %d seconds ago", 
                 current_time - g_lastRecoveryTime);
      return;
   }

   // SAFEGUARD 2: Verify we haven't reached max attempts
   if(group.attempts >= InpMultiOrderMaxAttempts)
   {
      PrintFormat("Multi-Order Recovery: Maximum attempts (%d) reached for group with base ticket #%d. Closing all positions.",
                 InpMultiOrderMaxAttempts, group.base_ticket);
      group.close_reason = "max_recovery_reached";
      CloseAllPositionsInGroup(group);
      return;
   }

   // SAFEGUARD 3: Check if we're approaching the max array size
   if(group.ticket_count >= 495)  // Using 495 to be safe with 500 array size
   {
      PrintFormat("Multi-Order Recovery: Approaching maximum tracking limit (%d positions). Closing all positions.",
                 500);
      group.close_reason = "array_limit_reached";
      CloseAllPositionsInGroup(group);
      return;
   }

   if(TryActivateHaltRecoveryHedge(group))
   {
      PrintFormat("Halt Multi-Recovery: Recovery entry paused for base #%d while temporary hedge control is active.",
                 group.base_ticket);
      return;
   }

   // Get the last recovery position's entry price for price movement verification
   double last_entry = 0;
   if(group.ticket_count > 0 && group.attempts > 0)
   {
      ulong last_ticket = group.tickets[group.ticket_count - 1];
      if(PositionSelectByTicket(last_ticket))
      {
         last_entry = PositionGetDouble(POSITION_PRICE_OPEN);
      }
   }

   // Increment attempts counter
   group.attempts++;
   string symbol = group.symbol;
   
   ENUM_POSITION_TYPE original_pos_type = group.type;
   ENUM_ORDER_TYPE recovery_order_type = DetermineRecoveryOrderType(group);

   if(InpMultiOrderReverseDirection)
   {
       PrintFormat("Multi-Order Recovery: Reversing direction. Original was %s, recovery will be %s.",
                   EnumToString(original_pos_type), EnumToString(recovery_order_type));
   }
   
   // Calculate ATR for SL/TP (using original logic)
   double atr_values[];
   if(CopyBuffer(iATR(symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) <= 0)
   {
      PrintFormat("Multi-Order Recovery: Could not get ATR value. Error %d", GetLastError());
      return;
   }
   double atr = atr_values[0];
   
   // Calculate entry, SL and TP prices
   double entry_price, sl_price, tp_price;
   
   // Check if we should use original trade's SL distance or follow global SL/TP method
   if(InpMultiOrderUseOriginalSLDistance && group.original_sl_distance > 0)
   {
      // Use the original trade's SL distance for recovery trades
      double sl_distance = group.original_sl_distance;
      
      if(recovery_order_type == ORDER_TYPE_BUY)
      {
         entry_price = SymbolInfoDouble(symbol, SYMBOL_ASK);
         sl_price = entry_price - sl_distance;
         // For TP, use the same distance to maintain 1:1 ratio (or use original ratio if available)
         tp_price = entry_price + sl_distance;
      }
      else // SELL
      {
         entry_price = SymbolInfoDouble(symbol, SYMBOL_BID);
         sl_price = entry_price + sl_distance;
         tp_price = entry_price - sl_distance;
      }
      
      PrintFormat("Multi-Order Recovery: Using original SL distance (%.5f) for recovery position. 1:1 risk-reward ratio applied.",
                 sl_distance);
   }
   else if(InpSLTPMethod == SLTP_FIXED_POINTS)
   {
      // Use fixed points method for recovery trades to match original trade method
      double point_value = SymbolInfoDouble(symbol, SYMBOL_POINT);
      
      if(recovery_order_type == ORDER_TYPE_BUY)
      {
         entry_price = SymbolInfoDouble(symbol, SYMBOL_ASK);
         sl_price = entry_price - (InpFixedSLPoints * point_value);
         tp_price = entry_price + (InpFixedTPPoints * point_value);
      }
      else // SELL
      {
         entry_price = SymbolInfoDouble(symbol, SYMBOL_BID);
         sl_price = entry_price + (InpFixedSLPoints * point_value);
         tp_price = entry_price - (InpFixedTPPoints * point_value);
      }
      
      PrintFormat("Multi-Order Recovery: Using fixed points method for recovery position. SL: %.0f points, TP: %.0f points",
                 InpFixedSLPoints, InpFixedTPPoints);
   }
   else
   {
      // Use ATR-based method (original logic)
      double sl_multiplier = InpMultiOrderCustomSLTP ? InpMultiOrderSLMultiplier : InpAtrMultiplierSL;
      double tp_multiplier = InpMultiOrderCustomSLTP ? InpMultiOrderTPMultiplier : InpAtrMultiplierTP;
      
      if(InpMultiOrderCustomSLTP)
      {
         PrintFormat("Multi-Order Recovery: Using custom SL/TP multipliers for RECOVERY position. SL: %.2f × ATR, TP: %.2f × ATR (default: %.2f, %.2f)",
                    sl_multiplier, tp_multiplier, InpAtrMultiplierSL, InpAtrMultiplierTP);
      }
      
      if(recovery_order_type == ORDER_TYPE_BUY)
      {
         entry_price = SymbolInfoDouble(symbol, SYMBOL_ASK);
         sl_price = entry_price - (atr * sl_multiplier);
         tp_price = entry_price + (atr * tp_multiplier);
      }
      else // SELL
      {
         entry_price = SymbolInfoDouble(symbol, SYMBOL_BID);
         sl_price = entry_price + (atr * sl_multiplier);
         tp_price = entry_price - (atr * tp_multiplier);
      }
      
      PrintFormat("Multi-Order Recovery: Using ATR-based method for recovery position. ATR: %.5f, SL Mult: %.2f, TP Mult: %.2f",
                 atr, sl_multiplier, tp_multiplier);
   }

   // Determine lot size to use - either same as original trade or risk-based calculation
   double volume;
   if(InpMultiOrderUseOriginalLot)
   {
      volume = group.original_lot;
      PrintFormat("Multi-Order Recovery: Using original trade lot size: %.2f (option InpMultiOrderUseOriginalLot=true)",
                 volume);
   }
   else
   {
      // Handle different risk calculation methods
      if(InpRiskCalcMethod == RISK_CALC_FIXED_LOT)
      {
         // Use fixed lot size directly
         volume = InpFixedLotSize;
         PrintFormat("Multi-Order Recovery: Using fixed lot size: %.2f (Fixed Lot Mode)", volume);
      }
      else
      {
         // For percentage-based methods, use main trade's lot as base (ensures consistency with main trade risk%)
         // This avoids recalculating with different SL distances
         volume = group.original_lot;
         PrintFormat("Multi-Order Recovery: Using original trade lot size: %.2f (Base for percentage-based risk methods)",
                 volume);
      }
   }
   
   // Apply lot multiplier if enabled and threshold reached
   double original_volume = volume; // Store the calculated volume before applying multiplier
   
   if(InpMultiOrderLotMultiplierStart > 0 && 
      group.attempts > InpMultiOrderLotMultiplierStart && 
      InpMultiOrderLotMultiplier > 1.0)
   {
      int multiplier_steps = group.attempts - InpMultiOrderLotMultiplierStart;
      double multiplier = MathPow(InpMultiOrderLotMultiplier, multiplier_steps);
      if(InpMultiOrderLotReduction)
      {
         // Reduce lot size for each recovery (anti-martingale)
         volume = NormalizeDouble(volume / multiplier, 2);
         PrintFormat("Multi-Order Recovery: Applying lot REDUCTION for attempt %d. Risk-based: %.2f, Multiplier: %.2f, Final: %.2f",
                    group.attempts, original_volume, multiplier, volume);
      }
      else
      {
         // Increase lot size for each recovery (martingale)
         volume = NormalizeDouble(volume * multiplier, 2);
         PrintFormat("Multi-Order Recovery: Applying lot INCREASE for attempt %d. Risk-based: %.2f, Multiplier: %.2f, Final: %.2f",
                    group.attempts, original_volume, multiplier, volume);
      }
      
      // Ensure volume is within allowed limits
      double min_lot = GetEffectiveMinLot(symbol);
      double max_lot = GetEffectiveMaxLot(symbol);
      double lot_step = SymbolInfoDouble(symbol, SYMBOL_VOLUME_STEP);
      volume = MathMax(min_lot, volume);
      volume = MathMin(max_lot, volume);
      if(lot_step > 0)
      {
         volume = MathFloor(volume / lot_step) * lot_step;
      }
      volume = NormalizeDouble(volume, 2); // Ensure proper normalization
   }
   
   // Prepare and send the order
   MqlTradeRequest request;
   MqlTradeResult result;
   ZeroMemory(request);
   ZeroMemory(result);
   
   request.action = TRADE_ACTION_DEAL;
   request.symbol = symbol;
   request.volume = volume;
   request.type = recovery_order_type;
   request.price = entry_price;
   
   // For the last recovery attempt, use real SL to conclude recovery failure
   // For all other recovery positions, use synthetic SL
   bool is_final_recovery = (group.attempts >= InpMultiOrderMaxAttempts);
   if(is_final_recovery)
   {
      // This is the last allowed recovery position - use real SL
      request.sl = sl_price;
      PrintFormat("Multi-Order Recovery: Using real SL (%.5f) for final recovery position (attempt %d of %d)",
                 sl_price, group.attempts, InpMultiOrderMaxAttempts);
   }
   else
   {
      // Not the last recovery position - use synthetic SL
      request.sl = 0;
      
      // Store the synthetic SL value to draw it after position is opened
      double synthetic_sl = (recovery_order_type == ORDER_TYPE_BUY) ? sl_price : sl_price;
   }
   
   request.tp = 0; // Don't set individual TPs - we'll close all positions together when profit target is reached
   request.deviation = InpMaxSlippagePoints;
   request.magic = InpMagicNumber;
   request.type_filling = GetSupportedFillingMode(_Symbol);
   
   if(!IsSpreadAcceptable()) return;
   
   // Multi-tier fallback system for recovery trades
   bool trade_opened = false;
   string fallback_reason = "";
   double calculated_volume = volume;
   
   // Attempt 1: Try with calculated volume
   request.volume = volume;
   request.comment = StringFormat("Recovery-%d for #%d", group.attempts, group.base_ticket);
   
   if(SendDollarExitAwareOrder(request, result))
   {
      trade_opened = true;
      PrintFormat("Multi-Order Recovery: Successfully opened with calculated lot size %.2f", volume);
   }
   else
   {
      int first_error = GetLastError();
      PrintFormat("Multi-Order Recovery: Failed with calculated lot %.2f. Error: %d. Trying fallback...", volume, first_error);
      
      // Attempt 2: Try with original trade lot size
      if(group.original_lot > 0 && group.original_lot != volume)
      {
         volume = group.original_lot;
         request.volume = volume;
         request.comment = StringFormat("Recovery-%d-FALLBACK-ORIG for #%d", group.attempts, group.base_ticket);
         ZeroMemory(result); // Clear previous result
         
         if(SendDollarExitAwareOrder(request, result))
         {
            trade_opened = true;
            fallback_reason = StringFormat("(FALLBACK: Used original lot %.2f instead of calculated %.2f)", volume, calculated_volume);
            PrintFormat("Multi-Order Recovery: Successfully opened with original lot size %.2f", volume);
         }
         else
         {
            int second_error = GetLastError();
            PrintFormat("Multi-Order Recovery: Failed with original lot %.2f. Error: %d. Trying minimum lot...", volume, second_error);
            
            // Attempt 3: Try with minimum lot (0.01)
            double min_lot = MathMax(0.01, GetEffectiveMinLot(symbol));
            volume = min_lot;
            request.volume = volume;
            request.comment = StringFormat("Recovery-%d-FALLBACK-MIN for #%d", group.attempts, group.base_ticket);
            ZeroMemory(result); // Clear previous result
            
            if(SendDollarExitAwareOrder(request, result))
            {
               trade_opened = true;
               fallback_reason = StringFormat("(FALLBACK: Used minimum lot %.2f, orig calc: %.2f, orig trade: %.2f)", volume, calculated_volume, group.original_lot);
               PrintFormat("Multi-Order Recovery: Successfully opened with minimum lot size %.2f", volume);
            }
            else
            {
               int third_error = GetLastError();
               PrintFormat("Multi-Order Recovery: ALL FALLBACK ATTEMPTS FAILED! Calc lot %.2f (Error %d), Orig lot %.2f (Error %d), Min lot %.2f (Error %d)", 
                          calculated_volume, first_error, group.original_lot, second_error, volume, third_error);
               group.attempts--; // Revert the increment since all attempts failed
            }
         }
      }
      else
      {
         // Skip attempt 2 if original lot is same as calculated or invalid
         double min_lot = MathMax(0.01, GetEffectiveMinLot(symbol));
         volume = min_lot;
         request.volume = volume;
         request.comment = StringFormat("Recovery-%d-FALLBACK-MIN for #%d", group.attempts, group.base_ticket);
         ZeroMemory(result); // Clear previous result
         
         if(SendDollarExitAwareOrder(request, result))
         {
            trade_opened = true;
            fallback_reason = StringFormat("(FALLBACK: Used minimum lot %.2f instead of calculated %.2f)", volume, calculated_volume);
            PrintFormat("Multi-Order Recovery: Successfully opened with minimum lot size %.2f", volume);
         }
         else
         {
            int final_error = GetLastError();
            PrintFormat("Multi-Order Recovery: ALL ATTEMPTS FAILED! Calc lot %.2f (Error %d), Min lot %.2f (Error %d)", 
                       calculated_volume, first_error, volume, final_error);
            group.attempts--; // Revert the increment since all attempts failed
         }
      }
   }
   
   if(!trade_opened)
   {
      return; // Exit if all attempts failed
   }
   
   // Trade was successfully opened (either normal or fallback)
   PrintFormat("Multi-Order Recovery: Successfully opened recovery position #%d (attempt %d of %d) for base ticket #%d, Lot: %.2f %s",
              result.order, group.attempts, InpMultiOrderMaxAttempts, group.base_ticket, volume, fallback_reason);
   
   // Update the global last recovery time
   g_lastRecoveryTime = current_time;

    // Reset Pattern 9 recovery confirmation state so next recovery is re-evaluated cleanly
    ResetPattern9RecoveryStateAfterTrade(group.base_ticket);
    // Reset Pattern 18 recovery confirmation state so next recovery is re-evaluated cleanly
    ResetPattern18RecoveryStateAfterTrade(group.base_ticket);
   
   // Draw the synthetic SL line for recovery position, if not the last attempt
   if(!is_final_recovery)
   {
      DrawSyntheticSLLine(result.order, sl_price, (ENUM_POSITION_TYPE)((recovery_order_type == ORDER_TYPE_BUY) ? POSITION_TYPE_BUY : POSITION_TYPE_SELL));
      PrintFormat("Multi-Order Recovery: Created synthetic SL line at %.5f for recovery position #%d", 
                 sl_price, result.order);
   }
     // --- NEW LOGIC: Remove main trade TP when first recovery triggers ---
     if (group.attempts == 1 && group.base_ticket > 0) // Only on first recovery
     {
           if (PositionSelectByTicket(group.base_ticket))
           {
              // Fetch base position details
              double base_current_sl = PositionGetDouble(POSITION_SL);
              ulong base_ticket = group.base_ticket;

              double main_tp = PositionGetDouble(POSITION_TP);
              if (main_tp != 0.0)
              {
                 MqlTradeRequest mod_req; MqlTradeResult mod_res;
                 ZeroMemory(mod_req); ZeroMemory(mod_res);
                 mod_req.action = TRADE_ACTION_SLTP;
                 mod_req.position = base_ticket;
                 mod_req.symbol = group.symbol;
                 mod_req.tp = 0.0;
                 mod_req.sl = base_current_sl; // keep SL unchanged
                 mod_req.magic = InpMagicNumber;
                 mod_req.comment = "Remove TP for multi recovery";
                 mod_req.type_filling = GetSupportedFillingMode(group.symbol);
                 if (SendDollarExitAwareOrder(mod_req, mod_res))
                 {
                    PrintFormat("Multi-Order Recovery: Main trade TP removed (set to zero) for base ticket #%d due to recovery trigger.", base_ticket);
                 }
                 else
                 {
                    PrintFormat("Multi-Order Recovery: Failed to remove main trade TP for base ticket #%d. Error: %d", base_ticket, GetLastError());
                 }
              }
           }
        }
                
   // Add the new position to the group
   if(result.order > 0 && group.ticket_count < 500) // Changed from 50 to 500 to match array size
   {
      group.tickets[group.ticket_count] = result.order;
      group.ticket_count++;
      group.total_volume += volume;
      group.activated = true;
      
      // If this is the final recovery position, mark it for special handling
      if(is_final_recovery)
      {
         PrintFormat("Multi-Order Recovery: Position #%d is the final recovery attempt. Group will be closed if SL is hit.",
                    result.order);
      }
   }
}

//+------------------------------------------------------------------+
//| Clean up closed Multi-Order Groups                               |
//+------------------------------------------------------------------+
void CleanupMultiOrderGroups()
{
   for(int i = ArraySize(MultiOrderGroups) - 1; i >= 0; i--)
   {
      // Check if we've reached or exceeded max attempts globally
      if(MultiOrderGroups[i].attempts >= InpMultiOrderMaxAttempts)
      {
         PrintFormat("Multi-Order Recovery: Group #%d has reached/exceeded maximum attempts (%d vs %d). Will force close all positions.",
                    MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].attempts, InpMultiOrderMaxAttempts);
         MultiOrderGroups[i].close_reason = "max_recovery_reached";
         CloseAllPositionsInGroup(MultiOrderGroups[i]);
         
         // Clean up all chart objects for this group
         CleanupGroupChartObjects(MultiOrderGroups[i]);
         
         // After closing all positions, clean up the group
         for(int j = i; j < ArraySize(MultiOrderGroups) - 1; j++)
         {
            MultiOrderGroups[j] = MultiOrderGroups[j + 1];
         }
         ArrayResize(MultiOrderGroups, ArraySize(MultiOrderGroups) - 1);
         SaveRecoveryState();
         continue; // Skip to next group after removing this one
      }
      
      // Continue with normal position checking
      bool all_closed = true;
      int open_positions = 0;
      ulong last_open_ticket = 0;
      bool last_recovery_closed = false;
      bool is_final_recovery = (MultiOrderGroups[i].attempts >= InpMultiOrderMaxAttempts);
      
      // Count how many positions are still open and which ones
      for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
      {
         ulong current_ticket = MultiOrderGroups[i].tickets[j];
         
         if(PositionSelectByTicket(current_ticket))
         {
            all_closed = false;
            open_positions++;
            last_open_ticket = current_ticket;
         }
         else
         {
            // Position was closed, clean up its synthetic SL line and TP line
            CleanupSyntheticSLLine(current_ticket);
            CleanupOriginalTradeTPLine(current_ticket);
            PrintFormat("Multi-Order Recovery: Cleaned up synthetic SL line and TP line for closed position #%d", current_ticket);
         }
      }
      
      // If all positions are closed, remove this group
      if(all_closed)
      {
         PrintFormat("Multi-Order Recovery: Removing group with base ticket #%d (all positions closed)",
                    MultiOrderGroups[i].base_ticket);
         
         // Clean up all chart objects for this group
         CleanupGroupChartObjects(MultiOrderGroups[i]);
                    
         // Shift remaining groups
         for(int j = i; j < ArraySize(MultiOrderGroups) - 1; j++)
         {
            MultiOrderGroups[j] = MultiOrderGroups[j + 1];
         }
         
         // Resize array and save the new state
         ArrayResize(MultiOrderGroups, ArraySize(MultiOrderGroups) - 1);
         SaveRecoveryState();
      }
      // If the last recovery position was closed by SL, close all remaining positions
      else if(last_recovery_closed && open_positions > 0)
      {
         PrintFormat("Multi-Order Recovery: Final recovery position hit SL with %d other position(s) still open. Closing entire group.",
                    open_positions);
         MultiOrderGroups[i].close_reason = "recovery_failed";
         CloseAllPositionsInGroup(MultiOrderGroups[i]);
         
         // Clean up all chart objects for this group
         CleanupGroupChartObjects(MultiOrderGroups[i]);
         
         // After closing all positions, remove the group
         for(int j = i; j < ArraySize(MultiOrderGroups) - 1; j++)
         {
            MultiOrderGroups[j] = MultiOrderGroups[j + 1];
         }
         ArrayResize(MultiOrderGroups, ArraySize(MultiOrderGroups) - 1);
         SaveRecoveryState();
      }
   }
}

