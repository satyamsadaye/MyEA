                    PrintFormat("Pattern 8: Failed to place %s order. Error: %d", 
                               (final_order_type == ORDER_TYPE_BUY) ? "BUY" : "SELL", GetLastError());
                }
            }
            else
            {
                PrintFormat("[DEV MODE] Pattern 8: Would place %s order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (RED→%dGREEN HA)",
                           (final_order_type == ORDER_TYPE_BUY) ? "BUY" : "SELL",
                           entryPrice, stopLoss, takeProfit, lots, g_p8_consecutiveGreen);
            }
            
            // Mark signal as processed
            g_lastSignalTime = current_bar_time;
        }
        else
        {
            if(!g_is_backtesting)
            {
                PrintFormat("Pattern 8: BUY pattern available but %s", 
                           buy_pattern_used ? "already used" : "too soon after last trigger");
            }
        }
    }
    // Process SELL signal
    else if(sell_pattern_found)
    {
        bool is_new_sell_pattern = (current_bar_time != last_sell_pattern_time);
        
        if(is_new_sell_pattern)
        {
            sell_pattern_used = false; // Reset for new pattern
            last_sell_pattern_time = current_bar_time;
        }
        
        if(!sell_pattern_used && (TimeCurrent() - last_sell_trigger_time >= 300)) // 5 minutes minimum
        {
            g_p8_sellSignalReady = true;
            sell_pattern_used = true;
            last_sell_trigger_time = TimeCurrent();
            
            if(!g_is_backtesting)
            {
                PrintFormat("Pattern 8: SELL signal TRIGGERED - %d consecutive RED after GREEN setup", 
                           g_p8_consecutiveRed);
            }
            
            // Execute SELL trade
            ENUM_ORDER_TYPE final_order_type = InpReverseSignal ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
            
            // Apply trade direction filter
            final_order_type = GetFinalOrderType(final_order_type);
            if(final_order_type != ORDER_TYPE_BUY && final_order_type != ORDER_TYPE_SELL)
