// Register manual opened position into MultiOrderGroups so recovery recognizes it
void Manual_RegisterForRecovery(ulong ticket)
{
   if(ticket == 0) return;
   if(!PositionSelectByTicket(ticket)) return;

   // Find empty slot
   int idx = -1;
   for(int i=0;i<ArraySize(MultiOrderGroups);i++)
   {
      if(MultiOrderGroups[i].base_ticket == 0) { idx = i; break; }
   }
   if(idx == -1)
   {
      // expand array
      idx = ArraySize(MultiOrderGroups);
      ArrayResize(MultiOrderGroups, idx+1);
   }

   MultiOrderGroups[idx].base_ticket = ticket;
   MultiOrderGroups[idx].tickets[0] = ticket;
   MultiOrderGroups[idx].ticket_count = 1;
   MultiOrderGroups[idx].symbol = PositionGetString(POSITION_SYMBOL);
   MultiOrderGroups[idx].type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
   MultiOrderGroups[idx].original_lot = PositionGetDouble(POSITION_VOLUME);
   MultiOrderGroups[idx].total_volume = MultiOrderGroups[idx].original_lot;
   MultiOrderGroups[idx].original_entry = PositionGetDouble(POSITION_PRICE_OPEN);
   MultiOrderGroups[idx].original_tp = PositionGetDouble(POSITION_TP);
   MultiOrderGroups[idx].activated = false;
   MultiOrderGroups[idx].recovery_triggered = false;
   MultiOrderGroups[idx].attempts = 0;
   MultiOrderGroups[idx].close_reason = "";
   MultiOrderGroups[idx].halt_recovery_active = false;
   MultiOrderGroups[idx].halt_hedge_ticket = 0;
   MultiOrderGroups[idx].halt_hedge_lot = 0.0;
   MultiOrderGroups[idx].halt_hedge_open_time = 0;
   MultiOrderGroups[idx].halt_next_trigger_attempt = MathMax(1, InpHaltRecoveryAfterTrades);
   MultiOrderGroups[idx].realized_pnl_memory = 0.0;
   
   // FIX for synthetic SL with fixed points: Calculate original SL correctly
   double position_sl = PositionGetDouble(POSITION_SL);
   string reg_symbol = PositionGetString(POSITION_SYMBOL);
   ENUM_POSITION_TYPE reg_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
   
   // If SL is 0 (synthetic SL), calculate it based on SLTP method
   if(position_sl == 0.0 && InpUseSyntheticSL)
   {
      if(InpSLTPMethod == SLTP_FIXED_POINTS)
      {
         // Calculate SL using fixed points
         double point_value = SymbolInfoDouble(reg_symbol, SYMBOL_POINT);
         if(reg_type == POSITION_TYPE_BUY)
            position_sl = MultiOrderGroups[idx].original_entry - (InpFixedSLPoints * point_value);
         else
            position_sl = MultiOrderGroups[idx].original_entry + (InpFixedSLPoints * point_value);
         
         PrintFormat("Manual trade %d: Calculated synthetic SL using fixed points (%.0f pts) = %.5f",
                    ticket, InpFixedSLPoints, position_sl);
      }
      else
      {
         // Calculate SL using ATR multiplier
         double atr_vals[];
         if(CopyBuffer(iATR(reg_symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_vals) > 0)
         {
            double atr = atr_vals[0];
            if(reg_type == POSITION_TYPE_BUY)
               position_sl = MultiOrderGroups[idx].original_entry - (atr * InpAtrMultiplierSL);
            else
               position_sl = MultiOrderGroups[idx].original_entry + (atr * InpAtrMultiplierSL);
            
            PrintFormat("Manual trade %d: Calculated synthetic SL using ATR multiplier (%.2f × ATR %.5f) = %.5f",
                       ticket, InpAtrMultiplierSL, atr, position_sl);
         }
      }
   }
   
   MultiOrderGroups[idx].original_sl = position_sl;
   
   if(position_sl != 0)
      MultiOrderGroups[idx].original_sl_distance = MathAbs(MultiOrderGroups[idx].original_entry - position_sl);
   else
      MultiOrderGroups[idx].original_sl_distance = 0.0;
   PrintFormat("Manual trade %d registered for multi-order recovery (group index %d)", ticket, idx);

   // If multi-order recovery is enabled, convert real SL to synthetic SL (remove real SL and draw synthetic line)
   if(InpMultiOrderEnabled)
   {
      // FIRST: Calculate the synthetic SL that will be displayed
      double synthetic_sl = 0;
      if(InpSLTPMethod == SLTP_FIXED_POINTS)
      {
         double point_value = SymbolInfoDouble(MultiOrderGroups[idx].symbol, SYMBOL_POINT);
         if(MultiOrderGroups[idx].type == POSITION_TYPE_BUY)
            synthetic_sl = MultiOrderGroups[idx].original_entry - (InpFixedSLPoints * point_value);
         else
            synthetic_sl = MultiOrderGroups[idx].original_entry + (InpFixedSLPoints * point_value);
         PrintFormat("Multi-Order Recovery (Manual): Using fixed points synthetic SL: %.0f points -> SL: %.5f", InpFixedSLPoints, synthetic_sl);
      }
      else
      {
         double atr_vals[];
         if(CopyBuffer(iATR(MultiOrderGroups[idx].symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_vals) > 0)
         {
            double atr = atr_vals[0];
            if(MultiOrderGroups[idx].type == POSITION_TYPE_BUY)
               synthetic_sl = MultiOrderGroups[idx].original_entry - (atr * InpAtrMultiplierSL);
            else
               synthetic_sl = MultiOrderGroups[idx].original_entry + (atr * InpAtrMultiplierSL);
            PrintFormat("Multi-Order Recovery (Manual): ATR-based synthetic SL: ATR=%.5f, SL=%.5f", atr, synthetic_sl);
         }
      }

      // SECOND: Draw the synthetic SL line FIRST (before trying to modify position)
      DrawSyntheticSLLine(ticket, synthetic_sl, MultiOrderGroups[idx].type);
      if(MultiOrderGroups[idx].original_tp != 0)
         DrawOriginalTradeTPLine(ticket, MultiOrderGroups[idx].original_tp);

      // THIRD: Now try to remove the real SL from the position
      MqlTradeRequest req; MqlTradeResult res; ZeroMemory(req); ZeroMemory(res);
      req.action = TRADE_ACTION_SLTP;
      req.position = ticket;
      req.symbol = MultiOrderGroups[idx].symbol;
      req.comment = "RohitEA Multi-Order Recovery (Manual)";

      // Keep TP but remove real SL (use synthetic SL)
      req.tp = MultiOrderGroups[idx].original_tp;
      req.sl = 0;

      if(IsSpreadAcceptable())
      {
         bool sent = SendDollarExitAwareOrder(req, res);
         if(!sent)
         {
            PrintFormat("Multi-Order Recovery (Manual): Failed to update SL/TP for position #%d. OrderSend returned false. Error: %d", ticket, GetLastError());
         }
         else if(res.retcode != TRADE_RETCODE_DONE)
         {
            PrintFormat("Multi-Order Recovery (Manual): Failed to update SL/TP for position #%d. Retcode: %d, Comment: %s", ticket, res.retcode, res.comment);
         }
         else
         {
            PrintFormat("Multi-Order Recovery (Manual): Kept original TP (%.5f) but using synthetic SL for position #%d", MultiOrderGroups[idx].original_tp, ticket);
         }
      }
      else
      {
         PrintFormat("Multi-Order Recovery (Manual): Spread not acceptable, synthetic SL line drawn but position SL not removed. Retrying later.");
      }
   }
}

//+------------------------------------------------------------------+
//| Process a CSV file of manual signals for backtesting (one line)  |
//| Format per line:  YYYY.MM.DD HH:MM, ACTION                        |
//| ACTION: BUY or SELL or CLOSE                                     |
//+------------------------------------------------------------------+
void ProcessManualSignalFile()
{
   if(!InpManualSignalUseFile) return;

   int handle = FileOpen(InpManualSignalFileName, FILE_READ|FILE_COMMON|FILE_ANSI);
   if(handle <= 0)
   {
      // try without FILE_COMMON (local Files folder)
      handle = FileOpen(InpManualSignalFileName, FILE_READ|FILE_ANSI);
      if(handle <= 0) return;
   }

   while(!FileIsEnding(handle))
   {
      string line = FileReadString(handle);
      line = StringTrim(line);
      if(StringLen(line) == 0) continue;
      string parts[];
      int pc = StringSplit(line, ',', parts);
      if(pc < 2) continue;
      string timeStr = StringTrim(parts[0]);
      string action = StringTrim(parts[1]);
      // normalize action
      StringToLower(action);

      // build a unique key to track execution
      string key = timeStr + "|" + action;
      bool done = false;
      for(int i=0;i<ArraySize(g_manual_signals_executed);i++) if(g_manual_signals_executed[i] == key) { done = true; break; }
      if(done) continue;

      // parse time - accept either epoch seconds or 'YYYY.MM.DD HH:MM' style
      datetime t = 0;
      if(StringFind(timeStr, ".") != -1 || StringFind(timeStr, ":") != -1)
      {
         // ensure seconds
         if(StringFind(timeStr, ":") != -1 && StringLen(StringSubstr(timeStr, StringFind(timeStr, ":"))) <= 3)
            timeStr = timeStr + ":00";
         if(StringFind(timeStr, " ") == -1) timeStr = timeStr + " 00:00:00";
         t = StringToTime(timeStr);
      }
      else
      {
         long v = (long)StringToInteger(timeStr);
         t = (datetime)v;
      }

      // If time matches the closed bar time, execute
      datetime closedBarTime = iTime(_Symbol, _Period, 1);
      if(t == closedBarTime)
      {
         if(StringFind(action, "buy") != -1)
         {
            PrintFormat("Manual signal file: executing BUY for time %s", timeStr);
            Manual_ExecuteBuy();
            ArrayResize(g_manual_signals_executed, ArraySize(g_manual_signals_executed) + 1);
            g_manual_signals_executed[ArraySize(g_manual_signals_executed)-1] = key;
         }
         else if(StringFind(action, "sell") != -1)
         {
            PrintFormat("Manual signal file: executing SELL for time %s", timeStr);
            Manual_ExecuteSell();
            ArrayResize(g_manual_signals_executed, ArraySize(g_manual_signals_executed) + 1);
            g_manual_signals_executed[ArraySize(g_manual_signals_executed)-1] = key;
         }
         else if(StringFind(action, "close") != -1)
         {
            PrintFormat("Manual signal file: executing CLOSE for time %s", timeStr);
            Manual_CloseAll();
            ArrayResize(g_manual_signals_executed, ArraySize(g_manual_signals_executed) + 1);
            g_manual_signals_executed[ArraySize(g_manual_signals_executed)-1] = key;
         }
      }
   }

   FileClose(handle);
}


void Manual_CloseAll()
{
   int total = PositionsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket>0 && PositionSelectByTicket(ticket))
      {
         if(PositionGetString(POSITION_SYMBOL) == _Symbol)
            ClosePosition(ticket);
      }
   }
}

void Manual_MoveToBreakeven()
{
   int total = PositionsTotal();
   for(int i = total - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket>0 && PositionSelectByTicket(ticket))
      {
         if(PositionGetString(POSITION_SYMBOL) == _Symbol)
         {
            double entry = PositionGetDouble(POSITION_PRICE_OPEN);
            double tp = PositionGetDouble(POSITION_TP);
            MqlTradeRequest req={}; MqlTradeResult res={};
            req.action = TRADE_ACTION_SLTP;
            req.position = ticket;
            req.sl = entry;
            req.tp = tp;
            bool sent = SendDollarExitAwareOrder(req,res);
            if(!sent)
               PrintFormat("Failed to send breakeven modify for %d - Error: %d", ticket, GetLastError());
            else if(res.retcode==TRADE_RETCODE_DONE)
               PrintFormat("Moved position %d to breakeven", ticket);
            else
               PrintFormat("Failed to move position %d to breakeven: Retcode=%d, Comment=%s", ticket, res.retcode, res.comment);
         }
      }
   }
}


