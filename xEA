string GDPanelMoney(double value)
{
   string currency = AccountInfoString(ACCOUNT_CURRENCY);
   return currency + " " + DoubleToString(value, 2);
}

string GDPanelSignedMoney(double value)
{
   string sign = (value > 0.0 ? "+" : "");
   return sign + GDPanelMoney(value);
}

string GDPanelSignedPercent(double value)
{
   string sign = (value > 0.0 ? "+" : "");
   return sign + DoubleToString(value, 1) + "%";
}

datetime GDPanelUtcDayStart(datetime utc_time)
{
   MqlDateTime parts;
   TimeToStruct(utc_time, parts);
   parts.hour = 0;
   parts.min = 0;
   parts.sec = 0;
   return StructToTime(parts);
}

string GDPanelDateKey(datetime utc_day)
{
