   ExtOHLCRecoveryTrackers[idx].pending_level_key = "";
   return idx;
}

//+------------------------------------------------------------------+
//| Build unique key for OHLC recovery level                        |
//+------------------------------------------------------------------+
string BuildOHLCRecoveryLevelKey(ulong base_ticket, ENUM_TIMEFRAMES tf, datetime bar_time, string price_tag, double level_price)
{
   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
   return IntegerToString((int)base_ticket) + "|" +
          EnumToString(tf) + "|" +
          IntegerToString((int)bar_time) + "|" +
          price_tag + "|" +
          DoubleToString(level_price, digits);
}

//+------------------------------------------------------------------+
//| Check if OHLC level already used                                |
//+------------------------------------------------------------------+
bool IsOHLCRecoveryLevelUsed(ulong base_ticket, string level_key)
{
   if(level_key == "")
      return false;

   int idx = FindOHLCRecoveryUsageIndex(base_ticket, false);
   if(idx < 0)
      return false;

   for(int i = 0; i < ExtOHLCRecoveryUsage[idx].used_count; i++)
   {
      if(ExtOHLCRecoveryUsage[idx].used_keys[i] == level_key)
         return true;
   }
   return false;
}

//+------------------------------------------------------------------+
//| Mark OHLC level as used (one trade per level)                   |
//+------------------------------------------------------------------+
void MarkOHLCRecoveryLevelUsed(ulong base_ticket, string level_key)
{
   if(level_key == "")
      return;

   int idx = FindOHLCRecoveryUsageIndex(base_ticket, true);
   if(idx < 0)
      return;

   if(IsOHLCRecoveryLevelUsed(base_ticket, level_key))
      return;

   if(ExtOHLCRecoveryUsage[idx].used_count < ArraySize(ExtOHLCRecoveryUsage[idx].used_keys))
   {
      ExtOHLCRecoveryUsage[idx].used_keys[ExtOHLCRecoveryUsage[idx].used_count] = level_key;
      ExtOHLCRecoveryUsage[idx].used_count++;
   }
}

//+------------------------------------------------------------------+
//| Store pending OHLC level to commit only after successful trade   |
//+------------------------------------------------------------------+
void TrackPendingOHLCRecoveryLevel(ulong base_ticket, const string level_key)
{
   int idx = FindOHLCRecoveryTrackerIndex(base_ticket, true);
   if(idx < 0)
      return;
   ExtOHLCRecoveryTrackers[idx].pending_level_key = level_key;
}

//+------------------------------------------------------------------+
//| Commit pending OHLC level usage after trade attempt              |
//+------------------------------------------------------------------+
void CommitPendingOHLCRecoveryLevel(ulong base_ticket, bool trade_opened)
{
   int idx = FindOHLCRecoveryTrackerIndex(base_ticket, false);
   if(idx < 0)
      return;

   string pending_key = ExtOHLCRecoveryTrackers[idx].pending_level_key;
   ExtOHLCRecoveryTrackers[idx].pending_level_key = "";

   if(trade_opened && pending_key != "")
      MarkOHLCRecoveryLevelUsed(base_ticket, pending_key);
}

//+------------------------------------------------------------------+
//| Draw OHLC recovery level line                                    |
//+------------------------------------------------------------------+
void DrawOHLCRecoveryLevelLine(ulong base_ticket, ENUM_TIMEFRAMES tf, datetime bar_time, string price_tag, double level_price, bool is_used)
{
   if(g_is_backtesting || !InpOHLCRecoveryDrawLevels)
      return;

   string obj_name = OHLC_RECOVERY_LINE_PREFIX +
                     IntegerToString((int)base_ticket) + "_" +
                     EnumToString(tf) + "_" +
                     IntegerToString((int)bar_time) + "_" +
                     price_tag;

   if(ObjectFind(0, obj_name) < 0)
   {
      if(!ObjectCreate(0, obj_name, OBJ_HLINE, 0, 0, level_price))
         return;
   }

   color tf_color = clrDeepSkyBlue;
   if(tf == PERIOD_W1) tf_color = clrOrange;
   if(tf == PERIOD_MN1) tf_color = clrGold;
   if(is_used) tf_color = clrSilver;

   ObjectSetDouble(0, obj_name, OBJPROP_PRICE, level_price);
   ObjectSetInteger(0, obj_name, OBJPROP_COLOR, tf_color);
   ObjectSetInteger(0, obj_name, OBJPROP_WIDTH, is_used ? 1 : 2);
   ObjectSetInteger(0, obj_name, OBJPROP_STYLE, is_used ? STYLE_DOT : STYLE_SOLID);
   ObjectSetInteger(0, obj_name, OBJPROP_BACK, true);
}

//+------------------------------------------------------------------+
//| Draw all configured D/W/M OHLC levels for a recovery group       |
//+------------------------------------------------------------------+
void DrawOHLCRecoveryLevelsForBase(ulong base_ticket, string symbol)
{
   if(g_is_backtesting || !InpOHLCRecoveryDrawLevels || !InpOHLCLevelRecoveryConfirmationEnabled)
      return;

   if(!InpOHLCRecoveryUseDaily && !InpOHLCRecoveryUseWeekly && !InpOHLCRecoveryUseMonthly)
      return;

   if(!InpOHLCRecoveryUseOpen && !InpOHLCRecoveryUseHigh && !InpOHLCRecoveryUseLow && !InpOHLCRecoveryUseClose)
      return;

   int lookback = MathMax(1, InpOHLCRecoveryLookbackCandles);

   ENUM_TIMEFRAMES tfs[3];
   int tf_count = 0;
   if(InpOHLCRecoveryUseDaily) tfs[tf_count++] = PERIOD_D1;
   if(InpOHLCRecoveryUseWeekly) tfs[tf_count++] = PERIOD_W1;
   if(InpOHLCRecoveryUseMonthly) tfs[tf_count++] = PERIOD_MN1;

   for(int t = 0; t < tf_count; t++)
   {
      ENUM_TIMEFRAMES tf = tfs[t];
      for(int shift = 1; shift <= lookback; shift++)
      {
         datetime bar_time = iTime(symbol, tf, shift);
         if(bar_time <= 0) continue;

         double o = iOpen(symbol, tf, shift);
         double h = iHigh(symbol, tf, shift);
         double l = iLow(symbol, tf, shift);
         double c = iClose(symbol, tf, shift);
         if(o <= 0 || h <= 0 || l <= 0 || c <= 0) continue;

         string tags[4];
         tags[0] = "O"; tags[1] = "H"; tags[2] = "L"; tags[3] = "C";
         double lvls[4];
         lvls[0] = o; lvls[1] = h; lvls[2] = l; lvls[3] = c;
         bool enabled_level[4];
         enabled_level[0] = InpOHLCRecoveryUseOpen;
         enabled_level[1] = InpOHLCRecoveryUseHigh;
         enabled_level[2] = InpOHLCRecoveryUseLow;
         enabled_level[3] = InpOHLCRecoveryUseClose;

         for(int k = 0; k < 4; k++)
         {
            if(!enabled_level[k])
               continue;

            string level_key = BuildOHLCRecoveryLevelKey(base_ticket, tf, bar_time, tags[k], lvls[k]);
            bool used = IsOHLCRecoveryLevelUsed(base_ticket, level_key);
            DrawOHLCRecoveryLevelLine(base_ticket, tf, bar_time, tags[k], lvls[k], used);
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Check D/W/M OHLC levels for recovery confirmation               |
//+------------------------------------------------------------------+
bool IsOHLCLevelsConfirmingRecovery(ulong base_ticket, bool is_buy_recovery, string symbol, string &matched_level_key)
{
   matched_level_key = "";
   if(!InpOHLCLevelRecoveryConfirmationEnabled)
      return true;

   if(!InpOHLCRecoveryUseDaily && !InpOHLCRecoveryUseWeekly && !InpOHLCRecoveryUseMonthly)
      return false;

   if(!InpOHLCRecoveryUseOpen && !InpOHLCRecoveryUseHigh && !InpOHLCRecoveryUseLow && !InpOHLCRecoveryUseClose)
      return false;

   // Keep levels visible while we evaluate touch confirmation.
   DrawOHLCRecoveryLevelsForBase(base_ticket, symbol);

   int lookback = MathMax(1, InpOHLCRecoveryLookbackCandles);
   double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
   if(point <= 0) point = 0.00001;
   double mid = (bid + ask) / 2.0;
   double spread_points = MathAbs(ask - bid) / point;
   double touch_tolerance_points = MathMax(1.0, spread_points + 0.5);

   ENUM_TIMEFRAMES tfs[3];
   int tf_count = 0;
   if(InpOHLCRecoveryUseDaily) tfs[tf_count++] = PERIOD_D1;
   if(InpOHLCRecoveryUseWeekly) tfs[tf_count++] = PERIOD_W1;
   if(InpOHLCRecoveryUseMonthly) tfs[tf_count++] = PERIOD_MN1;

   string best_key = "";
   string best_desc = "";
   double best_distance = 1e100;

   for(int t = 0; t < tf_count; t++)
   {
      ENUM_TIMEFRAMES tf = tfs[t];
      for(int shift = 1; shift <= lookback; shift++)
      {
         datetime bar_time = iTime(symbol, tf, shift);
         if(bar_time <= 0) continue;

         double o = iOpen(symbol, tf, shift);
         double h = iHigh(symbol, tf, shift);
         double l = iLow(symbol, tf, shift);
         double c = iClose(symbol, tf, shift);
         if(o <= 0 || h <= 0 || l <= 0 || c <= 0) continue;

         string tags[4];
         tags[0] = "O"; tags[1] = "H"; tags[2] = "L"; tags[3] = "C";
         double lvls[4];
         lvls[0] = o; lvls[1] = h; lvls[2] = l; lvls[3] = c;
         bool enabled_level[4];
         enabled_level[0] = InpOHLCRecoveryUseOpen;
         enabled_level[1] = InpOHLCRecoveryUseHigh;
         enabled_level[2] = InpOHLCRecoveryUseLow;
         enabled_level[3] = InpOHLCRecoveryUseClose;

         for(int k = 0; k < 4; k++)
         {
            if(!enabled_level[k])
               continue;

            string level_key = BuildOHLCRecoveryLevelKey(base_ticket, tf, bar_time, tags[k], lvls[k]);
            bool used = IsOHLCRecoveryLevelUsed(base_ticket, level_key);

            if(used) continue;

            bool touched_by_spread = (lvls[k] >= MathMin(bid, ask) && lvls[k] <= MathMax(bid, ask));
            double distance_points = MathAbs(mid - lvls[k]) / point;
            bool touched_by_tolerance = (distance_points <= touch_tolerance_points);
            bool touched = touched_by_spread || touched_by_tolerance;
            if(!touched) continue;

            if(distance_points < best_distance)
            {
               best_distance = distance_points;
               best_key = level_key;
               best_desc = StringFormat("%s[%s-%s-%d]=%.5f",
                                        EnumToString(tf),
                                        TimeToString(bar_time, TIME_DATE),
                                        tags[k],
                                        shift,
                                        lvls[k]);
            }
         }
      }
   }

   if(best_key != "")
   {
      matched_level_key = best_key;
      if(!g_is_backtesting)
      {
         PrintFormat("OHLC Recovery %s: CONFIRMED for base #%d at level %s (Bid=%.5f Ask=%.5f)",
                     is_buy_recovery ? "BUY" : "SELL",
                     base_ticket,
                     best_desc,
                     bid,
                     ask);
      }
      return true;
   }

   return false;
}

