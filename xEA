//+------------------------------------------------------------------+
//| Find OHLC recovery usage index                                  |
//+------------------------------------------------------------------+
int FindOHLCRecoveryUsageIndex(ulong base_ticket, bool create_if_missing)
{
   for(int i = 0; i < ArraySize(ExtOHLCRecoveryUsage); i++)
   {
      if(ExtOHLCRecoveryUsage[i].base_ticket == base_ticket)
         return i;
   }

   if(!create_if_missing)
      return -1;

   int idx = ArraySize(ExtOHLCRecoveryUsage);
   ArrayResize(ExtOHLCRecoveryUsage, idx + 1);
   ExtOHLCRecoveryUsage[idx].base_ticket = base_ticket;
   ExtOHLCRecoveryUsage[idx].used_count = 0;
   return idx;
}

