bool IsBuyOrderType(const ENUM_ORDER_TYPE order_type)
{
   return order_type == ORDER_TYPE_BUY ||
          order_type == ORDER_TYPE_BUY_LIMIT ||
          order_type == ORDER_TYPE_BUY_STOP ||
          order_type == ORDER_TYPE_BUY_STOP_LIMIT;
}

ENUM_ORDER_TYPE ProfitCalcOrderType(const ENUM_ORDER_TYPE order_type)
{
   return IsBuyOrderType(order_type) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
}

double NormalizeSymbolPrice(const string symbol, const double price)
{
   if(price <= 0.0)
      return 0.0;

   return NormalizeDouble(price, (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS));
}

double GlobalDollarEntryPriceForRequest(MqlTradeRequest &request)
{
   if(request.price > 0.0)
      return request.price;

   if(IsBuyOrderType(request.type))
      return SymbolInfoDouble(request.symbol, SYMBOL_ASK);

   return SymbolInfoDouble(request.symbol, SYMBOL_BID);
}

bool PriceForDollarPnL(const string symbol,
                       const ENUM_ORDER_TYPE order_type,
                       const double volume,
                       const double entry,
                       const double target_money,
                       double &target_price)
{
   target_price = 0.0;
   if(symbol == "" || volume <= 0.0 || entry <= 0.0 || target_money == 0.0)
      return false;

   double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
   if(point <= 0.0)
      point = 0.00001;

   ENUM_ORDER_TYPE calc_type = ProfitCalcOrderType(order_type);
   bool buy = (calc_type == ORDER_TYPE_BUY);
   bool profit_target = (target_money > 0.0);
   bool price_above_entry = (buy && profit_target) || (!buy && !profit_target);

   double range = MathMax(point, entry * 0.001);
   double low = entry;
   double high = entry;
   double probe = entry;
   double profit = 0.0;

   for(int i = 0; i < 60; i++)
   {
      probe = price_above_entry ? entry + range : entry - range;
      if(probe <= 0.0)
         return false;

      if(!OrderCalcProfit(calc_type, symbol, volume, entry, probe, profit))
         return false;

      if((profit_target && profit >= target_money) ||
         (!profit_target && profit <= target_money))
         break;

      range *= 2.0;
   }

   if((profit_target && profit < target_money) ||
      (!profit_target && profit > target_money))
      return false;

   if(price_above_entry)
   {
      low = entry;
      high = probe;
   }
   else
   {
      low = probe;
      high = entry;
   }

   for(int i = 0; i < 80; i++)
   {
      double mid = (low + high) / 2.0;
      if(!OrderCalcProfit(calc_type, symbol, volume, entry, mid, profit))
         return false;

      if(price_above_entry)
      {
         if((profit_target && profit < target_money) ||
            (!profit_target && profit > target_money))
            low = mid;
         else
            high = mid;
      }
      else
      {
         if((profit_target && profit < target_money) ||
            (!profit_target && profit > target_money))
            high = mid;
         else
            low = mid;
      }
   }

   target_price = NormalizeSymbolPrice(symbol, (low + high) / 2.0);
   return target_price > 0.0;
}

bool CalculateGlobalDollarSLTP(const string symbol,
                               const ENUM_ORDER_TYPE order_type,
                               const double volume,
                               const double entry,
                               double &sl,
                               double &tp)
{
   sl = 0.0;
   tp = 0.0;

   double loss_limit = MathAbs(InpGlobalDollarLossLimit);
   double profit_target = MathAbs(InpGlobalDollarProfitTarget);
   bool ok = false;

   if(loss_limit > 0.0)
      ok = PriceForDollarPnL(symbol, order_type, volume, entry, -loss_limit, sl) || ok;

   if(profit_target > 0.0)
      ok = PriceForDollarPnL(symbol, order_type, volume, entry, profit_target, tp) || ok;

   return ok;
}

bool ApplyGlobalDollarSLTPToRequest(MqlTradeRequest &request)
{
   if(!InpGlobalDollarExitEnabled)
      return false;

   double volume = request.volume;
   ENUM_ORDER_TYPE order_type = request.type;
   double entry = GlobalDollarEntryPriceForRequest(request);

   if(request.action == TRADE_ACTION_SLTP && request.position > 0 && PositionSelectByTicket(request.position))
   {
      volume = PositionGetDouble(POSITION_VOLUME);
      order_type = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY ? ORDER_TYPE_BUY : ORDER_TYPE_SELL);
      entry = PositionGetDouble(POSITION_PRICE_OPEN);
      request.symbol = PositionGetString(POSITION_SYMBOL);
   }
   else if(request.action == TRADE_ACTION_MODIFY && request.order > 0 && OrderSelect(request.order))
   {
      volume = OrderGetDouble(ORDER_VOLUME_CURRENT);
      order_type = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      entry = request.price > 0.0 ? request.price : OrderGetDouble(ORDER_PRICE_OPEN);
      request.symbol = OrderGetString(ORDER_SYMBOL);
   }

   double sl = 0.0;
   double tp = 0.0;
   if(!CalculateGlobalDollarSLTP(request.symbol, order_type, volume, entry, sl, tp))
      return false;

   request.sl = sl;
   request.tp = tp;

   PrintFormat("Global Dollar Exit: %s SL/TP for %s %.2f lot at %.5f -> SL %.5f ($%.2f), TP %.5f ($%.2f)",
               EnumToString(InpGlobalDollarSLTPMode), request.symbol, volume, entry,
               request.sl, MathAbs(InpGlobalDollarLossLimit), request.tp, MathAbs(InpGlobalDollarProfitTarget));
   return true;
}

bool SendDollarExitAwareOrder(MqlTradeRequest &request, MqlTradeResult &result)
{
   UpdateGlobalDollarLossStreakPause();

   if(IsGlobalDollarStopTradingActive())
   {
      bool is_new_market_entry = (request.action == TRADE_ACTION_DEAL && request.position == 0);
      bool is_new_pending_entry = (request.action == TRADE_ACTION_PENDING);

      if(is_new_market_entry || is_new_pending_entry)
      {
         ZeroMemory(result);
         result.retcode = TRADE_RETCODE_REJECT;
         result.comment = "Global dollar stop trading active: " + g_globalDollarStopTradingReason;
         PrintFormat("Global Dollar Stop Trading: blocked new %s order on %s. Reason: %s",
                     EnumToString(request.action), request.symbol, g_globalDollarStopTradingReason);
         return false;
      }
   }

   if(IsGlobalDollarLossStreakPauseActive())
   {
      bool is_new_market_entry = (request.action == TRADE_ACTION_DEAL && request.position == 0);
      bool is_new_pending_entry = (request.action == TRADE_ACTION_PENDING);

      if(is_new_market_entry || is_new_pending_entry)
      {
         string pause_reason = GlobalDollarLossStreakPauseReason();
         ZeroMemory(result);
         result.retcode = TRADE_RETCODE_REJECT;
         result.comment = "Global dollar streak pause active";
         PrintFormat("Global Dollar %s Streak Pause: blocked new %s order on %s. Reason: %s",
                     GlobalDollarStreakPauseTriggerText(),
                     EnumToString(request.action), request.symbol, pause_reason);
         return false;
      }
   }

   if(IsGlobalDollarDailyDrawdownTradePauseActive())
   {
      bool is_new_market_entry = (request.action == TRADE_ACTION_DEAL && request.position == 0);
      bool is_new_pending_entry = (request.action == TRADE_ACTION_PENDING);

      if(is_new_market_entry || is_new_pending_entry)
      {
         string pause_reason = GlobalDollarDailyDrawdownTradePauseReason();
         ZeroMemory(result);
         result.retcode = TRADE_RETCODE_REJECT;
         result.comment = "Daily DD trades-left pause active";
         PrintFormat("Global Dollar Daily DD Trade Pause: blocked new %s order on %s. Reason: %s",
                     EnumToString(request.action), request.symbol, pause_reason);
         return false;
      }
   }

   if(InpGlobalDollarExitEnabled)
   {
      bool managed_request = false;

      if(request.magic == InpMagicNumber)
      {
         managed_request = (request.symbol == "" || IsGlobalDollarExitManagedSymbol(request.symbol));
      }

      if(!managed_request && request.position > 0 && PositionSelectByTicket(request.position))
      {
         managed_request = (PositionGetInteger(POSITION_MAGIC) == InpMagicNumber &&
                            IsGlobalDollarExitManagedSymbol(PositionGetString(POSITION_SYMBOL)));
      }

      if(!managed_request && request.order > 0 && OrderSelect(request.order))
      {
         managed_request = (OrderGetInteger(ORDER_MAGIC) == InpMagicNumber &&
                            IsGlobalDollarExitManagedSymbol(OrderGetString(ORDER_SYMBOL)));
      }

      if(managed_request &&
         (request.action == TRADE_ACTION_DEAL ||
          request.action == TRADE_ACTION_PENDING ||
          request.action == TRADE_ACTION_MODIFY ||
          request.action == TRADE_ACTION_SLTP))
      {
         if(!(request.action == TRADE_ACTION_DEAL && request.position > 0))
            ApplyGlobalDollarSLTPToRequest(request);
      }
   }

   return OrderSend(request, result);
}

double CalculateGlobalDollarExitPnL(int &position_count)
{
   double total_pnl = 0.0;
   position_count = 0;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      total_pnl += PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
      position_count++;
   }

   return total_pnl;
}

double CalculateGlobalDollarStopTradingPnL(int &deal_count, int &position_count)
{
   double total_pnl = 0.0;
   deal_count = 0;
   position_count = 0;

   datetime history_from = (g_globalDollarStopTradingStartTime > 0 ? g_globalDollarStopTradingStartTime : 0);
   if(HistorySelect(history_from, TimeCurrent()))
   {
      int total_deals = HistoryDealsTotal();
      for(int i = 0; i < total_deals; i++)
      {
         ulong deal_ticket = HistoryDealGetTicket(i);
         if(deal_ticket == 0) continue;
         if(HistoryDealGetInteger(deal_ticket, DEAL_MAGIC) != InpMagicNumber) continue;

         string symbol = HistoryDealGetString(deal_ticket, DEAL_SYMBOL);
         if(symbol != "" && !IsGlobalDollarExitManagedSymbol(symbol)) continue;

         total_pnl += HistoryDealGetDouble(deal_ticket, DEAL_PROFIT) +
                      HistoryDealGetDouble(deal_ticket, DEAL_COMMISSION) +
                      HistoryDealGetDouble(deal_ticket, DEAL_SWAP);
         deal_count++;
      }
   }

   if(!InpGlobalDollarStopTradingIncludeOpenPnL)
      return total_pnl;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      total_pnl += PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
      position_count++;
   }

   return total_pnl;
}

