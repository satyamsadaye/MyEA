                       entryPrice, stopLoss, takeProfit, lots);
            g_lastSignalTime = current_bar_time;
        }
    }
    else
    {
        // No valid signals found - provide clear feedback why
        if(!g_is_backtesting)
        {
            string trend_status = (supertrend_direction == 1) ? "UPTREND (BUY only)" : "DOWNTREND (SELL only)";
            string stoch_status = "";
            
            if(stoch_k < InpStochasticLowLevel)
                stoch_status = StringFormat("oversold (%.2f < %.2f) - Good for BUY", stoch_k, InpStochasticLowLevel);
            else if(stoch_k > InpStochasticHighLevel)
                stoch_status = StringFormat("overbought (%.2f > %.2f) - Good for SELL", stoch_k, InpStochasticHighLevel);
            else
                stoch_status = StringFormat("neutral (%.2f between %.2f-%.2f)", stoch_k, InpStochasticLowLevel, InpStochasticHighLevel);
            
            PrintFormat("Pattern 5: NO SIGNAL - SuperTrend: %s, Stochastic: %s", trend_status, stoch_status);
        }
    }
