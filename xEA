      {
         PrintFormat("Trailing Scale: Closing scale order #%I64u linked to base #%I64u.",
                     scale_ticket, base_ticket);
         ClosePosition(scale_ticket);
      }
   }

   RemoveTrailingScaleGroupByIndex(idx);
}

bool BuildTrailingFallbackSL(const string symbol,
                             const bool is_buy,
                             const double current_tp,
                             const double requested_sl,
                             double &fallback_sl)
{
   MqlTick latest_tick;
   if(!SymbolInfoTick(symbol, latest_tick))
      return false;

   double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
   if(point <= 0.0)
      point = _Point;

   double stop_level_pts = (double)SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double freeze_level_pts = (double)SymbolInfoInteger(symbol, SYMBOL_TRADE_FREEZE_LEVEL);
   double min_gap = (MathMax(stop_level_pts, freeze_level_pts) + 1.0) * point;

   double candidate = requested_sl;
   if(is_buy)
   {
      double max_by_price = latest_tick.bid - min_gap;
      if(candidate > max_by_price)
         candidate = max_by_price;

      if(current_tp > 0.0)
      {
         double max_by_tp = current_tp - min_gap;
         if(candidate > max_by_tp)
            candidate = max_by_tp;
      }
   }
   else
   {
      double min_by_price = latest_tick.ask + min_gap;
      if(candidate < min_by_price)
         candidate = min_by_price;

      if(current_tp > 0.0)
      {
         double min_by_tp = current_tp + min_gap;
         if(candidate < min_by_tp)
            candidate = min_by_tp;
      }
   }

   int digits = (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS);
   candidate = NormalizeDouble(candidate, digits);
   if(candidate <= 0.0)
      return false;

   fallback_sl = candidate;
   return true;
}

