void ForceCloseOrphanRecoveryTrades()
{
    for(int i = ArraySize(MultiOrderGroups) - 1; i >= 0; i--)
    {
        ulong base_ticket = MultiOrderGroups[i].base_ticket;
        bool main_trade_exists = PositionSelectByTicket(base_ticket);
        bool has_recovery_trades = false;
        int open_recovery_count = 0;
        
        // Count open recovery trades
        for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
        {
            ulong ticket = MultiOrderGroups[i].tickets[j];
            if(ticket != base_ticket && PositionSelectByTicket(ticket))
            {
                has_recovery_trades = true;
                open_recovery_count++;
            }
        }
        
        // If no main trade but recovery trades are open, check if this is a hedged group
        if(!main_trade_exists && has_recovery_trades)
        {
            // IMPORTANT: Do NOT close hedged groups as orphans - let hedging logic handle them
            if(MultiOrderGroups[i].hedge_activated)
            {
                PrintFormat("HEDGED GROUP #%d: Main position closed but keeping recovery/hedge positions for profit monitoring", base_ticket);
                // Continue monitoring this group for positive profit
                continue;
            }
            
            // Only close non-hedged orphan recovery trades
            PrintFormat("Force closing %d orphan recovery trades for group with base ticket #%d", open_recovery_count, base_ticket);
            MultiOrderGroups[i].close_reason = "orphan_recovery";
            CloseAllPositionsInGroup(MultiOrderGroups[i]);
            
            // VALIDATION: Check if all positions were closed successfully
            Sleep(300);
            ValidateGroupClosure(MultiOrderGroups[i], "Orphan Recovery Cleanup");
            
            CleanupGroupChartObjects(MultiOrderGroups[i]);
        }
    }
}

