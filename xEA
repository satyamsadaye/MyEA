//+------------------------------------------------------------------+
//| Post-closure validation for multi-order groups                   |
//+------------------------------------------------------------------+
void ValidateGroupClosure(MultiOrderGroup &group, string trigger_reason)
{
    PrintFormat("VALIDATION: Starting post-closure validation for group (base: #%d, reason: %s)", 
               group.base_ticket, trigger_reason);
    
    int remaining_positions = 0;
    ulong stubborn_tickets[];
    
    // Check which positions from the group are still open
    for(int i = 0; i < group.ticket_count; i++)
    {
        ulong ticket = group.tickets[i];
        if(PositionSelectByTicket(ticket))
        {
            remaining_positions++;
            ArrayResize(stubborn_tickets, remaining_positions);
            stubborn_tickets[remaining_positions - 1] = ticket;
            
            PrintFormat("VALIDATION: Position #%d still open (Type: %s, Profit: %.2f)", 
                       ticket, 
                       (ticket == group.base_ticket ? "ORIGINAL" : "RECOVERY"),
                       PositionGetDouble(POSITION_PROFIT));
        }
    }
    
    if(remaining_positions == 0)
    {
        PrintFormat("VALIDATION: SUCCESS - All positions in group properly closed");
        return;
    }
    
    // Attempt emergency closure of remaining positions
    PrintFormat("VALIDATION: EMERGENCY - %d positions still open, attempting immediate closure", 
               remaining_positions);
    
    int emergency_closed = 0;
    for(int i = 0; i < remaining_positions; i++)
    {
        ulong ticket = stubborn_tickets[i];
        
        PrintFormat("VALIDATION: Emergency closure attempt for position #%d", ticket);
        
        // Use the enhanced ForceClosePosition with specific reason
        if(ForceClosePosition(ticket, "VALIDATION EMERGENCY"))
        {
            emergency_closed++;
        }
        else
        {
            // Log critical failure for manual intervention
            PrintFormat("VALIDATION: CRITICAL - Position #%d cannot be closed! Manual intervention required!", ticket);
            
            // Try to get position details for troubleshooting
            if(PositionSelectByTicket(ticket))
            {
                double position_profit = PositionGetDouble(POSITION_PROFIT);
                double position_swap = PositionGetDouble(POSITION_SWAP);
                string position_symbol = PositionGetString(POSITION_SYMBOL);
                double position_volume = PositionGetDouble(POSITION_VOLUME);
                
                PrintFormat("VALIDATION: Stubborn position details - Ticket: #%d, Symbol: %s, Volume: %.2f, P&L: %.2f, Swap: %.2f", 
                           ticket, position_symbol, position_volume, position_profit, position_swap);
            }
        }
        
        // Small delay between emergency closure attempts
        Sleep(100);
    }
    
    if(emergency_closed == remaining_positions)
    {
        PrintFormat("VALIDATION: RECOVERED - Emergency closure successful, all %d positions now closed", 
                   remaining_positions);
    }
    else
    {
        int still_open = remaining_positions - emergency_closed;
        PrintFormat("VALIDATION: PARTIAL RECOVERY - %d positions closed, %d still open (ORPHAN ALERT!)", 
                   emergency_closed, still_open);
    }
}

//+------------------------------------------------------------------+
//| Comprehensive recovery system status report                      |
//+------------------------------------------------------------------+
void LogRecoverySystemStatus(string context = "Status Check")
{
    int total_groups = ArraySize(MultiOrderGroups);
    int total_positions = 0;
    int total_recovery_positions = 0;
    int active_groups = 0;
    double total_pnl = 0.0;
    
    for(int i = 0; i < total_groups; i++)
    {
        // Count positions that actually exist
        int group_existing_positions = 0;
        for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
        {
            if(PositionSelectByTicket(MultiOrderGroups[i].tickets[j]))
            {
                group_existing_positions++;
                total_positions++;
                if(j > 0) total_recovery_positions++; // Not the base trade
            }
        }
        
        if(group_existing_positions > 0)
        {
            active_groups++;
            double group_profit = CalculateGroupProfit(MultiOrderGroups[i]);
            total_pnl += group_profit;
        }
    }
    
    PrintFormat("RECOVERY STATUS (%s): %d active groups, %d total positions (%d recoveries), Combined P&L: %.2f USD", 
               context, active_groups, total_positions, total_recovery_positions, total_pnl);
    
    // Alert if numbers seem excessive
    if(total_recovery_positions >= 100)
    {
        PrintFormat("RECOVERY ALERT: High recovery count (%d) detected - Monitor for performance impact", 
                   total_recovery_positions);
    }
}

//+------------------------------------------------------------------+
//| Force cleanup of orphan recovery positions (no base trade exists) |
//+------------------------------------------------------------------+
void CleanupOrphanRecoveryTrades()
{
    int total_positions = PositionsTotal();
    int orphan_recovery_closed = 0;
    
    // Check all open positions for orphan recovery trades
    for(int i = total_positions - 1; i >= 0; i--)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket <= 0) continue;
        
        if(PositionSelectByTicket(ticket))
        {
            // Only check positions with our magic number
            if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
            
            string comment = PositionGetString(POSITION_COMMENT);
            
            // Check if this is a recovery position (usually has "Recovery" in comment or is in MultiOrderGroups)
            bool is_recovery_trade = false;
            ulong base_ticket = 0;
            
            // Check if this position is in any MultiOrderGroup as a recovery trade
            for(int j = 0; j < ArraySize(MultiOrderGroups); j++)
            {
                for(int k = 0; k < MultiOrderGroups[j].ticket_count; k++)
                {
                    if(MultiOrderGroups[j].tickets[k] == ticket && k > 0) // k > 0 means it's not the base trade
                    {
                        is_recovery_trade = true;
                        base_ticket = MultiOrderGroups[j].base_ticket;
                        break;
                    }
                }
                if(is_recovery_trade) break;
            }
            
            // If this is a recovery trade, check if base trade still exists
            if(is_recovery_trade && base_ticket > 0)
            {
                if(!PositionSelectByTicket(base_ticket))
                {
                    // Re-select the orphan recovery position to get its current details
                    if(!PositionSelectByTicket(ticket))
                    {
                        PrintFormat("ORPHAN CLEANUP: Cannot re-select recovery position #%d for closure", ticket);
                        continue;
                    }
                    
                    // Base trade doesn't exist - this is an orphan recovery position
                    if(ForceClosePosition(ticket, "ORPHAN RECOVERY CLEANUP"))
                    {
                        PrintFormat("ORPHAN CLEANUP: Closed orphan recovery position #%d (Base Trade #%d no longer exists)", 
                                   ticket, base_ticket);
                        orphan_recovery_closed++;
                    }
                }
            }
        }
    }
    
    if(orphan_recovery_closed > 0)
    {
        PrintFormat("ORPHAN CLEANUP: Closed %d orphan recovery positions", orphan_recovery_closed);
    }
}

//+------------------------------------------------------------------+
//| Validate DCA groups and remove groups with non-existent main trades |
//+------------------------------------------------------------------+
void ValidateDCAGroups()
{
    if(!InpDCAEnabled) return;
    
    for(int i = ArraySize(DCAGroups) - 1; i >= 0; i--)
    {
        // Check if main trade still exists
        if(!PositionSelectByTicket(DCAGroups[i].main_ticket))
        {
            PrintFormat("DCA VALIDATION: Main trade #%d no longer exists. Cleaning up group with %d orders.", 
                       DCAGroups[i].main_ticket, DCAGroups[i].dca_count);
            
            // Cancel all DCA orders in this group
            CancelDCAOrders(DCAGroups[i]);
            
            // Remove the group
            RemoveDCAGroup(i);
        }
    }
}

//+------------------------------------------------------------------+
//| Validate MultiOrder groups and remove groups with non-existent base trades |
//+------------------------------------------------------------------
void ValidateMultiOrderGroups()
{
    for(int i = ArraySize(MultiOrderGroups) - 1; i >= 0; i--)
    {
        // Check if base trade still exists
        if(!PositionSelectByTicket(MultiOrderGroups[i].base_ticket))
        {
            PrintFormat("RECOVERY VALIDATION: Base trade #%d no longer exists. Cleaning up group with %d positions.", 
                       MultiOrderGroups[i].base_ticket, MultiOrderGroups[i].ticket_count);
            
            // Close all recovery positions in this group
            for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
            {
                ulong ticket = MultiOrderGroups[i].tickets[j];
                if(ticket > 0 && PositionSelectByTicket(ticket))
                {
                    ForceClosePosition(ticket, "RECOVERY VALIDATION");
                }
            }
            
            // Clean up all chart objects for this group
            CleanupGroupChartObjects(MultiOrderGroups[i]);
            
            // Remove the group by shifting remaining groups
            for(int k = i; k < ArraySize(MultiOrderGroups) - 1; k++)
            {
                MultiOrderGroups[k] = MultiOrderGroups[k + 1];
            }
            ArrayResize(MultiOrderGroups, ArraySize(MultiOrderGroups) - 1);
        }
    }
}

//+------------------------------------------------------------------+
//| Master cleanup function - removes ALL orphan trades and orders   |
//+------------------------------------------------------------------+
void MasterOrphanCleanup()
{
    PrintFormat("=== MASTER ORPHAN CLEANUP STARTING ===");
    
    // 1. Clean up orphan DCA orders and positions
    CleanupOrphanDCAOrders();
    
    // 2. Clean up orphan recovery trades
    CleanupOrphanRecoveryTrades();
    
    // 3. Validate and clean DCA groups
    ValidateDCAGroups();
    
    // 4. Validate and clean MultiOrder groups
    ValidateMultiOrderGroups();
    
    // 5. Clean up any visual objects
    CleanupAllDCAObjects();
    
    PrintFormat("=== MASTER ORPHAN CLEANUP COMPLETED ===");
}

//+------------------------------------------------------------------+
//| Cancel all DCA orders for a group                               |
//+------------------------------------------------------------------+
void CancelDCAOrders(DCAGroup &group)
{
    for(int i = 0; i < group.dca_count; i++)
    {
        ulong ticket = group.dca_tickets[i];
        if(ticket > 0)
        {
            if(OrderSelect(ticket))
            {
                MqlTradeRequest request;
                MqlTradeResult result;
                ZeroMemory(request);
                ZeroMemory(result);
                
                request.action = TRADE_ACTION_REMOVE;
                request.order = ticket;
                
                if(!IsSpreadAcceptable()) return;
                if(SendDollarExitAwareOrder(request, result))
                {
                    PrintFormat("DCA: Cancelled order #%d", ticket);
                }
                else
                {
                    PrintFormat("DCA: Failed to cancel order #%d. Error: %d", ticket, GetLastError());
                }
            }
            
            // Clean up visual line
            CleanupDCALine(ticket);
        }
    }
}

//+------------------------------------------------------------------+
//| Remove DCA group from array                                     |
//+------------------------------------------------------------------+
void RemoveDCAGroup(int index)
{
    // Shift remaining groups
    for(int i = index; i < ArraySize(DCAGroups) - 1; i++)
    {
        DCAGroups[i] = DCAGroups[i + 1];
    }
    
    // Resize array
    ArrayResize(DCAGroups, ArraySize(DCAGroups) - 1);
}

//+------------------------------------------------------------------+
//| Draw visual line for DCA order                                  |
