//+------------------------------------------------------------------+
//| Check if Percentage Distance confirms BUY recovery               |
//| Conditions: Price has fallen X% below synthetic SL               |
//| Opens recovery on unique percentage milestones (1%, 2%, 3%, etc) |
//+------------------------------------------------------------------+
bool IsPercentageConfirmingBuyRecovery(ulong ticket, double entry_price, double synthetic_sl)
{
   if(!InpPercentageRecoveryConfirmationEnabled)
      return true;
   
   // Get current price (BID for buy recovery)
   double current_price = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Calculate the distance from synthetic SL to current price as percentage
   // For BUY: price below SL (moving into loss area)
   double sl_distance = entry_price - synthetic_sl;  // Original risk distance
   double current_distance = synthetic_sl - current_price;  // How far below SL
   
   if(sl_distance == 0 || current_distance <= 0)
      return false;  // Price not below SL or invalid
   
   // Calculate percentage: (distance below SL / original risk) * 100
   double percentage_distance = (current_distance / MathAbs(sl_distance)) * 100.0;
   
   // Find or initialize tracker for this position
   int tracker_idx = -1;
   for(int i = 0; i < ArraySize(ExtPercentageRecoveryTrackers); i++)
   {
      if(ExtPercentageRecoveryTrackers[i].ticket == ticket)
      {
         tracker_idx = i;
         break;
      }
   }
   
   if(tracker_idx == -1)
   {
      // New position - initialize tracker
      tracker_idx = ArraySize(ExtPercentageRecoveryTrackers);
      ArrayResize(ExtPercentageRecoveryTrackers, tracker_idx + 1);
      ExtPercentageRecoveryTrackers[tracker_idx].ticket = ticket;
      ExtPercentageRecoveryTrackers[tracker_idx].last_percentage_milestone = 0;
      ExtPercentageRecoveryTrackers[tracker_idx].initialized = false;
   }
   
   // Calculate which milestone we're at using exponential growth
   // Milestone 1: step (1%)
   // Milestone 2: step * multiplier (2% with x2)
   // Milestone 3: step * multiplier^2 (4% with x2)
   // Formula: step * (multiplier ^ (n-1))
   
   double current_milestone = InpPercentageRecoveryStep;
   int milestone_count = 1;
   
   // Find which milestone level we're currently at
   while(percentage_distance > current_milestone && milestone_count < 100)
   {
      milestone_count++;
      // Use exponential: step * (multiplier ^ (count-1))
      current_milestone = InpPercentageRecoveryStep * MathPow(InpPercentageRecoveryMultiplier, milestone_count - 1);
   }
   
   // Backtrack to the milestone we just passed or are at
   if(percentage_distance < current_milestone && milestone_count > 1)
   {
      milestone_count--;
      current_milestone = InpPercentageRecoveryStep * MathPow(InpPercentageRecoveryMultiplier, milestone_count - 1);
   }
   
   // If we've reached a new milestone that we haven't triggered yet
   bool new_milestone_reached = (current_milestone > ExtPercentageRecoveryTrackers[tracker_idx].last_percentage_milestone);
   
   if(new_milestone_reached && percentage_distance >= current_milestone)
   {
      ExtPercentageRecoveryTrackers[tracker_idx].last_percentage_milestone = current_milestone;
      
      if(!g_is_backtesting)
      {
         PrintFormat("Percentage Recovery BUY: CONFIRMED - Price %.5f is %.2f%% below SyntheticSL %.5f. Milestone: %.2f%%",
                     current_price, percentage_distance, synthetic_sl, current_milestone);
      }
      return true;
   }
   
   return false;
}

