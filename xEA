//+------------------------------------------------------------------+
//| Clean up all chart objects for a group                           |
//+------------------------------------------------------------------+
void CleanupGroupChartObjects(MultiOrderGroup &group)
{
   // Clean up all synthetic SL lines and TP lines for the group
   for(int i = 0; i < group.ticket_count; i++)
   {
      ulong ticket = group.tickets[i];
      CleanupSyntheticSLLine(ticket);
      CleanupOriginalTradeTPLine(ticket);
      
      // Clean up recovery target lines
      string recovery_line = "RECOVERY_TARGET_LINE_" + IntegerToString((int)ticket);
      ObjectDelete(0, recovery_line);
      
      // Clean up multi-recovery target lines
      string multi_recovery_line = "MULTI_RECOVERY_TARGET_LINE_" + IntegerToString((int)ticket);
      ObjectDelete(0, multi_recovery_line);
      
      // Clean up multi-recovery breakeven lines
      string breakeven_line = "MULTI_RECOVERY_BREAKEVEN_LINE_" + IntegerToString((int)ticket);
      ObjectDelete(0, breakeven_line);
   }
   
   // Clean up any other group-specific objects
   string base_ticket_str = IntegerToString((int)group.base_ticket);
   
   // Delete any objects that might contain the base ticket in their name
   int total_objects = ObjectsTotal(0);
   for(int i = total_objects - 1; i >= 0; i--)
   {
      string obj_name = ObjectName(0, i);
      if(StringFind(obj_name, base_ticket_str) >= 0)
      {
         ObjectDelete(0, obj_name);
      }
   }
   
   ChartRedraw(0); // Force chart redraw to ensure all objects are removed
}

