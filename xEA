//+------------------------------------------------------------------+
//| Clean up all DCA objects on deinit                             |
//+------------------------------------------------------------------+
void CleanupAllDCAObjects()
{
    // Cancel all DCA orders
    for(int i = 0; i < ArraySize(DCAGroups); i++)
    {
        CancelDCAOrders(DCAGroups[i]);
    }
    
    // Remove all DCA visual objects
    int total_objects = ObjectsTotal(0);
    for(int i = total_objects - 1; i >= 0; i--)
    {
        string obj_name = ObjectName(0, i);
        if(StringFind(obj_name, "DCA_LINE_") >= 0)
        {
            ObjectDelete(0, obj_name);
        }
    }
    
    ChartRedraw(0);
}

//+------------------------------------------------------------------+
//| Check if DCA Smart Exit condition is met                        |
//+------------------------------------------------------------------+
void CheckDCASmartExit()
{
    if(!InpDCAEnabled || !InpDCASmartExit) return;
    
    // Get all positions with our magic number
    double total_profit = 0.0;
    double main_trade_target_profit = 0.0;
    bool has_main_trade = false;
    bool has_dca_trades = false;
    int total_positions = 0;
    
    // Calculate total current profit and identify trade types
    for(int i = 0; i < PositionsTotal(); i++)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket == 0) continue;
        if(!PositionSelectByTicket(ticket)) continue;
        if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
        
        string position_symbol = PositionGetString(POSITION_SYMBOL);
        if(position_symbol != _Symbol) continue;
        
        total_positions++;
        double pos_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
        total_profit += pos_profit;
        
        string comment = PositionGetString(POSITION_COMMENT);
        
        // Check if this is a DCA trade (comment contains "DCA" or if it's a recovery trade)
        if(StringFind(comment, "DCA") >= 0 || StringFind(comment, "MultiOrder") >= 0)
        {
            has_dca_trades = true;
        }
        else
        {
            // This is likely the main trade
            has_main_trade = true;
            
            // Calculate what the target profit would be for this trade
            double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
            double current_price = PositionGetDouble(POSITION_PRICE_CURRENT);
            double volume = PositionGetDouble(POSITION_VOLUME);
            ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
            
            // Get the TP price to calculate target profit
            double tp_price = PositionGetDouble(POSITION_TP);
            if(tp_price > 0)
            {
                double profit_distance = 0;
                if(pos_type == POSITION_TYPE_BUY)
                    profit_distance = tp_price - entry_price;
                else
                    profit_distance = entry_price - tp_price;
                    
                // Calculate target profit in account currency
                double tick_size = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
                double tick_value = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
                if(tick_size > 0)
                {
                    main_trade_target_profit = (profit_distance / tick_size) * tick_value * volume;
                }
            }
        }
    }
    
    // Only proceed if we have both main trade and DCA/recovery trades, and overall profit is positive
    if(!has_main_trade || !has_dca_trades || total_profit <= 0 || main_trade_target_profit <= 0)
        return;
    
    // Calculate what percentage of target profit we've achieved
    double profit_percentage = (total_profit / main_trade_target_profit) * 100.0;
    
    // Check if we've reached the exit threshold
    if(profit_percentage >= InpDCAExitProfitPercent)
    {
        PrintFormat("DCA Smart Exit triggered! Combined P&L: %.2f (%.1f%% of main target: %.2f). Closing all positions.", 
                   total_profit, profit_percentage, main_trade_target_profit);
        
        // Close all positions
        CloseAllEAPositions();
        
        // Cancel any remaining DCA orders
        CleanupOrphanDCAOrders();
        
        PrintFormat("DCA Smart Exit completed. Closed %d positions.", total_positions);
    }
    else
    {
        // Optional: Log the current status periodically
        static datetime last_log_time = 0;
        if(TimeCurrent() - last_log_time >= 300) // Log every 5 minutes
        {
            PrintFormat("DCA Smart Exit monitoring: Combined P&L: %.2f (%.1f%% of target: %.2f, need %.1f%%)", 
                       total_profit, profit_percentage, main_trade_target_profit, InpDCAExitProfitPercent);
            last_log_time = TimeCurrent();
        }
    }
}

//+------------------------------------------------------------------+
//| Close all EA positions                                           |
//+------------------------------------------------------------------+
void CloseAllEAPositions()
{
    for(int i = PositionsTotal() - 1; i >= 0; i--)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket == 0) continue;
        if(!PositionSelectByTicket(ticket)) continue;
        if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
        
        string position_symbol = PositionGetString(POSITION_SYMBOL);
        if(position_symbol != _Symbol) continue;
        
        ForceClosePosition(ticket);
    }
    
    // Clean up all remaining chart objects after closing all positions
    CleanupAllChartObjects();
}

