string FormatGlobalDollarLossStreakUtcResetTime()
{
   int reset_hour = InpGlobalDollarLossStreakResetUtcHour;
   int reset_minute = InpGlobalDollarLossStreakResetUtcMinute;
   if(reset_hour < 0) reset_hour = 0;
   if(reset_hour > 23) reset_hour = 23;
   if(reset_minute < 0) reset_minute = 0;
   if(reset_minute > 59) reset_minute = 59;
   return StringFormat("%02d:%02d UTC", reset_hour, reset_minute);
}

datetime GetNextGlobalDollarUtcResetTime()
{
   datetime utc_now = TimeGMT();
   int reset_hour = InpGlobalDollarLossStreakResetUtcHour;
   int reset_minute = InpGlobalDollarLossStreakResetUtcMinute;
   if(reset_hour < 0) reset_hour = 0;
   if(reset_hour > 23) reset_hour = 23;
   if(reset_minute < 0) reset_minute = 0;
   if(reset_minute > 59) reset_minute = 59;

   MqlDateTime utc_reset;
   TimeToStruct(utc_now, utc_reset);
   utc_reset.hour = reset_hour;
   utc_reset.min = reset_minute;
   utc_reset.sec = 0;

   datetime next_reset_utc = StructToTime(utc_reset);
   if(next_reset_utc <= utc_now)
      next_reset_utc += 24 * 3600;

   return next_reset_utc;
}

string FormatGlobalDollarResetRemainingTime(const int remaining_seconds)
{
   int safe_seconds = remaining_seconds;
   if(safe_seconds < 0) safe_seconds = 0;
   int days = safe_seconds / 86400;
   int hours = (safe_seconds % 86400) / 3600;
   int minutes = (safe_seconds % 3600) / 60;

   if(days > 0)
      return StringFormat("%dd %dh %dm", days, hours, minutes);

   return StringFormat("%dh %dm", hours, minutes);
}

void LogGlobalDollarUtcResetCountdown(bool force_log = false)
{
   if(!InpGlobalDollarExitEnabled)
      return;

   datetime server_now = TimeCurrent();
   if(!force_log && g_globalDollarUtcResetLastLogTime > 0 && (server_now - g_globalDollarUtcResetLastLogTime) < 1800)
      return;

   datetime utc_now = TimeGMT();
   datetime next_reset_utc = GetNextGlobalDollarUtcResetTime();
   int remaining_seconds = (int)(next_reset_utc - utc_now);
   if(remaining_seconds < 0) remaining_seconds = 0;

   PrintFormat("GLOBAL DOLLAR EXIT: UTC daily drawdown reset countdown. Reset time: %s, Current UTC: %s, Next reset UTC: %s, Time remaining: %s.",
               FormatGlobalDollarLossStreakUtcResetTime(),
               TimeToString(utc_now, TIME_DATE|TIME_MINUTES),
               TimeToString(next_reset_utc, TIME_DATE|TIME_MINUTES),
               FormatGlobalDollarResetRemainingTime(remaining_seconds));

   g_globalDollarUtcResetLastLogTime = server_now;
}

datetime GetGlobalDollarLossStreakPauseUntil()
{
   datetime server_now = TimeCurrent();

   if(InpGlobalDollarLossStreakPauseMode != GDLS_PAUSE_UNTIL_UTC_RESET)
      return server_now + MathMax(1, InpGlobalDollarLossStreakPauseHours) * 3600;

   datetime utc_now = TimeGMT();
   datetime next_reset_utc = GetNextGlobalDollarUtcResetTime();

   return next_reset_utc + (server_now - utc_now);
}

bool IsGlobalDollarLossStreakPauseActive()
{
   if(!InpGlobalDollarLossStreakPauseEnabled)
      return false;

   if(g_globalDollarLossStreakPauseUntil <= 0)
      return false;

   datetime now = TimeCurrent();
   if(now < g_globalDollarLossStreakPauseUntil)
      return true;

   PrintFormat("Global Dollar %s Streak Pause ended at server time %s. New trades are allowed.",
               GlobalDollarStreakPauseTriggerText(),
               TimeToString(now, TIME_DATE|TIME_SECONDS));
   g_globalDollarLossStreakPauseUntil = 0;
   g_globalDollarLossStreak = 0;
   SaveGlobalDollarLossStreakState();
   return false;
}

string GlobalDollarLossStreakPauseReason()
{
   if(!IsGlobalDollarLossStreakPauseActive())
      return "";

   int remaining_seconds = (int)(g_globalDollarLossStreakPauseUntil - TimeCurrent());
   int remaining_minutes = (int)MathCeil((double)MathMax(0, remaining_seconds) / 60.0);
   string reset_info = InpGlobalDollarLossStreakPauseMode == GDLS_PAUSE_UNTIL_UTC_RESET ?
                       " (" + FormatGlobalDollarLossStreakUtcResetTime() + ")" :
                       "";
   return StringFormat("%s streak pause active: %d consecutive %s closes, resumes %s server time%s (~%d min)",
                       GlobalDollarStreakPauseTriggerText(),
                       g_globalDollarLossStreak,
                       GlobalDollarStreakPauseOutcomeText(),
                       TimeToString(g_globalDollarLossStreakPauseUntil, TIME_DATE|TIME_MINUTES),
                       reset_info,
                       remaining_minutes);
}

int GlobalDollarDailyDrawdownTradesLeft(double &daily_dd_left, double &planned_loss)
{
   daily_dd_left = 0.0;
   planned_loss = MathAbs(InpGlobalDollarPanelPlannedLossMoney);

   if(planned_loss <= 0.0)
      return -1;

   GDPanelLoadOrResetDailyState();

   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double daily_limit_money = GDPanelDrawdownLimitMoney(InpGlobalDollarPanelDailyDrawdownLimitMode,
                                                        InpGlobalDollarPanelMaxDailyDrawdownValue,
                                                        g_gdPanelDailyStartEquity);
   double daily_floor = g_gdPanelDailyStartEquity - daily_limit_money;
   daily_dd_left = equity - daily_floor;

   return (int)MathFloor(MathMax(0.0, daily_dd_left) / planned_loss);
}

bool IsGlobalDollarDailyDrawdownTradePauseActive()
{
   if(!InpGlobalDollarExitEnabled || !InpGlobalDollarDailyDDTradePauseEnabled)
      return false;

   double daily_dd_left = 0.0;
   double planned_loss = 0.0;
   int trades_left = GlobalDollarDailyDrawdownTradesLeft(daily_dd_left, planned_loss);
   if(trades_left < 0)
      return false;

   return trades_left <= MathMax(0, InpGlobalDollarDailyDDTradesLeftStopAt);
}

string GlobalDollarDailyDrawdownTradePauseReason()
{
   if(!InpGlobalDollarExitEnabled || !InpGlobalDollarDailyDDTradePauseEnabled)
      return "";

   double daily_dd_left = 0.0;
   double planned_loss = 0.0;
   int trades_left = GlobalDollarDailyDrawdownTradesLeft(daily_dd_left, planned_loss);
   if(trades_left < 0)
      return "planned loss money is not configured";

   return StringFormat("daily DD planned-loss trades left %d <= stop setting %d (daily DD left %.2f, planned loss %.2f)",
                       trades_left,
                       MathMax(0, InpGlobalDollarDailyDDTradesLeftStopAt),
                       daily_dd_left,
                       planned_loss);
}

void UpdateGlobalDollarLossStreakPause()
{
   if(!InpGlobalDollarLossStreakPauseEnabled)
      return;

   datetime now = TimeCurrent();
   if(IsGlobalDollarLossStreakPauseActive())
      return;

   datetime history_from = (g_globalDollarLossStreakHistoryFrom > 0 ? g_globalDollarLossStreakHistoryFrom : now);
   if(!HistorySelect(history_from, now))
      return;

   int total_deals = HistoryDealsTotal();
   for(int i = 0; i < total_deals; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0 || deal_ticket <= g_globalDollarLossStreakLastDeal) continue;
      if(HistoryDealGetInteger(deal_ticket, DEAL_MAGIC) != InpMagicNumber) continue;

      ENUM_DEAL_TYPE deal_type = (ENUM_DEAL_TYPE)HistoryDealGetInteger(deal_ticket, DEAL_TYPE);
      if(deal_type != DEAL_TYPE_BUY && deal_type != DEAL_TYPE_SELL) continue;

      ENUM_DEAL_ENTRY deal_entry = (ENUM_DEAL_ENTRY)HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
      if(deal_entry != DEAL_ENTRY_OUT && deal_entry != DEAL_ENTRY_INOUT && deal_entry != DEAL_ENTRY_OUT_BY) continue;

      string symbol = HistoryDealGetString(deal_ticket, DEAL_SYMBOL);

      double net_profit = HistoryDealGetDouble(deal_ticket, DEAL_PROFIT) +
                          HistoryDealGetDouble(deal_ticket, DEAL_COMMISSION) +
                          HistoryDealGetDouble(deal_ticket, DEAL_SWAP);
      ENUM_DEAL_REASON deal_reason = (ENUM_DEAL_REASON)HistoryDealGetInteger(deal_ticket, DEAL_REASON);
      bool selected_streak_close = IsGlobalDollarSelectedStreakClose(net_profit, deal_reason);
      bool opposite_streak_close = IsGlobalDollarOppositeStreakClose(net_profit, deal_reason);

      g_globalDollarLossStreakLastDeal = deal_ticket;
      g_globalDollarLossStreakHistoryFrom = (datetime)HistoryDealGetInteger(deal_ticket, DEAL_TIME);
      SaveGlobalDollarLossStreakState();

      if(selected_streak_close)
      {
         g_globalDollarLossStreak++;
         PrintFormat("Global Dollar %s Streak: closed %s deal #%d on %s, net %.2f. Streak %d/%d.",
                     GlobalDollarStreakPauseTriggerText(), GlobalDollarStreakPauseOutcomeText(),
                     deal_ticket, symbol, net_profit, g_globalDollarLossStreak, MathMax(1, InpGlobalDollarLossStreakCount));
         SaveGlobalDollarLossStreakState();
      }
      else if(opposite_streak_close)
      {
         if(g_globalDollarLossStreak > 0)
            PrintFormat("Global Dollar %s Streak reset by opposite close deal #%d on %s, net %.2f.",
                        GlobalDollarStreakPauseTriggerText(), deal_ticket, symbol, net_profit);
         g_globalDollarLossStreak = 0;
         SaveGlobalDollarLossStreakState();
      }

      int streak_limit = MathMax(1, InpGlobalDollarLossStreakCount);
      if(g_globalDollarLossStreak >= streak_limit)
      {
         g_globalDollarLossStreakPauseUntil = GetGlobalDollarLossStreakPauseUntil();
         PrintFormat("Global Dollar %s Streak Pause triggered after %d consecutive %s closes for magic %d. Mode: %s, UTC Reset: %s. Pausing new trades until %s server time.",
                     GlobalDollarStreakPauseTriggerText(),
                     g_globalDollarLossStreak,
                     GlobalDollarStreakPauseOutcomeText(),
                     InpMagicNumber,
                     GlobalDollarLossStreakPauseModeText(),
                     FormatGlobalDollarLossStreakUtcResetTime(),
                     TimeToString(g_globalDollarLossStreakPauseUntil, TIME_DATE|TIME_SECONDS));
         SaveGlobalDollarLossStreakState();
         break;
      }
   }
}

void CancelGlobalDollarStopTradingPendingOrders()
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(!OrderSelect(ticket)) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;

      string symbol = OrderGetString(ORDER_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      MqlTradeRequest request;
      MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);

      request.action = TRADE_ACTION_REMOVE;
      request.order = ticket;
      request.symbol = symbol;
      request.magic = InpMagicNumber;
      request.comment = "Global dollar stop trading";

      if(!OrderSend(request, result))
      {
         PrintFormat("Global Dollar Stop Trading: Failed to remove pending order #%d. Error: %d",
                     ticket, GetLastError());
      }
      else if(result.retcode != TRADE_RETCODE_DONE)
      {
         PrintFormat("Global Dollar Stop Trading: Pending order remove rejected for #%d. Retcode: %d, Comment: %s",
                     ticket, result.retcode, result.comment);
      }
   }
}

void CloseGlobalDollarStopTradingPositions()
{
   string close_comment = "GDStop " + g_globalDollarStopTradingReason;
   if(StringLen(close_comment) > 31)
      close_comment = StringSubstr(close_comment, 0, 31);

   int closed_count = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      PrintFormat("Global Dollar Stop Trading: Closing position #%d on %s. Reason: %s",
                  ticket, symbol, g_globalDollarStopTradingReason);

      if(ClosePositionWithComment(ticket, close_comment))
         closed_count++;
   }

   PrintFormat("Global Dollar Stop Trading: Closed %d live position(s). Reason: %s",
               closed_count, g_globalDollarStopTradingReason);
}

void EnforceGlobalDollarStopTrading()
{
   if(!InpGlobalDollarStopTradingEnabled)
      return;

   if(g_globalDollarStopTradingTriggered)
   {
      if(InpGlobalDollarStopTradingCloseOpenPositions)
         CloseGlobalDollarStopTradingPositions();
      CancelGlobalDollarStopTradingPendingOrders();
      return;
   }

   int deal_count = 0;
   int position_count = 0;
   double total_pnl = CalculateGlobalDollarStopTradingPnL(deal_count, position_count);

   double profit_limit = MathAbs(InpGlobalDollarStopTradingProfit);
   double loss_limit = MathAbs(InpGlobalDollarStopTradingLoss);

   if(profit_limit > 0.0 && total_pnl >= profit_limit)
   {
      g_globalDollarStopTradingTriggered = true;
      g_globalDollarStopTradingPnL = total_pnl;
      g_globalDollarStopTradingReason = "profit stop " + DoubleToString(total_pnl, 2) +
                                        " >= " + DoubleToString(profit_limit, 2);
   }
   else if(loss_limit > 0.0 && total_pnl <= -loss_limit)
   {
      g_globalDollarStopTradingTriggered = true;
      g_globalDollarStopTradingPnL = total_pnl;
      g_globalDollarStopTradingReason = "loss stop " + DoubleToString(total_pnl, 2) +
                                        " <= -" + DoubleToString(loss_limit, 2);
   }

   if(g_globalDollarStopTradingTriggered)
   {
      PrintFormat("Global Dollar Stop Trading triggered: %s. Deals=%d, counted open positions=%d. Close live positions: %s. Cancelling pending orders and blocking new trades.",
                  g_globalDollarStopTradingReason, deal_count, position_count,
                  InpGlobalDollarStopTradingCloseOpenPositions ? "YES" : "NO");
      if(InpGlobalDollarStopTradingCloseOpenPositions)
         CloseGlobalDollarStopTradingPositions();
      CancelGlobalDollarStopTradingPendingOrders();
   }
}

void ApplyGlobalDollarSLTPToPositions()
{
   if(!InpGlobalDollarExitEnabled)
      return;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      ENUM_ORDER_TYPE order_type = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY ? ORDER_TYPE_BUY : ORDER_TYPE_SELL);
      double volume = PositionGetDouble(POSITION_VOLUME);
      double entry = PositionGetDouble(POSITION_PRICE_OPEN);
      double desired_sl = 0.0;
      double desired_tp = 0.0;
      if(!CalculateGlobalDollarSLTP(symbol, order_type, volume, entry, desired_sl, desired_tp))
         continue;

      double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
      if(point <= 0.0) point = 0.00001;

      double current_sl = PositionGetDouble(POSITION_SL);
      double current_tp = PositionGetDouble(POSITION_TP);
      if(MathAbs(current_sl - desired_sl) < point / 2.0 &&
         MathAbs(current_tp - desired_tp) < point / 2.0)
         continue;

      MqlTradeRequest request;
      MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);

      request.action = TRADE_ACTION_SLTP;
      request.position = ticket;
      request.symbol = symbol;
      request.sl = desired_sl;
      request.tp = desired_tp;
      request.magic = InpMagicNumber;
      request.comment = "Global dollar exit: dollar SL/TP";

      if(!SendDollarExitAwareOrder(request, result))
      {
         PrintFormat("Global Dollar Exit: Failed to set dollar SL/TP for position #%d. Error: %d",
                     ticket, GetLastError());
      }
      else if(result.retcode != TRADE_RETCODE_DONE)
      {
         PrintFormat("Global Dollar Exit: Dollar SL/TP rejected for position #%d. Retcode: %d, Comment: %s",
                     ticket, result.retcode, result.comment);
      }
      else
      {
         PrintFormat("Global Dollar Exit: Updated dollar SL/TP for position #%d to SL %.5f / TP %.5f",
                     ticket, desired_sl, desired_tp);
      }
   }
}

void ApplyGlobalDollarSLTPToPendingOrders()
{
   if(!InpGlobalDollarExitEnabled)
      return;

   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0) continue;
      if(!OrderSelect(ticket)) continue;
      if(OrderGetInteger(ORDER_MAGIC) != InpMagicNumber) continue;

      string symbol = OrderGetString(ORDER_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      ENUM_ORDER_TYPE order_type = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      double volume = OrderGetDouble(ORDER_VOLUME_CURRENT);
      double entry = OrderGetDouble(ORDER_PRICE_OPEN);
      double desired_sl = 0.0;
      double desired_tp = 0.0;
      if(!CalculateGlobalDollarSLTP(symbol, order_type, volume, entry, desired_sl, desired_tp))
         continue;

      double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
      if(point <= 0.0) point = 0.00001;

      double current_sl = OrderGetDouble(ORDER_SL);
      double current_tp = OrderGetDouble(ORDER_TP);
      if(MathAbs(current_sl - desired_sl) < point / 2.0 &&
         MathAbs(current_tp - desired_tp) < point / 2.0)
         continue;

      MqlTradeRequest request;
      MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);

      request.action = TRADE_ACTION_MODIFY;
      request.order = ticket;
      request.symbol = symbol;
      request.price = entry;
      request.stoplimit = OrderGetDouble(ORDER_PRICE_STOPLIMIT);
      request.sl = desired_sl;
      request.tp = desired_tp;
      request.type_time = (ENUM_ORDER_TYPE_TIME)OrderGetInteger(ORDER_TYPE_TIME);
      request.expiration = (datetime)OrderGetInteger(ORDER_TIME_EXPIRATION);
      request.type_filling = GetSupportedFillingMode(symbol);
      request.magic = InpMagicNumber;

      if(!SendDollarExitAwareOrder(request, result))
      {
         PrintFormat("Global Dollar Exit: Failed to set dollar SL/TP for pending order #%d. Error: %d",
                     ticket, GetLastError());
      }
      else if(result.retcode != TRADE_RETCODE_DONE)
      {
         PrintFormat("Global Dollar Exit: Pending dollar SL/TP rejected for #%d. Retcode: %d, Comment: %s",
                     ticket, result.retcode, result.comment);
      }
      else
      {
         PrintFormat("Global Dollar Exit: Updated pending order #%d dollar SL/TP to SL %.5f / TP %.5f",
                     ticket, desired_sl, desired_tp);
      }
   }
}

void CloseGlobalDollarExitPositions(const string reason)
{
   int closed_count = 0;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      if(!IsGlobalDollarExitManagedSymbol(symbol)) continue;

      PrintFormat("Global Dollar Exit: Closing position #%d on %s. Reason: %s", ticket, symbol, reason);
      if(ClosePosition(ticket))
         closed_count++;
   }

   PrintFormat("Global Dollar Exit: Closed %d position(s). Reason: %s", closed_count, reason);
}

void EnforceGlobalDollarExit()
{
   if(!InpGlobalDollarExitEnabled) return;
   if(IsGlobalDollarStopTradingActive()) return;

   ApplyGlobalDollarSLTPToPositions();
   ApplyGlobalDollarSLTPToPendingOrders();

   int position_count = 0;
   double total_pnl = CalculateGlobalDollarExitPnL(position_count);
   if(position_count <= 0) return;

   if(InpGlobalDollarProfitTarget > 0.0 && total_pnl >= InpGlobalDollarProfitTarget)
   {
      PrintFormat("Global Dollar Exit: Profit target reached %.2f >= %.2f. Closing %d EA position(s).",
                  total_pnl, InpGlobalDollarProfitTarget, position_count);
      CloseGlobalDollarExitPositions("global_dollar_profit_exit");
      return;
   }

   double loss_limit = MathAbs(InpGlobalDollarLossLimit);
   if(loss_limit > 0.0 && total_pnl <= -loss_limit)
   {
      PrintFormat("Global Dollar Exit: Loss limit reached %.2f <= -%.2f. Closing %d EA position(s).",
                  total_pnl, loss_limit, position_count);
      CloseGlobalDollarExitPositions("global_dollar_loss_exit");
   }
}

void OnTick()
{
   // Get current time for all time-based checks
   datetime current_time = TimeCurrent();

   UpdateGlobalDollarLossStreakPause();
   if(IsGlobalDollarLossStreakPauseActive())
      CancelGlobalDollarStopTradingPendingOrders();
   if(IsGlobalDollarDailyDrawdownTradePauseActive())
      CancelGlobalDollarStopTradingPendingOrders();

   EnforceGlobalDollarStopTrading();
   EnforceGlobalDollarExit();

    // Trailing safety net: run from ticks too.
    // This helps when timer cadence is sparse in tester/live.
    if(InpEnableTrailSL && !InpGlobalDollarExitEnabled)
    {
        ApplyTrailingStop();
    }

    if(InpMultiOrderEnabled && InpPattern9RecoveryConfirmationEnabled && InpPattern9RecoveryUseOpenPriceTrigger)
    {
        ProcessPattern9RecoveryOpenTriggers();
    }
    if(InpMultiOrderEnabled && InpPattern18RecoveryConfirmationEnabled && InpPattern18RecoveryUseOpenPriceTrigger)
    {
        ProcessPattern18RecoveryOpenTriggers();
    }

    if(!InpMultiOrderEnabled)
    {
        ProcessStandaloneTimeBasedExit();
    }

    // Recovery safety net: run multi-order recovery from ticks too.
    // This keeps recovery active even if timer scheduling is sparse.
    static datetime last_recovery_tick_process = 0;
    if(InpMultiOrderEnabled && current_time != last_recovery_tick_process)
    {
        ProcessMultiOrderRecovery();
        last_recovery_tick_process = current_time;
    }
    
    // Reset volume recovery tracker on new bar
    {
        datetime current_bar_time = iTime(_Symbol, _Period, 0);
        if(current_bar_time != ExtVolumeRecoveryTracker.last_volume_recovery_bar)
        {
            ExtVolumeRecoveryTracker.volume_recovery_triggered = false;
        }
    }
    
    //+------------------------------------------------------------------+
    //| GLOBAL P&L AND HEDGE MONITORING SYSTEM                                |
    //+------------------------------------------------------------------+
    // This system monitors the total P&L of position groups and implements
    // automatic hedging when losses exceed specified thresholds.
    // 
    // Hedge Activation:
    // - Triggers when group P&L drops below InpGlobalHedgeThreshold (-$20)
    // - Opens opposite position with equal volume to original positions
    // - Prevents new recovery trades while hedge is active
    //
    // Hedge Management:
    // - Continuously monitors both group and hedge position P&L
    // - Closes hedge if its loss exceeds InpGlobalHedgeExitThreshold (-$20)
    // - Automatic closure of hedge when group reaches profit target
    //
    // Safety Features:
    // - Only one hedge position per group
    // - Full volume matching to ensure complete protection
    // - Automatic reset of hedge flags after closure
    
    if(InpGlobalPnLMonitorEnabled && InpMultiOrderEnabled)
    {
      static datetime last_emergency_check = 0;
      // Monitor groups every 5 seconds for hedge conditions
      if(current_time - last_emergency_check >= 5)
      {
         for(int emergency_idx = 0; emergency_idx < ArraySize(MultiOrderGroups); emergency_idx++)
         {
            // Skip empty or invalid groups
            if(MultiOrderGroups[emergency_idx].base_ticket == 0) continue;
            
            // Clean up orphaned hedge flags if hedge position no longer exists
            if(MultiOrderGroups[emergency_idx].hedge_activated)
            {
                if(!PositionSelectByTicket(MultiOrderGroups[emergency_idx].hedge_ticket))
                {
                    PrintFormat("⚡ Cleaning up orphaned hedge flags for group #%d - Hedge #%d no longer exists",
                              MultiOrderGroups[emergency_idx].base_ticket,
                              MultiOrderGroups[emergency_idx].hedge_ticket);
                              
                    MultiOrderGroups[emergency_idx].hedge_activated = false;
                    MultiOrderGroups[emergency_idx].hedge_ticket = 0;
                    MultiOrderGroups[emergency_idx].hedge_entry = 0;
                    MultiOrderGroups[emergency_idx].hedge_lot = 0;
                    MultiOrderGroups[emergency_idx].hedge_time = 0;
                    MultiOrderGroups[emergency_idx].hedge_trigger_distance = 0;
                }
            }
            
            // Effective P&L = live (open positions) + realized memory (closed hedge/halt legs)
            double live_group_profit = CalculateGroupProfit(MultiOrderGroups[emergency_idx]);
            double remembered_profit = MultiOrderGroups[emergency_idx].realized_pnl_memory;
            double emergency_profit = live_group_profit + remembered_profit;
                
                //+------------------------------------------------------------------+
                //| HEDGE ACTIVATION LOGIC                                            |
                //+------------------------------------------------------------------+
                // Check conditions for opening a new hedge position:
                // 1. Global hedging must be enabled
                // 2. No existing hedge for this group
                // 3. No existing hedge in ANY group
                // 4. Group P&L below activation threshold
                
                // First check if any hedge is active in any group
                bool any_hedge_active = false;
                for(int check_idx = 0; check_idx < ArraySize(MultiOrderGroups); check_idx++)
                {
                    if(MultiOrderGroups[check_idx].hedge_activated)
                    {
                        // Verify if the hedge position still exists
                        if(MultiOrderGroups[check_idx].hedge_ticket > 0 && 
                           PositionSelectByTicket(MultiOrderGroups[check_idx].hedge_ticket))
                        {
                            any_hedge_active = true;
                            if(!g_is_backtesting)
                            {
                                PrintFormat("⚡ HEDGE BLOCKED: Cannot open new hedge for group #%d - Active hedge #%d exists in group #%d",
                                          MultiOrderGroups[emergency_idx].base_ticket,
                                          MultiOrderGroups[check_idx].hedge_ticket,
                                          MultiOrderGroups[check_idx].base_ticket);
                            }
                            break;
                        }
                    }
                }
                
                if(InpGlobalHedgeEnabled && !MultiOrderGroups[emergency_idx].hedge_activated && 
                   !any_hedge_active && live_group_profit <= InpGlobalHedgeThreshold)
                {
                    // Calculate total volume of all positions in group for full hedge coverage
                    double total_lot = MultiOrderGroups[emergency_idx].total_volume;
                    
                    // Determine hedge direction - always opposite of group's main direction
                    // For BUY groups -> SELL hedge
                    // For SELL groups -> BUY hedge
                    ENUM_POSITION_TYPE hedge_type = (MultiOrderGroups[emergency_idx].type == POSITION_TYPE_BUY) ? 
                                                   POSITION_TYPE_SELL : POSITION_TYPE_BUY;
                                                   
                    // Open hedge position
                    double hedge_price = 0;
                    if(hedge_type == POSITION_TYPE_BUY)
                        hedge_price = SymbolInfoDouble(MultiOrderGroups[emergency_idx].symbol, SYMBOL_ASK);
                    else
                        hedge_price = SymbolInfoDouble(MultiOrderGroups[emergency_idx].symbol, SYMBOL_BID);
                        
                    // Create detailed hedge position comment
                    string hedge_comment = StringFormat("⚡HEDGE[%d] P&L:%.2f$ Vol:%.2f Protect:%s", 
                                                      MultiOrderGroups[emergency_idx].base_ticket,
                                                      live_group_profit, total_lot,
                                                      hedge_type == POSITION_TYPE_BUY ? "SELL→BUY" : "BUY→SELL");
                                                      
                    ulong hedge_ticket = OpenPosition(MultiOrderGroups[emergency_idx].symbol, hedge_type, 
                                                    total_lot, 0, 0, hedge_comment);
                                                    
                    if(hedge_ticket != 0)
                    {
                        MultiOrderGroups[emergency_idx].hedge_activated = true;
                        MultiOrderGroups[emergency_idx].hedge_ticket = hedge_ticket;
                        MultiOrderGroups[emergency_idx].hedge_entry = hedge_price;
                        MultiOrderGroups[emergency_idx].hedge_lot = total_lot;
                        MultiOrderGroups[emergency_idx].hedge_time = current_time;
                        MultiOrderGroups[emergency_idx].hedge_trigger_distance = live_group_profit;
                        
                        PrintFormat("HEDGE ACTIVATED: Group #%d opened hedge position #%d (%.2f lots) at %.5f due to P&L: %.2f USD",
                                  MultiOrderGroups[emergency_idx].base_ticket, hedge_ticket, total_lot, 
                                  hedge_price, live_group_profit);
                    }
                }
                
                //+------------------------------------------------------------------+
                //| HEDGE MONITORING AND EXIT LOGIC                                     |
                //+------------------------------------------------------------------+
                // Monitor active hedge positions for exit conditions:
                // 1. Hedge P&L drops below exit threshold
                // 2. Original group reaches profit target
                if(MultiOrderGroups[emergency_idx].hedge_activated)
                {
                    // Verify hedge position exists and calculate its current P&L
                    if(PositionSelectByTicket(MultiOrderGroups[emergency_idx].hedge_ticket))
                    {
                        // Calculate total P&L including swaps
                        double hedge_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
                        
                        // Check if hedge position has reached its thresholds
                        if(hedge_profit >= InpGlobalHedgePositiveThreshold)
                        {
                            //--- Close ALL positions in the group as we've reached positive threshold
                            PrintFormat("HEDGE PROFIT TARGET: Group #%d hedge position reached profit target %.2f USD. Closing ALL positions!",
                                      MultiOrderGroups[emergency_idx].base_ticket, hedge_profit);
                                      
                            // Close all positions in the group
                            CloseAllGroupPositions(MultiOrderGroups[emergency_idx]);
                            
                            //--- Reset group tracking
                            ResetGroupData(emergency_idx);
                        }
                        else if((InpGlobalHedgeExitThreshold < 0 && hedge_profit <= InpGlobalHedgeExitThreshold) || 
                               (InpGlobalHedgeExitThreshold > 0 && hedge_profit >= InpGlobalHedgeExitThreshold))
                        {
                            //--- Close the hedge position when it reaches target (profit or loss)
                            if(ClosePosition(MultiOrderGroups[emergency_idx].hedge_ticket))
                            {
                                RememberRealizedGroupPnL(MultiOrderGroups[emergency_idx], hedge_profit, "global hedge close");
                                // Log successful hedge closure with P&L details
                                PrintFormat("HEDGE CLOSED: Group #%d hedge position #%d closed at P&L: %.2f USD",
                                          MultiOrderGroups[emergency_idx].base_ticket, 
                                          MultiOrderGroups[emergency_idx].hedge_ticket, hedge_profit);
                                          
                                //--- Reset hedge-related tracking data but keep the group active
                                MultiOrderGroups[emergency_idx].hedge_ticket = 0;              // Clear hedge ticket
                                MultiOrderGroups[emergency_idx].hedge_entry = 0;               // Clear hedge entry price
                                MultiOrderGroups[emergency_idx].hedge_lot = 0;                 // Clear hedge lot size
                                MultiOrderGroups[emergency_idx].hedge_activated = false;        // Allow new hedges
                                
                                // Log that recovery trades can resume
                                PrintFormat("GROUP #%d: Hedge position closed independently. Recovery trades can now resume.",
                                          MultiOrderGroups[emergency_idx].base_ticket);
                                MultiOrderGroups[emergency_idx].hedge_ticket = 0;              // Clear ticket
                                MultiOrderGroups[emergency_idx].hedge_entry = 0;               // Clear entry price
                                MultiOrderGroups[emergency_idx].hedge_lot = 0;                 // Clear volume
                                MultiOrderGroups[emergency_idx].hedge_time = 0;                // Clear timestamp
                                MultiOrderGroups[emergency_idx].hedge_trigger_distance = 0;     // Clear trigger level
                            }
                        }
                    }
                }
                
                //+------------------------------------------------------------------+
                //| EMERGENCY PROFIT TARGET EXIT                                        |
                //+------------------------------------------------------------------+
                // IMPORTANT: Apply group P&L exit once recovery mode is ENGAGED:
                // a) recovery trades exist, OR
                // b) recovery trigger has fired (synthetic SL hit / distance reached) even if confirmations delayed, OR
                // c) attempts/activation flags are set.
                
                int total_positions_in_group = MultiOrderGroups[emergency_idx].ticket_count;
                bool has_recovery_trades = (total_positions_in_group > 1);
                bool recovery_engaged = has_recovery_trades ||
                                        MultiOrderGroups[emergency_idx].activated ||
                                        MultiOrderGroups[emergency_idx].attempts > 0 ||
                                        MultiOrderGroups[emergency_idx].recovery_triggered;
                
                // Check group P&L exit once recovery is engaged
                if(recovery_engaged && emergency_profit >= InpGlobalPnLExitThreshold)
                {
                    // Log emergency exit with profit details
                    PrintFormat("EMERGENCY GLOBAL P&L EXIT: Group #%d effective %.2f USD (live %.2f + memory %.2f, threshold %.2f) with %d recovery trades (engaged: %s) - FORCE CLOSING NOW!",
                               MultiOrderGroups[emergency_idx].base_ticket, emergency_profit, live_group_profit, remembered_profit, InpGlobalPnLExitThreshold,
                               MathMax(0, total_positions_in_group - 1),
                               MultiOrderGroups[emergency_idx].recovery_triggered ? "TRIGGERED" : "ACTIVE");
                    
                    //--- First close any active hedge position
                    // Hedge must be closed before group positions to prevent temporary exposure
                    if(MultiOrderGroups[emergency_idx].hedge_activated)
                    {
                        // Close hedge position first
                        ClosePosition(MultiOrderGroups[emergency_idx].hedge_ticket);
                        
                        // Reset hedge flags immediately
                        MultiOrderGroups[emergency_idx].hedge_activated = false;
                        MultiOrderGroups[emergency_idx].hedge_ticket = 0;
                    }
                    
                    // Set descriptive close reason to show in trading history
                    string close_desc = StringFormat("✅SAVED by HEDGE %.2f$ [Group:%d]", 
                                                   emergency_profit,
                                                   MultiOrderGroups[emergency_idx].base_ticket);
                    MultiOrderGroups[emergency_idx].close_reason = close_desc;
                    CloseAllPositionsInGroup(MultiOrderGroups[emergency_idx]);
                    
                    // VALIDATION: Check if all positions were closed successfully
                    Sleep(500); // Brief pause to allow closure completion
                    ValidateGroupClosure(MultiOrderGroups[emergency_idx], "Emergency Global P&L Exit");
                }
                else if(recovery_engaged && emergency_profit >= (InpGlobalPnLExitThreshold * 0.2)) // log progress only when recovery engaged
                {
                    double remaining = InpGlobalPnLExitThreshold - emergency_profit;
                    if(remaining < 0) remaining = 0;
                    PrintFormat("EMERGENCY P&L WATCH: Group #%d effective %.2f USD (live %.2f + memory %.2f, remaining %.2f)",
                               MultiOrderGroups[emergency_idx].base_ticket, emergency_profit, live_group_profit, remembered_profit, remaining);
                }
            }
            last_emergency_check = current_time;
        }
    }
    
    // EMERGENCY GLOBAL DRAWDOWN CHECK - Run on every tick
    if(InpGlobalDrawdownMonitorEnabled)
    {
        static datetime last_drawdown_check = 0;
        
        // Check every 5 seconds or if we have significant losses
        if(current_time - last_drawdown_check >= 5)
        {
            double total_drawdown = 0.0;
            int total_positions = 0;
            
            // Calculate total drawdown across all groups
            for(int dd_idx = 0; dd_idx < ArraySize(MultiOrderGroups); dd_idx++)
            {
                if(MultiOrderGroups[dd_idx].base_ticket == 0) continue;
                
                double group_profit = CalculateGroupProfit(MultiOrderGroups[dd_idx]);
                total_drawdown += group_profit;
                if(group_profit < 0) total_positions++;
            }
            
            // Add single positions not in groups
            for(int pos = 0; pos < PositionsTotal(); pos++)
            {
                ulong ticket = PositionGetTicket(pos);
                if(ticket == 0) continue;
                
                if(!PositionSelectByTicket(ticket)) continue;
                
                long magic = PositionGetInteger(POSITION_MAGIC);
                
                if(magic != InpMagicNumber) continue;
                
                // Check if this position is already counted in a group
                bool in_group = false;
                for(int g = 0; g < ArraySize(MultiOrderGroups); g++)
                {
                    if(MultiOrderGroups[g].base_ticket == 0) continue;
                    if(MultiOrderGroups[g].base_ticket == ticket) { in_group = true; break; }
                    for(int r = 0; r < MultiOrderGroups[g].attempts; r++)
                    {
                        if(MultiOrderGroups[g].tickets[r] == ticket) { in_group = true; break; }
                    }
                    if(in_group) break;
                    if(MultiOrderGroups[g].hedge_ticket == ticket) { in_group = true; break; }
                }
                
                if(!in_group)
                {
                    double pos_profit = PositionGetDouble(POSITION_PROFIT) + PositionGetDouble(POSITION_SWAP);
                    total_drawdown += pos_profit;
                }
            }
            
            if(total_drawdown <= InpGlobalDrawdownExitThreshold)
            {
                PrintFormat("EMERGENCY GLOBAL DRAWDOWN EXIT: Total drawdown %.2f USD (<= %.2f threshold) - CLOSING ALL POSITIONS!",
                           total_drawdown, InpGlobalDrawdownExitThreshold);
                
                // Use the new global closure function
                CloseAllPositionsGlobally("emergency_global_drawdown");
                
                // Brief pause to allow closures
                Sleep(500);
            }
            else if(total_drawdown <= (InpGlobalDrawdownExitThreshold * 0.8)) // Warn at 80% of threshold
            {
                PrintFormat("DRAWDOWN WARNING: Total drawdown %.2f USD (%.2f USD from %.2f threshold)",
                           total_drawdown, InpGlobalDrawdownExitThreshold - total_drawdown, InpGlobalDrawdownExitThreshold);
            }
            
            last_drawdown_check = current_time;
        }
    }
    
    // Check for copy trading signals (check for new positions and closed positions)
    CheckForNewPositions();
    CheckForClosedPositions();
    
    // ENHANCED ORPHAN MONITORING: More frequent cleanup when many recovery positions exist
    static datetime last_orphan_check = 0;
    static int orphan_check_interval = 60; // Start with 60 seconds
    
    // Calculate total recovery positions across all groups
    int total_recovery_positions = 0;
    for(int group_idx = 0; group_idx < ArraySize(MultiOrderGroups); group_idx++)
    {
        total_recovery_positions += (MultiOrderGroups[group_idx].ticket_count - 1); // -1 to exclude base trade
    }
    
    // Adjust cleanup frequency based on recovery position count
    if(total_recovery_positions >= 200)
        orphan_check_interval = 10; // Every 10 seconds for 200+ recoveries
    else if(total_recovery_positions >= 100)
        orphan_check_interval = 20; // Every 20 seconds for 100+ recoveries  
    else if(total_recovery_positions >= 50)
        orphan_check_interval = 30; // Every 30 seconds for 50+ recoveries
    else
        orphan_check_interval = 60; // Default 60 seconds for smaller counts
    
    if(current_time - last_orphan_check >= orphan_check_interval)
    {
        if(total_recovery_positions >= 50) // Only log for significant recovery counts
        {
            PrintFormat("ORPHAN MONITOR: %d total recovery positions detected, running cleanup (interval: %ds)", 
                       total_recovery_positions, orphan_check_interval);
        }
        
        CleanupOrphanDCAOrders();
        CleanupOrphanRecoveryTrades();
        
        last_orphan_check = current_time;
    }
    
    // New bar detection
    datetime current_bar_time = (datetime)SeriesInfoInteger(_Symbol, _Period, SERIES_LASTBAR_DATE);
    if(current_bar_time == last_tick_time)
    {
        // Even on the same bar, we should check for any positions and cancel pending orders if needed
        int ea_positions = CountPositionsWithMagicNumber();
        bool limit_reached = false;
        
        if(InpMultiOrderEnabled) {
            if(ea_positions > 0) limit_reached = true;
        } else {
            if(ea_positions >= InpMaxOpenPositions && !ShouldAllowAdditionalPosition()) limit_reached = true;
        }
        
        if(limit_reached)
        {
            // If we've reached max positions for new trades, cancel all pending orders
            CancelAllPendingOrders();

            // Reset order tickets
            g_buyStopTicket = 0;
            g_sellStopTicket = 0;
            g_p3_buyStopTicket = 0;
            g_p3_sellStopTicket = 0;
            g_p4_buyStopTicket = 0;
            g_p4_sellStopTicket = 0;
            g_p5_lastBuyTicket = 0;
            g_p5_lastSellTicket = 0;
        }

        if(InpPatternType == PATTERN_20_THREE_GREEN_HHHL_RETEST)
        {
            ProcessPattern20Touch(!limit_reached);
        }

        // Pattern 9 optional intrabar open-price trigger needs same-bar tick processing
        if(!limit_reached && InpPatternType == PATTERN_9_PRICE_FALL)
        {
            ProcessPattern9OpenTriggerTick();
        }
        if(!limit_reached && InpPatternType == PATTERN_10_PRICE_MOVEMENT)
        {
            ProcessPattern10OpenTriggerTick();
        }
        if(!limit_reached && InpPatternType == PATTERN_18_SIGNATURE_VOLUME)
        {
            ProcessPattern18OpenTriggerTick();
        }
        if(!limit_reached && InpPatternType == PATTERN_19_OHLC_RECOVERY_ENTRY && !InpPattern19WaitForClose)
        {
            HandlePattern19_OHLCRecoveryEntry();
        }
        return; // Not a new bar, exit after checking positions
    }
    last_tick_time = current_bar_time;

    // Reset signal time on new bar to allow new signals
    if(g_lastSignalTime != 0)
    {
        PrintFormat("New bar detected. Resetting signal time tracking.");
        g_lastSignalTime = 0;
    }

    // Check for any positions - if we have max positions, we won't place new orders
    CheckAndCleanupPendingOrders();
    
    // Check DCA Smart Exit condition
    if(InpDCAEnabled && InpDCASmartExit)
    {
        CheckDCASmartExit();
    }
    
    // Update HeikinAshi recovery ready state on each new bar
    if(InpHARecoveryConfirmationEnabled)
    {
        UpdateHeikinAshiRecoveryReadyState();
    }
    
    // Update MACD recovery ready state on each new bar
    if(InpMACDRecoveryConfirmationEnabled)
    {
        UpdateMACDRecoveryReadyState();
    }
    
    // Update ROC recovery ready state on each new bar
    if(InpROCRecoveryConfirmationEnabled)
    {
        UpdateROCRecoveryReadyState();
    }

    // --- Main Logic on New Bar ---
    if(IsGlobalDollarStopTradingActive())
    {
        PrintFormat("Global Dollar Stop Trading active: no new pattern trades. Reason: %s",
                    g_globalDollarStopTradingReason);
        return;
    }

    if(IsGlobalDollarLossStreakPauseActive())
    {
        PrintFormat("Global Dollar %s Streak Pause active: no new pattern trades. Reason: %s",
                    GlobalDollarStreakPauseTriggerText(), GlobalDollarLossStreakPauseReason());
        return;
    }

    if(IsGlobalDollarDailyDrawdownTradePauseActive())
    {
        PrintFormat("Global Dollar Daily DD Trade Pause active: no new pattern trades. Reason: %s",
                    GlobalDollarDailyDrawdownTradePauseReason());
        return;
    }

    // 1. Check if we should process new trade signals
    int ea_positions = CountPositionsWithMagicNumber();
    bool stop_new_signals = false;
    
    if(InpMultiOrderEnabled) {
        if(ea_positions > 0) stop_new_signals = true;
    } else {
        if(ea_positions >= InpMaxOpenPositions && !ShouldAllowAdditionalPosition()) stop_new_signals = true;
    }

    if(InpPatternType == PATTERN_20_THREE_GREEN_HHHL_RETEST)
    {
        UpdatePattern20SetupOnNewClosedBar();
        if(stop_new_signals)
            ProcessPattern20Touch(false);
    }
    
    if(stop_new_signals)
    {
        // If limit is reached, we should not process new signals.
        // For standard mode, print a message. For multi-order, it's expected behavior.
        if(!InpMultiOrderEnabled)
        {
            PrintFormat("EA already has %d position(s) open (max: %d). No new signals will be processed.",
                        ea_positions, InpMaxOpenPositions);
        }
        // Pending orders are handled by CheckAndCleanupPendingOrders, so just return.
        return;
    }

    // 2. Check for enough data
    int requiredBars = MathMax(InpRsiPeriod, InpAtrPeriod) + InpPattern2Bars; // Need enough for both patterns
    if(Bars(_Symbol, _Period) < requiredBars)
    {
        return;
    }

    // Handle pattern based on selection
   // Process manual signals from file (useful for non-visual backtests)
   ProcessManualSignalFile();

    switch(InpPatternType)
    {
        case PATTERN_1_VOLUME:
            HandlePattern1();
            break;

        case PATTERN_2_BREAKOUT:
            HandlePattern2();
            break;

        case PATTERN_3_PREV_BAR:
            HandlePattern3();
            break;

        case PATTERN_4_BOX_BREAKOUT:
            HandlePattern4();
            break;
            
        case PATTERN_5_SUPERTREND_STOCH:
            HandlePattern5();
            break;

        case PATTERN_6_REVERSAL:
            HandlePattern6();
            break;
        case PATTERN_7_HEIKINASHI_TREND:
            HandlePattern7_HeikinAshiTrend();
            break;
        case PATTERN_8_HEIKINASHI_CONSECUTIVE:
            HandlePattern8_HeikinAshiConsecutive();
            break;
            
        case PATTERN_9_PRICE_FALL:
            HandlePattern9_PriceFall();
            break;
            
        case PATTERN_10_PRICE_MOVEMENT:
            HandlePattern10_PriceMovement();
            break;

      case PATTERN_11_TRENDLINE:
         HandlePattern11_Trendline();
         break;

      case PATTERN_12_MANUAL:
         // Manual trading mode selected: do not trigger any automatic pattern trades
         if(!g_is_backtesting)
            PrintFormat("Pattern 12 (Manual): Automatic pattern signals are disabled. Use manual buttons to trade.");
         break;
         
      case PATTERN_13_PREV_CANDLE_COLOR:
         HandlePattern13_PrevCandleColor();
         break;
            case PATTERN_14_BREAK_LOW_VOLUME:
               HandlePattern14_BreakLowVolume();
               break;
            case PATTERN_15_VOLUME_OSCILLATION:
               HandlePattern15_VolumeOscillation();
               break;
             case PATTERN_16_GREEN_CANDLE_BREAKOUT:
                HandlePattern16_GreenCandleBreakout();
                break;
            case PATTERN_17_STATASTICAL:
               HandlePattern17_Statastical();
               break;
             case PATTERN_18_SIGNATURE_VOLUME:
                HandlePattern18_SignatureVolume();
                break;
             case PATTERN_19_OHLC_RECOVERY_ENTRY:
                HandlePattern19_OHLCRecoveryEntry();
                break;
             case PATTERN_20_THREE_GREEN_HHHL_RETEST:
                HandlePattern20_ThreeGreenHHHLRetest();
                break;
      }
}

void UpdatePattern9RetraceEvent(double currentPrice, double refPriceHigh, double refPriceLow, double fallPercent, double risePercent)
{
    if(!InpPattern9RetraceEnabled)
        return;

    if(fallPercent >= InpPattern9FallPercent)
    {
        double drop = refPriceHigh - currentPrice;
        if(drop > 0)
        {
            g_p9_buyEventActive = true;
            g_p9_lastFallRefHigh = refPriceHigh;
            g_p9_lastFallLow = currentPrice;
            g_p9_buyRetraceTarget = currentPrice + (drop * (InpPattern9RetracePercent / 100.0));
        }
    }

    if(g_p9_buyEventActive && currentPrice < g_p9_lastFallLow)
    {
        g_p9_lastFallLow = currentPrice;
        double drop = g_p9_lastFallRefHigh - currentPrice;
        if(drop > 0)
            g_p9_buyRetraceTarget = currentPrice + (drop * (InpPattern9RetracePercent / 100.0));
    }

    if(risePercent >= InpPattern9FallPercent)
    {
        double climb = currentPrice - refPriceLow;
        if(climb > 0)
        {
            g_p9_sellEventActive = true;
            g_p9_lastRiseRefLow = refPriceLow;
            g_p9_lastRiseHigh = currentPrice;
            g_p9_sellRetraceTarget = currentPrice - (climb * (InpPattern9RetracePercent / 100.0));
        }
    }

    if(g_p9_sellEventActive && currentPrice > g_p9_lastRiseHigh)
    {
        g_p9_lastRiseHigh = currentPrice;
        double climb = currentPrice - g_p9_lastRiseRefLow;
        if(climb > 0)
            g_p9_sellRetraceTarget = currentPrice - (climb * (InpPattern9RetracePercent / 100.0));
    }
}

bool IsPattern9BuyRetraceReady(double currentPrice)
{
    if(!InpPattern9RetraceEnabled || !g_p9_buyEventActive)
        return true;

    return currentPrice >= g_p9_buyRetraceTarget;
}

bool IsPattern9SellRetraceReady(double currentPrice)
{
    if(!InpPattern9RetraceEnabled || !g_p9_sellEventActive)
        return true;

    return currentPrice <= g_p9_sellRetraceTarget;
}

void ResetPattern9OpenTriggerState()
{
    g_p9_pendingOpenTrigger = false;
    g_p9_pendingBuy = false;
    g_p9_pendingSell = false;
    g_p9_pendingBarTime = 0;
    g_p9_pendingBarOpen = 0.0;
    g_p9_pendingFallPercent = 0.0;
    g_p9_pendingRisePercent = 0.0;
}

bool ExecutePattern9BuyOrder(double fallPercent)
{
    int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
    double entryPrice = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
    double stopLoss = 0.0;
    double takeProfit = 0.0;
    CalculateSLTP(entryPrice, POSITION_TYPE_BUY, stopLoss, takeProfit);
    stopLoss = NormalizeDouble(stopLoss, digits);
    takeProfit = NormalizeDouble(takeProfit, digits);

    double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
    if(lots <= 0)
        return false;

    if(!InpDevelopmentMode)
    {
        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);

        request.action = TRADE_ACTION_DEAL;
        request.symbol = _Symbol;
        request.volume = lots;
        request.type = ORDER_TYPE_BUY;
        request.price = entryPrice;
        request.sl = stopLoss;
        request.tp = takeProfit;
        request.deviation = InpMaxSlippagePoints;
        request.magic = InpMagicNumber;
        request.comment = StringFormat("RohitEA P9-Fall%.2f", fallPercent);
        request.type_filling = GetSupportedFillingMode(_Symbol);

        if(IsSpreadAcceptable())
        {
            if(SendDollarExitAwareOrder(request, result))
            {
                PrintFormat("Pattern 9: Placed BUY order #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (Fall: %.2f%%)",
                           result.order, entryPrice, stopLoss, takeProfit, lots, fallPercent);
                g_p9_lastBuyTicket = result.order;
                g_p9_signalProcessed = true;
                g_p9_buyEventActive = false;

                if(result.order > 0)
                {
                    CreateDCAOrders(result.order);
                }
                return true;
            }
            PrintFormat("Pattern 9: Failed to place BUY order. Error: %d", GetLastError());
        }
    }
    else
    {
        PrintFormat("[DEV MODE] Pattern 9: Would place BUY order at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (Fall: %.2f%%)",
                   entryPrice, stopLoss, takeProfit, lots, fallPercent);
        g_p9_signalProcessed = true;
        g_p9_buyEventActive = false;
        return true;
    }

    return false;
}

