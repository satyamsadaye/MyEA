void ResetPattern18OpenTriggerState()
{
   g_p18_pendingOpenTrigger = false;
   g_p18_pendingTradeAction = "";
   g_p18_pendingBarTime = 0;
   g_p18_pendingBarOpen = 0.0;
}

void ExecutePattern18TradeAction(const string trade_action)
{
   ExecuteTrade(trade_action);
   ulong last_ticket = GetLastTradeTicket();
   if(trade_action == "buy")
      g_p18_lastBuyTicket = last_ticket;
   else
      g_p18_lastSellTicket = last_ticket;
   g_p18_signalProcessed = true;
}

//+------------------------------------------------------------------+
//| Pattern 18 helper: select trade action based on input mode       |
//+------------------------------------------------------------------+
string SelectPattern18TradeAction()
{
   if(InpPattern18TradeMode == P18_TRADE_BUY_ONLY)
      return "buy";
   if(InpPattern18TradeMode == P18_TRADE_SELL_ONLY)
      return "sell";

   // Random mode: pick one side. If master direction blocks one side, prefer allowed side.
   bool buy_allowed = (InpTradeDirection != TRADE_DIR_SELL_ONLY);
   bool sell_allowed = (InpTradeDirection != TRADE_DIR_BUY_ONLY);
   if(buy_allowed && !sell_allowed) return "buy";
   if(sell_allowed && !buy_allowed) return "sell";

   return ((MathRand() % 2) == 0) ? "buy" : "sell";
}

void ProcessPattern18OpenTriggerTick()
{
   if(!InpPattern18UseOpenPriceTrigger || !g_p18_pendingOpenTrigger)
      return;

   datetime current_bar_time = iTime(_Symbol, _Period, 0);
   if(current_bar_time != g_p18_pendingBarTime)
   {
      if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: Open-trigger entry expired for bar %s",
                     TimeToString(g_p18_pendingBarTime, TIME_DATE|TIME_MINUTES));
      }
      ResetPattern18OpenTriggerState();
      return;
   }

   double triggerPercent = MathMax(0.0, InpPattern18OpenPriceTriggerPercent);
   double buyTriggerPrice = g_p18_pendingBarOpen * (1.0 + triggerPercent / 100.0);
   double sellTriggerPrice = g_p18_pendingBarOpen * (1.0 - triggerPercent / 100.0);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(g_p18_pendingTradeAction == "buy" && ask >= buyTriggerPrice)
   {
      if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: BUY open trigger hit at %.5f (required %.5f, +%.4f%% from open %.5f)",
                     ask, buyTriggerPrice, triggerPercent, g_p18_pendingBarOpen);
      }
      ExecutePattern18TradeAction("buy");
      ResetPattern18OpenTriggerState();
      return;
   }

   if(g_p18_pendingTradeAction == "sell" && bid <= sellTriggerPrice)
   {
      if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: SELL open trigger hit at %.5f (required %.5f, -%.4f%% from open %.5f)",
                     bid, sellTriggerPrice, triggerPercent, g_p18_pendingBarOpen);
      }
      ExecutePattern18TradeAction("sell");
      ResetPattern18OpenTriggerState();
      return;
   }
}

//+------------------------------------------------------------------+
//| Handle Pattern 18 - Signature Volume                             |
//| Base lock condition (right-to-left):                             |
//| cv<pv, pv<pv1, pv1>pv2, pv2<pv3, pv3>pv4, pv4<pv5               |
//| After lock: wait first V(i)>V(i+1), then next closed candle      |
//| must have lower volume than that first higher-volume candle.      |
//+------------------------------------------------------------------+
void HandlePattern18_SignatureVolume()
{
   if(!InpPattern18Enabled) return;
   if(!IsTradingHour() || IsNewsTime()) return;

   if(g_p18_pendingOpenTrigger)
   {
      datetime open_bar_time = iTime(_Symbol, _Period, 0);
      if(open_bar_time != g_p18_pendingBarTime)
      {
         if(InpPattern18LogDetails)
            PrintFormat("Pattern 18: Open-trigger entry expired for bar %s", TimeToString(g_p18_pendingBarTime, TIME_DATE|TIME_MINUTES));
         ResetPattern18OpenTriggerState();
      }
   }

   datetime barTime = iTime(_Symbol, _Period, 1); // process once per closed candle
   if(barTime == g_p18_lastBarTime) return;
   g_p18_lastBarTime = barTime;

   if(Bars(_Symbol, _Period) < 8) return; // need bar indexes 1..7

   long cv  = (long)iVolume(_Symbol, _Period, 1);
   long pv  = (long)iVolume(_Symbol, _Period, 2);
   long pv1 = (long)iVolume(_Symbol, _Period, 3);
   long pv2 = (long)iVolume(_Symbol, _Period, 4);
   long pv3 = (long)iVolume(_Symbol, _Period, 5);
   long pv4 = (long)iVolume(_Symbol, _Period, 6);
   long pv5 = (long)iVolume(_Symbol, _Period, 7);

   bool base_pattern = (cv < pv &&
                        pv < pv1 &&
                        pv1 > pv2 &&
                        pv2 < pv3 &&
                        pv3 > pv4 &&
                        pv4 < pv5);

   if(!g_p18_locked)
   {
      if(base_pattern)
      {
         g_p18_locked = true;
         g_p18_lockBarTime = barTime;
         g_p18_firstGreaterFound = false;
         g_p18_firstGreaterVolume = 0;
         g_p18_firstGreaterBarTime = 0;

         if(InpPattern18LogDetails)
            PrintFormat("Pattern 18: SIGNATURE LOCKED at %s | cv=%ld pv=%ld pv1=%ld pv2=%ld pv3=%ld pv4=%ld pv5=%ld",
                        TimeToString(barTime), cv, pv, pv1, pv2, pv3, pv4, pv5);
      }
      else if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: Base signature not found at %s (cv=%ld pv=%ld pv1=%ld pv2=%ld pv3=%ld pv4=%ld pv5=%ld)",
                     TimeToString(barTime), cv, pv, pv1, pv2, pv3, pv4, pv5);
      }
      return;
   }

   // Lock exists: wait for first candle where volume > previous volume
   if(!g_p18_firstGreaterFound)
   {
      if(cv > pv)
      {
         g_p18_firstGreaterFound = true;
         g_p18_firstGreaterVolume = cv;
         g_p18_firstGreaterBarTime = barTime;
         if(InpPattern18LogDetails)
            PrintFormat("Pattern 18: First higher-volume candle found at %s (vol=%ld > prev=%ld). Waiting next candle close.",
                        TimeToString(barTime), cv, pv);
      }
      else if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: Locked and waiting first higher-volume candle (current=%ld, previous=%ld).", cv, pv);
      }
      return;
   }

   // First higher-volume candle already found.
   // If volumes keep increasing consecutively, keep shifting to the latest increasing candle.
   // Confirm only when volume drops below the latest tracked increasing-volume candle.
   if(barTime <= g_p18_firstGreaterBarTime)
      return;

   if(cv > g_p18_firstGreaterVolume)
   {
      if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: Consecutive increase detected at %s (current=%ld > tracked=%ld). Shifting trigger reference forward.",
                     TimeToString(barTime), cv, g_p18_firstGreaterVolume);
      }
      g_p18_firstGreaterVolume = cv;
      g_p18_firstGreaterBarTime = barTime;
      return;
   }

   if(cv < g_p18_firstGreaterVolume)
   {
      string trade_action = SelectPattern18TradeAction();
      if(InpPattern18LogDetails)
      {
         PrintFormat("Pattern 18: Trigger confirmed at %s (current=%ld < firstHigher=%ld). Executing %s.",
                     TimeToString(barTime), cv, g_p18_firstGreaterVolume, trade_action);
      }

      if(InpPattern18UseOpenPriceTrigger)
      {
         double bar_open = iOpen(_Symbol, _Period, 0);
         datetime pending_bar_time = iTime(_Symbol, _Period, 0);
         if(bar_open > 0.0 && pending_bar_time > 0)
         {
            g_p18_pendingOpenTrigger = true;
            g_p18_pendingTradeAction = trade_action;
            g_p18_pendingBarTime = pending_bar_time;
            g_p18_pendingBarOpen = bar_open;
            g_p18_signalProcessed = true;

            double target_price = (trade_action == "buy")
                                  ? (bar_open * (1.0 + MathMax(0.0, InpPattern18OpenPriceTriggerPercent) / 100.0))
                                  : (bar_open * (1.0 - MathMax(0.0, InpPattern18OpenPriceTriggerPercent) / 100.0));

            if(InpPattern18LogDetails)
            {
               PrintFormat("Pattern 18: Open trigger armed for %s. Waiting for %.2f%% move from %.5f to %.5f before entry.",
                           trade_action,
                           MathMax(0.0, InpPattern18OpenPriceTriggerPercent),
                           bar_open,
                           target_price);
            }
         }
         else
         {
            if(InpPattern18LogDetails)
            {
               Print("Pattern 18: Could not read current candle open. Falling back to immediate execution.");
            }
            ExecutePattern18TradeAction(trade_action);
         }
      }
      else
      {
         ExecutePattern18TradeAction(trade_action);
      }
   }
   else if(InpPattern18LogDetails)
   {
      PrintFormat("Pattern 18: Current volume equals tracked increasing volume at %s (current=%ld). Waiting for next candle.",
                  TimeToString(barTime), cv);
      return;
   }

// Trigger confirmed and processed, restart lock search.
   ResetPattern18LockState();
}

string SelectPattern19RandomTradeAction()
{
   bool buy_allowed = (InpTradeDirection != TRADE_DIR_SELL_ONLY);
   bool sell_allowed = (InpTradeDirection != TRADE_DIR_BUY_ONLY);

   if(buy_allowed && !sell_allowed) return "buy";
   if(sell_allowed && !buy_allowed) return "sell";

   return ((MathRand() % 2) == 0) ? "buy" : "sell";
}

bool GetNearestTouchedPattern19OHLCLevel(string symbol, bool use_closed_candle_touch, double &level_price, string &level_desc)
{
   level_price = 0.0;
   level_desc = "";

   if(!InpPattern19UseDaily && !InpPattern19UseWeekly && !InpPattern19UseMonthly)
      return false;

   if(!InpPattern19UseOpen && !InpPattern19UseHigh && !InpPattern19UseLow && !InpPattern19UseClose)
      return false;

   int lookback = MathMax(1, InpPattern19LookbackCandles);
   double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
   double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
   if(point <= 0) point = 0.00001;

   double mid = (bid + ask) / 2.0;
   double close1 = iClose(symbol, _Period, 1);
   double high1 = iHigh(symbol, _Period, 1);
   double low1 = iLow(symbol, _Period, 1);
   double spread_points = MathAbs(ask - bid) / point;
   double touch_tolerance_points = MathMax(1.0, spread_points + 0.5);

   ENUM_TIMEFRAMES tfs[3];
   int tf_count = 0;
   if(InpPattern19UseDaily) tfs[tf_count++] = PERIOD_D1;
   if(InpPattern19UseWeekly) tfs[tf_count++] = PERIOD_W1;
   if(InpPattern19UseMonthly) tfs[tf_count++] = PERIOD_MN1;

   double best_distance = 1e100;
   double best_level = 0.0;
   string best_desc = "";

   for(int t = 0; t < tf_count; t++)
   {
      ENUM_TIMEFRAMES tf = tfs[t];
      for(int shift = 1; shift <= lookback; shift++)
      {
         datetime bar_time = iTime(symbol, tf, shift);
         if(bar_time <= 0) continue;

         string tags[4];
         tags[0] = "O"; tags[1] = "H"; tags[2] = "L"; tags[3] = "C";
         double lvls[4];
         lvls[0] = iOpen(symbol, tf, shift);
         lvls[1] = iHigh(symbol, tf, shift);
         lvls[2] = iLow(symbol, tf, shift);
         lvls[3] = iClose(symbol, tf, shift);
         bool enabled_level[4];
         enabled_level[0] = InpPattern19UseOpen;
         enabled_level[1] = InpPattern19UseHigh;
         enabled_level[2] = InpPattern19UseLow;
         enabled_level[3] = InpPattern19UseClose;

         for(int k = 0; k < 4; k++)
         {
            if(!enabled_level[k]) continue;
            if(lvls[k] <= 0.0) continue;

            bool touched = false;
            double distance_points = 0.0;
            if(use_closed_candle_touch)
            {
               touched = (low1 <= lvls[k] && lvls[k] <= high1);
               distance_points = MathAbs(close1 - lvls[k]) / point;
            }
            else
            {
               bool touched_by_spread = (lvls[k] >= MathMin(bid, ask) && lvls[k] <= MathMax(bid, ask));
               distance_points = MathAbs(mid - lvls[k]) / point;
               bool touched_by_tolerance = (distance_points <= touch_tolerance_points);
               touched = touched_by_spread || touched_by_tolerance;
            }
            if(!touched) continue;

            if(distance_points < best_distance)
            {
               best_distance = distance_points;
               best_level = lvls[k];
               best_desc = StringFormat("%s[%s-%s-%d]=%.5f",
                                        EnumToString(tf),
                                        TimeToString(bar_time, TIME_DATE),
                                        tags[k],
                                        shift,
                                        lvls[k]);
            }
         }
      }
   }

   if(best_desc == "")
      return false;

   level_price = best_level;
   level_desc = best_desc;
   return true;
}

void HandlePattern19_OHLCRecoveryEntry()
{
   if(!InpPattern19Enabled) return;
   if(!IsTradingHour() || IsNewsTime()) return;

   bool wait_for_close = InpPattern19WaitForClose;
   datetime signal_bar_time = iTime(_Symbol, _Period, 0);
   if(signal_bar_time <= 0) return;
   if(wait_for_close)
   {
      datetime closed_bar_time = iTime(_Symbol, _Period, 1);
      if(closed_bar_time <= 0) return;
      if(closed_bar_time == g_p19_lastBarTime) return;
      g_p19_lastBarTime = closed_bar_time;
   }

   if(InpPattern19WaitCandles > 0 && g_p19_lastSignalBarTime > 0)
   {
      int shift = iBarShift(_Symbol, _Period, g_p19_lastSignalBarTime, false);
      int bars_since_signal = (shift >= 0) ? MathMax(0, shift - 1) : InpPattern19WaitCandles;
      if(bars_since_signal < InpPattern19WaitCandles)
      {
         if(InpPattern19LogDetails)
         {
            PrintFormat("Pattern 19: Waiting %d/%d candles after last signal before allowing a new trade.",
                        bars_since_signal,
                        InpPattern19WaitCandles);
         }
         return;
      }
   }

   double matched_level = 0.0;
   string matched_desc = "";
   if(!GetNearestTouchedPattern19OHLCLevel(_Symbol, wait_for_close, matched_level, matched_desc))
   {
      if(InpPattern19LogDetails)
         Print(wait_for_close ? "Pattern 19: No touched OHLC level found on the last closed candle." : "Pattern 19: No touched OHLC level found on current price.");
      return;
   }

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double current_ref = wait_for_close ? iClose(_Symbol, _Period, 1) : ((bid + ask) / 2.0);
   double prev_close = wait_for_close ? iClose(_Symbol, _Period, 2) : iClose(_Symbol, _Period, 1);
   if(prev_close <= 0.0) return;

   bool level_below_price = (matched_level < current_ref);
   bool level_above_price = (matched_level > current_ref);
   bool coming_down = (current_ref < prev_close);
   bool coming_up = (current_ref > prev_close);

   string trade_action = "";

   // Random mode explicitly ignores breakout/non-breakout behavior.
   if(InpPattern19TradeMode == P19_TRADE_RANDOM)
   {
      trade_action = SelectPattern19RandomTradeAction();
   }
   else
   {
      if(InpPattern19SignalMode == P19_SIGNAL_BREAKOUT)
      {
         // Breakout interpretation:
         // - Level below + price coming down => SELL
         // - Level above + price coming up   => BUY
         if(level_below_price && coming_down)
            trade_action = "sell";
         else if(level_above_price && coming_up)
            trade_action = "buy";
      }
      else
      {
         // Non-breakout interpretation:
         // - Level below current price => BUY
         // - Level above current price => SELL
         if(level_below_price)
            trade_action = "buy";
         else if(level_above_price)
            trade_action = "sell";
      }

      if(trade_action == "buy" && InpPattern19TradeMode == P19_TRADE_SELL_ONLY)
         trade_action = "";
      if(trade_action == "sell" && InpPattern19TradeMode == P19_TRADE_BUY_ONLY)
         trade_action = "";
   }

   if(trade_action == "")
   {
      if(InpPattern19LogDetails)
      {
         PrintFormat("Pattern 19: Level touched (%s) but no valid trade action (mode=%s, trade_mode=%s, level=%.5f, mid=%.5f, prevClose=%.5f).",
                     matched_desc,
                     EnumToString(InpPattern19SignalMode),
                     EnumToString(InpPattern19TradeMode),
                     matched_level,
                     current_ref,
                     prev_close);
      }
      return;
   }

   if(InpPattern19LogDetails)
   {
      PrintFormat("Pattern 19: %s signal at %s | level=%s | mid=%.5f prevClose=%.5f (coming_down=%s coming_up=%s) | executing %s",
                  EnumToString(InpPattern19SignalMode),
                  TimeToString(signal_bar_time),
                  matched_desc,
                  current_ref,
                  prev_close,
                  coming_down ? "YES" : "NO",
                  coming_up ? "YES" : "NO",
                  trade_action);
   }

   ExecuteTrade(trade_action);
   g_p19_lastSignalBarTime = signal_bar_time;
}

