                }
            }
            else
            {
                PrintFormat("Pattern 5: Failed to place BUY order. Result code: %d", result.retcode);
                PrintFormat("[DEBUG] Trade result details: Retcode=%d, Deal=%d, Order=%d, Volume=%.4f", 
                           result.retcode, result.deal, result.order, result.volume);
                PrintFormat("[DEBUG] Result price: %.5f, Bid: %.5f, Ask: %.5f, Comment: %s", 
                           result.price, result.bid, result.ask, result.comment);
            }
        }
        else
        {
