      lines_to_display[line_idx++] = StringFormat("Current P/L: %.2f %s", ExtCurrentProfit, currency);
      lines_to_display[line_idx++] = "-------- POSITION METRICS --------";
      lines_to_display[line_idx++] = StringFormat("Max Loss (Entry→SL): %.2f %s", ExtStaticMaxLoss, currency);
      lines_to_display[line_idx++] = StringFormat("Max Profit (Entry→TP): %.2f %s", ExtStaticMaxProfit, currency);
      if(ExtStaticMaxLoss > 0)
        {
         lines_to_display[line_idx++] = StringFormat("Risk/Reward: 1 : %.2f", ExtStaticRRatio);
        }
      else
        {
         lines_to_display[line_idx++] = "Risk/Reward: N/A";
        }
     }
   else
     {
      lines_to_display[line_idx++] = "Active Position: None";
      lines_to_display[line_idx++] = "Current P/L: N/A";
      lines_to_display[line_idx++] = "-------- POSITION METRICS --------";
      lines_to_display[line_idx++] = "Max Loss (Entry→SL): N/A";
      lines_to_display[line_idx++] = "Max Profit (Entry→TP): N/A";
      lines_to_display[line_idx++] = "Risk/Reward: N/A";
     }
   lines_to_display[line_idx++] = "------------------------------------";
   lines_to_display[line_idx++] = "Server Time: " + TimeToString(TimeCurrent(), TIME_SECONDS);

   ArrayResize(lines_to_display, line_idx);
   ExtTotalDisplayLines = line_idx;

   ENUM_BASE_CORNER actual_corner;
   int base_x_offset;
   int base_y_offset;
   int line_height = InpDisplayFontSize + InpDisplayLineSpacing;

   if(InpDisplayAnchor == ANCHOR_CENTER_CHART)
     {
      actual_corner = CORNER_LEFT_UPPER;
      long chart_width = ChartGetInteger(current_chart_id, CHART_WIDTH_IN_PIXELS, 0);
      long chart_height = ChartGetInteger(current_chart_id, CHART_HEIGHT_IN_PIXELS, 0);

      int total_block_height = ExtTotalDisplayLines * line_height;
      int max_text_width_estimate = 0;
      double avg_char_width_factor = 0.65;

      for(int i=0; i < line_idx && i < ArraySize(lines_to_display); i++)
        {
         int current_line_len = StringLen(lines_to_display[i]);
         int current_width_estimate = (int)(current_line_len * InpDisplayFontSize * avg_char_width_factor);
         if(current_width_estimate > max_text_width_estimate) max_text_width_estimate = current_width_estimate;
        }

      base_x_offset = (int)((chart_width - max_text_width_estimate) / 2) + InpDisplayXOffset;
      base_y_offset = (int)((chart_height - total_block_height) / 2) + InpDisplayYOffset;

      base_x_offset = MathMax(0, base_x_offset);
      base_y_offset = MathMax(0, base_y_offset);
     }
   else if(InpDisplayAnchor == ANCHOR_BOTTOM_LEFT)
     {
      actual_corner = CORNER_LEFT_LOWER;
      base_x_offset = InpDisplayXOffset;
      base_y_offset = InpDisplayYOffset;
     }
   else
     {
      actual_corner = CORNER_LEFT_UPPER;
      base_x_offset = InpDisplayXOffset;
      base_y_offset = InpDisplayYOffset;
     }

   int current_y_draw_offset = base_y_offset;

   for(int i=0; i < ExtTotalDisplayLines; i++)
     {
      int y_pos_for_label = (actual_corner == CORNER_LEFT_LOWER) ? (base_y_offset + i * line_height) : current_y_draw_offset;

      CreateOrUpdateLabel(current_chart_id, DISPLAY_OBJECT_PREFIX + IntegerToString(i), lines_to_display[i],
                          base_x_offset, y_pos_for_label,
                          InpDisplayFontSize, InpDisplayFontColor, actual_corner);
      if(actual_corner != CORNER_LEFT_LOWER) current_y_draw_offset += line_height;
     }

   for(int i = ExtTotalDisplayLines; i < ExtTotalDisplayLines + 10; i++)
     {
        string old_label_name = DISPLAY_OBJECT_PREFIX + IntegerToString(i);
        if(ObjectFind(current_chart_id, old_label_name) >= 0)
          {
            ObjectSetString(current_chart_id, old_label_name, OBJPROP_TEXT, "");
          }
        else { break; }
     }
   ChartRedraw(current_chart_id);
  }

bool ClosePositionsByTypeForCandleExit(ENUM_POSITION_TYPE positionTypeToClose)
{
    bool all_closed_for_type = true;
    int total_positions = PositionsTotal();
    string type_str = (positionTypeToClose == POSITION_TYPE_BUY) ? "BUY" : "SELL";
    string current_chart_symbol = Symbol();

    PrintFormat("Candle Exit: Attempting to close %s positions for symbol %s, magic %d.",
                type_str, current_chart_symbol, InpMagicNumber);

    ulong tickets_to_close[];
    int ticket_count = 0;

    for (int i = 0; i < total_positions; i++)
    {
        ulong current_ticket = PositionGetTicket(i);
        if (current_ticket > 0)
        {
            if (PositionSelectByTicket(current_ticket))
            {
                if (PositionGetInteger(POSITION_MAGIC) == InpMagicNumber &&
                    (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE) == positionTypeToClose &&
                    PositionGetString(POSITION_SYMBOL) == current_chart_symbol)
                {
                    ArrayResize(tickets_to_close, ticket_count + 1);
                    tickets_to_close[ticket_count] = current_ticket;
                    ticket_count++;
                }
            }
        }
    }

    if (ticket_count == 0)
    {
        return true;
    }

    PrintFormat("Candle Exit: Found %d %s position(s) to close for symbol %s.", ticket_count, type_str, current_chart_symbol);

    for (int i = 0; i < ticket_count; i++)
    {
        ulong ticket = tickets_to_close[i];
        if (!PositionSelectByTicket(ticket))
        {
            PrintFormat("Candle Exit: Error selecting position ticket %d for closure: %d", ticket, GetLastError());
            all_closed_for_type = false;
            continue;
        }

        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);

        request.action = TRADE_ACTION_DEAL;
        request.position = ticket;
        request.symbol = PositionGetString(POSITION_SYMBOL);
        request.volume = PositionGetDouble(POSITION_VOLUME);
        request.deviation = InpMaxSlippagePoints;
        request.magic = InpMagicNumber;
        request.comment = "RohitEA CandleExit";
        request.type_filling = GetSupportedFillingMode(_Symbol);

        if ((ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
        {
            request.price = SymbolInfoDouble(request.symbol, SYMBOL_BID);
            request.type = ORDER_TYPE_SELL;
        }
        else
        {
            request.price = SymbolInfoDouble(request.symbol, SYMBOL_ASK);
            request.type = ORDER_TYPE_BUY;
        }

        PrintFormat("Candle Exit: Attempting market close for %s position #%d, Symbol %s, Volume %.2f",
                    type_str, ticket, request.symbol, request.volume);

        if (!SendDollarExitAwareOrder(request, result))
        {
            PrintFormat("Candle Exit: Error closing %s position %d: OrderSend Error %d, Retcode: %d, Server Msg: %s",
                        type_str, ticket, GetLastError(), result.retcode, result.comment);
            all_closed_for_type = false;
        }
        else
        {
            PrintFormat("Candle Exit: Successfully sent market close order for %s position %d. Retcode: %d, Deal: %d",
                        type_str, ticket, result.retcode, result.deal);
        }
    }
    return all_closed_for_type;
}

void CalculateHeikinAshi(string symbol, ENUM_TIMEFRAMES timeframe, int bar_index, HeikinAshiValues &prev_ha, HeikinAshiValues &ha)
{
   double open = iOpen(symbol, timeframe, bar_index);
   double high = iHigh(symbol, timeframe, bar_index);
   double low = iLow(symbol, timeframe, bar_index);
   double close = iClose(symbol, timeframe, bar_index);

   if(bar_index == 0 && prev_ha.haClose == 0)
   {
      ha.haClose = (open + high + low + close) / 4;
      ha.haOpen = (open + close) / 2;
      ha.haHigh = high;
      ha.haLow = low;
   }
   else
   {
      ha.haClose = (open + high + low + close) / 4;
      ha.haOpen = (prev_ha.haOpen + prev_ha.haClose) / 2;
      ha.haHigh = MathMax(high, MathMax(ha.haOpen, ha.haClose));
      ha.haLow = MathMin(low, MathMin(ha.haOpen, ha.haClose));
   }
}

void GetHeikinAshiValues(string symbol, ENUM_TIMEFRAMES timeframe, int bar_index, HeikinAshiValues &result)
{
   datetime current_time = TimeCurrent();

   if(LastHeikinAshiCalcTime < iTime(symbol, timeframe, 0) || ArraySize(HeikinAshiCache) == 0)
   {
      int bars_to_cache = MathMin(100, Bars(symbol, timeframe));
      ArrayResize(HeikinAshiCache, bars_to_cache);

      HeikinAshiValues prev_ha;
      prev_ha.haOpen = 0;
      prev_ha.haClose = 0;
      prev_ha.haHigh = 0;
      prev_ha.haLow = 0;

      for(int i = bars_to_cache - 1; i >= 0; i--)
      {
         CalculateHeikinAshi(symbol, timeframe, i, prev_ha, HeikinAshiCache[i]);
         prev_ha = HeikinAshiCache[i];
      }

      LastHeikinAshiCalcTime = current_time;
   }

   if(bar_index < ArraySize(HeikinAshiCache))
   {
      result = HeikinAshiCache[bar_index];
      return;
   }

   result.haOpen = 0;
   result.haClose = 0;
   result.haHigh = 0;
   result.haLow = 0;

   PrintFormat("Warning: Requested Heikin Ashi bar %d is outside cached range (0-%d)",
               bar_index, ArraySize(HeikinAshiCache) - 1);
}

void CheckCandleExitConditions()
{
    // Periodically scan and force close orphan recovery trades before candle exit logic
    ForceCloseOrphanRecoveryTrades();

    if (!InpCandleExitEnabled || Bars(_Symbol, _Period) < 3)
        return;

    string current_symbol = _Symbol;
    ENUM_TIMEFRAMES current_period = _Period;

    datetime bar_open_time_bar0 = iTime(current_symbol, current_period, 0);
    if (bar_open_time_bar0 == ExtLastBarTimeForCandleExit && ExtLastBarTimeForCandleExit != 0)
    {
        return;
    }

    double close_bar1, low_bar2, high_bar2;

    if(InpCandleExitType == HEIKIN_ASHI)
    {
        HeikinAshiValues ha_bar1;
        GetHeikinAshiValues(current_symbol, current_period, 1, ha_bar1);
        HeikinAshiValues ha_bar2;
        GetHeikinAshiValues(current_symbol, current_period, 2, ha_bar2);

        close_bar1 = ha_bar1.haClose;
        low_bar2 = ha_bar2.haLow;
        high_bar2 = ha_bar2.haHigh;

        PrintFormat("Candle Exit Check (Heikin Ashi): Bar1 HA Close=%.5f, Bar2 HA Low=%.5f, Bar2 HA High=%.5f",
                    close_bar1, low_bar2, high_bar2);
    }
    else
    {
        close_bar1 = iClose(current_symbol, current_period, 1);
        low_bar2 = iLow(current_symbol, current_period, 2);
        high_bar2 = iHigh(current_symbol, current_period, 2);
    }

    datetime time_open_bar1 = iTime(current_symbol, current_period, 1);

    bool close_buy_positions_triggered = false;
    bool close_sell_positions_triggered = false;

    // --- Entry-Candle Exit Method: check per-position entry-candle closes on configured TF
    if(InpEntryCandleExitMethodEnabled && ArraySize(ExtPositionTrackers) > 0)
    {
        for(int t = 0; t < ArraySize(ExtPositionTrackers); t++)
        {
            if(!ExtPositionTrackers[t].entry_candle_initialized) continue;

            ulong ticket = ExtPositionTrackers[t].ticket;
            if(ticket == 0) continue;
            if(!PositionSelectByTicket(ticket)) continue;
            if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
            if(PositionGetString(POSITION_SYMBOL) != current_symbol) continue;

            ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);

            ENUM_TIMEFRAMES tf = ExtPositionTrackers[t].entry_candle_tf;
            // time of last closed candle on that TF
            datetime last_closed_open_time = iTime(current_symbol, tf, 1);
            if(last_closed_open_time <= ExtPositionTrackers[t].last_checked_entry_candle) continue;

            double closed_close_price = 0.0;
            if(InpCandleExitType == HEIKIN_ASHI)
            {
               HeikinAshiValues ha_check;
               GetHeikinAshiValues(current_symbol, tf, 1, ha_check);
               closed_close_price = ha_check.haClose;
            }
            else
            {
               closed_close_price = iClose(current_symbol, tf, 1);
            }

            double entry_low = ExtPositionTrackers[t].entry_candle_low;
            double entry_high = ExtPositionTrackers[t].entry_candle_high;

            // Only exit if not above breakeven when InpCandleExitOnlyLoss is true
            double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
            double current_price = PositionGetDouble(POSITION_PRICE_CURRENT);

            if(posType == POSITION_TYPE_BUY)
            {
               if(closed_close_price < entry_low)
               {
                  if(!InpCandleExitOnlyLoss || current_price <= entry_price)
                  {
                      PrintFormat("Entry-Candle Exit: BUY position #%d triggered by closed candle on TF %d (close %.5f < entry low %.5f)", ticket, tf, closed_close_price, entry_low);
                      close_buy_positions_triggered = true;
                  }
               }
            }
            else if(posType == POSITION_TYPE_SELL)
            {
               if(closed_close_price > entry_high)
               {
                  if(!InpCandleExitOnlyLoss || current_price >= entry_price)
                  {
                      PrintFormat("Entry-Candle Exit: SELL position #%d triggered by closed candle on TF %d (close %.5f > entry high %.5f)", ticket, tf, closed_close_price, entry_high);
                      close_sell_positions_triggered = true;
                  }
               }
            }

            ExtPositionTrackers[t].last_checked_entry_candle = last_closed_open_time;
            if(close_buy_positions_triggered && close_sell_positions_triggered) break;
        }
    }

    if (close_bar1 < low_bar2)
    {
        PrintFormat("Candle Exit: BUY condition met on %s. %s Bar 1 Close (%.5f) < Bar 2 Low (%.5f)",
                    current_symbol,
                    InpCandleExitType == HEIKIN_ASHI ? "Heikin Ashi" : "Standard",
                    close_bar1, low_bar2);
        close_buy_positions_triggered = true;
    }

    if (close_bar1 > high_bar2)
    {
        PrintFormat("Candle Exit: SELL condition met on %s. %s Bar 1 Close (%.5f) > Bar 2 High (%.5f)",
                    current_symbol,
                    InpCandleExitType == HEIKIN_ASHI ? "Heikin Ashi" : "Standard",
                    close_bar1, high_bar2);
        close_sell_positions_triggered = true;
    }

    if (!close_buy_positions_triggered && !close_sell_positions_triggered)
    {
        ExtLastBarTimeForCandleExit = bar_open_time_bar0;
        return;
    }

    bool buy_action_taken = false;
    bool sell_action_taken = false;

    int total_open_positions = PositionsTotal();
    for (int i = total_open_positions - 1; i >= 0; i--)
    {
        ulong current_ticket = PositionGetTicket(i);
        if (current_ticket == 0) continue;

        if (!PositionSelectByTicket(current_ticket))
            continue;

        if (PositionGetInteger(POSITION_MAGIC) != InpMagicNumber || PositionGetString(POSITION_SYMBOL) != current_symbol)
            continue;

        long position_open_time_seconds = PositionGetInteger(POSITION_TIME);
        datetime position_entry_bar_open_time = iTime(current_symbol, current_period, iBarShift(current_symbol, current_period, position_open_time_seconds, false));

        if (position_entry_bar_open_time >= time_open_bar1)
        {
            continue;
        }

        ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);

        if (InpCandleExitOnlyLoss)
        {
            double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
            double current_price = PositionGetDouble(POSITION_PRICE_CURRENT);

            if (pos_type == POSITION_TYPE_BUY && current_price > entry_price)
            {
                PrintFormat("Candle Exit: BUY position #%d is above breakeven, skipping.", PositionGetInteger(POSITION_TICKET));
                continue;
            }
            else if (pos_type == POSITION_TYPE_SELL && current_price < entry_price)
            {
                PrintFormat("Candle Exit: SELL position #%d is above breakeven, skipping.", PositionGetInteger(POSITION_TICKET));
                continue;
            }
        }

        if (pos_type == POSITION_TYPE_BUY && close_buy_positions_triggered && !buy_action_taken)
        {
            PrintFormat("Candle Exit: Triggering closure for BUY positions on %s.", current_symbol);
            ClosePositionsByTypeForCandleExit(POSITION_TYPE_BUY);
            buy_action_taken = true;
        }
        else if (pos_type == POSITION_TYPE_SELL && close_sell_positions_triggered && !sell_action_taken)
        {
            PrintFormat("Candle Exit: Triggering closure for SELL positions on %s.", current_symbol);
            ClosePositionsByTypeForCandleExit(POSITION_TYPE_SELL);
            sell_action_taken = true;
        }

        if(buy_action_taken && sell_action_taken) break;
    }

    ExtLastBarTimeForCandleExit = bar_open_time_bar0;
}

void ApplyLossProtection()
{
   if(InpGlobalDollarExitEnabled) return;
   if(!InpLossProtectionEnabled) return;

   datetime current_time = TimeCurrent();
   int total_positions = PositionsTotal();

   for(int i = 0; i < total_positions; i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;

      if(!PositionSelectByTicket(ticket)) continue;

      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      bool found = false;
      for(int j = 0; j < ArraySize(ExtPositionTrackers); j++)
      {
         if(ExtPositionTrackers[j].ticket == ticket)
         {
            found = true;
            break;
         }
      }

      if(!found)
      {
         int size = ArraySize(ExtPositionTrackers);
         ArrayResize(ExtPositionTrackers, size + 1);
         ExtPositionTrackers[size].ticket = ticket;
         ExtPositionTrackers[size].open_time = (datetime)PositionGetInteger(POSITION_TIME);
         ExtPositionTrackers[size].original_sl = PositionGetDouble(POSITION_SL);
         ExtPositionTrackers[size].loss_protection_applied = false;
         ExtPositionTrackers[size].failed_sl_modification_attempts = 0;  // Initialize failed attempts counter
         ExtPositionTrackers[size].first_failed_attempt_time = 0;
         // Initialize entry-candle tracking fields
         ExtPositionTrackers[size].entry_candle_initialized = false;
         ExtPositionTrackers[size].entry_candle_low = 0.0;
         ExtPositionTrackers[size].entry_candle_high = 0.0;
         ExtPositionTrackers[size].entry_candle_tf = InpEntryCandleExitTF;
         ExtPositionTrackers[size].entry_candle_open_time = 0;
         ExtPositionTrackers[size].last_checked_entry_candle = 0;

         // If entry-candle exit method enabled, capture the entry candle on the chosen TF
         if(InpEntryCandleExitMethodEnabled)
         {
            string sym = PositionGetString(POSITION_SYMBOL);
            ENUM_TIMEFRAMES tf = InpEntryCandleExitTF;
            datetime open_time = ExtPositionTrackers[size].open_time;
            int shift = iBarShift(sym, tf, open_time, false);
            if(shift >= 0)
            {
               ExtPositionTrackers[size].entry_candle_open_time = iTime(sym, tf, shift);
               if(InpCandleExitType == HEIKIN_ASHI)
               {
                  HeikinAshiValues ha_val;
                  GetHeikinAshiValues(sym, tf, shift, ha_val);
                  ExtPositionTrackers[size].entry_candle_low = ha_val.haLow;
                  ExtPositionTrackers[size].entry_candle_high = ha_val.haHigh;
               }
               else
               {
                  ExtPositionTrackers[size].entry_candle_low = iLow(sym, tf, shift);
                  ExtPositionTrackers[size].entry_candle_high = iHigh(sym, tf, shift);
               }
               ExtPositionTrackers[size].entry_candle_initialized = true;
            }
         }

         PrintFormat("Loss Protection: Added position #%d to tracker.", ticket);
      }
   }

   for(int i = 0; i < ArraySize(ExtPositionTrackers); i++)
   {
      if(ExtPositionTrackers[i].loss_protection_applied) continue;

      if(current_time - ExtPositionTrackers[i].open_time >= InpLossProtectionTimerSeconds)
      {
         ulong ticket = ExtPositionTrackers[i].ticket;

         if(!PositionSelectByTicket(ticket))
         {
            ExtPositionTrackers[i].loss_protection_applied = true;
            continue;
         }

         string symbol = PositionGetString(POSITION_SYMBOL);
         ENUM_POSITION_TYPE position_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
         double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
         double current_sl = PositionGetDouble(POSITION_SL);
         double original_sl = ExtPositionTrackers[i].original_sl;

         if(original_sl == 0)
         {
            ExtPositionTrackers[i].loss_protection_applied = true;
            continue;
         }

         double current_price = 0;
         if(position_type == POSITION_TYPE_BUY)
            current_price = SymbolInfoDouble(symbol, SYMBOL_BID);
         else
            current_price = SymbolInfoDouble(symbol, SYMBOL_ASK);

         double new_sl = 0;
         double protection_factor = InpLossProtectionPercentage / 100.0;

         if(position_type == POSITION_TYPE_BUY)
         {
            double sl_distance = entry_price - original_sl;
            new_sl = entry_price - (sl_distance * protection_factor);
         }
         else
         {
            double sl_distance = original_sl - entry_price;
            new_sl = entry_price + (sl_distance * protection_factor);
         }

         bool should_modify = false;
         if(position_type == POSITION_TYPE_BUY && new_sl > current_sl) should_modify = true;
         else if(position_type == POSITION_TYPE_SELL && new_sl < current_sl) should_modify = true;

         if(should_modify)
         {
            int digits = (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS);
            new_sl = NormalizeDouble(new_sl, digits);

            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);

            request.action = TRADE_ACTION_SLTP;
            request.symbol = symbol;
            request.position = ticket;
            request.sl = new_sl;
            request.tp = PositionGetDouble(POSITION_TP);
            request.comment = "RohitEA Loss Protection";

            if(SendDollarExitAwareOrder(request, result))
            {
               PrintFormat("Loss Protection: Modified SL for position #%d to %.5f", ticket, new_sl);
               ExtPositionTrackers[i].loss_protection_applied = true;
               ExtPositionTrackers[i].failed_sl_modification_attempts = 0;
            }
            else
            {
               int last_error = GetLastError();
               PrintFormat("Loss Protection: Failed to modify SL for position #%d. Error: %d", ticket, last_error);
               
               // Track failed attempts ONLY if position is still in loss
               double position_profit = PositionGetDouble(POSITION_PROFIT);
               bool position_in_loss = (position_profit < 0);
               
               if(position_in_loss)
               {
                  if(ExtPositionTrackers[i].failed_sl_modification_attempts == 0)
                     ExtPositionTrackers[i].first_failed_attempt_time = current_time;
                  
                  ExtPositionTrackers[i].failed_sl_modification_attempts++;
                  PrintFormat("Loss Protection: Failed attempt #%d (position P&L: %.2f)", 
                     ExtPositionTrackers[i].failed_sl_modification_attempts, position_profit);
                  
                  // Check if we should force close at market
                  if(InpLossProtectionForceMarketClose)
                  {
                     if(ExtPositionTrackers[i].failed_sl_modification_attempts >= InpLossProtectionMaxFailedAttempts)
                     {
                        PrintFormat("Loss Protection: Max failed attempts (%d) reached for position #%d. Force closing at market price %.5f", 
                           InpLossProtectionMaxFailedAttempts, ticket, current_price);
                        
                        ClosePosition(ticket);
                        ExtPositionTrackers[i].loss_protection_applied = true;
                     }
                  }
               }
               else
               {
                  // Position recovered to profit - reset the failed counter
                  PrintFormat("Loss Protection: Position #%d recovered to profit (%.2f). Resetting failure counter.", ticket, position_profit);
                  ExtPositionTrackers[i].failed_sl_modification_attempts = 0;
                  ExtPositionTrackers[i].loss_protection_applied = true;  // Mark as done since position is now profitable
               }
            }
         }
         else
         {
            PrintFormat("Loss Protection: No SL modification needed for position #%d.", ticket);
            ExtPositionTrackers[i].loss_protection_applied = true;
         }
      }
   }

   for(int i = ArraySize(ExtPositionTrackers) - 1; i >= 0; i--)
   {
      if(!PositionSelectByTicket(ExtPositionTrackers[i].ticket))
      {
         for(int j = i; j < ArraySize(ExtPositionTrackers) - 1; j++)
         {
            ExtPositionTrackers[j] = ExtPositionTrackers[j + 1];
         }
         ArrayResize(ExtPositionTrackers, ArraySize(ExtPositionTrackers) - 1);
      }
   }
}
void ApplyBreakeven()
{
   if(InpGlobalDollarExitEnabled) return;
   if(!InpBreakevenEnabled) return;

   int total_positions = PositionsTotal();

   for(int i = 0; i < total_positions; i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;

      if(!PositionSelectByTicket(ticket)) continue;

      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;

      bool found = false;
      for(int j = 0; j < ArraySize(ExtBreakevenTrackers); j++)
      {
         if(ExtBreakevenTrackers[j].ticket == ticket)
         {
            found = true;
            break;
         }
      }

      if(!found)
      {
         int size = ArraySize(ExtBreakevenTrackers);
         ArrayResize(ExtBreakevenTrackers, size + 1);
         ExtBreakevenTrackers[size].ticket = ticket;
         ExtBreakevenTrackers[size].entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
         ExtBreakevenTrackers[size].original_sl = PositionGetDouble(POSITION_SL);
         ExtBreakevenTrackers[size].breakeven_applied = false;

         PrintFormat("Breakeven: Added position #%d to tracker.", ticket);
      }
   }

   for(int i = 0; i < ArraySize(ExtBreakevenTrackers); i++)
   {
      if(ExtBreakevenTrackers[i].breakeven_applied) continue;

      ulong ticket = ExtBreakevenTrackers[i].ticket;

      if(!PositionSelectByTicket(ticket))
      {
         ExtBreakevenTrackers[i].breakeven_applied = true;
         continue;
      }

      string symbol = PositionGetString(POSITION_SYMBOL);
      ENUM_POSITION_TYPE position_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      double entry_price = ExtBreakevenTrackers[i].entry_price;
      double current_price = PositionGetDouble(POSITION_PRICE_CURRENT);
      double current_sl = PositionGetDouble(POSITION_SL);
      double original_sl = ExtBreakevenTrackers[i].original_sl;

      if(original_sl == 0)
      {
         ExtBreakevenTrackers[i].breakeven_applied = true;
         continue;
      }

      double initial_risk = MathAbs(entry_price - original_sl);
      if(initial_risk == 0)
      {
         ExtBreakevenTrackers[i].breakeven_applied = true;
         continue;
      }

      double current_profit = 0; // price-difference profit (price units)
      if(position_type == POSITION_TYPE_BUY) current_profit = current_price - entry_price;
      else current_profit = entry_price - current_price;

      // Monetary profit (account currency) for the position
      double current_profit_money = PositionGetDouble(POSITION_PROFIT);

      double r_multiple = current_profit / initial_risk;

      if(r_multiple >= InpBreakevenRMultiple)
      {
         bool should_modify = false;
         if(position_type == POSITION_TYPE_BUY && entry_price > current_sl) should_modify = true;
         else if(position_type == POSITION_TYPE_SELL && entry_price < current_sl) should_modify = true;

         if(should_modify)
         {
            int digits = (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS);
            double new_sl = NormalizeDouble(entry_price, digits);

            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);

            request.action = TRADE_ACTION_SLTP;
            request.symbol = symbol;
            request.position = ticket;
            request.sl = new_sl;
            request.tp = PositionGetDouble(POSITION_TP);
            request.comment = "RohitEA Breakeven";

            if(SendDollarExitAwareOrder(request, result))
            {
               PrintFormat("Breakeven: Moved SL to entry for position #%d.", ticket);
               ExtBreakevenTrackers[i].breakeven_applied = true;
            }
            else
            {
               PrintFormat("Breakeven: Failed to modify SL for position #%d. Error: %d", ticket, GetLastError());
            }
         }
         else
         {
            ExtBreakevenTrackers[i].breakeven_applied = true;
         }
      }
   }

   for(int i = ArraySize(ExtBreakevenTrackers) - 1; i >= 0; i--)
   {
      if(!PositionSelectByTicket(ExtBreakevenTrackers[i].ticket))
      {
         for(int j = i; j < ArraySize(ExtBreakevenTrackers) - 1; j++)
         {
            ExtBreakevenTrackers[j] = ExtBreakevenTrackers[j + 1];
         }
         ArrayResize(ExtBreakevenTrackers, ArraySize(ExtBreakevenTrackers) - 1);
      }
   }
}

double TrailDistanceToMoney(const string symbol, const double distance, const double volume)
{
   if(distance <= 0.0 || volume <= 0.0)
      return 0.0;

   double tick_value = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);
   double tick_size = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tick_value <= 0.0 || tick_size <= 0.0)
      return 0.0;

   return (distance / tick_size) * tick_value * volume;
}

