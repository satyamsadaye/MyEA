bool IsTradingHour()
{
   if(!InpTradingHoursEnabled)
      return true;
   MqlDateTime tm;
   TimeToStruct(TimeCurrent(), tm);
   int hour = tm.hour * 100 + tm.min;
   if(hour >= InpTradingHourStart && hour <= InpTradingHourEnd)
      return true;
   return false;
}

