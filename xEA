//+------------------------------------------------------------------+
//| Handle Pattern 6 - Reversal Pattern                              |
//+------------------------------------------------------------------+
void HandlePattern6()
{
    // Get current bar time to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);

    // Check if we've already processed a signal for this bar
    if(current_bar_time == g_lastSignalTime)
    {
        return; // Signal already processed for this bar
    }

    // We need at least 3 bars for our pattern
    if(Bars(_Symbol, _Period) < 3)
    {
        return;
    }
    
    // If we have a pending signal from a previous bar, execute it now on the new bar
    if(g_p6_patternFormed && g_p6_pendingSignal != "" && g_p6_signalTime != current_bar_time)
    {
        PrintFormat("Pattern 6: Executing pending %s signal from previous bar detection", g_p6_pendingSignal);
        string trade_action = g_p6_pendingSignal;
        
        if(InpReverseSignal)
        {
            trade_action = (trade_action == "buy") ? "sell" : "buy";
            Print("Pattern 6: Signal has been reversed to " + trade_action);
        }
        
        ExecuteTrade(trade_action);
        g_lastSignalTime = current_bar_time; // Record signal time to prevent duplicates
        
        // Reset pattern state
        g_p6_patternFormed = false;
        g_p6_pendingSignal = "";
        return;
    }

    // IMPORTANT: For proper analysis, we need to look at fully completed bars
    
    // Get OHLC data for bars
    double opens[10], highs[10], lows[10], closes[10];
    long volumes[10];
    
    // Get more data than needed to ensure we have enough
    if(CopyOpen(_Symbol, _Period, 0, 10, opens) < 10 ||
       CopyHigh(_Symbol, _Period, 0, 10, highs) < 10 ||
       CopyLow(_Symbol, _Period, 0, 10, lows) < 10 ||
       CopyClose(_Symbol, _Period, 0, 10, closes) < 10 ||
       CopyTickVolume(_Symbol, _Period, 0, 10, volumes) < 10)
    {
        Print("Failed to get price or volume data for Pattern 6.");
        return;
    }

    // Bar 1 is the most recently COMPLETED bar (index 1)
    double bar1_open = opens[1];    // Most recent completed bar open
    double bar1_high = highs[1];    // Most recent completed bar high
    double bar1_low = lows[1];      // Most recent completed bar low
    double bar1_close = closes[1];  // Most recent completed bar close
    long bar1_volume = volumes[1];  // Most recent completed bar volume
    
    // Bar 2 is the bar before the most recently completed bar (index 2)
    double bar2_open = opens[2];    // Previous completed bar open
    double bar2_high = highs[2];    // Previous completed bar high
    double bar2_low = lows[2];      // Previous completed bar low
    double bar2_close = closes[2];  // Previous completed bar close
    long bar2_volume = volumes[2];  // Previous completed bar volume
    
    // Debug output to verify the data
    PrintFormat("Pattern 6 DEBUG - Bar 1 (index 1): O=%.5f, H=%.5f, L=%.5f, C=%.5f, V=%d, Color=%s", 
                bar1_open, bar1_high, bar1_low, bar1_close, bar1_volume,
                bar1_close > bar1_open ? "GREEN" : "RED");
                
    PrintFormat("Pattern 6 DEBUG - Bar 2 (index 2): O=%.5f, H=%.5f, L=%.5f, C=%.5f, V=%d, Color=%s", 
                bar2_open, bar2_high, bar2_low, bar2_close, bar2_volume,
                bar2_close > bar2_open ? "GREEN" : "RED");
    
    // Additional debug to check more bars
    PrintFormat("Pattern 6 DEBUG - Bar 3 (index 3): O=%.5f, H=%.5f, L=%.5f, C=%.5f, V=%d",
                opens[3], highs[3], lows[3], closes[3], volumes[3]);
    
    string pattern_signal = "";

    // --- BUY Signal Conditions ---
    // 1. Volume must be higher than previous bar
    bool volumeIncreased = bar1_volume > bar2_volume;
    // 2. Current candle is red
    bool bar1IsRed = bar1_close < bar1_open;
    // 3. Previous candle is red
    bool bar2IsRed = bar2_close < bar2_open;
    // 4. Lower high and lower low
    bool isLowerHigh = bar1_high < bar2_high;
    bool isLowerLow = bar1_low < bar2_low;
    // 5. Current candle closes below previous candle's low
    bool closesBelowPrevLow = bar1_close < bar2_low;

    // Debug output for buy conditions
    PrintFormat("Pattern 6 BUY Conditions: Volume Increased=%s (%d > %d), Bar1 Red=%s, Bar2 Red=%s, Lower High=%s, Lower Low=%s, Closes Below Prev Low=%s",
                volumeIncreased ? "true" : "false", bar1_volume, bar2_volume,
                bar1IsRed ? "true" : "false",
                bar2IsRed ? "true" : "false",
                isLowerHigh ? "true" : "false",
                isLowerLow ? "true" : "false",
                closesBelowPrevLow ? "true" : "false");

    // BUY PATTERN: Two red candles with lower high/low formation and close below previous low
    // Volume must be higher on the current bar compared to previous bar
    if (volumeIncreased && bar1IsRed && bar2IsRed && 
        ((isLowerHigh && isLowerLow) || closesBelowPrevLow))  // Relaxed condition: either lower formation OR close below prev low
    {
        PrintFormat("Pattern 6: BUY signal detected. Volume increased (%d > %d), Two red candles, with either lower high/low formation or close below previous low.", 
                   bar1_volume, bar2_volume);
        pattern_signal = "buy";
    }

    // --- SELL Signal Conditions ---
    // 1. Volume must be higher than previous bar (already calculated)
    // 2. Current candle is green
    bool bar1IsGreen = bar1_close > bar1_open;
    // 3. Previous candle is green
    bool bar2IsGreen = bar2_close > bar2_open;
    // 4. Higher high and higher low
    bool isHigherHigh = bar1_high > bar2_high;
    bool isHigherLow = bar1_low > bar2_low;
    // 5. Current candle closes above previous candle's high
    bool closesAbovePrevHigh = bar1_close > bar2_high;
    
    // Debug output for sell conditions
    PrintFormat("Pattern 6 SELL Conditions: Volume Increased=%s (%d > %d), Bar1 Green=%s, Bar2 Green=%s, Higher High=%s, Higher Low=%s, Closes Above Prev High=%s",
                volumeIncreased ? "true" : "false", bar1_volume, bar2_volume,
                bar1IsGreen ? "true" : "false",
                bar2IsGreen ? "true" : "false",
                isHigherHigh ? "true" : "false",
                isHigherLow ? "true" : "false",
                closesAbovePrevHigh ? "true" : "false");

    // SELL PATTERN: Two green candles with higher high/low formation and close above previous high
    // Volume must be higher on the current bar compared to previous bar
    if (volumeIncreased && bar1IsGreen && bar2IsGreen && 
        ((isHigherHigh && isHigherLow) || closesAbovePrevHigh))  // Relaxed condition: either higher formation OR close above prev high
    {
        PrintFormat("Pattern 6: SELL signal detected. Volume increased (%d > %d), Two green candles, with either higher high/low formation or close above previous high.", 
                   bar1_volume, bar2_volume);
        pattern_signal = "sell";
    }

    // If a pattern is detected, store it for execution on the next bar
    if(pattern_signal != "")
    {
        g_p6_patternFormed = true;
        g_p6_pendingSignal = pattern_signal;
        g_p6_signalTime = current_bar_time;
        PrintFormat("Pattern 6: %s signal stored for execution on next bar open", pattern_signal);
    }
}

//+------------------------------------------------------------------+
//| Handle Pattern 7 - HeikinAshi Trend                             |
//+------------------------------------------------------------------+
void HandlePattern7_HeikinAshiTrend()
{
    // Get current bar time to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    if(current_bar_time == g_lastSignalTime)
    {
        PrintFormat("Pattern 7: Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
        return;
    }
    // Need at least 2 completed bars for HA logic
    if(Bars(_Symbol, _Period) < 3)
        return;
    // Get Heikin Ashi values for current and previous completed bars
    HeikinAshiValues ha_curr, ha_prev;
    GetHeikinAshiValues(_Symbol, _Period, 1, ha_curr); // Most recent completed bar
    GetHeikinAshiValues(_Symbol, _Period, 2, ha_prev); // Bar before that

    // BUY: current HA close > previous HA high, current candle green, previous candle red
    bool buy_signal = (ha_curr.haClose > ha_prev.haHigh) && (ha_curr.haClose > ha_curr.haOpen) && (ha_prev.haClose < ha_prev.haOpen);
    // SELL: current HA close < previous HA low, current candle red, previous candle green
    bool sell_signal = (ha_curr.haClose < ha_prev.haLow) && (ha_curr.haClose < ha_curr.haOpen) && (ha_prev.haClose > ha_prev.haOpen);

    PrintFormat("Pattern 7: HA Trend - CurrClose=%.5f, PrevHigh=%.5f, PrevLow=%.5f, CurrColor=%s, PrevColor=%s", 
        ha_curr.haClose, ha_prev.haHigh, ha_prev.haLow, 
        (ha_curr.haClose > ha_curr.haOpen) ? "GREEN" : "RED", 
        (ha_prev.haClose > ha_prev.haOpen) ? "GREEN" : "RED");

    if(buy_signal)
    {
        Print("Pattern 7: HeikinAshi Trend BUY signal detected (close > prev high, green/red). Will buy at next candle open.");
        if(InpReverseSignal)
        {
            Print("Pattern 7: Signal reversed to SELL.");
            ExecuteTrade("sell");
        }
        else
        {
            ExecuteTrade("buy");
        }
        g_lastSignalTime = current_bar_time;
    }
    else if(sell_signal)
    {
        Print("Pattern 7: HeikinAshi Trend SELL signal detected (close < prev low, red/green). Will sell at next candle open.");
        if(InpReverseSignal)
        {
            Print("Pattern 7: Signal reversed to BUY.");
            ExecuteTrade("buy");
        }
        else
        {
            ExecuteTrade("sell");
        }
        g_lastSignalTime = current_bar_time;
    }
}

//+------------------------------------------------------------------+
//| Handle Pattern 8 - HeikinAshi Consecutive Candles               |
//+------------------------------------------------------------------+
void HandlePattern8_HeikinAshiConsecutive()
{
    // Get current bar time to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);
    
    // Check if this is a new bar
    if(current_bar_time == g_p8_lastBarTime)
    {
        // Same bar, don't process again unless in development mode
        if(!InpDevelopmentMode)
            return;
    }
    
    // Validate input parameter (clamp between 2 and 10)
    int consecutiveCandles = MathMax(2, MathMin(10, InpPattern8ConsecutiveCandles));
    
    // Need enough bars for analysis (setup + consecutive + buffer)
    if(Bars(_Symbol, _Period) < consecutiveCandles + 3)
    {
        if(!g_is_backtesting)
            PrintFormat("Pattern 8: Not enough bars. Need %d, have %d", consecutiveCandles + 3, Bars(_Symbol, _Period));
        return;
    }
    
    datetime last_closed_bar_time = iTime(_Symbol, _Period, 1);
    
    // Reset pattern detection variables
    g_p8_consecutiveGreen = 0;
    g_p8_consecutiveRed = 0;
    g_p8_has_setup_red = false;
    g_p8_has_setup_green = false;
    g_p8_setup_candle_index = -1;
    
    // NEW PATTERN LOGIC: Look for setup candle + consecutive pattern
    // For BUY: Need 1 RED setup candle followed by N consecutive GREEN candles
    // For SELL: Need 1 GREEN setup candle followed by N consecutive RED candles
    
    bool buy_pattern_found = false;
    bool sell_pattern_found = false;
    
    // Check for setup candle at various positions
    for(int setup_pos = consecutiveCandles + 1; setup_pos >= consecutiveCandles + 1; setup_pos--)
    {
        if(setup_pos >= Bars(_Symbol, _Period))
            continue;
            
        HeikinAshiValues setup_ha;
        GetHeikinAshiValues(_Symbol, _Period, setup_pos, setup_ha);
        
        bool setup_is_red = (setup_ha.haClose < setup_ha.haOpen);
        bool setup_is_green = (setup_ha.haClose > setup_ha.haOpen);
        
        // Check for BUY pattern: RED setup + GREEN consecutive
        if(setup_is_red)
        {
            int green_count = 0;
            bool pattern_valid = true;
            
            // Count consecutive GREEN candles after the RED setup
            for(int i = setup_pos - 1; i >= 1 && green_count < consecutiveCandles; i--)
            {
                HeikinAshiValues ha;
                GetHeikinAshiValues(_Symbol, _Period, i, ha);
                
                bool is_green = (ha.haClose > ha.haOpen);
                bool is_red = (ha.haClose < ha.haOpen);
                
                if(is_green)
                {
                    green_count++;
                }
                else if(is_red || InpPattern8StrictMode)
                {
                    // Pattern broken
                    pattern_valid = false;
                    break;
                }
                // In non-strict mode, neutral candles don't break the pattern but don't count
            }
            
            if(pattern_valid && green_count >= consecutiveCandles)
            {
                buy_pattern_found = true;
                g_p8_consecutiveGreen = green_count;
                g_p8_has_setup_red = true;
                g_p8_setup_candle_index = setup_pos;
                break;
            }
        }
        
        // Check for SELL pattern: GREEN setup + RED consecutive
        if(setup_is_green)
        {
            int red_count = 0;
            bool pattern_valid = true;
            
            // Count consecutive RED candles after the GREEN setup
            for(int i = setup_pos - 1; i >= 1 && red_count < consecutiveCandles; i--)
            {
                HeikinAshiValues ha;
                GetHeikinAshiValues(_Symbol, _Period, i, ha);
                
                bool is_green = (ha.haClose > ha.haOpen);
                bool is_red = (ha.haClose < ha.haOpen);
                
                if(is_red)
                {
                    red_count++;
                }
                else if(is_green || InpPattern8StrictMode)
                {
                    // Pattern broken
                    pattern_valid = false;
                    break;
                }
                // In non-strict mode, neutral candles don't break the pattern but don't count
            }
            
            if(pattern_valid && red_count >= consecutiveCandles)
            {
                sell_pattern_found = true;
                g_p8_consecutiveRed = red_count;
                g_p8_has_setup_green = true;
                g_p8_setup_candle_index = setup_pos;
                break;
            }
        }
    }
    
    // Update last bar time
    g_p8_lastBarTime = current_bar_time;
    
    // Candle-close visibility for live monitoring
    if(!g_is_backtesting && InpPattern8LogEachClosedCandle)
    {
        PrintFormat("Pattern 8 candle close check [%s]: Need=%d closed HA candles, WaitForClose=%s, Strict=%s, BUY RED->%dGREEN: %s, SELL GREEN->%dRED: %s",
                   TimeToString(last_closed_bar_time, TIME_DATE|TIME_MINUTES),
                   consecutiveCandles,
                   InpPattern8WaitForClose ? "YES" : "NO",
                   InpPattern8StrictMode ? "YES" : "NO",
                   consecutiveCandles, buy_pattern_found ? "FOUND" : "Not found",
                   consecutiveCandles, sell_pattern_found ? "FOUND" : "Not found");
        
        if(buy_pattern_found)
        {
            PrintFormat("Pattern 8: BUY Pattern Details - Setup RED at pos %d, %d consecutive GREEN candles", 
                       g_p8_setup_candle_index, g_p8_consecutiveGreen);
        }
        
        if(sell_pattern_found)
        {
            PrintFormat("Pattern 8: SELL Pattern Details - Setup GREEN at pos %d, %d consecutive RED candles", 
                       g_p8_setup_candle_index, g_p8_consecutiveRed);
        }
    }
    
    // Use static variables to prevent multiple triggers on the same pattern
    static bool buy_pattern_used = false;
    static bool sell_pattern_used = false;
    static datetime last_buy_trigger_time = 0;
    static datetime last_sell_trigger_time = 0;
    static datetime last_buy_pattern_time = 0;
    static datetime last_sell_pattern_time = 0;
    
    // Process BUY signal
    if(buy_pattern_found)
    {
        bool is_new_buy_pattern = (current_bar_time != last_buy_pattern_time);
        
        if(is_new_buy_pattern)
        {
            buy_pattern_used = false; // Reset for new pattern
            last_buy_pattern_time = current_bar_time;
        }
        
        if(!buy_pattern_used && (TimeCurrent() - last_buy_trigger_time >= 300)) // 5 minutes minimum
        {
            g_p8_buySignalReady = true;
            buy_pattern_used = true;
            last_buy_trigger_time = TimeCurrent();
            
            if(!g_is_backtesting)
            {
                PrintFormat("Pattern 8: BUY signal TRIGGERED - %d consecutive GREEN after RED setup", 
                           g_p8_consecutiveGreen);
            }
            
            // Execute BUY trade
            ENUM_ORDER_TYPE final_order_type = InpReverseSignal ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
            
            // Apply trade direction filter
            final_order_type = GetFinalOrderType(final_order_type);
            if(final_order_type != ORDER_TYPE_BUY && final_order_type != ORDER_TYPE_SELL)
            {
                PrintFormat("Pattern 8: BUY signal blocked by trade direction filter");
                return;
            }
            
            // Calculate entry, SL, and TP
            double entryPrice = (final_order_type == ORDER_TYPE_BUY) ? 
                              SymbolInfoDouble(_Symbol, SYMBOL_ASK) : 
                              SymbolInfoDouble(_Symbol, SYMBOL_BID);
            
            double atr = GetATRValue();
            double stopLoss, takeProfit;
            
            if(final_order_type == ORDER_TYPE_BUY)
            {
                stopLoss = entryPrice - (atr * InpAtrMultiplierSL);
                takeProfit = entryPrice + (atr * InpAtrMultiplierTP);
            }
            else
            {
                stopLoss = entryPrice + (atr * InpAtrMultiplierSL);
                takeProfit = entryPrice - (atr * InpAtrMultiplierTP);
            }
            
            double lots = CalculatePositionSize(_Symbol, entryPrice, stopLoss);
            if(lots <= 0)
            {
                PrintFormat("Pattern 8: Invalid position size calculated for %s order", 
                           (final_order_type == ORDER_TYPE_BUY) ? "BUY" : "SELL");
                return;
            }
            
            // Execute the trade
            if(!InpDevelopmentMode)
            {
                MqlTradeRequest request;
                MqlTradeResult result;
                ZeroMemory(request);
                ZeroMemory(result);
                
                request.action = TRADE_ACTION_DEAL;
                request.symbol = _Symbol;
                request.volume = lots;
                request.type = final_order_type;
                request.price = entryPrice;
                request.sl = stopLoss;
                request.tp = takeProfit;
                request.deviation = InpMaxSlippagePoints;
                request.magic = InpMagicNumber;
                request.comment = StringFormat("RohitEA P8-HA%dG", consecutiveCandles);
                request.type_filling = GetSupportedFillingMode(_Symbol);
                
                if(!IsSpreadAcceptable()) return;
                if(SendDollarExitAwareOrder(request, result))
                {
                    PrintFormat("Pattern 8: Placed %s order #%d at %.5f, SL: %.5f, TP: %.5f, Lots: %.2f (RED→%dGREEN HA)",
                               (final_order_type == ORDER_TYPE_BUY) ? "BUY" : "SELL",
                               result.order, entryPrice, stopLoss, takeProfit, lots, g_p8_consecutiveGreen);
                    
                    if(final_order_type == ORDER_TYPE_BUY)
                        g_p8_lastBuyTicket = result.order;
                    else
                        g_p8_lastSellTicket = result.order;
                    
                    // Create DCA protection orders for this main trade
