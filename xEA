void HandleMultiOrderRecovery()
{
    if(!InpMultiOrderEnabled) return; // Corrected to use the existing variable
    
    for(int i = PositionsTotal() - 1; i >= 0; i--)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket <= 0 || !PositionSelectByTicket(ticket)) continue; // Ensure position is selected
        
        if(PositionGetString(POSITION_SYMBOL) != _Symbol || PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
        
        string comment = PositionGetString(POSITION_COMMENT);
        if(StringFind(comment, "Recovery-") < 0) continue;
        
        long recoveryLevel = GetRecoveryLevelFromComment(comment);
        if(recoveryLevel >= InpMultiOrderMaxAttempts) continue; // Corrected variable name
        
        double currentPrice = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? 
            SymbolInfoDouble(_Symbol, SYMBOL_BID) : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
        double entryPrice = PositionGetDouble(POSITION_PRICE_OPEN);
        double syntheticSL;
        
        // Use the same SL/TP method as the original trade for synthetic SL calculation
        if(InpSLTPMethod == SLTP_FIXED_POINTS)
        {
            // Use fixed points method for synthetic SL
            double point_value = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
            
            syntheticSL = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? 
                entryPrice - (InpFixedSLPoints * point_value) :
                entryPrice + (InpFixedSLPoints * point_value);
                
            PrintFormat("Multi-Order Recovery: Synthetic SL check using fixed points: %.0f points (SL: %.5f)",
                       InpFixedSLPoints, syntheticSL);
        }
        else
        {
            // Use ATR-based method for synthetic SL
            double atr = GetCurrentATR();
            if(atr == 0) continue;
            
            if(InpMultiOrderCustomSLTP)
            {
                syntheticSL = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? 
                    entryPrice - (atr * InpMultiOrderSLMultiplier) :
                    entryPrice + (atr * InpMultiOrderSLMultiplier);
            }
            else
            {
                syntheticSL = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ?
                    entryPrice - (atr * InpAtrMultiplierSL) :
                    entryPrice + (atr * InpAtrMultiplierSL);
            }
            
            PrintFormat("Multi-Order Recovery: Synthetic SL check using ATR-based method (ATR: %.5f, SL: %.5f)",
                       atr, syntheticSL);
        }
        
        bool shouldRecover = false;
        if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY)
        {
            shouldRecover = currentPrice <= syntheticSL;
        }
        else
        {
            shouldRecover = currentPrice >= syntheticSL;
        }
        
        if(shouldRecover)
        {
            double newLots;
            if(InpMultiOrderLotReduction)
            {
                // Reduce lot size (anti-martingale)
                newLots = PositionGetDouble(POSITION_VOLUME) / InpMultiOrderLotMultiplier;
                PrintFormat("Multi-Order Recovery: Applying lot REDUCTION. Original: %.2f, Multiplier: %.2f, New lot: %.2f",
                          PositionGetDouble(POSITION_VOLUME), InpMultiOrderLotMultiplier, newLots);
            }
            else
            {
                // Increase lot size (martingale)
                newLots = PositionGetDouble(POSITION_VOLUME) * InpMultiOrderLotMultiplier;
                PrintFormat("Multi-Order Recovery: Applying lot INCREASE. Original: %.2f, Multiplier: %.2f, New lot: %.2f",
                          PositionGetDouble(POSITION_VOLUME), InpMultiOrderLotMultiplier, newLots);
            }
            
            // Ensure volume is within allowed limits
            double min_lot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
            double max_lot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
            double lot_step = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);
            newLots = MathMax(min_lot, newLots);
            newLots = MathMin(max_lot, newLots);
            if(lot_step > 0)
            {
                newLots = MathFloor(newLots / lot_step) * lot_step;
            }
            newLots = NormalizeDouble(newLots, 2); // Ensure proper normalization
            
            MqlTradeRequest request = {};
            MqlTradeResult result = {};
            
            request.action = TRADE_ACTION_DEAL;
            request.symbol = _Symbol;
            request.volume = newLots;
            request.type = (PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
            request.price = SymbolInfoDouble(_Symbol, (request.type == ORDER_TYPE_BUY) ? SYMBOL_ASK : SYMBOL_BID);
            request.deviation = 5;
            request.magic = InpMagicNumber;
            request.comment = StringFormat("Recovery-%d for #%I64u", recoveryLevel + 1, ticket);
            
            if(!IsSpreadAcceptable()) return;
            bool orderSent = SendDollarExitAwareOrder(request, result);
            if(orderSent && result.retcode == TRADE_RETCODE_DONE)
            {
                Print("Recovery order placed: Level ", (int)recoveryLevel + 1, " for ticket #", (long)ticket);
                
                if(recoveryLevel + 1 >= InpMultiOrderMaxAttempts - 1)
                {
                    MqlTradeRequest modifyRequest = {};
                    MqlTradeResult modifyResult = {};
                    
                    double finalSL = 0;
                    
                    // Use the same SL/TP method as the original trade for final recovery SL
                    if(InpSLTPMethod == SLTP_FIXED_POINTS)
                    {
                        // Use fixed points method for final recovery SL
                        double point_value = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
                        
                        finalSL = (request.type == ORDER_TYPE_BUY) ?
                            request.price - (InpFixedSLPoints * point_value) :
                            request.price + (InpFixedSLPoints * point_value);
                            
                        PrintFormat("Multi-Order Recovery: Using fixed points for final recovery SL: %.0f points (SL: %.5f)",
                                   InpFixedSLPoints, finalSL);
                    }
                    else
                    {
                        // Use ATR-based method for final recovery SL
                        double atr = GetCurrentATR();
                        if(atr == 0) return;
                        
                        double sl_multiplier = InpMultiOrderCustomSLTP ? InpMultiOrderSLMultiplier : InpAtrMultiplierSL;
                        
                        finalSL = (request.type == ORDER_TYPE_BUY) ?
                            request.price - (atr * sl_multiplier) :
                            request.price + (atr * sl_multiplier);
                            
                        if(InpMultiOrderCustomSLTP)
                        {
                            PrintFormat("Multi-Order Recovery: Using custom SL multiplier for final recovery: %.2f × ATR (default: %.2f)",
                                       sl_multiplier, InpAtrMultiplierSL);
                        }
                        
                        PrintFormat("Multi-Order Recovery: Using ATR-based method for final recovery SL (ATR: %.5f, SL: %.5f)",
                                   atr, finalSL);
                    }
                    
                    modifyRequest.action = TRADE_ACTION_SLTP;
                    modifyRequest.comment = "RohitEA Final Recovery SL";
                    long position_ticket = HistoryDealGetInteger(result.deal, DEAL_POSITION_ID);
                    if(position_ticket > 0)
                    {
                       modifyRequest.position = position_ticket;
                       modifyRequest.symbol = _Symbol;
                       modifyRequest.sl = finalSL;
                       
                       if(!IsSpreadAcceptable()) return;
                       if(!SendDollarExitAwareOrder(modifyRequest, modifyResult))
                       {
                           Print("Failed to modify final recovery SL. Error: ", GetLastError());
                       }
                    }
                }
            }
            else
            {
                Print("Failed to place recovery order. Error: ", GetLastError());
            }
        }
    }
}

long GetRecoveryLevelFromComment(string comment)
{
    int recoveryStart = StringFind(comment, "Recovery-") + 9;
    int forPosition = StringFind(comment, " for");
    if(recoveryStart >= 9 && forPosition > recoveryStart)
    {
        string levelStr = StringSubstr(comment, recoveryStart, forPosition - recoveryStart);
        return StringToInteger(levelStr) - 1;
    }
    return 0;
}

