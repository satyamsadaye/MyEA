//+------------------------------------------------------------------+
//| Handle Pattern 17 - Statastical Probability Pattern              |
//+------------------------------------------------------------------+
void HandlePattern17_Statastical()
{
   datetime current_bar_time = iTime(_Symbol, _Period, 0);
   bool isNewBar = (current_bar_time != g_p17_lastBarTime);
   if(isNewBar)
   {
      g_p17_lastBarTime = current_bar_time;
      g_p17_signalProcessed = false;
   }

   // Keep heavy statistical scan to once per bar.
   if(!isNewBar && !g_is_backtesting)
      return;

   double point_value = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(point_value <= 0.0)
      return;

   int step_points = MathMax(1, InpPattern17PipStepPoints);
   int lookback = MathMax(1, InpPattern17LookbackCandles);
   int forward = MathMax(1, InpPattern17ForwardCandles);
   double step_distance = step_points * point_value;

   double upper_distance = MathMax(0, InpPattern17UpperLimitPoints) * point_value;
   double lower_distance = MathMax(0, InpPattern17LowerLimitPoints) * point_value;
   bool upper_enabled = (InpPattern17UpperLimitEnabled && upper_distance > 0.0);
   bool lower_enabled = (InpPattern17LowerLimitEnabled && lower_distance > 0.0);

   if(!upper_enabled && !lower_enabled)
   {
      Print("Pattern 17: Both upper and lower limits are disabled or zero. No signal generated.");
      return;
   }

   int bars_needed = lookback + forward + 5;
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, _Period, 0, bars_needed, rates);
   if(copied <= (forward + 2))
   {
      PrintFormat("Pattern 17: Not enough bars for scan. Need > %d, got %d.", forward + 2, copied);
      return;
   }

   int effective_lookback = MathMin(lookback, copied - forward - 1);
   if(effective_lookback <= 0)
      return;

   double upper_threshold = MathMax(0.0, MathMin(100.0, InpPattern17UpperChancePercent));
   double lower_threshold = MathMax(0.0, MathMin(100.0, InpPattern17LowerChancePercent));

   int max_distance_points = MathMax(MathMax(0, InpPattern17UpperLimitPoints), MathMax(0, InpPattern17LowerLimitPoints));
   int levels_by_distance = (max_distance_points > 0 ? (max_distance_points / step_points) : 0);
   int levels_to_draw = MathMin(MathMax(0, InpPattern17MaxVisualLevels), levels_by_distance);

   int upper_level_hits[];
   int lower_level_hits[];
   if(levels_to_draw > 0)
   {
      ArrayResize(upper_level_hits, levels_to_draw);
      ArrayResize(lower_level_hits, levels_to_draw);
      for(int lv = 0; lv < levels_to_draw; lv++)
      {
         upper_level_hits[lv] = 0;
         lower_level_hits[lv] = 0;
      }
   }

   int upper_yes = 0, upper_no = 0;
   int lower_yes = 0, lower_no = 0;
   int scan_index = 0;

   for(int idx = effective_lookback - 1; idx >= 0; idx--)
   {
      int base = forward + idx;
      scan_index++;

      double base_price = rates[base].close;
      double upper_target = base_price + upper_distance;
      double lower_target = base_price - lower_distance;
      bool hit_upper = false;
      bool hit_lower = false;
      int first_hit = 0; // 0 none, 1 upper, 2 lower, 3 both same candle

      double fwd_max = -1.0e100;
      double fwd_min = 1.0e100;
      int end_index = base - forward;

      for(int j = base - 1; j >= end_index; j--)
      {
         if(rates[j].high > fwd_max) fwd_max = rates[j].high;
         if(rates[j].low < fwd_min)  fwd_min = rates[j].low;

         bool touch_upper = upper_enabled && (rates[j].high >= upper_target);
         bool touch_lower = lower_enabled && (rates[j].low <= lower_target);

         if(touch_upper) hit_upper = true;
         if(touch_lower) hit_lower = true;

         if(InpPattern17RequireFirstHitWhenBoth && upper_enabled && lower_enabled && first_hit == 0)
         {
            if(touch_upper && !touch_lower) first_hit = 1;
            else if(touch_lower && !touch_upper) first_hit = 2;
            else if(touch_upper && touch_lower) first_hit = 3;
         }
      }

      bool upper_success = false;
      bool lower_success = false;

      if(upper_enabled)
      {
         if(InpPattern17RequireFirstHitWhenBoth && upper_enabled && lower_enabled)
            upper_success = (first_hit == 1);
         else
            upper_success = hit_upper;

         if(upper_success) upper_yes++;
         else upper_no++;
      }

      if(lower_enabled)
      {
         if(InpPattern17RequireFirstHitWhenBoth && upper_enabled && lower_enabled)
            lower_success = (first_hit == 2);
         else
            lower_success = hit_lower;

         if(lower_success) lower_yes++;
         else lower_no++;
      }

      if(levels_to_draw > 0)
      {
         for(int lv2 = 0; lv2 < levels_to_draw; lv2++)
         {
            double level_distance = (lv2 + 1) * step_distance;
            if(fwd_max >= base_price + level_distance)
               upper_level_hits[lv2]++;
            if(fwd_min <= base_price - level_distance)
               lower_level_hits[lv2]++;
         }
      }

      if(InpPattern17VerboseCandleLog)
      {
         string first_hit_text = "none";
         if(first_hit == 1) first_hit_text = "upper";
         else if(first_hit == 2) first_hit_text = "lower";
         else if(first_hit == 3) first_hit_text = "both_on_same_candle";

         PrintFormat("Pattern 17 Scan %d/%d: BaseTime=%s BaseClose=%.5f Next%dCandles => UpperTarget=%.5f (%s), LowerTarget=%.5f (%s), FirstHit=%s",
                     scan_index, effective_lookback,
                     TimeToString(rates[base].time, TIME_DATE|TIME_MINUTES),
                     base_price, forward,
                     upper_target, upper_success ? "YES" : "NO",
                     lower_target, lower_success ? "YES" : "NO",
                     first_hit_text);
      }
   }

   g_p17_lastSamples = effective_lookback;
   g_p17_upperProbability = upper_enabled ? ((double)upper_yes * 100.0 / effective_lookback) : 0.0;
   g_p17_lowerProbability = lower_enabled ? ((double)lower_yes * 100.0 / effective_lookback) : 0.0;

   bool buy_candidate = upper_enabled && (g_p17_upperProbability >= upper_threshold);
   bool sell_candidate = lower_enabled && (g_p17_lowerProbability >= lower_threshold);

   if(upper_enabled && lower_enabled && buy_candidate && sell_candidate)
   {
      if(g_p17_upperProbability > g_p17_lowerProbability)
         sell_candidate = false;
      else if(g_p17_lowerProbability > g_p17_upperProbability)
         buy_candidate = false;
      else
      {
         buy_candidate = false;
         sell_candidate = false;
      }
   }

   if(!IsPattern17BuyAllowed())
      buy_candidate = false;
   if(!IsPattern17SellAllowed())
      sell_candidate = false;

   string signal_text = "SKIP";
   if(buy_candidate) signal_text = "BUY";
   else if(sell_candidate) signal_text = "SELL";

   PrintFormat("Pattern 17 Summary: samples=%d, upper=%.2f%% (%d yes / %d no, threshold %.2f%%), lower=%.2f%% (%d yes / %d no, threshold %.2f%%), signal=%s",
               effective_lookback,
               g_p17_upperProbability, upper_yes, upper_no, upper_threshold,
               g_p17_lowerProbability, lower_yes, lower_no, lower_threshold,
               signal_text);

   if(InpPattern17ShowLevels && !g_is_backtesting)
   {
      DeletePattern17Objects();

      int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);
      double reference_price = rates[0].close;

      for(int lv3 = 0; lv3 < levels_to_draw; lv3++)
      {
         int level_points = (lv3 + 1) * step_points;
         double up_prob = ((double)upper_level_hits[lv3] * 100.0 / effective_lookback);
         double dn_prob = ((double)lower_level_hits[lv3] * 100.0 / effective_lookback);

         color up_color = (up_prob >= upper_threshold ? InpPattern17UpperLineColor : InpPattern17NeutralLineColor);
         color dn_color = (dn_prob >= lower_threshold ? InpPattern17LowerLineColor : InpPattern17NeutralLineColor);

         double up_price = NormalizeDouble(reference_price + ((lv3 + 1) * step_distance), digits);
         double dn_price = NormalizeDouble(reference_price - ((lv3 + 1) * step_distance), digits);

         string up_name = PATTERN17_OBJECT_PREFIX + "UP_" + IntegerToString(lv3 + 1);
         string dn_name = PATTERN17_OBJECT_PREFIX + "DN_" + IntegerToString(lv3 + 1);
         string up_label = StringFormat("P17 UP L%d (+%dpt): %.1f%%", lv3 + 1, level_points, up_prob);
         string dn_label = StringFormat("P17 DN L%d (-%dpt): %.1f%%", lv3 + 1, level_points, dn_prob);

         UpsertPattern17HLine(up_name, up_price, up_color, MathMax(1, InpPattern17LineWidth), up_label);
         UpsertPattern17HLine(dn_name, dn_price, dn_color, MathMax(1, InpPattern17LineWidth), dn_label);
      }

      color summary_color = InpPattern17NeutralLineColor;
      if(signal_text == "BUY") summary_color = InpPattern17UpperLineColor;
      if(signal_text == "SELL") summary_color = InpPattern17LowerLineColor;

      UpsertPattern17SummaryLabel(PATTERN17_OBJECT_PREFIX + "SUMMARY_1",
                                  StringFormat("P17 Statastical | Samples=%d | Signal=%s", effective_lookback, signal_text),
                                  12, 185, summary_color);
      UpsertPattern17SummaryLabel(PATTERN17_OBJECT_PREFIX + "SUMMARY_2",
                                  StringFormat("Upper=%.1f%% (need %.1f) | Lower=%.1f%% (need %.1f)",
                                               g_p17_upperProbability, upper_threshold,
                                               g_p17_lowerProbability, lower_threshold),
                                  12, 203, clrWhite);
   }
   else if(!g_is_backtesting)
   {
      DeletePattern17Objects();
   }

   Comment(StringFormat("Pattern 17 Statastical\nSamples: %d | Forward: %d candles\nUpper: %.2f%% (need %.2f%%)\nLower: %.2f%% (need %.2f%%)\nDecision: %s",
                        effective_lookback, forward,
                        g_p17_upperProbability, upper_threshold,
                        g_p17_lowerProbability, lower_threshold,
                        signal_text));

   bool can_trade = true;
   if(InpPattern17WaitForClose && !g_is_backtesting)
   {
      MqlRates current_rates[];
      ArraySetAsSeries(current_rates, true);
      if(CopyRates(_Symbol, _Period, 0, 1, current_rates) > 0)
         can_trade = (current_rates[0].time < TimeCurrent());
   }

   if(!isNewBar || g_p17_signalProcessed || !can_trade)
      return;

   if(buy_candidate)
   {
      PrintFormat("Pattern 17: BUY triggered (Upper %.2f%% >= %.2f%%).", g_p17_upperProbability, upper_threshold);
      ExecuteTrade("buy");
      g_p17_signalProcessed = true;
   }
   else if(sell_candidate)
   {
      PrintFormat("Pattern 17: SELL triggered (Lower %.2f%% >= %.2f%%).", g_p17_lowerProbability, lower_threshold);
      ExecuteTrade("sell");
      g_p17_signalProcessed = true;
   }
   else
   {
      Print("Pattern 17: No trade. Probability thresholds/trade mode not satisfied.");
   }
}

//+------------------------------------------------------------------+
ulong GetLastTradeTicket()
{
    // Search through all open positions to find the most recent one with our magic number
    int total_positions = PositionsTotal();
    if(total_positions > 0)
    {
        ulong recent_ticket = 0;
        datetime recent_time = 0;
        
        for(int i = 0; i < total_positions; i++)
        {
            ulong ticket = PositionGetTicket(i);
            if(ticket > 0 && PositionSelectByTicket(ticket))
            {
                if(PositionGetInteger(POSITION_MAGIC) == InpMagicNumber)
                {
                    datetime pos_time = (datetime)PositionGetInteger(POSITION_TIME);
                    if(pos_time > recent_time)
                    {
                        recent_time = pos_time;
                        recent_ticket = ticket;
                    }
                }
            }
        }
        
        return recent_ticket;
    }
    
    return 0;
}

//+------------------------------------------------------------------+
//| Count positions with this EA's magic number                       |
//+------------------------------------------------------------------+
int CountPositionsWithMagicNumber()
{
    int count = 0;
    int total_positions = PositionsTotal();

    for(int i = 0; i < total_positions; i++)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket == 0) continue;

        if(!PositionSelectByTicket(ticket)) continue;

        // Count only positions with our magic number
        if(PositionGetInteger(POSITION_MAGIC) == InpMagicNumber)
        {
            string comment = PositionGetString(POSITION_COMMENT);
            bool is_trailing_scale = (StringFind(comment, "Trailing Scale") >= 0);
            if(InpTrailingScaleEnabled && is_trailing_scale)
               continue;
            count++;
        }
    }

    return count;
}

//+------------------------------------------------------------------+
//| Handle Pattern 1 - Volume Based                                  |
//+------------------------------------------------------------------+
void HandlePattern1()
{
    // Get current bar time to prevent duplicate signals
    datetime current_bar_time = iTime(_Symbol, _Period, 0);

    // Check if we've already processed a signal for this bar
    if(current_bar_time == g_lastSignalTime)
    {
        if(!g_is_backtesting)
            PrintFormat("Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
        return;
    }

    // Get Volume data - use static array to avoid reallocations
    static long volumes[9];
    if(CopyTickVolume(_Symbol, _Period, 1, 9, volumes) < 9)
    {
        Print("Failed to get Volume values. Error: ", GetLastError());
        return;
    }

    long cv = volumes[0], pv = volumes[1], p1v = volumes[2], p2v = volumes[3],
         p3v = volumes[4], p4v = volumes[5], p5v = volumes[6];

    // Check for the base pattern
    bool customPattern = (p2v < p3v && cv > p4v && p4v < p5v && cv > pv && pv < p1v && cv > p2v);

    if(customPattern)
    {
        if(!g_is_backtesting)
            PrintFormat("Volume base pattern detected at bar time %s.", TimeToString(iTime(_Symbol, _Period, 1)));
        // Reset state machine
        g_patternFormed = true;
        g_barsAfterPattern = 0;
        g_volumeIncreaseFound = false;
        g_waitingForVolumeDecrease = false;
        g_signalVolume = cv;
        g_previousVolume = cv;
        return; // Wait for next bar
    }

    // If we are in a pattern-seeking state
    if(g_patternFormed)
    {
        g_barsAfterPattern++;

        // Timeout check
        if(g_barsAfterPattern > PATTERN_TIMEOUT)
        {
            if(!g_is_backtesting)
                Print("Pattern timed out.");
            g_patternFormed = false; // Reset state
            return;
        }

        // State Machine Update
        if(cv > g_previousVolume)
        {
            g_volumeIncreaseFound = true;
            g_waitingForVolumeDecrease = true;
            g_signalVolume = cv;
            if(!g_is_backtesting)
                PrintFormat("Volume increase found. Peak vol: %d", g_signalVolume);
        }

        if(g_waitingForVolumeDecrease && cv < g_previousVolume)
        {
            g_waitingForVolumeDecrease = false;
            if(!g_is_backtesting)
                Print("Volume decrease found.");
        }

        g_previousVolume = cv;

        if(g_volumeIncreaseFound && !g_waitingForVolumeDecrease)
        {
             if(cv < g_signalVolume)
             {
                if(!g_is_backtesting)
                    PrintFormat("Signal TRIGGERED. Peak vol: %d, current vol: %d", g_signalVolume, cv);

                double current_rsi = GetRSIValue();
                if(current_rsi == 0)
                {
                    Print("Failed to get RSI values for signal.");
                }
                else
                {
                    string trade_action = "";

                    if(current_rsi > InpRsiThreshold)
                    {
                        if(!g_is_backtesting)
                            PrintFormat("Original Signal: BUY on %s: RSI=%.2f > %.1f", _Symbol, current_rsi, InpRsiThreshold);
                        trade_action = "buy";
                    }
                    else if(current_rsi < InpRsiThreshold)
                    {
                        if(!g_is_backtesting)
                            PrintFormat("Original Signal: SELL on %s: RSI=%.2f < %.1f", _Symbol, current_rsi, InpRsiThreshold);
                        trade_action = "sell";
                    }

                    if(trade_action != "")
                    {
                        if(InpReverseSignal)
                        {
                            trade_action = (trade_action == "buy") ? "sell" : "buy";
                            if(!g_is_backtesting)
                                Print("Signal has been reversed to " + trade_action);
                        }
                        ExecuteTrade(trade_action);
                        g_lastSignalTime = current_bar_time; // Record signal time to prevent duplicates
                    }
                }
             }
             g_patternFormed = false;
        }
    }
}
//+------------------------------------------------------------------+
//| Validate and adjust price for pending orders                     |
//+------------------------------------------------------------------+
bool ValidateAndAdjustPrice(string symbol, double &price, ENUM_ORDER_TYPE order_type)
{
   double ask = SymbolInfoDouble(symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(symbol, SYMBOL_BID);
   double stopLevel = SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL) * SymbolInfoDouble(symbol, SYMBOL_POINT);

   switch(order_type)
   {
      case ORDER_TYPE_BUY_STOP:
         if(price <= ask)
         {
            PrintFormat("Buy Stop price (%.5f) must be above Ask (%.5f)", price, ask);
            return false;
         }
         if(price - ask < stopLevel)
         {
            price = ask + stopLevel;
            PrintFormat("Adjusted Buy Stop price to %.5f due to stop level", price);
         }
         break;

      case ORDER_TYPE_SELL_STOP:
         if(price >= bid)
         {
            PrintFormat("Sell Stop price (%.5f) must be below Bid (%.5f)", price, bid);
            return false;
         }
         if(bid - price < stopLevel)
         {
            price = bid - stopLevel;
            PrintFormat("Adjusted Sell Stop price to %.5f due to stop level", price);
         }
         break;

      case ORDER_TYPE_BUY_LIMIT:
         if(price >= bid)
         {
            PrintFormat("Buy Limit price (%.5f) must be below Bid (%.5f)", price, bid);
            return false;
         }
         if(bid - price < stopLevel)
         {
            price = bid - stopLevel;
            PrintFormat("Adjusted Buy Limit price to %.5f due to stop level", price);
         }
         break;

      case ORDER_TYPE_SELL_LIMIT:
         if(price <= ask)
         {
            PrintFormat("Sell Limit price (%.5f) must be above Ask (%.5f)", price, ask);
            return false;
         }
         if(price - ask < stopLevel)
         {
            price = ask + stopLevel;
            PrintFormat("Adjusted Sell Limit price to %.5f due to stop level", price);
         }
         break;
   }

   return true;
}

//+------------------------------------------------------------------+
//| Calculate position size based on risk                           |
//+------------------------------------------------------------------+
double CalculatePositionSize(string symbol, double entry_price, double sl_price)
{
   static double last_entry = 0;
   static double last_sl = 0;
   static double last_result = 0;
   
   // Return cached result if inputs haven't changed
   if(MathAbs(entry_price - last_entry) < 0.00001 && MathAbs(sl_price - last_sl) < 0.00001 && last_result > 0)
      return last_result;
   
   if(MathAbs(entry_price - sl_price) < SymbolInfoDouble(symbol, SYMBOL_POINT))
   {
      if(!g_is_backtesting)
         PrintFormat("Stop loss distance too small for position size calculation");
      return 0;
   }

   // Get tick value and calculate loss per lot
   double tick_value = SymbolInfoDouble(symbol, SYMBOL_TRADE_TICK_VALUE);
   double point_value = SymbolInfoDouble(symbol, SYMBOL_POINT);
   if(tick_value == 0 || point_value == 0)
   {
      if(!g_is_backtesting)
         PrintFormat("Invalid tick value or point value for %s", symbol);
      return 0;
   }

   double sl_distance_points = MathAbs(entry_price - sl_price) / point_value;
   double money_lost_per_lot = sl_distance_points * tick_value;

   if(money_lost_per_lot <= 0)
   {
      if(!g_is_backtesting)
         PrintFormat("Invalid loss per lot calculation: %.2f", money_lost_per_lot);
      return 0;
   }

   // Calculate risk amount based on method
   double risk_base = 0;
   switch(InpRiskCalcMethod)
   {
      case RISK_CALC_STARTING_BALANCE:
         risk_base = g_startingBalance;
         break;
      case RISK_CALC_BALANCE:
         risk_base = AccountInfoDouble(ACCOUNT_BALANCE);
         break;
      case RISK_CALC_EQUITY:
         risk_base = AccountInfoDouble(ACCOUNT_EQUITY);
         break;
      case RISK_CALC_FIXED_LOT:
         // For fixed lot, skip risk_base calculation
         break;
   }

   // Apply recovery factor to risk percentage if in recovery mode
   double effective_risk_pct = InpRiskPerTradePercentage;

   if(InpRecoveryMode == RECOVERY_ENABLED && g_inRecoveryMode)
   {
      effective_risk_pct = InpRiskPerTradePercentage * g_currentRecoveryFactor;
      if(!g_is_backtesting)
         PrintFormat("Recovery Mode Active: Risk adjusted from %.2f%% to %.2f%% (Factor: %.2f, Consecutive Losses: %d)",
                     InpRiskPerTradePercentage, effective_risk_pct, g_currentRecoveryFactor, g_consecutiveLosses);
   }

   // Cap risk at maximum allowed percentage
   effective_risk_pct = MathMin(effective_risk_pct, InpMaxRiskPercentage);

   double risk_amount = risk_base * (effective_risk_pct / 100.0);
   double calculated_lots;
   if(InpRiskCalcMethod == RISK_CALC_FIXED_LOT)
   {
      calculated_lots = InpFixedLotSize;
   }
   else
   {
      calculated_lots = risk_amount / money_lost_per_lot;
   }

   // Normalize lot size
   double min_lot = GetEffectiveMinLot(symbol);
   double max_lot = GetEffectiveMaxLot(symbol);
   double lot_step = SymbolInfoDouble(symbol, SYMBOL_VOLUME_STEP);

   calculated_lots = MathMax(min_lot, calculated_lots);
   calculated_lots = MathMin(max_lot, calculated_lots);
   if(lot_step > 0)
   {
      calculated_lots = MathFloor(calculated_lots / lot_step) * lot_step;
   }
   calculated_lots = NormalizeDouble(calculated_lots, 2);

   if(!g_is_backtesting)
      PrintFormat("Position Size Calc: Risk Base=%.2f, Risk Amount=%.2f, SL Distance=%.1f points, Loss/Lot=%.2f, Lots=%.2f",
                  risk_base, risk_amount, sl_distance_points, money_lost_per_lot, calculated_lots);

   // Cache the result
   last_entry = entry_price;
   last_sl = sl_price;
   last_result = calculated_lots;

   return calculated_lots;
}

//+------------------------------------------------------------------+
//| Calculate SL and TP based on selected method                     |
//+------------------------------------------------------------------+
void CalculateSLTP(double entry_price, ENUM_POSITION_TYPE position_type, double &stop_loss, double &take_profit, bool is_reversed = false)
{
   if(InpSLTPMethod == SLTP_ATR_MULTIPLIER)
   {
      // Use ATR multipliers (original method)
      double atr = GetATRValue();
      
      if(position_type == POSITION_TYPE_BUY && !is_reversed)
      {
         stop_loss = entry_price - (atr * InpAtrMultiplierSL);
         take_profit = entry_price + (atr * InpAtrMultiplierTP);
      }
      else if(position_type == POSITION_TYPE_SELL && !is_reversed)
      {
         stop_loss = entry_price + (atr * InpAtrMultiplierSL);
         take_profit = entry_price - (atr * InpAtrMultiplierTP);
      }
      else if(position_type == POSITION_TYPE_BUY && is_reversed) // Reversed BUY (acts like SELL)
      {
         stop_loss = entry_price + (atr * InpAtrMultiplierSL);
         take_profit = entry_price - (atr * InpAtrMultiplierTP);
      }
      else // position_type == POSITION_TYPE_SELL && is_reversed (acts like BUY)
      {
         stop_loss = entry_price - (atr * InpAtrMultiplierSL);
         take_profit = entry_price + (atr * InpAtrMultiplierTP);
      }
      
      if(!g_is_backtesting)
      {
         PrintFormat("[DEBUG] ATR Method (%s%s) - Entry: %.5f, ATR: %.5f, SL: %.5f (%.2fx), TP: %.5f (%.2fx)", 
                    position_type == POSITION_TYPE_BUY ? "BUY" : "SELL",
                    is_reversed ? " REVERSED" : "",
                    entry_price, atr, stop_loss, InpAtrMultiplierSL, take_profit, InpAtrMultiplierTP);
      }
   }
   else // SLTP_FIXED_POINTS
   {
      // Use fixed points
      double point_value = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
      
      // Get broker's minimum stop level
      int min_stop_level = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
      double min_stop_distance = min_stop_level * point_value;
      
      if(position_type == POSITION_TYPE_BUY && !is_reversed)
      {
         stop_loss = entry_price - (InpFixedSLPoints * point_value);
         take_profit = entry_price + (InpFixedTPPoints * point_value);
      }
      else if(position_type == POSITION_TYPE_SELL && !is_reversed)
      {
         stop_loss = entry_price + (InpFixedSLPoints * point_value);
         take_profit = entry_price - (InpFixedTPPoints * point_value);
      }
      else if(position_type == POSITION_TYPE_BUY && is_reversed) // Reversed BUY (acts like SELL)
      {
         stop_loss = entry_price + (InpFixedSLPoints * point_value);
         take_profit = entry_price - (InpFixedTPPoints * point_value);
      }
      else // position_type == POSITION_TYPE_SELL && is_reversed (acts like BUY)
      {
         stop_loss = entry_price - (InpFixedSLPoints * point_value);
         take_profit = entry_price + (InpFixedTPPoints * point_value);
      }
      
      // Validate against broker's minimum stop level
      double sl_distance = MathAbs(entry_price - stop_loss);
      double tp_distance = MathAbs(entry_price - take_profit);
      
      if(sl_distance < min_stop_distance)
      {
         PrintFormat("WARNING: Fixed SL distance (%.5f) is less than broker minimum (%.5f). SL Points: %.0f, Min Stop Level: %d", 
                    sl_distance, min_stop_distance, InpFixedSLPoints, min_stop_level);
      }
      
      if(tp_distance < min_stop_distance)
      {
         PrintFormat("WARNING: Fixed TP distance (%.5f) is less than broker minimum (%.5f). TP Points: %.0f, Min Stop Level: %d", 
                    tp_distance, min_stop_distance, InpFixedTPPoints, min_stop_level);
      }
      
      if(!g_is_backtesting)
      {
         PrintFormat("[DEBUG] Fixed Points Method (%s%s) - Entry: %.5f, SL: %.5f (%.0f pts), TP: %.5f (%.0f pts)", 
                    position_type == POSITION_TYPE_BUY ? "BUY" : "SELL",
                    is_reversed ? " REVERSED" : "",
                    entry_price, stop_loss, InpFixedSLPoints, take_profit, InpFixedTPPoints);
                    
         PrintFormat("[DEBUG] Fixed Points Details: Point Value: %.5f, SL Distance: %.5f, TP Distance: %.5f, Min Stop: %d points (%.5f)", 
                    point_value, sl_distance, tp_distance, min_stop_level, min_stop_distance);
      }
   }
}

//+------------------------------------------------------------------+
//| Handle Pattern 2 - Middle Bar Breakout                           |
//+------------------------------------------------------------------+
void HandlePattern2()
{
   // Get current bar time to prevent duplicate signals
   datetime current_bar_time = iTime(_Symbol, _Period, 0);

   // Check if we've already processed a signal for this bar
   if(current_bar_time == g_lastSignalTime)
   {
      PrintFormat("Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
      return;
   }

   // Get middle candle from last 100 bars
   int middleIndex = InpPattern2Bars / 2;
   double middleHigh = iHigh(_Symbol, _Period, middleIndex);
   double middleLow = iLow(_Symbol, _Period, middleIndex);

   // Get current order prices
   double currentBuyPrice = GetOrderPrice(g_buyStopTicket);
   double currentSellPrice = GetOrderPrice(g_sellStopTicket);

   // Check if we need to update buy order
   double buyStopPrice = middleHigh;
   bool shouldUpdateBuy = ShouldUpdateOrder(currentBuyPrice, buyStopPrice);

   // Check if we need to update sell order
   double sellStopPrice = middleLow;
   bool shouldUpdateSell = ShouldUpdateOrder(currentSellPrice, sellStopPrice);

   // If no significant changes, keep existing orders
   if(!shouldUpdateBuy && !shouldUpdateSell)
   {
      return;
   }
   
   // If we need to update, first cancel existing pending orders for this pattern
   CancelAllPendingOrders();

   // Reset our ticket trackers
   g_buyStopTicket = 0;
   g_sellStopTicket = 0;

   // Calculate ATR for SL/TP
   double atr_values[];
   if(CopyBuffer(iATR(_Symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) <= 0)
   {
      PrintFormat("Could not get ATR value. Error %d", GetLastError());
      return;
   }
   double atr = atr_values[0];

   // Place buy stop order if needed
   if(shouldUpdateBuy)
   {
      if(InpReverseSignal) // --- REVERSED LOGIC (SELL LIMIT) ---
      {
         if(InpTradeDirection == TRADE_DIR_BUY_ONLY)
         {
            PrintFormat("Pattern 2: Reversed SELL action blocked by Trade Direction Filter (BUY ONLY)");
         }
         else
         {
            Print("Signal Reversal is ON. Placing SELL LIMIT to fade breakout.");
            double sellLimitPrice = buyStopPrice;
            if(ValidateAndAdjustPrice(_Symbol, sellLimitPrice, ORDER_TYPE_SELL_LIMIT))
            {
               double sellSL = sellLimitPrice + (atr * InpAtrMultiplierSL);
               double sellTP = sellLimitPrice - (atr * InpAtrMultiplierTP);
               double sellLots = CalculatePositionSize(_Symbol, sellLimitPrice, sellSL);
               if(sellLots > 0)
               {
                  MqlTradeRequest request; MqlTradeResult result; ZeroMemory(request); ZeroMemory(result);
                  request.action = TRADE_ACTION_PENDING;
                  request.symbol = _Symbol;
                  request.volume = sellLots;
                  request.type = ORDER_TYPE_SELL_LIMIT;
                  request.price = sellLimitPrice;
                  request.sl = sellSL;
                  request.tp = sellTP;
                  request.magic = InpMagicNumber;
                  request.comment = "RohitEA Gamma";
                  if(!IsSpreadAcceptable()) return;
                  if(SendDollarExitAwareOrder(request, result)) { g_sellStopTicket = result.order; PrintFormat("Placed reversed sell limit order #%d at %.5f", g_sellStopTicket, sellLimitPrice); g_lastSignalTime = current_bar_time; }
                  else { PrintFormat("Failed to place reversed sell limit. Error: %d", GetLastError()); }
               }
            }
         }
      }
      else // --- ORIGINAL LOGIC (BUY STOP) ---
      {
         if(InpTradeDirection == TRADE_DIR_SELL_ONLY)
         {
            PrintFormat("Pattern 2: BUY action blocked by Trade Direction Filter (SELL ONLY)");
         }
         else
         {
            if(ValidateAndAdjustPrice(_Symbol, buyStopPrice, ORDER_TYPE_BUY_STOP))
            {
               double buySL = buyStopPrice - (atr * InpAtrMultiplierSL);
               double buyTP = buyStopPrice + (atr * InpAtrMultiplierTP);

               // Calculate position size based on risk
               double buyLots = CalculatePositionSize(_Symbol, buyStopPrice, buySL);
               if(buyLots <= 0)
               {
                  PrintFormat("Invalid position size calculated for buy stop order");
                  return;
               }

               MqlTradeRequest buyRequest;
               MqlTradeResult buyResult;
               ZeroMemory(buyRequest);
               ZeroMemory(buyResult);

               buyRequest.action = TRADE_ACTION_PENDING;
               buyRequest.symbol = _Symbol;
               buyRequest.volume = buyLots;  // Use calculated position size
               buyRequest.type = ORDER_TYPE_BUY_STOP;
               buyRequest.price = buyStopPrice;
               buyRequest.sl = buySL;
               buyRequest.tp = buyTP;
               buyRequest.magic = InpMagicNumber;
               buyRequest.comment = "RohitEA Beta";
               buyRequest.type_filling = GetSupportedFillingMode(_Symbol);

               if(!IsSpreadAcceptable()) return;
               if(SendDollarExitAwareOrder(buyRequest, buyResult))
               {
                  g_buyStopTicket = buyResult.order;
                  PrintFormat("Placed buy stop order #%d at %.5f, Lots=%.2f", g_buyStopTicket, buyStopPrice, buyLots);
                  // Record signal time to prevent duplicates
                  g_lastSignalTime = current_bar_time;
               }
               else
               {
                  PrintFormat("Failed to place buy stop order. Error: %d", GetLastError());
               }
            }
         }
      }
   }

   // Place sell stop order if needed
   if(shouldUpdateSell)
   {
      if(InpReverseSignal) // --- REVERSED LOGIC (BUY LIMIT) ---
      {
         if(InpTradeDirection == TRADE_DIR_SELL_ONLY)
         {
            PrintFormat("Pattern 2: Reversed BUY action blocked by Trade Direction Filter (SELL ONLY)");
         }
         else
         {
            Print("Signal Reversal is ON. Placing BUY LIMIT to fade breakout.");
            double buyLimitPrice = sellStopPrice;
            if(ValidateAndAdjustPrice(_Symbol, buyLimitPrice, ORDER_TYPE_BUY_LIMIT))
            {
               double buySL = buyLimitPrice - (atr * InpAtrMultiplierSL);
               double buyTP = buyLimitPrice + (atr * InpAtrMultiplierTP);
               double buyLots = CalculatePositionSize(_Symbol, buyLimitPrice, buySL);
               if(buyLots > 0)
               {
                  MqlTradeRequest request; MqlTradeResult result; ZeroMemory(request); ZeroMemory(result);
                  request.action = TRADE_ACTION_PENDING;
                  request.symbol = _Symbol;
                  request.volume = buyLots;
                  request.type = ORDER_TYPE_BUY_LIMIT;
                  request.price = buyLimitPrice;
                  request.sl = buySL;
                  request.tp = buyTP;
                  request.magic = InpMagicNumber;
                  request.comment = "RohitEA Delta";
                  if(!IsSpreadAcceptable()) return;
                  if(SendDollarExitAwareOrder(request, result)) { g_buyStopTicket = result.order; PrintFormat("Placed reversed buy limit order #%d at %.5f", g_buyStopTicket, buyLimitPrice); g_lastSignalTime = current_bar_time; }
                  else { PrintFormat("Failed to place reversed buy limit. Error: %d", GetLastError()); }
               }
            }
         }
      }
      else // --- ORIGINAL LOGIC (SELL STOP) ---
      {
         if(InpTradeDirection == TRADE_DIR_BUY_ONLY)
         {
            PrintFormat("Pattern 2: SELL action blocked by Trade Direction Filter (BUY ONLY)");
         }
         else
         {
            if(ValidateAndAdjustPrice(_Symbol, sellStopPrice, ORDER_TYPE_SELL_STOP))
            {
               double sellSL = sellStopPrice + (atr * InpAtrMultiplierSL);
               double sellTP = sellStopPrice - (atr * InpAtrMultiplierTP);

               // Calculate position size based on risk
               double sellLots = CalculatePositionSize(_Symbol, sellStopPrice, sellSL);
               if(sellLots <= 0)
               {
                  PrintFormat("Invalid position size calculated for sell stop order");
                  return;
               }

               MqlTradeRequest sellRequest;
               MqlTradeResult sellResult;
               ZeroMemory(sellRequest);
               ZeroMemory(sellResult);

               sellRequest.action = TRADE_ACTION_PENDING;
               sellRequest.symbol = _Symbol;
               sellRequest.volume = sellLots;  // Use calculated position size
               sellRequest.type = ORDER_TYPE_SELL_STOP;
               sellRequest.price = sellStopPrice;
               sellRequest.sl = sellSL;
               sellRequest.tp = sellTP;
               sellRequest.magic = InpMagicNumber;
               sellRequest.comment = "RohitEA Epsilon";
               sellRequest.type_filling = GetSupportedFillingMode(_Symbol);

               if(!IsSpreadAcceptable()) return;
               if(SendDollarExitAwareOrder(sellRequest, sellResult))
               {
                  g_sellStopTicket = sellResult.order;
                  PrintFormat("Placed sell stop order #%d at %.5f, Lots=%.2f", g_sellStopTicket, sellStopPrice, sellLots);
                  // Record signal time to prevent duplicates
                  g_lastSignalTime = current_bar_time;
               }
               else
               {
                  PrintFormat("Failed to place sell stop order. Error: %d", GetLastError());
               }
            }
         }
      }
   }

   g_lastOrderTime = TimeCurrent();
}

//+------------------------------------------------------------------+
//| Handle Pattern 3 - Pivot Point Breakout                          |
//+------------------------------------------------------------------+
void HandlePattern3()
{
   // Get current bar time to prevent duplicate signals
   datetime current_bar_time = iTime(_Symbol, _Period, 0);

   // Check if we've already processed a signal for this bar
   if(current_bar_time == g_lastSignalTime)
   {
      PrintFormat("Signal already processed for current bar at %s. Skipping.", TimeToString(current_bar_time));
      return;
   }

   // First cancel ALL pending orders in the account - This ensures we only have the latest orders
   CancelAllPendingOrders();

   // Reset Pattern 3 order tickets
   g_p3_buyStopTicket = 0;
   g_p3_sellStopTicket = 0;

   // --- PIVOT LOGIC IMPLEMENTATION (Efficient Method) ---
   // NOTE: InpPattern2Bars is used here as the number of bars on EACH side of the pivot.
   // For this pattern to work, set InpPattern2Bars to a small number (e.g., 3-10).
   int barsOnEachSide = InpPattern2Bars;
   int searchDepth = 200; // How many bars back to search for a pivot point.

   if(barsOnEachSide <= 0)
   {
      PrintFormat("Pattern 3: 'Number of bars to check' must be > 0. It is currently %d.", barsOnEachSide);
      return;
   }

   if(Bars(_Symbol, _Period) < searchDepth || Bars(_Symbol, _Period) < (barsOnEachSide * 2 + 1))
   {
       PrintFormat("Pattern 3: Not enough bars on chart for pivot search with %d bars on each side.", barsOnEachSide);
       return;
   }

   // --- Find Most Recent Pivot High ---
   double pivotHighPrice = 0;
   // Start search from index `barsOnEachSide` to ensure there are enough bars to the left (newer bars).
   // The range for iHighest/iLowest starts from `i - barsOnEachSide`, so we check if the bar `i` is the pivot.
   for(int i = barsOnEachSide; i < searchDepth; i++)
   {
       // Find the index of the highest bar in the range [i - barsOnEachSide, i + barsOnEachSide]
       int highestBarIndex = iHighest(_Symbol, _Period, MODE_HIGH, barsOnEachSide * 2 + 1, i - barsOnEachSide);

       // If the highest bar in the range is our current candidate bar `i`, it's a pivot high.
       if(highestBarIndex == i)
       {
           pivotHighPrice = iHigh(_Symbol, _Period, i);
           PrintFormat("Pattern 3: Found Pivot High at bar index %d, Price: %.5f", i, pivotHighPrice);
           break; // Found the most recent pivot, stop searching.
       }
   }

   // --- Find Most Recent Pivot Low ---
   double pivotLowPrice = 0;
   for(int i = barsOnEachSide; i < searchDepth; i++)
   {
       // Find the index of the lowest bar in the range [i - barsOnEachSide, i + barsOnEachSide]
       int lowestBarIndex = iLowest(_Symbol, _Period, MODE_LOW, barsOnEachSide * 2 + 1, i - barsOnEachSide);

       // If the lowest bar in the range is our current candidate bar `i`, it's a pivot low.
       if(lowestBarIndex == i)
       {
           pivotLowPrice = iLow(_Symbol, _Period, i);
           PrintFormat("Pattern 3: Found Pivot Low at bar index %d, Price: %.5f", i, pivotLowPrice);
           break; // Found the most recent pivot, stop searching.
       }
   }

   if (pivotHighPrice == 0 && pivotLowPrice == 0)
   {
      PrintFormat("Pattern 3: No valid pivot points found with %d bars on each side in the last %d bars.", barsOnEachSide, searchDepth);
      return;
   }

   // Calculate ATR for SL/TP
   double atr_values[];
   if(CopyBuffer(iATR(_Symbol, _Period, InpAtrPeriod), 0, 1, 1, atr_values) <= 0)
   {
      PrintFormat("Could not get ATR value. Error %d", GetLastError());
      return;
   }
   double atr = atr_values[0];

   if(InpReverseSignal)
   {
       // --- REVERSED LOGIC (Fading/Limit Orders) ---
       Print("Signal Reversal is ON. Placing LIMIT orders to fade breakouts.");

       // Place SELL LIMIT at Pivot High
       if(pivotHighPrice > 0)
       {
           if(InpTradeDirection == TRADE_DIR_BUY_ONLY)
           {
               PrintFormat("Pattern 3: Reversed SELL action blocked by Trade Direction Filter (BUY ONLY)");
           }
           else
           {
               double sellLimitPrice = pivotHighPrice;
               if(ValidateAndAdjustPrice(_Symbol, sellLimitPrice, ORDER_TYPE_SELL_LIMIT))
               {
                   double sellSL = sellLimitPrice + (atr * InpAtrMultiplierSL);
                   double sellTP = sellLimitPrice - (atr * InpAtrMultiplierTP);
                   double lots = CalculatePositionSize(_Symbol, sellLimitPrice, sellSL);
                   if(lots > 0)
                   {
                       MqlTradeRequest request; MqlTradeResult result; ZeroMemory(request); ZeroMemory(result);
                       request.action = TRADE_ACTION_PENDING;
                       request.symbol = _Symbol;
                       request.volume = lots;
                       request.type = ORDER_TYPE_SELL_LIMIT;
                       request.price = sellLimitPrice;
                       request.sl = sellSL;
                       request.tp = sellTP;
                       request.magic = InpMagicNumber;
                       request.comment = "RohitEA Zeta";
                       if(!IsSpreadAcceptable()) return;
                       if(SendDollarExitAwareOrder(request, result)) { g_p3_sellStopTicket = result.order; PrintFormat("Pattern 3: Placed reversed sell limit #%d at %.5f", g_p3_sellStopTicket, sellLimitPrice); g_lastSignalTime = current_bar_time; }
                       else { PrintFormat("Pattern 3: Failed to place reversed sell limit. Error: %d", GetLastError()); }
                   }
               }
           }
       }

       // Place BUY LIMIT at Pivot Low
       if(pivotLowPrice > 0)
       {
           if(InpTradeDirection == TRADE_DIR_SELL_ONLY)
           {
               PrintFormat("Pattern 3: Reversed BUY action blocked by Trade Direction Filter (SELL ONLY)");
           }
           else
           {
               double buyLimitPrice = pivotLowPrice;
               if(ValidateAndAdjustPrice(_Symbol, buyLimitPrice, ORDER_TYPE_BUY_LIMIT))
               {
                   double buySL = buyLimitPrice - (atr * InpAtrMultiplierSL);
                   double buyTP = buyLimitPrice + (atr * InpAtrMultiplierTP);
                   double lots = CalculatePositionSize(_Symbol, buyLimitPrice, buySL);
                   if(lots > 0)
                   {
                       MqlTradeRequest request; MqlTradeResult result; ZeroMemory(request); ZeroMemory(result);
                       request.action = TRADE_ACTION_PENDING;
                       request.symbol = _Symbol;
                       request.volume = lots;
                       request.type = ORDER_TYPE_BUY_LIMIT;
                       request.price = buyLimitPrice;
                       request.sl = buySL;
                       request.tp = buyTP;
                       request.magic = InpMagicNumber;
                       request.comment = "RohitEA Eta";
                       if(!IsSpreadAcceptable()) return;
                       if(SendDollarExitAwareOrder(request, result)) { g_p3_buyStopTicket = result.order; PrintFormat("Pattern 3: Placed reversed buy limit #%d at %.5f", g_p3_buyStopTicket, buyLimitPrice); g_lastSignalTime = current_bar_time; }
                       else { PrintFormat("Pattern 3: Failed to place reversed buy limit. Error: %d", GetLastError()); }
                   }
               }
           }
       }
   }
   else
   {
       // --- ORIGINAL LOGIC (Breakout/Stop Orders) ---
       // --- Place Buy Stop Order ---
       if(pivotHighPrice > 0)
       {
           if(InpTradeDirection == TRADE_DIR_SELL_ONLY)
           {
               PrintFormat("Pattern 3: BUY action blocked by Trade Direction Filter (SELL ONLY)");
           }
           else
           {
               double buyStopPrice = pivotHighPrice;
               if(ValidateAndAdjustPrice(_Symbol, buyStopPrice, ORDER_TYPE_BUY_STOP))
               {
                  double buySL = buyStopPrice - (atr * InpAtrMultiplierSL);
                  double buyTP = buyStopPrice + (atr * InpAtrMultiplierTP);

                  double buyLots = CalculatePositionSize(_Symbol, buyStopPrice, buySL);
                  if(buyLots > 0)
                  {
                     MqlTradeRequest buyRequest;
                     MqlTradeResult buyResult;
                     ZeroMemory(buyRequest);
                     ZeroMemory(buyResult);

                     buyRequest.action = TRADE_ACTION_PENDING;
                     buyRequest.symbol = _Symbol;
                     buyRequest.volume = buyLots;
                     buyRequest.type = ORDER_TYPE_BUY_STOP;
                     buyRequest.price = buyStopPrice;
                     buyRequest.sl = buySL;
                     buyRequest.tp = buyTP;
                     buyRequest.magic = InpMagicNumber;
                     buyRequest.comment = "RohitEA Theta";
                     buyRequest.type_filling = GetSupportedFillingMode(_Symbol);

                     if(!IsSpreadAcceptable()) return;
                     if(SendDollarExitAwareOrder(buyRequest, buyResult))
                     {
                        g_p3_buyStopTicket = buyResult.order;
                        PrintFormat("Pattern 3: Placed pivot buy stop order #%d at %.5f, Lots=%.2f",
                              g_p3_buyStopTicket, buyStopPrice, buyLots);
                        g_lastSignalTime = current_bar_time;
                     }
                     else
                     {
                        PrintFormat("Pattern 3: Failed to place pivot buy stop order. Error: %d", GetLastError());
                     }
                  }
                  else
                  {
                     PrintFormat("Pattern 3: Invalid position size calculated for buy stop order");
                  }
               }
           }
       }

       // --- Place Sell Stop Order ---
       if(pivotLowPrice > 0)
       {
           if(InpTradeDirection == TRADE_DIR_BUY_ONLY)
           {
               PrintFormat("Pattern 3: SELL action blocked by Trade Direction Filter (BUY ONLY)");
           }
           else
           {
               double sellStopPrice = pivotLowPrice;
               if(ValidateAndAdjustPrice(_Symbol, sellStopPrice, ORDER_TYPE_SELL_STOP))
               {
                  double sellSL = sellStopPrice + (atr * InpAtrMultiplierSL);
                  double sellTP = sellStopPrice - (atr * InpAtrMultiplierTP);

                  double sellLots = CalculatePositionSize(_Symbol, sellStopPrice, sellSL);
                  if(sellLots > 0)
                  {
                     MqlTradeRequest sellRequest;
                     MqlTradeResult sellResult;
                     ZeroMemory(sellRequest);
                     ZeroMemory(sellResult);

                     sellRequest.action = TRADE_ACTION_PENDING;
                     sellRequest.symbol = _Symbol;
                     sellRequest.volume = sellLots;
                     sellRequest.type = ORDER_TYPE_SELL_STOP;
                     sellRequest.price = sellStopPrice;
                     sellRequest.sl = sellSL;
                     sellRequest.tp = sellTP;
                     sellRequest.magic = InpMagicNumber;
                     sellRequest.comment = "RohitEA Iota";
                     sellRequest.type_filling = GetSupportedFillingMode(_Symbol);

                     if(!IsSpreadAcceptable()) return;
                     if(SendDollarExitAwareOrder(sellRequest, sellResult))
                     {
                        g_p3_sellStopTicket = sellResult.order;
                        PrintFormat("Pattern 3: Placed pivot sell stop order #%d at %.5f, Lots=%.2f",
                                    g_p3_sellStopTicket, sellStopPrice, sellLots);
                        g_lastSignalTime = current_bar_time;
                     }
                     else
                     {
                        PrintFormat("Pattern 3: Failed to place pivot sell stop order. Error: %d", GetLastError());
                     }
                  }
                  else
                  {
                     PrintFormat("Pattern 3: Invalid position size calculated for sell stop order");
                  }
               }
           }
       }
   }
}

