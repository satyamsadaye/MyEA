//+------------------------------------------------------------------+
//| Cancel ALL pending orders in the account (except DCA orders)     |
//+------------------------------------------------------------------+
void CancelAllPendingOrders()
{
   int total_orders = OrdersTotal();

   if(total_orders == 0) return; // No orders to cancel

   PrintFormat("Cancelling non-DCA pending orders in the account (total: %d)", total_orders);

   int cancelled_count = 0;
   int dca_skipped_count = 0;

   // Need to use this approach as OrdersTotal() can change while we're processing
   for(int i = total_orders - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket <= 0) continue;

      // Check if this is a DCA order by examining the comment
      if(OrderSelect(ticket))
      {
         string comment = OrderGetString(ORDER_COMMENT);
         // Check if comment starts with "DCA" and contains "-T" and "-M" (DCA order pattern)
         if(StringFind(comment, "DCA") == 0 && StringFind(comment, "-T") > 0 && StringFind(comment, "-M") > 0)
         {
            dca_skipped_count++;
            PrintFormat("Skipping DCA order #%d (comment: %s)", ticket, comment);
            continue; // Skip DCA orders
         }
      }

      MqlTradeRequest request;
      MqlTradeResult result;
      ZeroMemory(request);
      ZeroMemory(result);

      request.action = TRADE_ACTION_REMOVE;
      request.order = ticket;

      if(!SendDollarExitAwareOrder(request, result))
      {
         PrintFormat("Failed to remove order #%d. Error: %d", ticket, GetLastError());
      }
      else
      {
         PrintFormat("Successfully cancelled pending order #%d", ticket);
         cancelled_count++;
      }
   }
   
   PrintFormat("Order cancellation complete: %d cancelled, %d DCA orders preserved", cancelled_count, dca_skipped_count);
}

