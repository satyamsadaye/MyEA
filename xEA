void DrawDCALine(ulong ticket, double price, int order_number)
{
    // Skip drawing during backtesting
    if(g_is_backtesting) return;
    
    string line_name = "DCA_LINE_" + IntegerToString((int)ticket);
    
    // Remove old line if exists
    ObjectDelete(0, line_name);
    
    // Create new line
    if(ObjectCreate(0, line_name, OBJ_HLINE, 0, 0, price))
    {
        ObjectSetInteger(0, line_name, OBJPROP_COLOR, DCA_LINE_COLOR);
        ObjectSetInteger(0, line_name, OBJPROP_WIDTH, DCA_LINE_WIDTH);
        ObjectSetInteger(0, line_name, OBJPROP_STYLE, DCA_LINE_STYLE);
        ObjectSetString(0, line_name, OBJPROP_TOOLTIP, 
                       StringFormat("DCA Order %d #%d: %.5f", order_number, ticket, price));
        
        // Add label
        string label_name = line_name + "_Label";
        ObjectDelete(0, label_name);
        
        datetime label_time = TimeCurrent() + PeriodSeconds(_Period) * 5;
        
        if(ObjectCreate(0, label_name, OBJ_TEXT, 0, label_time, price))
        {
            ObjectSetString(0, label_name, OBJPROP_TEXT, StringFormat("DCA%d", order_number));
            ObjectSetInteger(0, label_name, OBJPROP_COLOR, DCA_LINE_COLOR);
            ObjectSetInteger(0, label_name, OBJPROP_FONTSIZE, 8);
