   // Check for crossovers using previous values
   if(g_macd_prev_main != 0 && g_macd_prev_signal != 0)
   {
      // MACD line crossed above signal line (potential BUY recovery signal)
      if(g_macd_prev_main <= g_macd_prev_signal && main_value > signal_value)
      {
         g_macd_recovery_buy_ready = true;
         PrintFormat("MACD Recovery: BUY signal ready - MACD line crossed above signal (MACD: %.5f > Signal: %.5f)", 
                    main_value, signal_value);
