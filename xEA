// DCA input parameters have been consolidated in the main input section above

double GetEffectiveMinLot(string symbol) {
    double symbol_min = SymbolInfoDouble(symbol, SYMBOL_VOLUME_MIN);
    return (InpMinLot > 0.0) ? MathMax(InpMinLot, symbol_min) : symbol_min;
}

double GetEffectiveMaxLot(string symbol) {
    double symbol_max = SymbolInfoDouble(symbol, SYMBOL_VOLUME_MAX);
    return (InpMaxLot > 0.0) ? MathMin(InpMaxLot, symbol_max) : symbol_max;
}

//+------------------------------------------------------------------+
//| Get appropriate filling mode for the symbol                      |
//+------------------------------------------------------------------+
ENUM_ORDER_TYPE_FILLING GetSupportedFillingMode(string symbol)
{
    int filling_modes = (int)SymbolInfoInteger(symbol, SYMBOL_FILLING_MODE);
    
    // Prefer FOK (Fill or Kill) first
    if((filling_modes & SYMBOL_FILLING_FOK) != 0)
        return ORDER_FILLING_FOK;
    
    // Fall back to IOC (Immediate or Cancel)
    if((filling_modes & SYMBOL_FILLING_IOC) != 0)
        return ORDER_FILLING_IOC;
    
    // Default fallback
    return ORDER_FILLING_RETURN;
}

//+------------------------------------------------------------------+
//|                    DCA PROTECTION FUNCTIONS                      |
//+------------------------------------------------------------------+

//+------------------------------------------------------------------+
//| Create DCA protection orders for a main trade                    |
//+------------------------------------------------------------------+
void CreateDCAOrders(ulong main_ticket)
{
    if(!InpDCAEnabled) return;
    
    // Validate input parameters
    if(InpDCAOrderCount < 1 || InpDCAOrderCount > 10)
    {
        PrintFormat("DCA: Invalid order count %d. Must be between 1 and 10.", InpDCAOrderCount);
        return;
    }
    
    if(!PositionSelectByTicket(main_ticket))
    {
        PrintFormat("DCA: Cannot select main trade ticket %d", main_ticket);
        return;
    }
    
    // Get main trade details
    string symbol = PositionGetString(POSITION_SYMBOL);
    ENUM_POSITION_TYPE main_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
    double main_entry = PositionGetDouble(POSITION_PRICE_OPEN);
    double main_sl = PositionGetDouble(POSITION_SL);
    double main_lot = PositionGetDouble(POSITION_VOLUME);
    
    if(main_sl == 0)
    {
        PrintFormat("DCA: Main trade #%d has no stop loss. Cannot place DCA orders.", main_ticket);
        return;
    }
    
    // Get current ATR
    double atr = GetATRValue();
    if(atr <= 0)
    {
        PrintFormat("DCA: Cannot get ATR value for DCA orders.");
        return;
    }
    
    // Create new DCA group
    DCAGroup new_group;
    ZeroMemory(new_group);
    new_group.main_ticket = main_ticket;
    new_group.symbol = symbol;
    new_group.main_type = main_type;
    new_group.main_entry = main_entry;
    new_group.main_sl = main_sl;
    new_group.main_lot = main_lot;
    new_group.active = true;
    new_group.created_time = TimeCurrent();
    new_group.dca_count = 0;
    
    // Calculate starting price for DCA orders (distance from main entry)
    double start_distance = InpDCAStartDistanceATR * atr;
    double order_spacing = InpDCAOrderSpacingATR * atr;
    
    double dca_start_price;
    ENUM_ORDER_TYPE dca_order_type;
    
    // For BUY main trade, place SELL STOP orders BELOW main entry (protect against downtrend)
    // For SELL main trade, place BUY STOP orders ABOVE main entry (protect against uptrend)
    if(main_type == POSITION_TYPE_BUY)
    {
        dca_start_price = main_entry - start_distance;
        dca_order_type = ORDER_TYPE_SELL_STOP;
    }
    else // SELL main trade
    {
        dca_start_price = main_entry + start_distance;
        dca_order_type = ORDER_TYPE_BUY_STOP;
    }
    
    PrintFormat("DCA: Creating %d protection orders for %s main trade #%d (DCA Trade Group #%d)", 
                InpDCAOrderCount, EnumToString(main_type), main_ticket, g_dca_trade_counter + 1);
    PrintFormat("DCA: Main entry: %.5f, Start price: %.5f, Spacing: %.5f", 
                main_entry, dca_start_price, order_spacing);
    
    // Place DCA orders
    for(int i = 0; i < InpDCAOrderCount; i++)
    {
        double order_price = dca_start_price;
        if(main_type == POSITION_TYPE_BUY)
            order_price -= (i * order_spacing); // Move further DOWN from SL (protect against downtrend)
        else
            order_price += (i * order_spacing); // Move further UP from SL (protect against uptrend)
            
        // Calculate lot size for this DCA order
        double dca_lot = main_lot;
        if(InpDCAIncreaseLot)
        {
            // Apply multiplier progressively: order 1 = main_lot * multiplier, order 2 = main_lot * multiplier^2, etc.
            dca_lot = main_lot * MathPow(InpDCALotMultiplier, i);
            PrintFormat("DCA Order %d: Main lot %.2f * Multiplier %.2f^%d = %.2f", 
                       i, main_lot, InpDCALotMultiplier, i, dca_lot);
        }
        else
        {
            // Fixed multiplier for all DCA orders
            dca_lot = main_lot * InpDCALotMultiplier;
            PrintFormat("DCA Order %d: Main lot %.2f * Fixed multiplier %.2f = %.2f", 
                       i, main_lot, InpDCALotMultiplier, dca_lot);
        }
            
        // Normalize lot size
        dca_lot = NormalizeLotSize(symbol, dca_lot);
        
        // Calculate TP for DCA order if enabled
        double dca_tp = 0;
        if(InpDCAUseTP)
        {
            if(dca_order_type == ORDER_TYPE_SELL_STOP)
                dca_tp = order_price - (InpDCATPMultiplier * atr);
            else // ORDER_TYPE_BUY_STOP
                dca_tp = order_price + (InpDCATPMultiplier * atr);
        }
        
        // Place the DCA order
        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);
        
        request.action = TRADE_ACTION_PENDING;
        request.symbol = symbol;
        request.volume = dca_lot;
        request.type = dca_order_type;
        request.price = order_price;
        request.sl = 0; // No SL for DCA orders
        request.tp = dca_tp;
        request.deviation = InpMaxSlippagePoints;
        request.magic = InpMagicNumber;
        request.comment = StringFormat("DCA%d-T%d-M%d", i+1, g_dca_trade_counter + 1, main_ticket);
        request.type_filling = GetSupportedFillingMode(_Symbol);
        
        if(!IsSpreadAcceptable()) return;
        if(SendDollarExitAwareOrder(request, result))
        {
            new_group.dca_tickets[new_group.dca_count] = result.order;
            new_group.dca_count++;
            
            PrintFormat("DCA: Placed %s protection order #%d at %.5f for Main Trade #%d, Lot: %.2f, TP: %.5f", 
                       EnumToString(dca_order_type), result.order, order_price, main_ticket, dca_lot, dca_tp);
                       
            // Draw visual line for the DCA order
            DrawDCALine(result.order, order_price, i+1);
        }
        else
        {
            PrintFormat("DCA: Failed to place order %d. Error: %d", i+1, GetLastError());
        }
    }
    
    // Add the group to the array if any orders were placed
    if(new_group.dca_count > 0)
    {
        g_dca_trade_counter++; // Increment counter for next DCA trade
        int current_size = ArraySize(DCAGroups);
        ArrayResize(DCAGroups, current_size + 1);
        DCAGroups[current_size] = new_group;
        
        PrintFormat("DCA: Created Trade Group #%d with %d orders for main trade #%d", 
                   g_dca_trade_counter, new_group.dca_count, main_ticket);
    }
}

//+------------------------------------------------------------------+
//| Normalize lot size according to symbol specifications            |
//+------------------------------------------------------------------+
double NormalizeLotSize(string symbol, double lot)
{
    double min_lot = GetEffectiveMinLot(symbol);
    double max_lot = GetEffectiveMaxLot(symbol);
    double lot_step = SymbolInfoDouble(symbol, SYMBOL_VOLUME_STEP);
    
    lot = MathMax(min_lot, lot);
    lot = MathMin(max_lot, lot);
    
    if(lot_step > 0)
        lot = MathFloor(lot / lot_step) * lot_step;
        
    return NormalizeDouble(lot, 2);
}

//+------------------------------------------------------------------+
//| Process DCA groups - check for main trade closure               |
//+------------------------------------------------------------------+
void ProcessDCAGroups()
{
    if(!InpDCAEnabled) return;
    
    for(int i = ArraySize(DCAGroups) - 1; i >= 0; i--)
    {
        // Check if main trade still exists
        if(!PositionSelectByTicket(DCAGroups[i].main_ticket))
        {
            // Main trade closed - cancel all DCA orders and remove group
            PrintFormat("DCA: Main trade #%d exited. Cancelling %d DCA orders.", 
                       DCAGroups[i].main_ticket, DCAGroups[i].dca_count);
            CancelDCAOrders(DCAGroups[i]);
            RemoveDCAGroup(i);
            continue;
        }
        
        // Main trade is still running - keep DCA orders active for protection
        
        // Check status of DCA orders and remove filled/cancelled ones
        for(int j = DCAGroups[i].dca_count - 1; j >= 0; j--)
        {
            ulong dca_ticket = DCAGroups[i].dca_tickets[j];
            if(dca_ticket > 0)
            {
                // Check if DCA order still exists as pending order
                if(!OrderSelect(dca_ticket))
                {
                    // Order no longer exists - check if it was filled by checking for a deal
                    bool order_was_filled = false;
                    
                    // Check if this order was executed by checking recent deals
                    if(HistorySelect(TimeCurrent() - 3600, TimeCurrent())) // Check last hour
                    {
                        int total_deals = HistoryDealsTotal();
                        for(int deal_idx = total_deals - 1; deal_idx >= 0; deal_idx--)
                        {
                            ulong deal_ticket = HistoryDealGetTicket(deal_idx);
                            if(HistoryDealGetInteger(deal_ticket, DEAL_ORDER) == dca_ticket)
                            {
                                order_was_filled = true;
                                double deal_profit = HistoryDealGetDouble(deal_ticket, DEAL_PROFIT);
                                string deal_comment = HistoryDealGetString(deal_ticket, DEAL_COMMENT);
                                
                                if(deal_profit > 0)
                                    PrintFormat("DCA TP Hit: Order #%d executed with profit %.2f for Main Trade #%d", 
                                               dca_ticket, deal_profit, DCAGroups[i].main_ticket);
                                else
                                    PrintFormat("DCA Order Filled: Order #%d executed for Main Trade #%d", 
                                               dca_ticket, DCAGroups[i].main_ticket);
                                break;
                            }
                        }
                    }
                    
                    if(!order_was_filled)
                    {
                        PrintFormat("DCA: Order #%d was cancelled or expired for Main Trade #%d", 
                                   dca_ticket, DCAGroups[i].main_ticket);
                    }
                    
                    // Clean up visual line
                    CleanupDCALine(dca_ticket);
                    
                    // Remove from array by shifting remaining orders
                    for(int k = j; k < DCAGroups[i].dca_count - 1; k++)
                    {
                        DCAGroups[i].dca_tickets[k] = DCAGroups[i].dca_tickets[k + 1];
                    }
                    DCAGroups[i].dca_count--;
                }
            }
        }
        
        // If no DCA orders remain, remove the group
        if(DCAGroups[i].dca_count == 0)
        {
            PrintFormat("DCA: No DCA orders remain for main trade #%d. Removing group.", DCAGroups[i].main_ticket);
            RemoveDCAGroup(i);
        }
    }
}

//+------------------------------------------------------------------+
//| Force cleanup of orphan DCA orders AND positions (no main trade exists) |
//+------------------------------------------------------------------+
void CleanupOrphanDCAOrders()
{
    if(!InpDCAEnabled) return;
    
    // Rate limiting - only run cleanup every few seconds to prevent spam
    datetime current_time = TimeCurrent();
    if(current_time - g_last_orphan_cleanup_time < ORPHAN_CLEANUP_INTERVAL_SECONDS)
        return;
    
    g_last_orphan_cleanup_time = current_time;
    
    int total_orders = OrdersTotal();
    int total_positions = PositionsTotal();
    int orphan_orders_cancelled = 0;
    int orphan_positions_closed = 0;
    
    // 1. Check all pending orders for orphan DCA orders
    for(int i = total_orders - 1; i >= 0; i--)
    {
        ulong ticket = OrderGetTicket(i);
        if(ticket <= 0) continue;
        
        if(OrderSelect(ticket))
        {
            string comment = OrderGetString(ORDER_COMMENT);
            // Check if this is a DCA order
            if(StringFind(comment, "DCA") == 0 && StringFind(comment, "-T") > 0 && StringFind(comment, "-M") > 0)
            {
                // Extract main trade ticket from comment (format: DCA1-T1-M12345)
                int m_pos = StringFind(comment, "-M");
                if(m_pos > 0)
                {
                    string main_ticket_str = StringSubstr(comment, m_pos + 2);
                    ulong main_ticket = (ulong)StringToInteger(main_ticket_str);
                    
                    // Check if main trade still exists
                    if(!PositionSelectByTicket(main_ticket))
                    {
                        // Main trade doesn't exist - this is an orphan DCA order
                        MqlTradeRequest request;
                        MqlTradeResult result;
                        ZeroMemory(request);
                        ZeroMemory(result);
                        
                        request.action = TRADE_ACTION_REMOVE;
                        request.order = ticket;
                        
                        if(!IsSpreadAcceptable()) return;
                        if(SendDollarExitAwareOrder(request, result))
                        {
                            PrintFormat("ORPHAN CLEANUP: Cancelled orphan DCA order #%d (Main Trade #%d no longer exists)", 
                                       ticket, main_ticket);
                            orphan_orders_cancelled++;
                            
                            // Clean up visual line
                            CleanupDCALine(ticket);
                        }
                        else
                        {
                            PrintFormat("ORPHAN CLEANUP: Failed to cancel orphan DCA order #%d. Error: %d", 
                                       ticket, GetLastError());
                        }
                    }
                }
            }
        }
    }
    
    // 2. Check all open positions for orphan DCA positions
    for(int i = total_positions - 1; i >= 0; i--)
    {
        ulong ticket = PositionGetTicket(i);
        if(ticket <= 0) continue;
        
        if(PositionSelectByTicket(ticket))
        {
            // Only check positions with our magic number
            if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
            
            string comment = PositionGetString(POSITION_COMMENT);
            // Check if this is an executed DCA position
            if(StringFind(comment, "DCA") == 0 && StringFind(comment, "-T") > 0 && StringFind(comment, "-M") > 0)
            {
                // Extract main trade ticket from comment (format: DCA1-T1-M12345)
                int m_pos = StringFind(comment, "-M");
                if(m_pos > 0)
                {
                    string main_ticket_str = StringSubstr(comment, m_pos + 2);
                    ulong main_ticket = (ulong)StringToInteger(main_ticket_str);
                    
                    // Check if main trade still exists
                    if(!PositionSelectByTicket(main_ticket))
                    {
                        // Re-select the orphan DCA position to get its current details
                        if(!PositionSelectByTicket(ticket))
                        {
                            PrintFormat("ORPHAN CLEANUP: Cannot re-select DCA position #%d for closure", ticket);
                            continue;
                        }
                        
                        // Main trade doesn't exist - this is an orphan DCA position
                        if(ForceClosePosition(ticket, "ORPHAN DCA CLEANUP"))
                        {
                            PrintFormat("ORPHAN CLEANUP: Closed orphan DCA position #%d (Main Trade #%d no longer exists)", 
                                       ticket, main_ticket);
                            orphan_positions_closed++;
                        }
                    }
                }
            }
        }
    }
    
    if(orphan_orders_cancelled > 0 || orphan_positions_closed > 0)
    {
        PrintFormat("ORPHAN CLEANUP: Cancelled %d orphan DCA orders, Closed %d orphan DCA positions", 
                   orphan_orders_cancelled, orphan_positions_closed);
    }
}
//+------------------------------------------------------------------+
//| Force close position using enhanced methods with comprehensive retries |
//+------------------------------------------------------------------+
bool ForceClosePosition(ulong ticket, string reason = "Force close")
{
    // Initial check - position might already be closed
    if(!PositionSelectByTicket(ticket))
    {
        PrintFormat("%s: Position #%d no longer exists (already closed)", reason, ticket);
        return true; // Position already closed - success
    }
    
    string symbol = PositionGetString(POSITION_SYMBOL);
    double volume = PositionGetDouble(POSITION_VOLUME);
    ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
    
    PrintFormat("%s: Starting enhanced closure of position #%d (%s %.2f lots on %s)", 
               reason, ticket, pos_type == POSITION_TYPE_BUY ? "BUY" : "SELL", volume, symbol);
    
    // Method 1: Standard close with retry logic
    for(int attempt = 1; attempt <= 3; attempt++)
    {
        // Re-check if position still exists before each attempt
        if(!PositionSelectByTicket(ticket))
        {
            PrintFormat("%s: Position #%d closed during attempt %d (SUCCESS)", reason, ticket, attempt);
            CleanupPositionChartObjects(ticket);
            return true;
        }
        
        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);
        
        request.action = TRADE_ACTION_DEAL;
        request.symbol = symbol;
        request.volume = volume;
        request.position = ticket;
        request.magic = InpMagicNumber;
        request.deviation = InpMaxSlippagePoints;
        request.comment = StringFormat("Force Close (%s)", reason);
        request.type_filling = GetSupportedFillingMode(symbol);
        
        if(pos_type == POSITION_TYPE_BUY)
        {
            request.type = ORDER_TYPE_SELL;
            request.price = SymbolInfoDouble(symbol, SYMBOL_BID);
        }
        else
        {
            request.type = ORDER_TYPE_BUY;
            request.price = SymbolInfoDouble(symbol, SYMBOL_ASK);
        }
        
        if(IsSpreadAcceptable() && SendDollarExitAwareOrder(request, result))
        {
            PrintFormat("%s: Successfully closed position #%d on standard attempt %d", reason, ticket, attempt);
            CleanupPositionChartObjects(ticket);
            return true;
        }
        
        int error_code = GetLastError();
        PrintFormat("%s: Standard close attempt %d failed for position #%d. Error: %d", 
                   reason, attempt, ticket, error_code);
        
        if(attempt < 3) Sleep(200); // Wait before next attempt
    }
    
    // Method 2: Alternative filling modes
    ENUM_ORDER_TYPE_FILLING filling_modes[] = {ORDER_FILLING_FOK, ORDER_FILLING_IOC, ORDER_FILLING_RETURN};
    string filling_names[] = {"FOK", "IOC", "RETURN"};
    
    for(int mode_idx = 0; mode_idx < 3; mode_idx++)
    {
        // Re-check position existence
        if(!PositionSelectByTicket(ticket))
        {
            PrintFormat("%s: Position #%d closed during %s filling attempt (SUCCESS)", 
                       reason, ticket, filling_names[mode_idx]);
            CleanupPositionChartObjects(ticket);
            return true;
        }
        
        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);
        
        request.action = TRADE_ACTION_DEAL;
        request.symbol = symbol;
        request.volume = volume;
        request.position = ticket;
        request.magic = InpMagicNumber;
        request.deviation = (mode_idx == 2) ? 0 : InpMaxSlippagePoints; // No deviation for RETURN mode
        request.comment = StringFormat("Force Close %s (%s)", filling_names[mode_idx], reason);
        request.type_filling = filling_modes[mode_idx];
        
        if(pos_type == POSITION_TYPE_BUY)
        {
            request.type = ORDER_TYPE_SELL;
            request.price = SymbolInfoDouble(symbol, SYMBOL_BID);
        }
        else
        {
            request.type = ORDER_TYPE_BUY;
            request.price = SymbolInfoDouble(symbol, SYMBOL_ASK);
        }
        
        if(IsSpreadAcceptable() && SendDollarExitAwareOrder(request, result))
        {
            PrintFormat("%s: Successfully closed position #%d using %s filling", 
                       reason, ticket, filling_names[mode_idx]);
            CleanupPositionChartObjects(ticket);
            return true;
        }
        
        PrintFormat("%s: %s filling failed for position #%d. Error: %d", 
                   reason, filling_names[mode_idx], ticket, GetLastError());
        
        Sleep(150); // Brief pause between filling mode attempts
    }
    
    // Method 3: Zero deviation with market prices
    for(int final_attempt = 1; final_attempt <= 2; final_attempt++)
    {
        // Final position check
        if(!PositionSelectByTicket(ticket))
        {
            PrintFormat("%s: Position #%d closed during final attempt %d (SUCCESS)", 
                       reason, ticket, final_attempt);
            CleanupPositionChartObjects(ticket);
            return true;
        }
        
        MqlTradeRequest request;
        MqlTradeResult result;
        ZeroMemory(request);
        ZeroMemory(result);
        
        request.action = TRADE_ACTION_DEAL;
        request.symbol = symbol;
        request.volume = volume;
        request.position = ticket;
        request.magic = InpMagicNumber;
        request.deviation = 0; // No deviation
        request.comment = StringFormat("Force Close Final %d (%s)", final_attempt, reason);
        request.type_filling = ORDER_FILLING_RETURN;
        
        // Get fresh market prices
        if(pos_type == POSITION_TYPE_BUY)
        {
            request.type = ORDER_TYPE_SELL;
            request.price = SymbolInfoDouble(symbol, SYMBOL_BID);
        }
        else
        {
            request.type = ORDER_TYPE_BUY;
            request.price = SymbolInfoDouble(symbol, SYMBOL_ASK);
        }
        
        if(SendDollarExitAwareOrder(request, result))
        {
            PrintFormat("%s: Successfully closed position #%d on final attempt %d (zero deviation)", 
                       reason, ticket, final_attempt);
            CleanupPositionChartObjects(ticket);
            return true;
        }
        
        PrintFormat("%s: Final attempt %d failed for position #%d. Error: %d", 
                   reason, final_attempt, ticket, GetLastError());
        
        if(final_attempt == 1) Sleep(300);
    }
    
    // Final verification - sometimes the position closes but we miss it
    if(!PositionSelectByTicket(ticket))
    {
        PrintFormat("%s: Position #%d is now closed (final verification SUCCESS)", reason, ticket);
        CleanupPositionChartObjects(ticket);
        return true;
    }
    
    // All methods failed
    PrintFormat("%s: CRITICAL FAILURE - Could not close position #%d after all attempts. Manual intervention required!", 
               reason, ticket);
    
    // Log position details for manual intervention
    if(PositionSelectByTicket(ticket))
    {
        PrintFormat("%s: Stubborn position details - Symbol: %s, Type: %s, Volume: %.2f, Profit: %.2f", 
                   reason, symbol, pos_type == POSITION_TYPE_BUY ? "BUY" : "SELL", 
                   volume, PositionGetDouble(POSITION_PROFIT));
    }
    
    return false;
}

