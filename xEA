//+------------------------------------------------------------------+
//| Update HeikinAshi Recovery Ready State                           |
//+------------------------------------------------------------------+
void UpdateHeikinAshiRecoveryReadyState()
{
   if(!InpHARecoveryConfirmationEnabled) return;
   
   datetime current_time = iTime(_Symbol, _Period, 0);
   
   // Skip if we already checked on this bar
   if(current_time == g_ha_recovery_last_check_time)
      return;
   
   g_ha_recovery_last_check_time = current_time;
   
   // Validate input parameter
   int consecutiveRequired = MathMax(1, MathMin(5, InpHARecoveryConsecutiveCandles));
   
   // Need enough bars for analysis (need 1 extra for the setup candle)
   if(Bars(_Symbol, _Period) < consecutiveRequired + 2)
      return;
   
   // NEW LOGIC: Check for proper sequence - setup candle + consecutive pattern
   // For BUY: Need 1 RED candle followed by X consecutive GREEN candles
   // For SELL: Need 1 GREEN candle followed by X consecutive RED candles
   
   bool validBuyPattern = false;
   bool validSellPattern = false;
   
   // Check BUY pattern: RED followed by consecutive GREEN
   HeikinAshiValues setupCandle;
   GetHeikinAshiValues(_Symbol, _Period, consecutiveRequired + 1, setupCandle); // The setup candle
   
   if(setupCandle.haOpen != 0 && setupCandle.haClose != 0) // Valid setup candle
   {
      bool setupIsRed = (setupCandle.haClose < setupCandle.haOpen);
      bool setupIsGreen = (setupCandle.haClose > setupCandle.haOpen);
      
      // Check BUY pattern: RED setup + consecutive GREEN
      if(setupIsRed)
      {
         int consecutiveGreen = 0;
         bool patternBroken = false;
         
         for(int i = consecutiveRequired; i >= 1; i--) // Check from oldest to newest
         {
            HeikinAshiValues ha;
            GetHeikinAshiValues(_Symbol, _Period, i, ha);
            
            if(ha.haOpen == 0 && ha.haClose == 0)
            {
               patternBroken = true;
               break;
            }
            
            bool isGreen = (ha.haClose > ha.haOpen);
            bool isDoji = MathAbs(ha.haClose - ha.haOpen) < (SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 2);
            
            if(isGreen && !isDoji)
            {
               consecutiveGreen++;
            }
            else
            {
               patternBroken = true;
               break;
            }
         }
         
         validBuyPattern = (!patternBroken && consecutiveGreen >= consecutiveRequired);
      }
      
      // Check SELL pattern: GREEN setup + consecutive RED
      if(setupIsGreen)
      {
         int consecutiveRed = 0;
         bool patternBroken = false;
         
         for(int i = consecutiveRequired; i >= 1; i--) // Check from oldest to newest
         {
            HeikinAshiValues ha;
            GetHeikinAshiValues(_Symbol, _Period, i, ha);
            
            if(ha.haOpen == 0 && ha.haClose == 0)
            {
               patternBroken = true;
               break;
            }
            
            bool isRed = (ha.haClose < ha.haOpen);
            bool isDoji = MathAbs(ha.haClose - ha.haOpen) < (SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 2);
            
            if(isRed && !isDoji)
            {
               consecutiveRed++;
            }
            else
            {
               patternBroken = true;
               break;
            }
         }
         
         validSellPattern = (!patternBroken && consecutiveRed >= consecutiveRequired);
      }
   }
   
   // Update global state based on valid patterns
   g_ha_recovery_consecutive_green = validBuyPattern ? consecutiveRequired : 0;
   g_ha_recovery_consecutive_red = validSellPattern ? consecutiveRequired : 0;
   
   // Debug output
   if(!g_is_backtesting)
   {
      // Show detailed pattern analysis
      string candleInfo = "";
      for(int i = consecutiveRequired + 1; i >= 1; i--)
      {
         HeikinAshiValues ha;
         GetHeikinAshiValues(_Symbol, _Period, i, ha);
         
         string candleColor = "X";
         if(ha.haOpen != 0 || ha.haClose != 0)
         {
            if(ha.haClose > ha.haOpen)
            {
               double diff = ha.haClose - ha.haOpen;
               bool isDoji = diff < (SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 2);
               candleColor = isDoji ? "D" : "G";
            }
            else if(ha.haClose < ha.haOpen)
            {
               double diff = ha.haOpen - ha.haClose;
               bool isDoji = diff < (SymbolInfoDouble(_Symbol, SYMBOL_POINT) * 2);
               candleColor = isDoji ? "D" : "R";
            }
            else
            {
               candleColor = "D";
            }
         }
         
         // Mark setup candle with brackets
         if(i == consecutiveRequired + 1)
            candleInfo += "[" + candleColor + "]";
         else
            candleInfo += candleColor;
            
         if(i > 1) candleInfo += ",";
      }
      
      PrintFormat("HA Pattern Analysis [%s]: Pattern=%s, BuyValid=%s, SellValid=%s, Need=%d", 
                  TimeToString(current_time, TIME_MINUTES),
                  candleInfo, 
                  validBuyPattern ? "YES" : "NO",
                  validSellPattern ? "YES" : "NO",
                  consecutiveRequired);
   }
}

//+------------------------------------------------------------------+
//| Check if HeikinAshi confirms BUY recovery                        |
//+------------------------------------------------------------------+
bool IsHeikinAshiConfirmingBuy()
{
   if(!InpHARecoveryConfirmationEnabled)
      return true;
      
   // Update the ready state first
   UpdateHeikinAshiRecoveryReadyState();
   
   int consecutiveRequired = MathMax(1, MathMin(5, InpHARecoveryConsecutiveCandles));
   
   // Check if we have a valid BUY pattern (RED setup + GREEN consecutive)
   bool has_valid_pattern = (g_ha_recovery_consecutive_green >= consecutiveRequired);
   
   // Use static variables to track pattern state and prevent multiple triggers
   static bool pattern_used = false;
   static datetime last_trigger_time = 0;
   static datetime last_pattern_time = 0;
   
   datetime current_time = iTime(_Symbol, _Period, 0);
   bool confirmed = false;
   
   if(has_valid_pattern)
   {
      // Check if this is a NEW pattern (different from last time)
      bool is_new_pattern = (current_time != last_pattern_time);
      
      if(is_new_pattern)
      {
         // Reset the usage flag for new patterns
         pattern_used = false;
         last_pattern_time = current_time;
         
         if(!g_is_backtesting)
         {
            PrintFormat("HeikinAshi BUY: New pattern detected at %s - ready to trigger", 
                       TimeToString(current_time, TIME_MINUTES));
         }
      }
      
      // Only confirm if pattern hasn't been used yet and enough time has passed
      if(!pattern_used && (TimeCurrent() - last_trigger_time >= 300)) // 5 minutes minimum
      {
         confirmed = true;
         pattern_used = true; // Mark this pattern as used
         last_trigger_time = TimeCurrent();
         
         if(!g_is_backtesting)
         {
            PrintFormat("HeikinAshi BUY Recovery: CONFIRMED! Pattern used, next trigger requires new pattern.");
         }
      }
      else
      {
         if(!g_is_backtesting)
         {
            PrintFormat("HeikinAshi BUY Recovery: Pattern available but %s", 
                       pattern_used ? "already used" : "too soon after last trigger");
         }
      }
   }
   else
   {
      // No valid pattern - reset everything
      pattern_used = false;
      last_pattern_time = 0;
      
      if(!g_is_backtesting)
      {
         PrintFormat("HeikinAshi BUY Recovery: No valid pattern - waiting for RED→GREEN sequence");
      }
   }
   
   return confirmed;
}

