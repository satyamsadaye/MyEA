                         g_macd_recovery_sell_ready ? "READY" : "WAITING",
                         g_macd_prev_main, g_macd_prev_signal);
            }
         }
      }
      
      // Load ROC recovery state if enabled
      if(InpROCRecoveryConfirmationEnabled)
      {
         string roc_file_name = GetStateFileName() + ".roc";
         if(FileIsExist(roc_file_name))
         {
            int roc_file_handle = FileOpen(roc_file_name, FILE_READ | FILE_CSV);
            if(roc_file_handle != INVALID_HANDLE)
            {
               FileReadString(roc_file_handle); // Skip header
               FileReadString(roc_file_handle); // Skip header
               FileReadString(roc_file_handle); // Skip header
               g_roc_recovery_buy_ready = (bool)StringToInteger(FileReadString(roc_file_handle));
