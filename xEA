bool IsPattern18ConfirmingRecoveryCore(ulong base_ticket, bool is_buy_recovery, int completed_recoveries)
{
   if(!InpPattern18RecoveryConfirmationEnabled)
      return true;

   ENUM_TIMEFRAMES p18_tf = GetPattern18RecoveryTimeframe();
   if(Bars(_Symbol, p18_tf) < 8)
      return false;

   datetime bar_time = iTime(_Symbol, p18_tf, 1); // last closed bar
   if(bar_time <= 0)
      return false;

   int tracker_idx = FindPattern18RecoveryTrackerIndex(base_ticket, true);
   if(tracker_idx < 0)
      return false;

   bool is_new_closed_bar = (bar_time != ExtPattern18RecoveryTrackers[tracker_idx].last_bar_time);
   if(is_new_closed_bar)
   {
      ExtPattern18RecoveryTrackers[tracker_idx].last_bar_time = bar_time;
      ExtPattern18RecoveryTrackers[tracker_idx].signal_processed = false;
   }

   if(!is_new_closed_bar || ExtPattern18RecoveryTrackers[tracker_idx].signal_processed)
      return false;

   long cv  = (long)iVolume(_Symbol, p18_tf, 1);
   long pv  = (long)iVolume(_Symbol, p18_tf, 2);
   long pv1 = (long)iVolume(_Symbol, p18_tf, 3);
   long pv2 = (long)iVolume(_Symbol, p18_tf, 4);
   long pv3 = (long)iVolume(_Symbol, p18_tf, 5);
   long pv4 = (long)iVolume(_Symbol, p18_tf, 6);
   long pv5 = (long)iVolume(_Symbol, p18_tf, 7);

   bool base_pattern = (cv < pv &&
                        pv < pv1 &&
                        pv1 > pv2 &&
                        pv2 < pv3 &&
                        pv3 > pv4 &&
                        pv4 < pv5);

   if(!ExtPattern18RecoveryTrackers[tracker_idx].locked)
   {
      if(base_pattern)
      {
         ExtPattern18RecoveryTrackers[tracker_idx].locked = true;
         ExtPattern18RecoveryTrackers[tracker_idx].lock_bar_time = bar_time;
         ExtPattern18RecoveryTrackers[tracker_idx].first_greater_found = false;
         ExtPattern18RecoveryTrackers[tracker_idx].first_greater_volume = 0;
         ExtPattern18RecoveryTrackers[tracker_idx].first_greater_bar_time = 0;
      }
      return false;
   }

   if(!ExtPattern18RecoveryTrackers[tracker_idx].first_greater_found)
   {
      if(cv > pv)
      {
         ExtPattern18RecoveryTrackers[tracker_idx].first_greater_found = true;
         ExtPattern18RecoveryTrackers[tracker_idx].first_greater_volume = cv;
         ExtPattern18RecoveryTrackers[tracker_idx].first_greater_bar_time = bar_time;
      }
      return false;
   }

   if(bar_time <= ExtPattern18RecoveryTrackers[tracker_idx].first_greater_bar_time)
      return false;

   if(cv > ExtPattern18RecoveryTrackers[tracker_idx].first_greater_volume)
   {
      ExtPattern18RecoveryTrackers[tracker_idx].first_greater_volume = cv;
      ExtPattern18RecoveryTrackers[tracker_idx].first_greater_bar_time = bar_time;
      return false;
   }

   bool confirmed = (cv < ExtPattern18RecoveryTrackers[tracker_idx].first_greater_volume);
   if(!confirmed)
      return false;

   ExtPattern18RecoveryTrackers[tracker_idx].signal_processed = true;
   ExtPattern18RecoveryTrackers[tracker_idx].locked = false;
   ExtPattern18RecoveryTrackers[tracker_idx].lock_bar_time = 0;
   ExtPattern18RecoveryTrackers[tracker_idx].first_greater_found = false;
   ExtPattern18RecoveryTrackers[tracker_idx].first_greater_volume = 0;
   ExtPattern18RecoveryTrackers[tracker_idx].first_greater_bar_time = 0;

   if(!g_is_backtesting)
   {
