void DeletePattern20Objects()
{
   int total_objects = ObjectsTotal(0);
   for(int i = total_objects - 1; i >= 0; i--)
   {
      string obj_name = ObjectName(0, i);
      if(StringFind(obj_name, PATTERN20_OBJECT_PREFIX) == 0)
         ObjectDelete(0, obj_name);
   }
}

void UpsertPattern20LevelLine()
{
   if(g_is_backtesting)
      return;

   if(!InpPattern20ShowLevel || !g_p20_levelActive || g_p20_firstCandleLow <= 0.0)
   {
      DeletePattern20Objects();
      return;
   }

   string name = PATTERN20_OBJECT_PREFIX + "FIRST_LOW";
   string label = StringFormat("P20 first candle low %.5f", g_p20_firstCandleLow);

   if(ObjectFind(0, name) < 0)
   {
      if(!ObjectCreate(0, name, OBJ_HLINE, 0, 0, g_p20_firstCandleLow))
         return;
   }

   ObjectSetDouble(0, name, OBJPROP_PRICE, g_p20_firstCandleLow);
   ObjectSetInteger(0, name, OBJPROP_COLOR, clrDeepSkyBlue);
   ObjectSetInteger(0, name, OBJPROP_WIDTH, 2);
   ObjectSetInteger(0, name, OBJPROP_STYLE, STYLE_DASH);
   ObjectSetInteger(0, name, OBJPROP_BACK, false);
   ObjectSetInteger(0, name, OBJPROP_SELECTABLE, false);
   ObjectSetInteger(0, name, OBJPROP_HIDDEN, false);
   ObjectSetString(0, name, OBJPROP_TEXT, label);
   ObjectSetString(0, name, OBJPROP_TOOLTIP, label);
}

void UpdatePattern20SetupOnNewClosedBar()
{
   if(!InpPattern20Enabled)
      return;

   datetime closed_bar_time = iTime(_Symbol, _Period, 1);
   if(closed_bar_time <= 0 || closed_bar_time == g_p20_lastClosedBarTime)
      return;

   g_p20_lastClosedBarTime = closed_bar_time;

   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   int copied = CopyRates(_Symbol, _Period, 1, 3, rates);
   if(copied < 3)
      return;

   bool oldest_green = (rates[2].close > rates[2].open);
   bool middle_green = (rates[1].close > rates[1].open);
   bool latest_green = (rates[0].close > rates[0].open);
   bool higher_highs = (rates[1].high > rates[2].high && rates[0].high > rates[1].high);
   bool higher_lows = (rates[1].low > rates[2].low && rates[0].low > rates[1].low);

   if(!(oldest_green && middle_green && latest_green && higher_highs && higher_lows))
      return;

   g_p20_patternFirstBarTime = rates[2].time;
   g_p20_patternLastBarTime = rates[0].time;
   g_p20_firstCandleLow = rates[2].low;
   g_p20_levelActive = true;
   g_p20_levelExpired = false;

   if(InpPattern20LogDetails)
   {
      PrintFormat("Pattern 20: New 3-green HH/HL setup. First=%s Low=%.5f | Middle H/L=%.5f/%.5f | Latest H/L=%.5f/%.5f. Waiting for first touch to buy.",
                  TimeToString(g_p20_patternFirstBarTime, TIME_DATE|TIME_MINUTES),
                  g_p20_firstCandleLow,
                  rates[1].high,
                  rates[1].low,
                  rates[0].high,
                  rates[0].low);
   }

   UpsertPattern20LevelLine();
}

void ProcessPattern20Touch(bool allow_entry)
{
   if(!InpPattern20Enabled)
      return;

   if(!g_p20_levelActive || g_p20_levelExpired || g_p20_firstCandleLow <= 0.0)
      return;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   if(bid <= 0.0)
      return;

   if(bid > g_p20_firstCandleLow)
      return;

   g_p20_levelActive = false;
   g_p20_levelExpired = true;
   DeletePattern20Objects();

   if(InpPattern20LogDetails)
   {
      PrintFormat("Pattern 20: First touch of latest setup low %.5f detected at bid %.5f. Level expired%s.",
                  g_p20_firstCandleLow,
                  bid,
                  allow_entry ? " and BUY entry requested" : " without entry because new trades are currently blocked");
   }

   if(!allow_entry)
      return;

   if(!IsTradingHour() || IsNewsTime())
   {
      if(InpPattern20LogDetails)
         Print("Pattern 20: Touch detected, but entry blocked by trading-hours/news filter.");
      return;
   }

   ExecuteTrade("buy");
}

void HandlePattern20_ThreeGreenHHHLRetest()
{
   UpdatePattern20SetupOnNewClosedBar();
   ProcessPattern20Touch(true);
}

