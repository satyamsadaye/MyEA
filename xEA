// Manual trade executions using existing OpenPosition helper
void Manual_ExecuteBuy()
{
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(ask <= 0) return;

   double atr = g_cached_atr;
   if(atr == 0 && g_atr_handle != INVALID_HANDLE)
   {
      double buf[];
      if(CopyBuffer(g_atr_handle, 0, 0, 1, buf) > 0) atr = buf[0];
   }

   double sl = 0, tp = 0;
   if(atr > 0)
   {
      double slDist = atr * InpAtrMultiplierSL;
      double tpDist = atr * InpAtrMultiplierTP;
      sl = NormalizeDouble(ask - slDist, _Digits);
      tp = NormalizeDouble(ask + tpDist, _Digits);
   }

   double lot = 0.0;
   if(InpRiskCalcMethod == RISK_CALC_FIXED_LOT)
   {
      lot = InpFixedLotSize > 0 ? InpFixedLotSize : GetEffectiveMinLot(_Symbol);
   }
   else
   {
      double sl_distance_price_abs = (sl>0) ? MathAbs(ask - sl) : 0.0;
      if(sl_distance_price_abs > 0)
         lot = CalculateLotFromSLDistance(_Symbol, sl_distance_price_abs);
      if(lot <= 0) lot = GetEffectiveMinLot(_Symbol);
   }
   ulong order_or_ticket = OpenPosition(_Symbol, POSITION_TYPE_BUY, lot, sl, tp, "MANUAL");
   if(order_or_ticket>0)
   {
      Print("Manual Buy order sent (id): ", order_or_ticket);
      // Try to find the actual position ticket (deal) created for the manual order
      ulong pos_ticket = 0;
      for(int wait=0; wait<5; wait++)
      {
         Sleep(200);
         for(int p=0; p<PositionsTotal(); p++)
         {
            ulong t = PositionGetTicket(p);
            if(t==0) continue;
            if(!PositionSelectByTicket(t)) continue;
            if(PositionGetString(POSITION_COMMENT) == "MANUAL" && PositionGetString(POSITION_SYMBOL) == _Symbol)
            {
               pos_ticket = t;
               break;
            }
         }
         if(pos_ticket>0) break;
      }
      if(pos_ticket>0)
      {
         PrintFormat("Manual Buy position detected: %d", pos_ticket);
         if(InpMultiOrderEnabled || InpManualRegisterForRecovery) Manual_RegisterForRecovery(pos_ticket);
      }
      else
      {
         Print("Manual Buy: Position ticket not found immediately; it may appear shortly.");
      }
   }
}

