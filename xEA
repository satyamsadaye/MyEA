      case 3: return InpTrailATRTF3;
      case 4: return InpTrailATRTF4;
      case 5: return InpTrailATRTF5;
      case 6: return InpTrailATRTF6;
      default: return InpTrailATRTF7;
   }
}

double GetATRValueForTimeframe(const string symbol, const ENUM_TIMEFRAMES timeframe, const int period)
{
   if(period <= 0)
      return 0.0;

   int handle = iATR(symbol, timeframe, period);
   if(handle == INVALID_HANDLE)
      return 0.0;

   double atr_buffer[];
   ArraySetAsSeries(atr_buffer, true);
   int copied = CopyBuffer(handle, 0, 0, 1, atr_buffer);
   IndicatorRelease(handle);
   if(copied <= 0)
      return 0.0;

   return atr_buffer[0];
}

void ApplyTrailingStop()
{
   if(InpGlobalDollarExitEnabled)
   {
      RemoveTrailLine();
      RemoveTrailTriggerLine();
      return;
   }

   if(!InpEnableTrailSL)
   {
      RemoveTrailLine();
      RemoveTrailTriggerLine();
      return;
   }

   int total_positions = PositionsTotal();
   bool has_managed_positions = false;

   for(int i = 0; i < total_positions; i++)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;

      if(!PositionSelectByTicket(ticket)) continue;
      if((ulong)PositionGetInteger(POSITION_MAGIC) != (ulong)InpMagicNumber) continue;

      string symbol = PositionGetString(POSITION_SYMBOL);
      string position_comment = PositionGetString(POSITION_COMMENT);
      MqlTick tick;
      if(!SymbolInfoTick(symbol, tick))
         continue;

      double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
      double current_sl = PositionGetDouble(POSITION_SL);
      ENUM_POSITION_TYPE position_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      bool is_buy = (position_type == POSITION_TYPE_BUY);
      bool use_synthetic_trailing = false;
      int synthetic_group_idx = -1;
      if(entry_price <= 0.0)
         continue;

      // Recovery has priority once started: completely disable trailing management for that group.
      if(InpMultiOrderEnabled)
      {
         int group_idx = FindMultiOrderGroupIndexByTicket(ticket);
         if(group_idx >= 0)
         {
            bool recovery_active_for_group = (MultiOrderGroups[group_idx].attempts > 0 ||
                                              MultiOrderGroups[group_idx].ticket_count > 1);
            if(recovery_active_for_group)
            {
               if(FindTrailingTrackerIndex(ticket) >= 0)
                  RemoveTrailingTracker(ticket);

               if(!g_is_backtesting)
               {
                  PrintFormat("Trailing Stop: Disabled for #%I64u because multi-order recovery is active for group #%d.",
                              ticket, MultiOrderGroups[group_idx].base_ticket);
               }
               continue;
            }
         }
      }

      has_managed_positions = true;

      // In multi-order mode, always trail base positions against the group's synthetic SL reference.
      // This keeps trailing and recovery aligned even if a broker-side SL still exists.
      if(InpMultiOrderEnabled)
      {
         for(int g = 0; g < ArraySize(MultiOrderGroups); g++)
         {
            if(MultiOrderGroups[g].base_ticket == ticket && MultiOrderGroups[g].original_sl > 0.0)
            {
               current_sl = MultiOrderGroups[g].original_sl;
               use_synthetic_trailing = true;
               synthetic_group_idx = g;
               break;
            }
         }
      }

      if(current_sl <= 0.0)
      {
         RemoveTrailTriggerLine();
         continue;
      }

      // Always show current active SL on chart (white line), even before first trail step.
      UpsertTrailLine(current_sl, "Current SL");

      // Force trailing exits to go through EA close path (with TRAILING_EXIT comment)
      // before broker-side SL closure when price touches the current trailed SL level.
      if(WasTrailingUsed(ticket))
      {
         bool trail_sl_touched = is_buy ? (tick.bid <= current_sl) : (tick.ask >= current_sl);
         if(trail_sl_touched)
         {
            PrintFormat("Trailing Stop: Price touched trailed SL for #%I64u at %.5f. Closing via EA with trailing exit comment.",
                        ticket, current_sl);
            ClosePosition(ticket);
            continue;
         }
      }

      int tracker_index = FindTrailingTrackerIndex(ticket);
      if(tracker_index < 0)
      {
         int size = ArraySize(ExtTrailingTrackers);
         ArrayResize(ExtTrailingTrackers, size + 1);
         tracker_index = size;
         ExtTrailingTrackers[tracker_index].ticket = ticket;
         double tracker_initial_sl = current_sl;
         double tracker_initial_risk = is_buy ? (entry_price - current_sl) : (current_sl - entry_price);

         // In synthetic trailing mode, anchor risk to the original synthetic SL distance.
         // This keeps trigger math stable even when no real broker SL exists.
         if(use_synthetic_trailing &&
            synthetic_group_idx >= 0 &&
            synthetic_group_idx < ArraySize(MultiOrderGroups))
         {
            double group_original_risk = MultiOrderGroups[synthetic_group_idx].original_sl_distance;
            if(group_original_risk > 0.0)
            {
               tracker_initial_risk = group_original_risk;
               tracker_initial_sl = is_buy ? (entry_price - group_original_risk)
                                           : (entry_price + group_original_risk);
            }
            else if(MultiOrderGroups[synthetic_group_idx].original_sl > 0.0)
            {
               tracker_initial_sl = MultiOrderGroups[synthetic_group_idx].original_sl;
               tracker_initial_risk = MathAbs(entry_price - tracker_initial_sl);
            }
         }

         ExtTrailingTrackers[tracker_index].initial_sl = tracker_initial_sl;
         ExtTrailingTrackers[tracker_index].initial_risk = tracker_initial_risk;
         ExtTrailingTrackers[tracker_index].steps_done = 0;
         PrintFormat("Trailing Stop: Added position #%I64u to tracker (risk=%.5f, synthetic=%s).",
                     ticket,
                     ExtTrailingTrackers[tracker_index].initial_risk,
                     use_synthetic_trailing ? "true" : "false");
      }

      int scale_group_idx = -1;

      double initial_risk = ExtTrailingTrackers[tracker_index].initial_risk;
      if(initial_risk <= 0.0 &&
         use_synthetic_trailing &&
         synthetic_group_idx >= 0 &&
         synthetic_group_idx < ArraySize(MultiOrderGroups))
      {
         double group_original_risk = MultiOrderGroups[synthetic_group_idx].original_sl_distance;
         if(group_original_risk > 0.0)
         {
            ExtTrailingTrackers[tracker_index].initial_risk = group_original_risk;
            ExtTrailingTrackers[tracker_index].initial_sl = is_buy ? (entry_price - group_original_risk)
                                                                    : (entry_price + group_original_risk);
            initial_risk = group_original_risk;
            PrintFormat("Trailing Stop: Repaired tracker risk for #%I64u using synthetic group distance %.5f.",
                        ticket, group_original_risk);
         }
      }
      if(initial_risk <= 0.0)
         continue;

      bool is_trailing_scale_position = (StringFind(position_comment, "Trailing Scale") >= 0);

      if(InpTrailingScaleEnabled && !is_trailing_scale_position)
      {
         RegisterTrailingScaleGroup(ticket);
         scale_group_idx = FindTrailingScaleGroupIndex(ticket);
      }

      double profit_dist = is_buy ? (tick.bid - entry_price) : (entry_price - tick.ask);
      double move_pct = InpTrailMovePercent / 100.0;
      bool rr_mode = (InpTrailingTriggerMode == TRAIL_MODE_RISK_REWARD);
      bool atr_ladder_mode = (InpTrailingTriggerMode == TRAIL_MODE_ATR_LADDER);
      double move_rr_per_step = MathMax(0.0, InpTrailMoveRRPerStep);
      bool use_rr_step_move = (rr_mode && move_rr_per_step > 0.0);
      if(rr_mode && !use_rr_step_move && !g_is_backtesting)
      {
         static datetime last_rr_fallback_log = 0;
         datetime now_t = TimeCurrent();
         if(now_t != last_rr_fallback_log)
         {
            PrintFormat("Trailing RR mode: InpTrailMoveRRPerStep=0. Using percent move (InpTrailMovePercent=%.2f%%).",
                        InpTrailMovePercent);
            last_rr_fallback_log = now_t;
         }
      }
      if(!atr_ladder_mode && move_pct <= 0.0 && !use_rr_step_move)
      {
         RemoveTrailTriggerLine();
         continue;
      }
      double rr_start = MathMax(0.0001, InpTrailStartRR);
      double rr_step = rr_start; // Simple RR mode: repeat trigger every same RR distance
      double atr_start_r = MathMax(0.0001, InpTrailATRStartR);
      double atr_step_r = MathMax(0.0001, InpTrailATRStepR);

      double trigger_start_dist = 0.0;
      double trigger_step_dist = 0.0;
      double levels_exact = 0.0;

      if(rr_mode)
      {
         trigger_start_dist = initial_risk * rr_start;
         trigger_step_dist = initial_risk * rr_step;
         if(trigger_start_dist <= 0.0 || trigger_step_dist <= 0.0)
         {
            RemoveTrailTriggerLine();
            continue;
          }
          levels_exact = ((profit_dist - trigger_start_dist) / trigger_step_dist) + 1.0;
      }
      else if(atr_ladder_mode)
      {
         trigger_start_dist = initial_risk * atr_start_r;
         trigger_step_dist = initial_risk * atr_step_r;
         if(trigger_start_dist <= 0.0 || trigger_step_dist <= 0.0)
         {
            RemoveTrailTriggerLine();
            continue;
         }
         levels_exact = ((profit_dist - trigger_start_dist) / trigger_step_dist) + 1.0;
      }
      else
      {
         double trigger_pct = InpTrailTriggerPercent / 100.0;
         if(trigger_pct <= 0.0)
         {
            RemoveTrailTriggerLine();
            continue;
         }
         trigger_start_dist = initial_risk * trigger_pct;
         trigger_step_dist = trigger_start_dist;
         if(trigger_start_dist <= 0.0)
         {
            RemoveTrailTriggerLine();
            continue;
         }
         levels_exact = profit_dist / trigger_start_dist;
      }

      int completed_steps = (int)MathFloor(levels_exact);

      if(completed_steps <= 0)
      {
         if(!InpTrailContinuous && ExtTrailingTrackers[tracker_index].steps_done >= 1)
         {
            RemoveTrailTriggerLine();
            continue;
         }

         double trigger_price = is_buy ? (entry_price + trigger_start_dist)
                                       : (entry_price - trigger_start_dist);
         string trigger_label = "";
         if(rr_mode)
            trigger_label = "Next trail @RR " + DoubleToString(rr_start, 2);
         else if(atr_ladder_mode)
            trigger_label = "Next ATR trail @RR " + DoubleToString(atr_start_r, 2) + " (" + EnumToString(GetTrailAtrLadderTimeframe(1)) + ")";
         else
            trigger_label = "Next trail @" + DoubleToString(InpTrailTriggerPercent, 2) + "%";
         UpsertTrailTriggerLine(trigger_price, trigger_label);
         continue;
      }

      double applied_steps = 1.0;
      if(InpTrailContinuous)
      {
         if(!atr_ladder_mode)
            applied_steps = levels_exact;
         ExtTrailingTrackers[tracker_index].steps_done = completed_steps;
         int next_step = completed_steps + 1;
         double next_trigger_dist = 0.0;
         string next_trigger_label = "";
         if(rr_mode)
         {
            double next_rr = rr_start + (double)(next_step - 1) * rr_step;
            next_trigger_dist = initial_risk * next_rr;
            next_trigger_label = "Next trail @RR " + DoubleToString(next_rr, 2);
         }
         else if(atr_ladder_mode)
         {
            double next_rr = atr_start_r + (double)(next_step - 1) * atr_step_r;
            next_trigger_dist = initial_risk * next_rr;
            ENUM_TIMEFRAMES next_tf = GetTrailAtrLadderTimeframe(next_step);
            next_trigger_label = "Next ATR trail @RR " + DoubleToString(next_rr, 2) + " (" + EnumToString(next_tf) + ")";
         }
         else
         {
            next_trigger_dist = trigger_step_dist * (double)next_step;
            double next_trigger_pct = (double)next_step * InpTrailTriggerPercent;
            next_trigger_label = "Next trail @" + DoubleToString(next_trigger_pct, 2) + "%";
         }
         double next_trigger_price = is_buy ? (entry_price + next_trigger_dist)
                                            : (entry_price - next_trigger_dist);
         UpsertTrailTriggerLine(next_trigger_price, next_trigger_label);
      }
      else
      {
         if(ExtTrailingTrackers[tracker_index].steps_done >= 1)
         {
            RemoveTrailTriggerLine();
            continue;
         }
         ExtTrailingTrackers[tracker_index].steps_done = 1;
         RemoveTrailTriggerLine();
      }

      double desired_risk = 0.0;
      if(rr_mode && move_rr_per_step > 0.0)
      {
         // RR discrete trailing mode:
         // Each completed trigger step moves SL by a fixed R amount.
         // Example: triggerRR=1.5, moveRRPerStep=0.5
         // -> at 1.5R: move 0.5R, at 3.0R: move another 0.5R, etc.
         double move_steps = InpTrailContinuous ? (double)completed_steps : 1.0;
         desired_risk = initial_risk * (1.0 - (move_steps * move_rr_per_step));
      }
      else if(!atr_ladder_mode)
      {
         desired_risk = initial_risk * (1.0 - applied_steps * move_pct);
      }
      if(!atr_ladder_mode && !use_rr_step_move && desired_risk < 0.0)
         desired_risk = 0.0;

      double desired_sl = 0.0;
      if(atr_ladder_mode)
      {
         int ladder_level = completed_steps;
         ENUM_TIMEFRAMES atr_tf = GetTrailAtrLadderTimeframe(ladder_level);
         int atr_period = MathMax(1, InpTrailATRAtrPeriod);
         double atr_value = GetATRValueForTimeframe(symbol, atr_tf, atr_period);
         double atr_distance = atr_value * MathMax(0.0, InpTrailATRAtrMultiplier);
         if(atr_distance <= 0.0)
         {
            if(!g_is_backtesting)
               PrintFormat("Trailing ATR ladder: ATR unavailable for %s on %s (period=%d).", symbol, EnumToString(atr_tf), atr_period);
            continue;
         }

         desired_sl = is_buy ? (tick.bid - atr_distance) : (tick.ask + atr_distance);
         applied_steps = (double)completed_steps;
      }
      else
      {
         desired_sl = is_buy ? (entry_price - desired_risk)
                            : (entry_price + desired_risk);
      }

      double point = SymbolInfoDouble(symbol, SYMBOL_POINT);
      if(point <= 0.0)
         point = _Point;

      double stop_level_pts = (double)SymbolInfoInteger(symbol, SYMBOL_TRADE_STOPS_LEVEL);
      double freeze_level_pts = (double)SymbolInfoInteger(symbol, SYMBOL_TRADE_FREEZE_LEVEL);
      double min_gap = (MathMax(stop_level_pts, freeze_level_pts) + 1.0) * point;
      double position_tp = PositionGetDouble(POSITION_TP);

      if(min_gap > 0.0)
      {
         if(is_buy && (tick.bid - desired_sl) < min_gap)
            desired_sl = tick.bid - min_gap;
         if(!is_buy && (desired_sl - tick.ask) < min_gap)
            desired_sl = tick.ask + min_gap;

         if(position_tp > 0.0)
         {
            if(is_buy)
            {
               double max_by_tp = position_tp - min_gap;
               if(desired_sl > max_by_tp)
                  desired_sl = max_by_tp;
            }
            else
            {
               double min_by_tp = position_tp + min_gap;
               if(desired_sl < min_by_tp)
                  desired_sl = min_by_tp;
            }
         }
      }

      if(InpTrailingScaleEnabled && scale_group_idx >= 0 && completed_steps > 0)
      {
         int max_scale_orders = MathMin(TRAILING_SCALE_ORDER_SLOTS, MathMax(1, InpTrailingScaleMaxOrders));
         bool max_reached = (ExtTrailingScaleGroups[scale_group_idx].scale_count >= max_scale_orders);
         bool repeat_blocked = (!InpTrailingScaleRepeat &&
                                (ExtTrailingScaleGroups[scale_group_idx].single_scale_consumed ||
                                 ExtTrailingScaleGroups[scale_group_idx].scale_count > 0));
         bool skip_first_trigger = (InpTrailingScaleStartOnSecondTrigger &&
                                    ExtTrailingScaleGroups[scale_group_idx].scale_count == 0 &&
                                    completed_steps == 1);

         if(max_reached)
         {
            if(ExtTrailingScaleGroups[scale_group_idx].last_scaled_step < completed_steps)
               ExtTrailingScaleGroups[scale_group_idx].last_scaled_step = completed_steps;
         }
         else if(skip_first_trigger)
         {
            if(ExtTrailingScaleGroups[scale_group_idx].last_scaled_step < completed_steps)
            {
               ExtTrailingScaleGroups[scale_group_idx].last_scaled_step = completed_steps;
               if(!g_is_backtesting)
               {
                  PrintFormat("Trailing Scale: Skipping first trigger for base #%I64u at step %d because InpTrailingScaleStartOnSecondTrigger=true.",
                              ticket, completed_steps);
               }
            }
         }
         else if(repeat_blocked)
         {
            if(ExtTrailingScaleGroups[scale_group_idx].last_scaled_step < completed_steps)
               ExtTrailingScaleGroups[scale_group_idx].last_scaled_step = completed_steps;
         }
         else if(completed_steps > ExtTrailingScaleGroups[scale_group_idx].last_scaled_step)
         {
            if(!InpTrailingScaleRepeat)
               ExtTrailingScaleGroups[scale_group_idx].single_scale_consumed = true;

            double scale_volume = ExtTrailingScaleGroups[scale_group_idx].original_lot;
            double scale_multiplier = MathMax(0.0, InpTrailingScaleLotMultiplier);
            if(scale_multiplier <= 0.0)
               scale_multiplier = 1.0;
            scale_volume *= scale_multiplier;
            double min_lot = GetEffectiveMinLot(symbol);
            double max_lot = GetEffectiveMaxLot(symbol);
            double lot_step = SymbolInfoDouble(symbol, SYMBOL_VOLUME_STEP);
            scale_volume = MathMax(min_lot, MathMin(max_lot, scale_volume));
            if(lot_step > 0.0)
               scale_volume = MathRound(scale_volume / lot_step) * lot_step;
            scale_volume = MathMax(min_lot, MathMin(max_lot, scale_volume));
            scale_volume = NormalizeDouble(scale_volume, 2);
            double scale_tp = PositionGetDouble(POSITION_TP);

            if(scale_volume > 0.0 && desired_sl > 0.0)
            {
               if(InpDevelopmentMode)
               {
                  PrintFormat("[DEV MODE] Trailing Scale: Step %d reached for #%I64u, would add %.2f lots (x%.2f original lot) at %.5f.",
                              completed_steps, ticket, scale_volume, scale_multiplier, desired_sl);
               }
               else
               {
                  ulong scale_ticket = OpenPosition(symbol, position_type, scale_volume, desired_sl, scale_tp, "RohitEA Trailing Scale");
                  if(scale_ticket > 0)
                  {
                     if(ExtTrailingScaleGroups[scale_group_idx].scale_count < TRAILING_SCALE_ORDER_SLOTS)
                        ExtTrailingScaleGroups[scale_group_idx].scale_tickets[ExtTrailingScaleGroups[scale_group_idx].scale_count++] = scale_ticket;
                     PrintFormat("Trailing Scale: Added scale order #%I64u for base #%I64u (step=%d, lots=%.2f, multiplier=%.2f).",
                                 scale_ticket, ticket, completed_steps, scale_volume, scale_multiplier);
                  }
                  else
                  {
                     PrintFormat("Trailing Scale: Failed to open scale order for base #%I64u (step=%d).",
                                 ticket, completed_steps);
                  }
               }
            }
            else
            {
               if(scale_volume <= 0.0)
                  PrintFormat("Trailing Scale: Skipped scaling for #%I64u because volume %.2f is invalid.",
                              ticket, scale_volume);
               else
                  PrintFormat("Trailing Scale: Skipped scaling for #%I64u because desired SL %.5f is invalid.",
                              ticket, desired_sl);
            }
            ExtTrailingScaleGroups[scale_group_idx].last_scaled_step = completed_steps;
         }
      }

      int digits = (int)SymbolInfoInteger(symbol, SYMBOL_DIGITS);
      desired_sl = NormalizeDouble(desired_sl, digits);
      if(desired_sl <= 0.0)
         continue;

      if(is_buy && desired_sl <= current_sl)
         continue;
      if(!is_buy && desired_sl >= current_sl)
         continue;
      if(MathAbs(desired_sl - current_sl) < (point * 0.5))
         continue;

      bool modified = false;
      if(use_synthetic_trailing)
      {
         if(synthetic_group_idx < 0 || synthetic_group_idx >= ArraySize(MultiOrderGroups))
            continue;

         MultiOrderGroups[synthetic_group_idx].original_sl = desired_sl;
         DrawSyntheticSLLine(ticket, desired_sl, position_type);
         modified = true;
         MarkTrailingUsage(ticket);

         PrintFormat("Trailing Stop: Updated synthetic SL for base #%I64u to %.5f (group %d).",
                     ticket, desired_sl, synthetic_group_idx);
      }
      else
      {
         MqlTradeRequest request;
         MqlTradeResult result;
         ZeroMemory(request);
         ZeroMemory(result);

         request.action = TRADE_ACTION_SLTP;
         request.symbol = symbol;
         request.position = ticket;
         request.magic = InpMagicNumber;
         request.sl = desired_sl;
         request.tp = position_tp;
         request.comment = "RohitEA Trailing SL";

         bool sent = SendDollarExitAwareOrder(request, result);
         modified = (sent && (result.retcode == 10009 || result.retcode == 10008)); // DONE / PLACED
         if(!modified)
         {
            int err = GetLastError();
            bool invalid_stops = (result.retcode == 10016) || (StringFind(result.comment, "Invalid stops") >= 0);

            if(invalid_stops)
            {
               MqlTick dbg_tick;
               double dbg_bid = 0.0, dbg_ask = 0.0;
               if(SymbolInfoTick(symbol, dbg_tick))
               {
                  dbg_bid = dbg_tick.bid;
                  dbg_ask = dbg_tick.ask;
               }
               PrintFormat("[TRAIL][INVALID_STOPS] ticket=%I64u requestedSL=%.5f currentSL=%.5f tp=%.5f bid=%.5f ask=%.5f minGap=%.5f (stopLvl=%.0f freezeLvl=%.0f). Trying fallback.",
                           ticket, desired_sl, current_sl, position_tp, dbg_bid, dbg_ask, min_gap, stop_level_pts, freeze_level_pts);

               double fallback_sl = 0.0;
               if(BuildTrailingFallbackSL(symbol, is_buy, position_tp, desired_sl, fallback_sl))
               {
                  bool improves = (is_buy && fallback_sl > current_sl) || (!is_buy && fallback_sl < current_sl);
                  bool moved = (MathAbs(fallback_sl - current_sl) >= (point * 0.5));
                  PrintFormat("[TRAIL][FALLBACK_CANDIDATE] ticket=%I64u fallbackSL=%.5f improves=%s moved=%s",
                              ticket, fallback_sl, improves ? "true" : "false", moved ? "true" : "false");

                  if(improves && moved)
                  {
                     request.sl = fallback_sl;
                     ZeroMemory(result);
                     bool retry_sent = SendDollarExitAwareOrder(request, result);
                     bool retry_ok = (retry_sent && (result.retcode == 10009 || result.retcode == 10008));
                     if(retry_ok)
                     {
                        modified = true;
                        desired_sl = fallback_sl;
                        PrintFormat("[TRAIL][FALLBACK_APPLIED] ticket=%I64u appliedSL=%.5f after invalid stops.",
                                    ticket, fallback_sl);
                     }
                     else
                     {
                        PrintFormat("[TRAIL][FALLBACK_FAILED] ticket=%I64u fallbackSL=%.5f retcode=%u error=%d",
                                    ticket, fallback_sl, result.retcode, GetLastError());
                        continue;
                     }
                  }
                  else
                  {
                     PrintFormat("[TRAIL][FALLBACK_SKIPPED] ticket=%I64u fallbackSL=%.5f currentSL=%.5f retcode=%u error=%d",
                                 ticket, fallback_sl, current_sl, result.retcode, err);
                     continue;
                  }
               }
               else
               {
                  PrintFormat("[TRAIL][FALLBACK_UNAVAILABLE] ticket=%I64u could not compute fallback from latest tick (retcode=%u, error=%d).",
                              ticket, result.retcode, err);
                  continue;
               }
            }
            else
            {
               PrintFormat("Trailing Stop: Failed to modify ticket #%I64u (retcode=%u, error=%d).", ticket, result.retcode, err);
               continue;
            }
         }
      }

      MarkTrailingUsage(ticket);

      double vol = PositionGetDouble(POSITION_VOLUME);
      double initial_risk_money = TrailDistanceToMoney(symbol, initial_risk, vol);
      double new_risk_money = TrailDistanceToMoney(symbol, MathAbs(entry_price - desired_sl), vol);
      double lock_dist = is_buy ? (desired_sl - entry_price) : (entry_price - desired_sl);
      if(lock_dist < 0.0)
         lock_dist = 0.0;
      double lock_money = TrailDistanceToMoney(symbol, lock_dist, vol);
      double profit_pct = (profit_dist / initial_risk) * 100.0;

      PrintFormat("Trail SL updated #%I64u: SL=%.5f, profit=%.2f%%, risk $%.2f/$%.2f, locked $%.2f, mode=%s, levels=%.2f",
                  ticket, desired_sl, profit_pct, new_risk_money, initial_risk_money, lock_money,
                  InpTrailContinuous ? "continuous" : "one-shot", levels_exact);

      UpsertTrailLine(desired_sl, "Trail SL");
   }

   if(!has_managed_positions)
   {
      RemoveTrailLine();
      RemoveTrailTriggerLine();
   }

   for(int i = ArraySize(ExtTrailingTrackers) - 1; i >= 0; i--)
   {
      if(!PositionSelectByTicket(ExtTrailingTrackers[i].ticket))
      {
         RemoveTrailingScaleGroupByBase(ExtTrailingTrackers[i].ticket);
         for(int j = i; j < ArraySize(ExtTrailingTrackers) - 1; j++)
         {
            ExtTrailingTrackers[j] = ExtTrailingTrackers[j + 1];
         }
         ArrayResize(ExtTrailingTrackers, ArraySize(ExtTrailingTrackers) - 1);
      }
   }
}

//+------------------------------------------------------------------+
//| Apply Kill Switch for all positions                              |
//| Closes positions if price moves:                                 |
//| 1. ATR mode: X times the SL distance in ATR terms                |
//| 2. Percent mode: X% from the entry price                         |
//+------------------------------------------------------------------+
void ApplyKillSwitch()
{
   int total_positions = PositionsTotal();
   int closed_count = 0;
   
   // Loop through all positions
   for(int i = 0; i < total_positions; i++)
   {
      // Get position ticket (need to use copy since positions might be closed during the loop)
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0) continue;
      
      // Only check positions with our magic number
      if(!PositionSelectByTicket(ticket)) continue;
      if(PositionGetInteger(POSITION_MAGIC) != InpMagicNumber) continue;
      
      // Get position details
      string symbol = PositionGetString(POSITION_SYMBOL);
      double entry_price = PositionGetDouble(POSITION_PRICE_OPEN);
      ENUM_POSITION_TYPE pos_type = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      double sl_price = PositionGetDouble(POSITION_SL);
      double tp_price = PositionGetDouble(POSITION_TP);
      
      // Get current price
      double current_price = SymbolInfoDouble(symbol, pos_type == POSITION_TYPE_BUY ? SYMBOL_BID : SYMBOL_ASK);
      
      // Logic for ATR-based kill switch
      if(InpKillSwitchUseATR)
      {
         double atr = GetATRValue();
         if(atr == 0) continue; // Skip if couldn't get ATR
         
         // Calculate SL distance in ATR terms
         double sl_distance = atr * InpAtrMultiplierSL * InpKillSwitchATRMultiplier;
         double price_move = MathAbs(current_price - entry_price);
         
         // Check if price moved more than X times the ATR-based SL
         if(price_move >= sl_distance)
         {
            // Close the position
            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);
            
            request.action = TRADE_ACTION_DEAL;
            request.position = ticket;
            request.symbol = symbol;
            request.volume = PositionGetDouble(POSITION_VOLUME);
            request.deviation = InpMaxSlippagePoints;
            request.magic = InpMagicNumber;
            request.comment = "RohitEA Kill Switch (ATR)";
            request.type_filling = GetSupportedFillingMode(_Symbol);
            
            if(pos_type == POSITION_TYPE_BUY)
            {
               request.price = SymbolInfoDouble(symbol, SYMBOL_BID);
               request.type = ORDER_TYPE_SELL;
            }
            else
            {
               request.price = SymbolInfoDouble(symbol, SYMBOL_ASK);
               request.type = ORDER_TYPE_BUY;
            }
            
            if(SendDollarExitAwareOrder(request, result))
            {
               PrintFormat("Kill Switch: Closed %s position #%d. Price moved %.2f points (%.2f × SL ATR) from entry (%.5f -> %.5f).",
                          EnumToString(pos_type), ticket, price_move, InpKillSwitchATRMultiplier, entry_price, current_price);
               closed_count++;
               i--; // Adjust counter as the positions list will be reindexed
               total_positions--;
            }
            else
            {
               PrintFormat("Kill Switch: Failed to close position #%d. Error: %d",
                          ticket, GetLastError());
            }
         }
      }
      // Logic for percentage-based kill switch
      else
      {
         double price_move_percent = MathAbs(current_price - entry_price) / entry_price * 100.0;
         
         if(price_move_percent >= InpKillSwitchPercent)
         {
            // Close the position
            MqlTradeRequest request;
            MqlTradeResult result;
            ZeroMemory(request);
            ZeroMemory(result);
            
            request.action = TRADE_ACTION_DEAL;
            request.position = ticket;
            request.symbol = symbol;
            request.volume = PositionGetDouble(POSITION_VOLUME);
            request.deviation = InpMaxSlippagePoints;
            request.magic = InpMagicNumber;
            request.comment = "RohitEA Kill Switch (%)";
            request.type_filling = GetSupportedFillingMode(_Symbol);
            
            if(pos_type == POSITION_TYPE_BUY)
            {
               request.price = SymbolInfoDouble(symbol, SYMBOL_BID);
               request.type = ORDER_TYPE_SELL;
            }
            else
            {
               request.price = SymbolInfoDouble(symbol, SYMBOL_ASK);
               request.type = ORDER_TYPE_BUY;
            }
            
            if(SendDollarExitAwareOrder(request, result))
            {
               PrintFormat("Kill Switch: Closed %s position #%d. Price moved %.2f%% from entry (%.5f -> %.5f).",
                          EnumToString(pos_type), ticket, price_move_percent, entry_price, current_price);
               closed_count++;
               i--; // Adjust counter as the positions list will be reindexed
               total_positions--;
            }
            else
            {
               PrintFormat("Kill Switch: Failed to close position #%d. Error: %d",
                          ticket, GetLastError());
            }
         }
      }
   }
   
   if(closed_count > 0)
   {
      PrintFormat("Kill Switch: Closed %d position(s) in total.", closed_count);
   }
}

//+------------------------------------------------------------------+
//| Update Trading Statistics                                        |
//+------------------------------------------------------------------+
void UpdateStatistics()
{
   // Only update every second to avoid excessive processing
   if(g_stats.last_update == TimeCurrent())
      return;

   g_stats.last_update = TimeCurrent();

   // Reset statistics
   g_stats.total_trades = 0;
   g_stats.winning_trades = 0;
   g_stats.losing_trades = 0;
   g_stats.gross_pnl = 0;
   g_stats.commission_total = 0;
   g_stats.net_pnl = 0;

   // Initialize RR array
   ArrayInitialize(g_stats.last_10_trades_rr, 0);

   // Get account history
   HistorySelect(0, TimeCurrent());
   int total_deals = HistoryDealsTotal();

   // Arrays to store trade data for RR calculation
   double trade_entry_prices[];
   double trade_sl_prices[];
   double trade_exit_prices[];
   datetime trade_open_times[];
   datetime trade_close_times[];
   double trade_profits[];
   int trade_count = 0;

   // Process all deals
   for(int i = 0; i < total_deals; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket <= 0)
         continue;

      // Check if deal belongs to our EA
      if(HistoryDealGetInteger(deal_ticket, DEAL_MAGIC) != InpMagicNumber)
         continue;

      // Get deal info
      double deal_profit = HistoryDealGetDouble(deal_ticket, DEAL_PROFIT);
      double deal_commission = HistoryDealGetDouble(deal_ticket, DEAL_COMMISSION);
      double deal_swap = HistoryDealGetDouble(deal_ticket, DEAL_SWAP);
      ENUM_DEAL_ENTRY deal_entry = (ENUM_DEAL_ENTRY)HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
      ENUM_DEAL_TYPE deal_type = (ENUM_DEAL_TYPE)HistoryDealGetInteger(deal_ticket, DEAL_TYPE);
      ENUM_DEAL_REASON deal_reason = (ENUM_DEAL_REASON)HistoryDealGetInteger(deal_ticket, DEAL_REASON);
      ulong deal_position_id = (ulong)HistoryDealGetInteger(deal_ticket, DEAL_POSITION_ID);

      if(deal_type != DEAL_TYPE_BUY && deal_type != DEAL_TYPE_SELL)
         continue;

      // Update commission total
      g_stats.commission_total += (deal_commission + deal_swap);

      // Track entry and exit for RR calculation
      if(deal_entry == DEAL_ENTRY_IN)
      {
         ArrayResize(trade_entry_prices, trade_count + 1);
         ArrayResize(trade_sl_prices, trade_count + 1);
         ArrayResize(trade_exit_prices, trade_count + 1);
         ArrayResize(trade_open_times, trade_count + 1);
         ArrayResize(trade_close_times, trade_count + 1);
         ArrayResize(trade_profits, trade_count + 1);

         trade_entry_prices[trade_count] = HistoryDealGetDouble(deal_ticket, DEAL_PRICE);
         trade_sl_prices[trade_count] = HistoryDealGetDouble(deal_ticket, DEAL_SL);
         trade_open_times[trade_count] = (datetime)HistoryDealGetInteger(deal_ticket, DEAL_TIME);
         trade_profits[trade_count] = 0; // Initialize profit
         trade_count++;
      }
      else if(deal_entry == DEAL_ENTRY_OUT)
      {
         if(trade_count > 0)
         {
            // Find matching entry
            for(int j = trade_count - 1; j >= 0; j--)
            {
               if(trade_exit_prices[j] == 0)  // Not yet processed
               {
                  trade_exit_prices[j] = HistoryDealGetDouble(deal_ticket, DEAL_PRICE);
                  trade_close_times[j] = (datetime)HistoryDealGetInteger(deal_ticket, DEAL_TIME);
                  trade_profits[j] = deal_profit;

                  // Update recovery mode tracking
                  if(InpRecoveryMode == RECOVERY_ENABLED &&
                     trade_close_times[j] > g_lastTradeCloseTime)
                  {
                     g_lastTradeCloseTime = trade_close_times[j];

                     // Check if this is a win or loss
                     if(deal_profit > 0)
                     {
                        // Reset consecutive losses on win
                        if(g_consecutiveLosses > 0)
                        {
                           PrintFormat("Recovery Mode: Win detected! Resetting consecutive losses from %d to 0",
                                      g_consecutiveLosses);
                           g_consecutiveLosses = 0;
                           g_currentRecoveryFactor = 1.0;
                           g_inRecoveryMode = false;
                        }
                     }
                     else if(deal_profit < 0)
                     {
                        // Increment consecutive losses on loss
                        g_consecutiveLosses++;

                        if(g_consecutiveLosses <= InpMaxConsecutiveLosses)
                        {
                           g_inRecoveryMode = true;
                           g_currentRecoveryFactor = MathPow(InpRecoveryFactor, g_consecutiveLosses);
                           PrintFormat("Recovery Mode: Loss detected! Consecutive losses: %d, New risk factor: %.2f",
                                      g_consecutiveLosses, g_currentRecoveryFactor);
                        }
                        else
                        {
                           PrintFormat("Recovery Mode: Maximum consecutive losses (%d) reached! Risk factor capped.",
                                      InpMaxConsecutiveLosses);
                           g_currentRecoveryFactor = MathPow(InpRecoveryFactor, InpMaxConsecutiveLosses);
                        }
                     }
                  }

                  break;
               }
            }
         }
      }

      // Update P&L
      g_stats.gross_pnl += deal_profit;
   }

   // Calculate statistics
   g_stats.net_pnl = g_stats.gross_pnl + g_stats.commission_total;

   // Calculate RR ratios and update trade counts
   double total_rr = 0;
   int rr_count = 0;

   for(int i = 0; i < trade_count; i++)
   {
      if(trade_exit_prices[i] == 0)  // Skip open trades
         continue;

      g_stats.total_trades++;

      double risk = MathAbs(trade_entry_prices[i] - trade_sl_prices[i]);
      if(risk == 0) continue;  // Skip trades with no SL

      double reward = MathAbs(trade_exit_prices[i] - trade_entry_prices[i]);
      double rr = reward / risk;

      // Store RR for last 10 trades
      if(g_stats.total_trades <= 10)
      {
         g_stats.last_10_trades_rr[g_stats.total_trades - 1] = rr;
      }
      else
      {
         // Shift array left and add new RR at end
         for(int j = 0; j < 9; j++)
         {
            g_stats.last_10_trades_rr[j] = g_stats.last_10_trades_rr[j + 1];
         }
         g_stats.last_10_trades_rr[9] = rr;
      }

      total_rr += rr;
      rr_count++;

      if(trade_profits[i] > 0)
         g_stats.winning_trades++;
      else if(trade_profits[i] < 0)
         g_stats.losing_trades++;
   }

   // Calculate win percentage and average RR
   if(g_stats.total_trades > 0)
   {
      g_stats.win_percentage = (double)g_stats.winning_trades / g_stats.total_trades * 100;
      if(rr_count > 0)
         g_stats.avg_rr = total_rr / rr_count;
   }

   // Calculate drawdown
   double current_balance = AccountInfoDouble(ACCOUNT_BALANCE);
   g_max_balance = MathMax(g_max_balance, current_balance);
   if(g_max_balance > 0)
   {
      double current_drawdown = (g_max_balance - current_balance) / g_max_balance * 100;
      g_stats.max_drawdown = current_drawdown;
   }
}

