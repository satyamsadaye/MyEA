      // MACD line crossed below signal line (potential SELL recovery signal)
      if(g_macd_prev_main >= g_macd_prev_signal && main_value < signal_value)
      {
         g_macd_recovery_sell_ready = true;
         PrintFormat("MACD Recovery: SELL signal ready - MACD line crossed below signal (MACD: %.5f < Signal: %.5f)", 
                    main_value, signal_value);
      }
   }
   
   // Store current values for next comparison
   g_macd_prev_main = main_value;
   g_macd_prev_signal = signal_value;
}

