}

datetime GDPanelServerTimeForUtc(datetime utc_time)
{
   datetime server_now = TimeTradeServer();
   if(server_now <= 0)
      server_now = TimeCurrent();
   return utc_time + (server_now - TimeGMT());
}

bool GDPanelIsTradeCloseDeal(ulong deal_ticket)
{
   long entry = HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
   if(entry != DEAL_ENTRY_OUT && entry != DEAL_ENTRY_OUT_BY && entry != DEAL_ENTRY_INOUT)
      return false;

   long type = HistoryDealGetInteger(deal_ticket, DEAL_TYPE);
   return (type == DEAL_TYPE_BUY || type == DEAL_TYPE_SELL);
}

bool GDPanelScopeAllowsSymbol(string symbol)
{
   if(InpGlobalDollarPanelStatsScope == PROP_STATS_CURRENT_SYMBOL && symbol != _Symbol)
      return false;
   return true;
}

long GDPanelMagicFilter()
{
   return (InpGlobalDollarPanelMagicNumber != 0 ? InpGlobalDollarPanelMagicNumber : InpMagicNumber);
}

int GDPanelFindTradeIndex(const GDPanelClosedTrade &trades[], ulong position_id)
{
   int count = ArraySize(trades);
   for(int i = 0; i < count; i++)
   {
      if(trades[i].position_id == position_id)
         return i;
   }
   return -1;
}

void GDPanelInitClosedTrade(GDPanelClosedTrade &trade, ulong position_id)
{
   trade.position_id = position_id;
   trade.open_time = 0;
   trade.close_time = 0;
   trade.symbol = "";
   trade.type = -1;
   trade.magic = 0;
   trade.volume = 0.0;
   trade.open_price = 0.0;
   trade.close_price = 0.0;
   trade.entry_sl = 0.0;
   trade.profit = 0.0;
   trade.commission = 0.0;
   trade.swap = 0.0;
   trade.net = 0.0;
   trade.risk_money = 0.0;
   trade.rr = 0.0;
}

void GDPanelFillEntryDetails(GDPanelClosedTrade &trade)
{
   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;
      if((ulong)HistoryDealGetInteger(ticket, DEAL_POSITION_ID) != trade.position_id)
         continue;

      long entry = HistoryDealGetInteger(ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_IN && entry != DEAL_ENTRY_INOUT)
         continue;

      trade.open_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      trade.symbol = HistoryDealGetString(ticket, DEAL_SYMBOL);
      trade.type = HistoryDealGetInteger(ticket, DEAL_TYPE);
      trade.magic = HistoryDealGetInteger(ticket, DEAL_MAGIC);
      trade.volume = HistoryDealGetDouble(ticket, DEAL_VOLUME);
      trade.open_price = HistoryDealGetDouble(ticket, DEAL_PRICE);
      trade.entry_sl = HistoryDealGetDouble(ticket, DEAL_SL);
      return;
   }
}

double GDPanelEstimateRiskMoney(const GDPanelClosedTrade &trade)
{
   if(trade.entry_sl <= 0.0 || trade.open_price <= 0.0 || trade.volume <= 0.0 || trade.symbol == "")
      return 0.0;

   double tick_size = SymbolInfoDouble(trade.symbol, SYMBOL_TRADE_TICK_SIZE);
   double tick_value = SymbolInfoDouble(trade.symbol, SYMBOL_TRADE_TICK_VALUE);
   if(tick_size <= 0.0 || tick_value <= 0.0)
      return 0.0;

   double price_risk = MathAbs(trade.open_price - trade.entry_sl);
   return (price_risk / tick_size) * tick_value * trade.volume;
}

void GDPanelSortTradesByCloseTimeDesc(GDPanelClosedTrade &trades[])
{
   int count = ArraySize(trades);
   for(int i = 0; i < count - 1; i++)
   {
      for(int j = i + 1; j < count; j++)
      {
         if(trades[j].close_time > trades[i].close_time)
         {
            GDPanelClosedTrade temp = trades[i];
            trades[i] = trades[j];
            trades[j] = temp;
         }
      }
   }
}

void GDPanelSortTradesByCloseTimeAsc(GDPanelClosedTrade &trades[])
{
   int count = ArraySize(trades);
   for(int i = 0; i < count - 1; i++)
   {
      for(int j = i + 1; j < count; j++)
      {
         if(trades[j].close_time < trades[i].close_time)
         {
            GDPanelClosedTrade temp = trades[i];
            trades[i] = trades[j];
            trades[j] = temp;
         }
      }
   }
}

int GDPanelBuildClosedTrades(datetime from_time, datetime to_time, GDPanelClosedTrade &trades[], bool apply_filters = true)
{
   ArrayResize(trades, 0);
   if(!HistorySelect(from_time, to_time))
      return 0;

   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0 || !GDPanelIsTradeCloseDeal(ticket))
         continue;

      string symbol = HistoryDealGetString(ticket, DEAL_SYMBOL);
      if(apply_filters && !GDPanelScopeAllowsSymbol(symbol))
         continue;

      ulong position_id = (ulong)HistoryDealGetInteger(ticket, DEAL_POSITION_ID);
      if(position_id == 0)
         continue;

      int index = GDPanelFindTradeIndex(trades, position_id);
      if(index < 0)
      {
         index = ArraySize(trades);
         ArrayResize(trades, index + 1);
         GDPanelInitClosedTrade(trades[index], position_id);
      }

      datetime close_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      if(close_time > trades[index].close_time)
      {
         trades[index].close_time = close_time;
         trades[index].close_price = HistoryDealGetDouble(ticket, DEAL_PRICE);
      }

      trades[index].symbol = symbol;
      trades[index].profit += HistoryDealGetDouble(ticket, DEAL_PROFIT);
      trades[index].commission += HistoryDealGetDouble(ticket, DEAL_COMMISSION);
      trades[index].swap += HistoryDealGetDouble(ticket, DEAL_SWAP);
   }

   int count = ArraySize(trades);
   int kept = 0;
   long magic_filter = GDPanelMagicFilter();
   for(int t = 0; t < count; t++)
   {
      GDPanelFillEntryDetails(trades[t]);
      if(apply_filters && InpGlobalDollarPanelFilterByMagicNumber && trades[t].magic != magic_filter)
         continue;

      trades[t].net = trades[t].profit + trades[t].commission + trades[t].swap;
      trades[t].risk_money = GDPanelEstimateRiskMoney(trades[t]);
      trades[t].rr = (trades[t].risk_money > 0.0 ? trades[t].net / trades[t].risk_money : 0.0);

      if(kept != t)
         trades[kept] = trades[t];
      kept++;
   }

   ArrayResize(trades, kept);
   return kept;
}

double GDPanelDealBalanceChange(ulong ticket)
{
   return HistoryDealGetDouble(ticket, DEAL_PROFIT) +
          HistoryDealGetDouble(ticket, DEAL_COMMISSION) +
          HistoryDealGetDouble(ticket, DEAL_SWAP);
}

bool GDPanelBalanceAtTime(datetime balance_time, double &balance)
{
   datetime now = TimeCurrent();
   if(!HistorySelect(0, now))
      return false;

   double later_changes = 0.0;
   int total = HistoryDealsTotal();
   for(int i = 0; i < total; i++)
   {
      ulong ticket = HistoryDealGetTicket(i);
      if(ticket == 0)
         continue;

      datetime deal_time = (datetime)HistoryDealGetInteger(ticket, DEAL_TIME);
      if(deal_time < balance_time || deal_time > now)
         continue;

      later_changes += GDPanelDealBalanceChange(ticket);
   }

   balance = AccountInfoDouble(ACCOUNT_BALANCE) - later_changes;
   return true;
}

void GDPanelSaveDailyState()
{
   GlobalVariableSet(GDPanelDailyEquityKey(g_gdPanelCurrentUtcDay), g_gdPanelDailyStartEquity);
   GlobalVariableSet(GDPanelDailyMinEquityKey(g_gdPanelCurrentUtcDay), g_gdPanelDailyMinEquity);
}

void GDPanelLoadOrResetDailyState()
{
   datetime utc_day = GDPanelUtcDayStart(TimeGMT());
   bool had_loaded_day = (g_gdPanelCurrentUtcDay != 0);
   bool new_day = (utc_day != g_gdPanelCurrentUtcDay);
   g_gdPanelCurrentUtcDay = utc_day;

   string equity_key = GDPanelDailyEquityKey(utc_day);
   string min_key = GDPanelDailyMinEquityKey(utc_day);
   double current_equity = AccountInfoDouble(ACCOUNT_EQUITY);
   double current_balance = AccountInfoDouble(ACCOUNT_BALANCE);

   if(!new_day && GlobalVariableCheck(equity_key))
      g_gdPanelDailyStartEquity = GlobalVariableGet(equity_key);
   else if(GlobalVariableCheck(equity_key))
      g_gdPanelDailyStartEquity = GlobalVariableGet(equity_key);
   else
   {
      double reconstructed_balance = 0.0;
      datetime reset_in_server_time = GDPanelServerTimeForUtc(utc_day);
      g_gdPanelDailyStartEquity = (had_loaded_day && new_day ? MathMax(current_balance, current_equity) : (GDPanelBalanceAtTime(reset_in_server_time, reconstructed_balance) ? reconstructed_balance : MathMax(current_balance, current_equity)));
      GlobalVariableSet(equity_key, g_gdPanelDailyStartEquity);
   }

   if(!new_day && GlobalVariableCheck(min_key))
      g_gdPanelDailyMinEquity = GlobalVariableGet(min_key);
   else if(GlobalVariableCheck(min_key))
      g_gdPanelDailyMinEquity = GlobalVariableGet(min_key);
   else
   {
      g_gdPanelDailyMinEquity = current_equity;
      GlobalVariableSet(min_key, g_gdPanelDailyMinEquity);
   }

   if(current_equity < g_gdPanelDailyMinEquity)
   {
      g_gdPanelDailyMinEquity = current_equity;
      GDPanelSaveDailyState();
   }
}

string GDPanelTimeLeftToUtcReset()
{
   datetime now = TimeGMT();
   datetime next_reset = GDPanelUtcDayStart(now) + 86400;
   int seconds_left = (int)MathMax(0, next_reset - now);
   int hours = seconds_left / 3600;
   int minutes = (seconds_left % 3600) / 60;
   int seconds = seconds_left % 60;
   return StringFormat("%02d:%02d:%02d", hours, minutes, seconds);
}

string GDPanelFormatAmPm(datetime value)
{
   MqlDateTime parts;
   TimeToStruct(value, parts);
   string suffix = (parts.hour >= 12 ? "PM" : "AM");
   int hour = parts.hour % 12;
   if(hour == 0)
      hour = 12;
   return StringFormat("%02d/%02d %02d:%02d %s", parts.mon, parts.day, hour, parts.min, suffix);
}

string GDPanelNextUtcResetInIst()
{
   datetime next_reset = GDPanelUtcDayStart(TimeGMT()) + 86400;
   return GDPanelFormatAmPm(next_reset + 5 * 3600 + 30 * 60);
}

color GDPanelStatusColor(double left, double limit)
{
   if(left < 0.0)
      return GDBadColor();
   if(left <= MathMax(1.0, limit * 0.2))
      return GDWarnColor();
   return GDGoodColor();
}

color GDPanelLagColor(double lag_percent, int sample_count)
{
   if(sample_count <= 0)
      return GDMutedColor();
   if(lag_percent > 0.0)
      return GDBadColor();
   if(lag_percent < 0.0)
      return GDGoodColor();
   return GDTextColor();
}

double GDPanelDrawdownLimitMoney(ENUM_DRAWDOWN_LIMIT_MODE mode, double value, double baseline)
{
   if(mode == DD_LIMIT_PERCENT_OF_BASE)
      return MathMax(0.0, baseline * value / 100.0);
   if(mode == DD_LIMIT_PERCENT_OF_START)
      return MathMax(0.0, InpGlobalDollarPanelStartingBalance * value / 100.0);
   return MathMax(0.0, value);
}

