//| Save Multi-Order Recovery State to File                          |
//+------------------------------------------------------------------+
void SaveRecoveryState()
{
   // Skip file operations during backtesting to improve performance
   if(g_is_backtesting) return;
   
   if(!InpMultiOrderEnabled &&
      !InpStochRSIConfirmationEnabled &&
      !InpHARecoveryConfirmationEnabled &&
      !InpMACDRecoveryConfirmationEnabled &&
      !InpROCRecoveryConfirmationEnabled &&
      !InpVolumeRecoveryConfirmationEnabled &&
      !InpPercentageRecoveryConfirmationEnabled &&
      !InpPattern9RecoveryConfirmationEnabled &&
      !InpOHLCLevelRecoveryConfirmationEnabled) return;

   string file_name = GetStateFileName();
   int file_handle = FileOpen(file_name, FILE_WRITE | FILE_CSV);

   if(file_handle == INVALID_HANDLE)
   {
      PrintFormat("Failed to open recovery state file '%s' for writing. Error: %d", file_name, GetLastError());
      return;
   }
   
   // Save stochastic RSI state
   if(InpStochRSIConfirmationEnabled)
   {
      int stoch_file_handle = FileOpen(GetStateFileName() + ".stoch", FILE_WRITE | FILE_CSV);
      if(stoch_file_handle != INVALID_HANDLE)
      {
         FileWrite(stoch_file_handle, "stoch_buy_ready", "stoch_sell_ready");
         FileWrite(stoch_file_handle, (string)g_stochastic_buy_ready, (string)g_stochastic_sell_ready);
         FileClose(stoch_file_handle);
      }
   }
   
   // Save HeikinAshi recovery state
   if(InpHARecoveryConfirmationEnabled)
   {
      int ha_file_handle = FileOpen(GetStateFileName() + ".ha", FILE_WRITE | FILE_CSV);
      if(ha_file_handle != INVALID_HANDLE)
      {
         FileWrite(ha_file_handle, "ha_buy_ready", "ha_sell_ready", "consecutive_green", "consecutive_red");
         FileWrite(ha_file_handle, (string)g_ha_recovery_buy_ready, (string)g_ha_recovery_sell_ready, 
                  (string)g_ha_recovery_consecutive_green, (string)g_ha_recovery_consecutive_red);
         FileClose(ha_file_handle);
      }
   }
   
   // Save MACD recovery state
   if(InpMACDRecoveryConfirmationEnabled)
   {
      int macd_file_handle = FileOpen(GetStateFileName() + ".macd", FILE_WRITE | FILE_CSV);
      if(macd_file_handle != INVALID_HANDLE)
      {
         FileWrite(macd_file_handle, "macd_buy_ready", "macd_sell_ready", "prev_main", "prev_signal");
         FileWrite(macd_file_handle, (string)g_macd_recovery_buy_ready, (string)g_macd_recovery_sell_ready, 
                  DoubleToString(g_macd_prev_main, 6), DoubleToString(g_macd_prev_signal, 6));
         FileClose(macd_file_handle);
      }
   }
   
   // Save ROC recovery state
   if(InpROCRecoveryConfirmationEnabled)
   {
      int roc_file_handle = FileOpen(GetStateFileName() + ".roc", FILE_WRITE | FILE_CSV);
      if(roc_file_handle != INVALID_HANDLE)
      {
         FileWrite(roc_file_handle, "roc_buy_ready", "roc_sell_ready", "prev_value");
         FileWrite(roc_file_handle, (string)g_roc_recovery_buy_ready, (string)g_roc_recovery_sell_ready, 
                  DoubleToString(g_roc_prev_value, 6));
         FileClose(roc_file_handle);
      }
   }

   // Write headers for multi-order recovery groups
   FileWrite(file_handle, "base_ticket", "ticket_count", "tickets", "symbol", "type", "original_lot", "total_volume", "original_sl", "original_entry", "original_tp", "potential_profit", "max_allowed_loss", "attempts", "activated", "original_sl_distance");

   for(int i = 0; i < ArraySize(MultiOrderGroups); i++)
   {
      string tickets_str = "";
      for(int j = 0; j < MultiOrderGroups[i].ticket_count; j++)
      {
         tickets_str += (j > 0 ? "," : "") + IntegerToString((long)MultiOrderGroups[i].tickets[j]);
      }

      FileWrite(file_handle,
                (string)MultiOrderGroups[i].base_ticket,
                (string)MultiOrderGroups[i].ticket_count,
                tickets_str,
                MultiOrderGroups[i].symbol,
                (string)MultiOrderGroups[i].type,
                DoubleToString(MultiOrderGroups[i].original_lot, 2),
                DoubleToString(MultiOrderGroups[i].total_volume, 2),
                DoubleToString(MultiOrderGroups[i].original_sl, 5),
                DoubleToString(MultiOrderGroups[i].original_entry, 5),
                DoubleToString(MultiOrderGroups[i].original_tp, 5),
                DoubleToString(MultiOrderGroups[i].potential_profit, 2),
                DoubleToString(MultiOrderGroups[i].max_allowed_loss, 2),
                (string)MultiOrderGroups[i].attempts,
                (string)MultiOrderGroups[i].activated,
                DoubleToString(MultiOrderGroups[i].original_sl_distance, 5)
               );
   }

   FileClose(file_handle);
}
