#include <Trade/Trade.mqh>

enum ENUM_RISK_MODE
{
   RISK_MODE_FIXED_LOT = 0,
   RISK_MODE_CURRENT_BALANCE_PERCENT = 1,
   RISK_MODE_STARTING_BALANCE_PERCENT = 2
};

input long   InpMagicNumber            = 12345;
input int    InpTakeProfitPoints       = 1000;
input int    InpStopLossPoints         = 1000;
input int    InpTrailingStartPoints    = 100;
input int    InpTrailingDistancePoints = 50;
input bool   InpTrailByThresholdSteps  = true;
input int    InpMaxConcurrentPositions = 1;

input group "Risk Settings"
input ENUM_RISK_MODE InpRiskMode       = RISK_MODE_FIXED_LOT;
input double InpFixedLotSize           = 0.10;
input double InpRiskPercent            = 1.0;
input double InpStartingBalance        = 1000.0;

CTrade trade;

string   EA_TAG                 = "PrevDayBreakoutEA";
string   TRAIL_LINE_BUY_NAME    = "PrevDayBreakout_Trail_BUY";
string   TRAIL_LINE_SELL_NAME   = "PrevDayBreakout_Trail_SELL";
datetime g_lastDailyBarTime     = 0;
datetime g_lastPlacedDayStart   = 0;
bool     g_dailyOrdersPlaced    = false;
bool     g_pendingDayReset      = false;
datetime g_lastRetryAttemptTime = 0;
int      g_retryIntervalSeconds = 30;
bool     g_skipCurrentDaySignal = false;
ulong    g_trailPosIds[];
bool     g_trailWasActivated[];
ulong    g_trailActivationLoggedPosIds[];

bool GetLastCompletedWeekdayCandleOHLC(double &outHigh, double &outLow)
{
   // Skip broker weekend glitch candles and use the latest completed Mon-Fri candle.
   for(int shift = 1; shift <= 14; shift++)
   {
      datetime barTime = iTime(_Symbol, PERIOD_D1, shift);
      if(barTime <= 0)
         continue;

      MqlDateTime dt;
      TimeToStruct(barTime, dt);
      if(dt.day_of_week == 0 || dt.day_of_week == 6) // Sunday or Saturday
         continue;

      double barHigh = iHigh(_Symbol, PERIOD_D1, shift);
      double barLow  = iLow(_Symbol, PERIOD_D1, shift);
      if(barHigh > 0.0 && barLow > 0.0)
      {
         outHigh = barHigh;
         outLow = barLow;
         return true;
      }
   }

   return false;
}

//+------------------------------------------------------------------+
//| Expert initialization                                            |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);
   trade.SetDeviationInPoints(20);

   g_lastDailyBarTime = iTime(_Symbol, PERIOD_D1, 0);
   if(g_lastDailyBarTime > 0)
   {
      g_lastPlacedDayStart = g_lastDailyBarTime;
      g_pendingDayReset = true;
   }

   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Expert deinitialization                                          |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   ObjectDelete(0, TRAIL_LINE_BUY_NAME);
   ObjectDelete(0, TRAIL_LINE_SELL_NAME);
}

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   DetectNewDayAndRefresh();
   TryProcessPendingDayReset();
   EnforceMaxPositionLimit();
   EnsureDailyPendingOrdersPlaced();
   ManageTrailingStopsTickByTick();
}

//+------------------------------------------------------------------+
//| Trade transaction handler                                        |
//+------------------------------------------------------------------+
void OnTradeTransaction(const MqlTradeTransaction &trans, const MqlTradeRequest &request, const MqlTradeResult &result)
{
   if(trans.type != TRADE_TRANSACTION_DEAL_ADD)
      return;

   if(trans.deal == 0 || !HistoryDealSelect(trans.deal))
      return;

   string sym = HistoryDealGetString(trans.deal, DEAL_SYMBOL);
   long magic = (long)HistoryDealGetInteger(trans.deal, DEAL_MAGIC);
   if(sym != _Symbol || magic != InpMagicNumber)
      return;

   long entry = (long)HistoryDealGetInteger(trans.deal, DEAL_ENTRY);
   ulong posId = (ulong)HistoryDealGetInteger(trans.deal, DEAL_POSITION_ID);

   if(entry == DEAL_ENTRY_IN)
   {
      LogEntryRiskReward(trans.deal, posId);
      return;
   }

   if(entry != DEAL_ENTRY_OUT)
      return;

   long reason = (long)HistoryDealGetInteger(trans.deal, DEAL_REASON);

   if(reason == DEAL_REASON_SL)
   {
      if(WasTrailingSLActivated(posId))
         Print("[", EA_TAG, "] Trailing SL Exit. PositionId=", posId, " Deal=", trans.deal);
      else
         Print("[", EA_TAG, "] Full SL Exit. PositionId=", posId, " Deal=", trans.deal);
   }

   RemoveTrailingState(posId);
   RemoveTrailActivationLoggedState(posId);
}

//+------------------------------------------------------------------+
//| Detect day change and reset                                      |
//+------------------------------------------------------------------+
void DetectNewDayAndRefresh()
{
   datetime currentD1Start = iTime(_Symbol, PERIOD_D1, 0);
   if(currentD1Start <= 0)
      return;

   if(currentD1Start != g_lastDailyBarTime)
   {
      g_lastDailyBarTime = currentD1Start;
      g_lastPlacedDayStart = currentD1Start;
      g_pendingDayReset = true;
      g_dailyOrdersPlaced = false;
      g_skipCurrentDaySignal = false;
      g_lastRetryAttemptTime = 0;
   }
}

//+------------------------------------------------------------------+
//| Check if symbol can be traded in current server session          |
//+------------------------------------------------------------------+
bool IsSymbolTradeOpenNow()
{
   long tradeMode = SymbolInfoInteger(_Symbol, SYMBOL_TRADE_MODE);
   if(tradeMode == SYMBOL_TRADE_MODE_DISABLED || tradeMode == SYMBOL_TRADE_MODE_CLOSEONLY)
      return false;

   if(!TerminalInfoInteger(TERMINAL_TRADE_ALLOWED) || !MQLInfoInteger(MQL_TRADE_ALLOWED))
      return false;

   datetime nowTs = TimeTradeServer();
   if(nowTs <= 0)
      nowTs = TimeCurrent();
   if(nowTs <= 0)
      return false;

   MqlDateTime dt;
   TimeToStruct(nowTs, dt);
   ENUM_DAY_OF_WEEK dow = (ENUM_DAY_OF_WEEK)dt.day_of_week;
   int secNow = dt.hour * 3600 + dt.min * 60 + dt.sec;

   datetime from = 0, to = 0;
   bool hasAnySession = false;
   for(int i = 0; i < 10; i++)
   {
      if(!SymbolInfoSessionTrade(_Symbol, dow, i, from, to))
         break;

      hasAnySession = true;
      MqlDateTime sFrom, sTo;
      TimeToStruct(from, sFrom);
      TimeToStruct(to, sTo);
      int secFrom = sFrom.hour * 3600 + sFrom.min * 60 + sFrom.sec;
      int secTo   = sTo.hour * 3600 + sTo.min * 60 + sTo.sec;

      if(secFrom <= secTo)
      {
         if(secNow >= secFrom && secNow <= secTo)
            return true;
      }
      else
      {
         // Overnight session (crosses midnight).
         if(secNow >= secFrom || secNow <= secTo)
            return true;
      }
   }

   // If broker does not expose sessions, fall back to quote availability.
   if(!hasAnySession)
   {
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
      return (bid > 0.0 && ask > 0.0);
   }

   return false;
}

int CountEAOwnOpenPositions()
{
   int count = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0 || !PositionSelectByTicket(ticket))
         continue;

      string sym = PositionGetString(POSITION_SYMBOL);
      long magic = (long)PositionGetInteger(POSITION_MAGIC);
      if(sym == _Symbol && magic == InpMagicNumber)
         count++;
   }
   return count;
}

int EffectiveMaxConcurrentPositions()
{
   return MathMax(1, InpMaxConcurrentPositions);
}

bool IsMaxPositionLimitReached()
{
   return (CountEAOwnOpenPositions() >= EffectiveMaxConcurrentPositions());
}

void EnforceMaxPositionLimit()
{
   if(!IsMaxPositionLimitReached())
      return;

   // Prevent any additional entries once max open positions is reached.
   DeleteAllEAOwnPendingOrders();
}

//+------------------------------------------------------------------+
//| Execute new-day reset only when symbol is tradable               |
//+------------------------------------------------------------------+
void TryProcessPendingDayReset()
{
   if(!g_pendingDayReset)
      return;

   if(!IsSymbolTradeOpenNow())
      return;

   ResetForNewDayAndPlaceOrders();
   g_pendingDayReset = false;
}

//+------------------------------------------------------------------+
//| Reset daily orders/positions and place fresh pending orders      |
//+------------------------------------------------------------------+
void ResetForNewDayAndPlaceOrders()
{
   if(IsMaxPositionLimitReached())
   {
      g_skipCurrentDaySignal = true;
      g_dailyOrdersPlaced = true;
      Print("[", EA_TAG, "] Max open position limit reached. Current day signal skipped.");
      return;
   }

   DeleteAllEAOwnPendingOrders();
   ObjectDelete(0, TRAIL_LINE_BUY_NAME);
   ObjectDelete(0, TRAIL_LINE_SELL_NAME);
   g_dailyOrdersPlaced = false;

   double prevHigh = 0.0;
   double prevLow  = 0.0;
   if(!GetLastCompletedWeekdayCandleOHLC(prevHigh, prevLow))
   {
      Print("[", EA_TAG, "] Previous weekday (Mon-Fri) OHLC not available yet.");
      return;
   }

   // Try immediately; if market/session is closed this will be retried on next ticks.
   PlaceBreakoutPendingOrders(prevHigh, prevLow);
}

//+------------------------------------------------------------------+
//| Place both buy stop and sell stop                                |
//+------------------------------------------------------------------+
bool HasPendingOrPositionSide(bool isBuySide)
{
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0 || !OrderSelect(ticket))
         continue;

      string sym = OrderGetString(ORDER_SYMBOL);
      long magic = (long)OrderGetInteger(ORDER_MAGIC);
      if(sym != _Symbol || magic != InpMagicNumber)
         continue;

      ENUM_ORDER_TYPE type = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(isBuySide && (type == ORDER_TYPE_BUY_STOP || type == ORDER_TYPE_BUY_LIMIT || type == ORDER_TYPE_BUY_STOP_LIMIT))
         return true;
      if(!isBuySide && (type == ORDER_TYPE_SELL_STOP || type == ORDER_TYPE_SELL_LIMIT || type == ORDER_TYPE_SELL_STOP_LIMIT))
         return true;
   }

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0 || !PositionSelectByTicket(ticket))
         continue;

      string sym = PositionGetString(POSITION_SYMBOL);
      long magic = (long)PositionGetInteger(POSITION_MAGIC);
      if(sym != _Symbol || magic != InpMagicNumber)
         continue;

      long posType = PositionGetInteger(POSITION_TYPE);
      if(isBuySide && posType == POSITION_TYPE_BUY)
         return true;
      if(!isBuySide && posType == POSITION_TYPE_SELL)
         return true;
   }

   return false;
}

//+------------------------------------------------------------------+
//| Place only missing side pending orders                           |
//+------------------------------------------------------------------+
void PlaceBreakoutPendingOrders(double buyPrice, double sellPrice)
{
   if(g_skipCurrentDaySignal)
   {
      g_dailyOrdersPlaced = true;
      return;
   }

   if(IsMaxPositionLimitReached())
   {
      g_dailyOrdersPlaced = true;
      return;
   }

   if(!IsSymbolTradeOpenNow())
   {
      g_dailyOrdersPlaced = false;
      return;
   }

   double lotSize = CalculateLotSizeByRiskMode();
   if(lotSize <= 0.0)
   {
      Print("[", EA_TAG, "] Lot size calculation failed. Orders not placed.");
      return;
   }

   double slBuy = NormalizeDouble(buyPrice - InpStopLossPoints * _Point, _Digits);
   double tpBuy = NormalizeDouble(buyPrice + InpTakeProfitPoints * _Point, _Digits);

   double slSell = NormalizeDouble(sellPrice + InpStopLossPoints * _Point, _Digits);
   double tpSell = NormalizeDouble(sellPrice - InpTakeProfitPoints * _Point, _Digits);

   buyPrice  = NormalizeDouble(buyPrice, _Digits);
   sellPrice = NormalizeDouble(sellPrice, _Digits);

   trade.SetExpertMagicNumber(InpMagicNumber);

   bool hasBuySide = HasPendingOrPositionSide(true);
   bool hasSellSide = HasPendingOrPositionSide(false);

   bool buyOk = hasBuySide;
   bool sellOk = hasSellSide;
   uint buyRetcode = 0;
   uint sellRetcode = 0;

   int stopLevelPts = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   double minGap = stopLevelPts * _Point;
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);

   if(!hasBuySide)
   {
      bool buyPriceValidNow = (buyPrice > ask + minGap);
      if(buyPriceValidNow)
      {
         buyOk = trade.BuyStop(lotSize, buyPrice, _Symbol, slBuy, tpBuy, ORDER_TIME_DAY, 0, "PrevDayBuyBreakout");
         buyRetcode = trade.ResultRetcode();
         if(!buyOk && buyRetcode != TRADE_RETCODE_MARKET_CLOSED && buyRetcode != TRADE_RETCODE_INVALID_PRICE)
            Print("[", EA_TAG, "] BuyStop failed. Retcode=", buyRetcode, " ", trade.ResultRetcodeDescription());
      }
      else
      {
         buyOk = false;
      }
   }

   if(!hasSellSide)
   {
      bool sellPriceValidNow = (sellPrice < bid - minGap);
      if(sellPriceValidNow)
      {
         sellOk = trade.SellStop(lotSize, sellPrice, _Symbol, slSell, tpSell, ORDER_TIME_DAY, 0, "PrevDaySellBreakout");
         sellRetcode = trade.ResultRetcode();
         if(!sellOk && sellRetcode != TRADE_RETCODE_MARKET_CLOSED && sellRetcode != TRADE_RETCODE_INVALID_PRICE)
            Print("[", EA_TAG, "] SellStop failed. Retcode=", sellRetcode, " ", trade.ResultRetcodeDescription());
      }
      else
      {
         sellOk = false;
      }
   }

   if((buyOk || hasBuySide) && (sellOk || hasSellSide))
   {
      g_dailyOrdersPlaced = true;
      Print("[", EA_TAG, "] New day pending orders placed. Lot=", DoubleToString(lotSize, 2), " BuyStop=", buyPrice, " SellStop=", sellPrice);
   }
   else
   {
      g_dailyOrdersPlaced = false;
   }
}

//+------------------------------------------------------------------+
//| Retry daily pending placement until market/session opens         |
//+------------------------------------------------------------------+
void EnsureDailyPendingOrdersPlaced()
{
   if(g_dailyOrdersPlaced)
      return;
   if(g_pendingDayReset)
      return;
   if(g_skipCurrentDaySignal)
   {
      g_dailyOrdersPlaced = true;
      return;
   }
   if(IsMaxPositionLimitReached())
   {
      g_dailyOrdersPlaced = true;
      return;
   }

   datetime currentD1Start = iTime(_Symbol, PERIOD_D1, 0);
   if(currentD1Start <= 0 || currentD1Start != g_lastPlacedDayStart)
      return;

   datetime nowTs = TimeCurrent();
   if(g_lastRetryAttemptTime > 0 && (nowTs - g_lastRetryAttemptTime) < g_retryIntervalSeconds)
      return;
   g_lastRetryAttemptTime = nowTs;

   // Avoid retry spam when symbol cannot trade in this tick/session.
   if(!IsSymbolTradeOpenNow())
      return;

   bool hasBuySide = false;
   bool hasSellSide = false;

   // Check pending orders first.
   for(int i = OrdersTotal() - 1; i >= 0; i--)
   {
      ulong ticket = OrderGetTicket(i);
      if(ticket == 0 || !OrderSelect(ticket))
         continue;

      string sym = OrderGetString(ORDER_SYMBOL);
      long magic = (long)OrderGetInteger(ORDER_MAGIC);
      ENUM_ORDER_TYPE type = (ENUM_ORDER_TYPE)OrderGetInteger(ORDER_TYPE);
      if(sym != _Symbol || magic != InpMagicNumber)
         continue;

      if(type == ORDER_TYPE_BUY_STOP || type == ORDER_TYPE_BUY_LIMIT || type == ORDER_TYPE_BUY_STOP_LIMIT)
         hasBuySide = true;
      else if(type == ORDER_TYPE_SELL_STOP || type == ORDER_TYPE_SELL_LIMIT || type == ORDER_TYPE_SELL_STOP_LIMIT)
         hasSellSide = true;
   }

   // Also count already-triggered positions as side present.
   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0 || !PositionSelectByTicket(ticket))
         continue;

      string sym = PositionGetString(POSITION_SYMBOL);
      long magic = (long)PositionGetInteger(POSITION_MAGIC);
      if(sym != _Symbol || magic != InpMagicNumber)
         continue;

      long posType = PositionGetInteger(POSITION_TYPE);
      if(posType == POSITION_TYPE_BUY)
         hasBuySide = true;
      else if(posType == POSITION_TYPE_SELL)
         hasSellSide = true;
   }

   if(hasBuySide && hasSellSide)
   {
      g_dailyOrdersPlaced = true;
      return;
   }

   double prevHigh = 0.0;
   double prevLow  = 0.0;
   if(!GetLastCompletedWeekdayCandleOHLC(prevHigh, prevLow))
      return;

   PlaceBreakoutPendingOrders(prevHigh, prevLow);
}

//+------------------------------------------------------------------+
//| Calculate lot based on selected risk mode                        |
//+------------------------------------------------------------------+
double CalculateLotSizeByRiskMode()
{
   if(InpRiskMode == RISK_MODE_FIXED_LOT)
      return NormalizeLotToSymbol(InpFixedLotSize);

   if(InpStopLossPoints <= 0)
      return 0.0;

   double baseBalance = 0.0;
   if(InpRiskMode == RISK_MODE_CURRENT_BALANCE_PERCENT)
      baseBalance = AccountInfoDouble(ACCOUNT_BALANCE);
   else if(InpRiskMode == RISK_MODE_STARTING_BALANCE_PERCENT)
      baseBalance = InpStartingBalance;

   if(baseBalance <= 0.0 || InpRiskPercent <= 0.0)
      return 0.0;

   double riskMoney = baseBalance * (InpRiskPercent / 100.0);
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);

   if(tickValue <= 0.0 || tickSize <= 0.0)
      return 0.0;

   // Money value of one point move for 1.00 lot.
   double pointValuePerLot = tickValue * (_Point / tickSize);
   if(pointValuePerLot <= 0.0)
      return 0.0;

   double moneyLossPerLotAtSL = InpStopLossPoints * pointValuePerLot;
   if(moneyLossPerLotAtSL <= 0.0)
      return 0.0;

   double rawLot = riskMoney / moneyLossPerLotAtSL;
   return NormalizeLotToSymbol(rawLot);
}

//+------------------------------------------------------------------+
//| Normalize lot to broker min/max/step                             |
//+------------------------------------------------------------------+
double NormalizeLotToSymbol(double lot)
{
   double volMin  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double volMax  = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   double volStep = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_STEP);

   if(volMin <= 0.0 || volMax <= 0.0 || volStep <= 0.0)
      return 0.0;

   double normalized = MathFloor((lot + 1e-12) / volStep) * volStep;
   if(normalized < volMin)
      normalized = volMin;
   if(normalized > volMax)
      normalized = volMax;

   int digits = 2;
   if(volStep < 1.0)
      digits = (int)MathRound(-MathLog10(volStep));

   return NormalizeDouble(normalized, digits);
}

//+------------------------------------------------------------------+
//| Manage trailing SL each tick                                     |
//+------------------------------------------------------------------+
void ManageTrailingStopsTickByTick()
{
   bool hasBuyPos = false;
   bool hasSellPos = false;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);
      if(ticket == 0)
         continue;

      if(!PositionSelectByTicket(ticket))
         continue;

      string sym = PositionGetString(POSITION_SYMBOL);
      long magic = (long)PositionGetInteger(POSITION_MAGIC);
      if(sym != _Symbol || magic != InpMagicNumber)
         continue;

      long type = PositionGetInteger(POSITION_TYPE);
      ulong posId = (ulong)PositionGetInteger(POSITION_IDENTIFIER);
      double openPrice = PositionGetDouble(POSITION_PRICE_OPEN);
      double currentSL = PositionGetDouble(POSITION_SL);
      double currentTP = PositionGetDouble(POSITION_TP);

      EnsureTrailingState(posId, false);

      if(type == POSITION_TYPE_BUY)
      {
         hasBuyPos = true;
         double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
         double profitPoints = (bid - openPrice) / _Point;
         bool trailingEligible = (profitPoints >= InpTrailingStartPoints);

         if(trailingEligible)
         {
            if(!WasTrailActivationLogged(posId))
            {
               Print("[", EA_TAG, "] BUY position ", ticket, " now met trailing level at ",
                     DoubleToString(profitPoints, 1), " points. Trailing is now active.");
               MarkTrailActivationLogged(posId);
            }

            double desiredSL = 0.0;
            if(InpTrailByThresholdSteps && InpTrailingStartPoints > 0)
            {
               int steps = (int)MathFloor(profitPoints / InpTrailingStartPoints);
               double lockPoints = (steps * InpTrailingStartPoints) - InpTrailingDistancePoints;
               desiredSL = NormalizeDouble(openPrice + lockPoints * _Point, _Digits);
            }
            else
            {
               desiredSL = NormalizeDouble(bid - InpTrailingDistancePoints * _Point, _Digits);
            }

            if(desiredSL > currentSL && desiredSL < bid)
            {
               if(trade.PositionModify(ticket, desiredSL, currentTP))
               {
                  DrawOrUpdateTrailLine(TRAIL_LINE_BUY_NAME, desiredSL, clrLime);
                  EnsureTrailingState(posId, true);
               }
               else
               {
                  if(!TryApplyFallbackTrailSL(ticket, POSITION_TYPE_BUY, currentTP, desiredSL))
                     Print("[", EA_TAG, "] Buy trail modify failed. Retcode=", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());
               }
            }
            else
            {
               DrawOrUpdateTrailLine(TRAIL_LINE_BUY_NAME, desiredSL, clrLime);
            }
         }
      }
      else if(type == POSITION_TYPE_SELL)
      {
         hasSellPos = true;
         double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
         double profitPoints = (openPrice - ask) / _Point;
         bool trailingEligible = (profitPoints >= InpTrailingStartPoints);

         if(trailingEligible)
         {
            if(!WasTrailActivationLogged(posId))
            {
               Print("[", EA_TAG, "] SELL position ", ticket, " now met trailing level at ",
                     DoubleToString(profitPoints, 1), " points. Trailing is now active.");
               MarkTrailActivationLogged(posId);
            }

            double desiredSL = 0.0;
            if(InpTrailByThresholdSteps && InpTrailingStartPoints > 0)
            {
               int steps = (int)MathFloor(profitPoints / InpTrailingStartPoints);
               double lockPoints = (steps * InpTrailingStartPoints) - InpTrailingDistancePoints;
               desiredSL = NormalizeDouble(openPrice - lockPoints * _Point, _Digits);
            }
            else
            {
               desiredSL = NormalizeDouble(ask + InpTrailingDistancePoints * _Point, _Digits);
            }

            bool canMove = (currentSL == 0.0 || desiredSL < currentSL) && desiredSL > ask;
            if(canMove)
            {
               if(trade.PositionModify(ticket, desiredSL, currentTP))
               {
                  DrawOrUpdateTrailLine(TRAIL_LINE_SELL_NAME, desiredSL, clrTomato);
                  EnsureTrailingState(posId, true);
               }
               else
               {
                  if(!TryApplyFallbackTrailSL(ticket, POSITION_TYPE_SELL, currentTP, desiredSL))
                     Print("[", EA_TAG, "] Sell trail modify failed. Retcode=", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());
               }
            }
            else
            {
               DrawOrUpdateTrailLine(TRAIL_LINE_SELL_NAME, desiredSL, clrTomato);
            }
         }
      }
   }

   if(!hasBuyPos)
      ObjectDelete(0, TRAIL_LINE_BUY_NAME);
   if(!hasSellPos)
      ObjectDelete(0, TRAIL_LINE_SELL_NAME);
}

//+------------------------------------------------------------------+
//| Track whether trailing SL has been activated per position        |
//+------------------------------------------------------------------+
int FindTrailingStateIndex(ulong positionId)
{
   for(int i = 0; i < ArraySize(g_trailPosIds); i++)
   {
      if(g_trailPosIds[i] == positionId)
         return i;
   }
   return -1;
}

void EnsureTrailingState(ulong positionId, bool trailingActivated)
{
   if(positionId == 0)
      return;

   int idx = FindTrailingStateIndex(positionId);
   if(idx >= 0)
   {
      if(trailingActivated)
         g_trailWasActivated[idx] = true;
      return;
   }

   int newSize = ArraySize(g_trailPosIds) + 1;
   ArrayResize(g_trailPosIds, newSize);
   ArrayResize(g_trailWasActivated, newSize);
   g_trailPosIds[newSize - 1] = positionId;
   g_trailWasActivated[newSize - 1] = trailingActivated;
}

bool WasTrailingSLActivated(ulong positionId)
{
   int idx = FindTrailingStateIndex(positionId);
   if(idx < 0)
      return false;
   return g_trailWasActivated[idx];
}

void RemoveTrailingState(ulong positionId)
{
   int idx = FindTrailingStateIndex(positionId);
   if(idx < 0)
      return;

   int last = ArraySize(g_trailPosIds) - 1;
   if(idx != last)
   {
      g_trailPosIds[idx] = g_trailPosIds[last];
      g_trailWasActivated[idx] = g_trailWasActivated[last];
   }

   ArrayResize(g_trailPosIds, last);
   ArrayResize(g_trailWasActivated, last);
}

int FindTrailActivationLoggedIndex(ulong positionId)
{
   for(int i = 0; i < ArraySize(g_trailActivationLoggedPosIds); i++)
   {
      if(g_trailActivationLoggedPosIds[i] == positionId)
         return i;
   }
   return -1;
}

bool WasTrailActivationLogged(ulong positionId)
{
   return (FindTrailActivationLoggedIndex(positionId) >= 0);
}

void MarkTrailActivationLogged(ulong positionId)
{
   if(positionId == 0 || WasTrailActivationLogged(positionId))
      return;

   int newSize = ArraySize(g_trailActivationLoggedPosIds) + 1;
   ArrayResize(g_trailActivationLoggedPosIds, newSize);
   g_trailActivationLoggedPosIds[newSize - 1] = positionId;
}

void RemoveTrailActivationLoggedState(ulong positionId)
{
   int idx = FindTrailActivationLoggedIndex(positionId);
   if(idx < 0)
      return;

   int last = ArraySize(g_trailActivationLoggedPosIds) - 1;
   if(idx != last)
      g_trailActivationLoggedPosIds[idx] = g_trailActivationLoggedPosIds[last];

   ArrayResize(g_trailActivationLoggedPosIds, last);
}

double ComputeMoneyAtPrice(long posType, double volume, double entryPrice, double closePrice)
{
   double pnl = 0.0;
   ENUM_ORDER_TYPE calcType = (posType == POSITION_TYPE_BUY) ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   if(OrderCalcProfit(calcType, _Symbol, volume, entryPrice, closePrice, pnl))
      return pnl;

   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double tickSize  = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_SIZE);
   if(tickValue <= 0.0 || tickSize <= 0.0)
      return 0.0;

   double points = (posType == POSITION_TYPE_BUY)
                 ? ((closePrice - entryPrice) / _Point)
                 : ((entryPrice - closePrice) / _Point);
   double pointValuePerLot = tickValue * (_Point / tickSize);
   return points * pointValuePerLot * volume;
}

void LogEntryRiskReward(ulong dealTicket, ulong positionId)
{
   if(dealTicket == 0 || !HistoryDealSelect(dealTicket))
      return;

   double entryPrice = HistoryDealGetDouble(dealTicket, DEAL_PRICE);
   double volume     = HistoryDealGetDouble(dealTicket, DEAL_VOLUME);
   if(entryPrice <= 0.0 || volume <= 0.0)
      return;

   long dealTypeLong = HistoryDealGetInteger(dealTicket, DEAL_TYPE);
   long posType = -1;
   if(dealTypeLong == DEAL_TYPE_BUY)
      posType = POSITION_TYPE_BUY;
   else if(dealTypeLong == DEAL_TYPE_SELL)
      posType = POSITION_TYPE_SELL;
   else
      return;

   double sl = 0.0, tp = 0.0;
   bool gotPosition = false;
   if(positionId > 0)
      gotPosition = PositionSelectByTicket(positionId);

   if(gotPosition)
   {
      sl = PositionGetDouble(POSITION_SL);
      tp = PositionGetDouble(POSITION_TP);
   }
   else
   {
      sl = HistoryDealGetDouble(dealTicket, DEAL_SL);
      tp = HistoryDealGetDouble(dealTicket, DEAL_TP);
   }

   double maxLoss = 0.0;
   double maxProfit = 0.0;
   bool hasLoss = false;
   bool hasProfit = false;

   if(sl > 0.0)
   {
      double lossPnl = ComputeMoneyAtPrice(posType, volume, entryPrice, sl);
      maxLoss = MathAbs(lossPnl);
      hasLoss = true;
   }

   if(tp > 0.0)
   {
      double profitPnl = ComputeMoneyAtPrice(posType, volume, entryPrice, tp);
      maxProfit = MathAbs(profitPnl);
      hasProfit = true;
   }

   string rrText = "n/a";
   if(hasLoss && hasProfit && maxLoss > 0.0)
      rrText = DoubleToString(maxProfit / maxLoss, 2);

   string side = (posType == POSITION_TYPE_BUY) ? "BUY" : "SELL";
   Print("[", EA_TAG, "] ", side, " trade opened. PositionId=", positionId,
         " Entry=", DoubleToString(entryPrice, _Digits),
         " SL=", (sl > 0.0 ? DoubleToString(sl, _Digits) : "none"),
         " TP=", (tp > 0.0 ? DoubleToString(tp, _Digits) : "none"),
         " MaxLoss=", (hasLoss ? DoubleToString(maxLoss, 2) : "n/a"),
         " MaxProfit=", (hasProfit ? DoubleToString(maxProfit, 2) : "n/a"),
         " RR=", rrText);
}

bool TryApplyFallbackTrailSL(ulong ticket, long posType, double currentTP, double desiredSL)
{
   uint firstRetcode = trade.ResultRetcode();
   string firstDesc = trade.ResultRetcodeDescription();

   int stopLevelPts = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_STOPS_LEVEL);
   int freezeLevelPts = (int)SymbolInfoInteger(_Symbol, SYMBOL_TRADE_FREEZE_LEVEL);
   int minProtectPts = MathMax(stopLevelPts, freezeLevelPts) + 1;
   double minProtectGap = minProtectPts * _Point;

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double fallbackSL = desiredSL;

   if(posType == POSITION_TYPE_BUY)
      fallbackSL = NormalizeDouble(MathMin(desiredSL, bid - minProtectGap), _Digits);
   else if(posType == POSITION_TYPE_SELL)
      fallbackSL = NormalizeDouble(MathMax(desiredSL, ask + minProtectGap), _Digits);
   else
      return false;

   if((posType == POSITION_TYPE_BUY && fallbackSL <= 0.0) ||
      (posType == POSITION_TYPE_SELL && fallbackSL <= 0.0))
      return false;

   if(trade.PositionModify(ticket, fallbackSL, currentTP))
   {
      Print("[", EA_TAG, "] Trail modify fallback applied. Ticket=", ticket,
            " RequestedSL=", DoubleToString(desiredSL, _Digits),
            " FallbackSL=", DoubleToString(fallbackSL, _Digits),
            " InitialRetcode=", firstRetcode, " ", firstDesc);
      return true;
   }

   Print("[", EA_TAG, "] Trail modify failed even after fallback. Ticket=", ticket,
         " RequestedSL=", DoubleToString(desiredSL, _Digits),
         " FallbackSL=", DoubleToString(fallbackSL, _Digits),
         " InitialRetcode=", firstRetcode, " ", firstDesc,
         " FallbackRetcode=", trade.ResultRetcode(), " ", trade.ResultRetcodeDescription());
   return false;
}

