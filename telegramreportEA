string CapitalizeFirst(string value)
{
   if(StringLen(value) <= 0)
      return value;

   ushort first = StringGetCharacter(value, 0);
   if(first >= 'a' && first <= 'z')
      first -= 32;

   return ShortToString(first) + StringSubstr(value, 1);
}

string ShortDateTimeText(datetime value)
{
   if(value <= 0)
      return "n/a";

   MqlDateTime parts;
   TimeToStruct(value, parts);
   return TwoDigits(parts.mon) + "/" +
          TwoDigits(parts.day) + " " +
          TwoDigits(parts.hour) + ":" +
          TwoDigits(parts.min);
}

string PadRight(string value, int width)
{
   string result = value;
   while(StringLen(result) < width)
      result += " ";

   if(StringLen(result) > width)
      result = StringSubstr(result, 0, width);

   return result;
}

string PadLeft(string value, int width)
{
   string result = value;
   while(StringLen(result) < width)
      result = " " + result;

   if(StringLen(result) > width)
      result = StringSubstr(result, 0, width);

   return result;
}

string PadRightKeep(string value, int width)
{
   string result = value;
   while(StringLen(result) < width)
      result += " ";

   return result;
}

string PadLeftKeep(string value, int width)
{
   string result = value;
   while(StringLen(result) < width)
      result = " " + result;

   return result;
}

string EscapeHtml(string value)
{
   string result = value;
   StringReplace(result, "&", "&amp;");
   StringReplace(result, "<", "&lt;");
   StringReplace(result, ">", "&gt;");
   return result;
}

string StripTelegramHtml(string value)
{
   string result = value;
   StringReplace(result, "<b>", "");
   StringReplace(result, "</b>", "");
   StringReplace(result, "<code>", "");
   StringReplace(result, "</code>", "");
   StringReplace(result, "<pre>", "");
   StringReplace(result, "</pre>", "");
   StringReplace(result, "&amp;", "&");
   StringReplace(result, "&lt;", "<");
   StringReplace(result, "&gt;", ">");
   return result;
}

bool MagicNumberAllowed(long magic)
{
   if(!g_effective_magic_filter_enabled)
      return true;

   return magic == g_effective_magic_filter;
}

void RefreshEffectiveMagicFilterFromChart()
{
   g_effective_magic_filter_enabled = InpUseMagicNumberFilter;
   g_effective_magic_filter = InpMagicNumberFilter;

   if(ObjectFind(0, CUSTOM_MAGIC_EDIT_NAME) < 0)
      return;

   string magic_text = CustomEditText(CUSTOM_MAGIC_EDIT_NAME);
   string clean = CleanInput(magic_text);
   string lower = ToLowerText(clean);

   if(clean == "" || lower == "all" || lower == "off" || lower == "any")
   {
      g_effective_magic_filter_enabled = false;
      return;
   }

   g_effective_magic_filter = (long)StringToInteger(clean);
   g_effective_magic_filter_enabled = true;
}

