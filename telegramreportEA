              EscapeHtml(ShortDateTimeText(trades[worst_trade_index].close_time)) + "\n";

   return text;
}

string BuildStreakAnalysisText(const ClosedTrade &trades[], int count)
{
   int current_type = 0;
   int current_len = 0;
   int max_win_streak = 0;
   int max_loss_streak = 0;
   int win_streak_count = 0;
   int loss_streak_count = 0;
   int win_streak_sum = 0;
   int loss_streak_sum = 0;

   for(int i = count - 1; i >= 0; i--)
   {
      int outcome = TradeOutcomeCode(trades[i].net);
      if(outcome == 0)
      {
         FinishStreak(current_type, current_len,
                      max_win_streak, max_loss_streak,
                      win_streak_count, loss_streak_count,
                      win_streak_sum, loss_streak_sum);
         current_type = 0;
         current_len = 0;
         continue;
      }

      if(current_type == outcome)
      {
         current_len++;
      }
      else
      {
         FinishStreak(current_type, current_len,
                      max_win_streak, max_loss_streak,
                      win_streak_count, loss_streak_count,
                      win_streak_sum, loss_streak_sum);
         current_type = outcome;
         current_len = 1;
      }
   }

   int active_type = current_type;
   int active_len = current_len;
   FinishStreak(current_type, current_len,
                max_win_streak, max_loss_streak,
                win_streak_count, loss_streak_count,
                win_streak_sum, loss_streak_sum);

   double average_win_streak = (win_streak_count > 0 ? (double)win_streak_sum / win_streak_count : 0.0);
   double average_loss_streak = (loss_streak_count > 0 ? (double)loss_streak_sum / loss_streak_count : 0.0);

   string text = "\n<b>Streak Analysis</b>\n";
   text += "Current streak: <b>" + StreakText(active_type, active_len) + "</b>\n";
   text += "Win streaks: <b>" + (string)win_streak_count + "</b> | max <b>" + (string)max_win_streak + "</b> | avg <b>" + DoubleToString(average_win_streak, 1) + "</b>\n";
   text += "Loss streaks: <b>" + (string)loss_streak_count + "</b> | max <b>" + (string)max_loss_streak + "</b> | avg <b>" + DoubleToString(average_loss_streak, 1) + "</b>\n";
   return text;
}

void FinishStreak(int streak_type,
                  int streak_len,
                  int &max_win_streak,
                  int &max_loss_streak,
                  int &win_streak_count,
                  int &loss_streak_count,
                  int &win_streak_sum,
                  int &loss_streak_sum)
{
   if(streak_len <= 0)
      return;

   if(streak_type > 0)
   {
      win_streak_count++;
      win_streak_sum += streak_len;
      if(streak_len > max_win_streak)
         max_win_streak = streak_len;
   }
   else if(streak_type < 0)
   {
      loss_streak_count++;
      loss_streak_sum += streak_len;
      if(streak_len > max_loss_streak)
         max_loss_streak = streak_len;
   }
}

int TradeOutcomeCode(double value)
{
   if(IsBreakEvenTrade(value))
      return 0;
   if(value > 0.0)
      return 1;
   return -1;
}

string StreakText(int streak_type, int streak_len)
{
   if(streak_len <= 0 || streak_type == 0)
      return "BE/none";
   if(streak_type > 0)
      return (string)streak_len + " wins";
   return (string)streak_len + " losses";
}

datetime FirstTradeOpenTime(const ClosedTrade &trades[])
{
   datetime first_time = 0;
   int count = ArraySize(trades);

   for(int i = 0; i < count; i++)
   {
      if(trades[i].open_time <= 0)
         continue;

      if(first_time <= 0 || trades[i].open_time < first_time)
         first_time = trades[i].open_time;
   }

   return first_time;
}

bool BalanceAtTime(datetime balance_time, double &balance)
{
   if(balance_time <= 0)
      return false;

   datetime now = TimeCurrent();
   if(!HistorySelect(0, now))
   {
      Log("BalanceAtTime HistorySelect failed: " + (string)GetLastError());
      return false;
   }

   double later_balance_changes = 0.0;
   int deals_total = HistoryDealsTotal();
   for(int i = 0; i < deals_total; i++)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0)
         continue;

      datetime deal_time = (datetime)HistoryDealGetInteger(deal_ticket, DEAL_TIME);
      if(deal_time < balance_time || deal_time > now)
         continue;

      later_balance_changes += DealBalanceChange(deal_ticket);
   }

   balance = AccountInfoDouble(ACCOUNT_BALANCE) - later_balance_changes;
   return true;
}

double DealBalanceChange(ulong deal_ticket)
{
   double profit = HistoryDealGetDouble(deal_ticket, DEAL_PROFIT);
   double commission = HistoryDealGetDouble(deal_ticket, DEAL_COMMISSION);
   double swap = HistoryDealGetDouble(deal_ticket, DEAL_SWAP);
   return profit + commission + swap;
}

long TradeDurationMinutes(const ClosedTrade &trade)
{
   if(trade.open_time <= 0 || trade.close_time <= 0 || trade.close_time < trade.open_time)
      return 0;

   long seconds = (long)(trade.close_time - trade.open_time);
   long minutes = seconds / 60;
   if(seconds > 0 && minutes == 0)
      return 1;

   return minutes;
}

