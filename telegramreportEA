string MoneyText(double value)
{
   string currency = AccountInfoString(ACCOUNT_CURRENCY);
   string sign = (value >= 0.0 ? "+" : "");
   return sign + DoubleToString(value, 2) + " " + currency;
}

string MoneyTextNoCurrency(double value)
{
   string sign = (value >= 0.0 ? "+" : "");
   return sign + DoubleToString(value, 2);
}

string ResultStatusText(double value)
{
   if(value > 0.0)
      return "Net profitable";
   if(value < 0.0)
      return "Net loss";

   return "Break-even";
}

string CapitalizeFirst(string value)
{
   if(StringLen(value) <= 0)
      return value;

   ushort first = StringGetCharacter(value, 0);
   if(first >= 'a' && first <= 'z')
      first -= 32;

   return ShortToString(first) + StringSubstr(value, 1);
}

string PadRight(string value, int width)
{
   string result = value;
   while(StringLen(result) < width)
      result += " ";

   if(StringLen(result) > width)
      result = StringSubstr(result, 0, width);

   return result;
}

string PadLeft(string value, int width)
{
   string result = value;
   while(StringLen(result) < width)
      result = " " + result;

   if(StringLen(result) > width)
      result = StringSubstr(result, 0, width);

   return result;
}

string EscapeHtml(string value)
{
   string result = value;
   StringReplace(result, "&", "&amp;");
   StringReplace(result, "<", "&lt;");
   StringReplace(result, ">", "&gt;");
   return result;
}

string StripTelegramHtml(string value)
{
   string result = value;
   StringReplace(result, "<b>", "");
   StringReplace(result, "</b>", "");
   StringReplace(result, "<code>", "");
   StringReplace(result, "</code>", "");
   StringReplace(result, "<pre>", "");
   StringReplace(result, "</pre>", "");
   StringReplace(result, "&amp;", "&");
   StringReplace(result, "&lt;", "<");
   StringReplace(result, "&gt;", ">");
   return result;
}

bool MagicNumberAllowed(long magic)
{
   if(!InpUseMagicNumberFilter)
      return true;

   return magic == InpMagicNumberFilter;
}

