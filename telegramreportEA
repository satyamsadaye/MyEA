void CheckEquityTargetAlert()
{
   double equity = AccountInfoDouble(ACCOUNT_EQUITY);
   string levels_str = CleanInput(InpEquityTargetLevels);
   if(levels_str == "")
      return;

   double levels[];
   string texts[];
   int count = ParseEquityTargetEntries(levels_str, levels, texts);
   if(count == 0)
      return;

   for(int i = 0; i < count; i++)
   {
      double target = levels[i];
      if(target <= 0.0)
         continue;

      bool already_triggered = IsEquityLevelTriggered(target);

      if(equity >= target)
      {
         if(!already_triggered)
         {
            string custom = CleanInput(texts[i]);
            string msg = "<b>🚨 Equity Alert</b>\n";
            msg += "Account: <b>" + EscapeHtml(AccountInfoString(ACCOUNT_NAME)) + "</b>\n";
            msg += "Login: <code>" + (string)AccountInfoInteger(ACCOUNT_LOGIN) + "</code>\n";
            msg += "Server: " + EscapeHtml(AccountInfoString(ACCOUNT_SERVER)) + "\n";
            msg += "Currency: " + EscapeHtml(AccountInfoString(ACCOUNT_CURRENCY)) + "\n";
            msg += "Current equity: <b>" + MoneyAmountText(equity) + "</b>\n";
            msg += "Target level: <b>" + MoneyAmountText(target) + "</b>\n";
            if(custom != "")
               msg += "\n" + EscapeHtml(custom) + "\n";
            SendTelegram(msg);
            AddEquityTriggeredLevel(target);
            Log("Equity target alert sent. equity=" + DoubleToString(equity, 2) + " target=" + DoubleToString(target, 2) + " text=" + custom);
         }
      }
      else
      {
         if(already_triggered && InpEquityAlertMode == EQUITY_ALERT_EVERY_TIME)
         {
            RemoveEquityTriggeredLevel(target);
            Log("Equity dropped below target " + DoubleToString(target, 2) + ", alert flag reset.");
         }
      }
   }
}

int ParseEquityTargetEntries(string text, double &levels[], string &texts[])
{
   ArrayResize(levels, 0);
   ArrayResize(texts, 0);
   text = CleanInput(text);
   if(text == "")
      return 0;

   int count = 0;
   int len = StringLen(text);
   int start = 0;
   for(int pos = 0; pos <= len; pos++)
   {
      if(pos == len || StringGetCharacter(text, pos) == ';')
      {
         string entry = CleanInput(StringSubstr(text, start, pos - start));
         if(entry != "")
         {
            int colon = StringFind(entry, ":");
            double level = 0.0;
            string entry_text = "";
            if(colon > 0)
            {
               level = StringToDouble(CleanInput(StringSubstr(entry, 0, colon)));
               entry_text = CleanInput(StringSubstr(entry, colon + 1));
            }
            else
            {
               level = StringToDouble(entry);
            }

            if(level > 0.0)
            {
               count++;
               ArrayResize(levels, count);
               ArrayResize(texts, count);
               levels[count - 1] = level;
               texts[count - 1] = entry_text;
            }
         }
         start = pos + 1;
      }
   }

   return count;
}

bool IsEquityLevelTriggered(double level)
{
   string key = "," + DoubleToString(level, 2) + ",";
   return StringFind(g_equity_target_levels_triggered, key) >= 0;
}

void AddEquityTriggeredLevel(double level)
{
   if(!IsEquityLevelTriggered(level))
      g_equity_target_levels_triggered += "," + DoubleToString(level, 2) + ",";
}

void RemoveEquityTriggeredLevel(double level)
{
   string key = "," + DoubleToString(level, 2) + ",";
   int pos = StringFind(g_equity_target_levels_triggered, key);
   if(pos >= 0)
   {
      string before = StringSubstr(g_equity_target_levels_triggered, 0, pos);
      string after = StringSubstr(g_equity_target_levels_triggered, pos + StringLen(key));
      g_equity_target_levels_triggered = before + after;
   }
}

void CheckConsecutiveTradesAlert()
{
   if(!HistorySelect(0, TimeCurrent()))
   {
      Log("CheckConsecutiveTradesAlert: HistorySelect failed");
      return;
   }

   int win_streak = 0;
   int loss_streak = 0;
   int deals_total = HistoryDealsTotal();
   bool found_streak_type = false;
   bool streak_is_win = false;

   for(int i = deals_total - 1; i >= 0; i--)
   {
      ulong deal_ticket = HistoryDealGetTicket(i);
      if(deal_ticket == 0)
         continue;

      long entry = HistoryDealGetInteger(deal_ticket, DEAL_ENTRY);
      if(entry != DEAL_ENTRY_OUT && entry != DEAL_ENTRY_OUT_BY && entry != DEAL_ENTRY_INOUT)
         continue;

      double profit = HistoryDealGetDouble(deal_ticket, DEAL_PROFIT);

      if(IsBreakEvenTrade(profit))
         continue;

      if(!found_streak_type)
      {
         streak_is_win = (profit > 0.0);
         found_streak_type = true;
      }

      if((streak_is_win && profit > 0.0) || (!streak_is_win && profit <= 0.0))
      {
         if(streak_is_win)
            win_streak++;
         else
            loss_streak++;
      }
      else
         break;
   }

   if(win_streak >= InpAlertWinStreakCount && win_streak > g_last_alerted_win_streak)
   {
      string msg = "<b>🔥 Consecutive Wins: " + (string)win_streak + "</b>\n";
      msg += "Account: <b>" + EscapeHtml(AccountInfoString(ACCOUNT_NAME)) + "</b>\n";
      msg += "Login: <code>" + (string)AccountInfoInteger(ACCOUNT_LOGIN) + "</code>\n";
      msg += "Server: " + EscapeHtml(AccountInfoString(ACCOUNT_SERVER)) + "\n";
      SendTelegram(msg);
      g_last_alerted_win_streak = win_streak;
      g_last_alerted_loss_streak = 0;
      Log("Consecutive wins alert sent: " + (string)win_streak);
   }

   if(loss_streak >= InpAlertLossStreakCount && loss_streak > g_last_alerted_loss_streak)
   {
      string msg = "<b>⚠️ Consecutive Losses: " + (string)loss_streak + "</b>\n";
      msg += "Account: <b>" + EscapeHtml(AccountInfoString(ACCOUNT_NAME)) + "</b>\n";
      msg += "Login: <code>" + (string)AccountInfoInteger(ACCOUNT_LOGIN) + "</code>\n";
      msg += "Server: " + EscapeHtml(AccountInfoString(ACCOUNT_SERVER)) + "\n";
      SendTelegram(msg);
      g_last_alerted_loss_streak = loss_streak;
      g_last_alerted_win_streak = 0;
      Log("Consecutive losses alert sent: " + (string)loss_streak);
   }

   if(win_streak == 0)
      g_last_alerted_win_streak = 0;

   if(loss_streak == 0)
      g_last_alerted_loss_streak = 0;
}
